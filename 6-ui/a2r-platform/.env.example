# A2R Platform Environment Configuration
# ======================================
# Copy this file to .env.local or .env.development

# =============================================================================
# A2R Gateway (Single Source of Truth)
# =============================================================================
# All API requests go through the A2R Gateway
# Default: http://127.0.0.1:3210

VITE_A2R_BASE_URL=http://127.0.0.1:3210

# =============================================================================
# Deprecated - DO NOT USE
# =============================================================================
# These are kept for backward compatibility during migration.
# New code MUST use VITE_A2R_BASE_URL only.

# VITE_API_URL=http://127.0.0.1:3000        # ❌ Deprecated
# VITE_VOICE_URL=http://127.0.0.1:8001      # ❌ Deprecated
# VITE_OPERATOR_URL=http://127.0.0.1:3010   # ❌ Deprecated
# VITE_RAILS_URL=http://127.0.0.1:3011      # ❌ Deprecated
# VITE_KERNEL_URL=http://127.0.0.1:3004     # ❌ Deprecated

# =============================================================================
# Application Settings
# =============================================================================

VITE_APP_NAME=A2R Platform
VITE_APP_ENV=development

# =============================================================================
# Authentication (Optional)
# =============================================================================

# VITE_AUTH_TOKEN=
# VITE_AUTH_PROVIDER=jwt

# =============================================================================
# Feature Flags
# =============================================================================

VITE_FEATURE_VOICE=true
VITE_FEATURE_OPERATOR=true
VITE_FEATURE_RAILS=true
VITE_FEATURE_SSE=true
