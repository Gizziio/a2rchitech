# A2R Node Agent - Environment Configuration Example
# Copy this file to .env and fill in your values

# Required: Your node authentication token
# Get your token from: https://app.allternit.com/settings/nodes
ALLTERNIT_TOKEN=your_token_here

# Optional: Custom node ID (auto-generated if not set)
ALLTERNIT_NODE_ID=my-node-1

# Optional: Control plane URL (default: wss://control.allternit.com)
ALLTERNIT_CONTROL_PLANE=wss://control.allternit.com

# Optional: Node capabilities/labels for scheduling
# Comma-separated list of capabilities
ALLTERNIT_LABELS=docker,production

# Optional: Maximum concurrent jobs (default: 10)
ALLTERNIT_MAX_CONCURRENT_JOBS=10

# Optional: Log level (default: info)
# Options: error, warn, info, debug, trace
RUST_LOG=info
