# =============================================================================
# A2R Platform Development Environment Variables
# =============================================================================
# Copy this file to .env and customize values as needed.
# DO NOT commit .env to version control!
# =============================================================================

# =============================================================================
# Core Application Settings
# =============================================================================

# Application environment (development, staging, production)
NODE_ENV=development
APP_ENV=development

# Application URLs
APP_URL=http://localhost:3000
API_URL=http://localhost:8080
WS_URL=ws://localhost:8080

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=a2r-dev-password
POSTGRES_DB=allternit_platform
DATABASE_URL=postgres://postgres:a2r-dev-password@postgres:5432/allternit_platform?sslmode=disable

# Connection pool settings
DATABASE_MAX_CONNECTIONS=20
DATABASE_MIN_CONNECTIONS=5
DATABASE_CONNECTION_TIMEOUT=30000

# =============================================================================
# Redis Configuration
# =============================================================================

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=a2r-redis-password
REDIS_DB=0
REDIS_URL=redis://:a2r-redis-password@redis:6379/0

# Redis connection settings
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=1000
REDIS_CONNECT_TIMEOUT=5000

# =============================================================================
# Object Storage (MinIO/S3)
# =============================================================================

# MinIO Configuration
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minio-admin-password
MINIO_REGION=us-east-1
MINIO_USE_SSL=false

# S3-compatible buckets
S3_ASSETS_BUCKET=a2r-assets
S3_UPLOADS_BUCKET=a2r-uploads
S3_EXPORTS_BUCKET=a2r-exports

# AWS S3 (for production use)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT_URL=http://localstack:4566
AWS_S3_FORCE_PATH_STYLE=true

# =============================================================================
# Authentication & Security
# =============================================================================

# JWT Configuration
JWT_SECRET=a2r-dev-jwt-secret-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=a2r-dev-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Encryption keys (must be 32 characters for AES-256)
ENCRYPTION_KEY=a2r-dev-encryption-key-32-chars!!

# Session configuration
SESSION_SECRET=a2r-dev-session-secret-change-in-production
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTP_ONLY=true
SESSION_COOKIE_SAME_SITE=lax

# =============================================================================
# AI/ML Services
# =============================================================================

# OpenAI
OPENAI_API_KEY=
OPENAI_ORG_ID=
OPENAI_MODEL=gpt-4-turbo-preview

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Vector Database (ChromaDB)
CHROMA_URL=http://chromadb:8000
CHROMA_COLLECTION_NAME=a2r-agents

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# =============================================================================
# Message Queue & Workflow
# =============================================================================

# NATS
NATS_URL=nats://nats:4222
NATS_MONITORING_URL=http://nats:8222

# Temporal
TEMPORAL_HOST=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=a2r-tasks

# =============================================================================
# Email Configuration (Mailpit)
# =============================================================================

# SMTP Settings
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Email defaults
EMAIL_FROM=noreply@a2r.local
EMAIL_FROM_NAME="A2R Platform"
EMAIL_REPLY_TO=support@a2r.local

# Mailpit web UI
MAILPIT_HOST=mailpit
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025
MAILPIT_URL=http://localhost:8025

# =============================================================================
# Monitoring & Logging
# =============================================================================

# Log levels: error, warn, info, debug, trace
LOG_LEVEL=debug
LOG_FORMAT=json

# Tracing
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_SERVICE_NAME=allternit-platform
OTEL_SERVICE_VERSION=1.0.0

# Metrics
METRICS_ENABLED=true
METRICS_PORT=9090

# =============================================================================
# Feature Flags
# =============================================================================

# Enable/disable features
FEATURE_AI_AGENTS=true
FEATURE_WORKFLOWS=true
FEATURE_ANALYTICS=true
FEATURE_NOTIFICATIONS=true
FEATURE_WEBHOOKS=true
FEATURE_API_KEYS=true

# Development features
FEATURE_DEBUG_UI=true
FEATURE_MOCK_SERVICES=false
FEATURE_SEED_DATA=true

# =============================================================================
# Third-Party Integrations
# =============================================================================

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Webhook secrets
WEBHOOK_SECRET=whsec_dev_webhook_secret_change_in_production

# =============================================================================
# LocalStack (AWS Emulation)
# =============================================================================

LOCALSTACK_HOST=localstack
LOCALSTACK_PORT=4566
LOCALSTACK_SERVICES=s3,sqs,sns,lambda,iam,sts,cloudformation,dynamodb,kinesis
LOCALSTACK_DEBUG=0
LOCALSTACK_PERSISTENCE=1

# =============================================================================
# Development Tools
# =============================================================================

# Hot reload
AIR_CONFIG=.air.toml
CARGO_WATCH_DELAY=2

# Testing
TEST_DATABASE_URL=postgres://postgres:a2r-dev-password@postgres:5432/allternit_platform_test?sslmode=disable
TEST_REDIS_URL=redis://:a2r-redis-password@redis:6379/1

# =============================================================================
# VPN & Network
# =============================================================================

# WireGuard
WIREGUARD_ENABLED=false
WIREGUARD_ENDPOINT=
WIREGUARD_PORT=51820
WIREGUARD_DNS=1.1.1.1,8.8.8.8

# =============================================================================
# Advanced Configuration
# =============================================================================

# Request timeouts (milliseconds)
REQUEST_TIMEOUT=30000
UPLOAD_MAX_SIZE=104857600  # 100MB

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:8080
CORS_CREDENTIALS=true

# Cache TTLs (seconds)
CACHE_TTL_SHORT=300
CACHE_TTL_MEDIUM=3600
CACHE_TTL_LONG=86400
