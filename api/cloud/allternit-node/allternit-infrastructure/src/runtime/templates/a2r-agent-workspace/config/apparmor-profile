#include <tunables/global>

# A2R Agent Workspace - AppArmor Profile
# Restrictive security profile for agent execution

/usr/local/bin/agent-runner {
  #include <abstractions/base>
  #include <abstractions/nameservice>
  #include <abstractions/python>
  #include <abstractions/ssl_certs>

  # Basic capabilities
  capability chown,
  capability dac_override,
  capability dac_read_search,
  capability fowner,
  capability fsetid,
  capability kill,
  capability setgid,
  capability setuid,
  capability sys_chroot,

  # Deny dangerous capabilities
  deny capability sys_admin,
  deny capability sys_boot,
  deny capability sys_module,
  deny capability sys_rawio,
  deny capability sys_time,
  deny capability mknod,
  deny capability net_admin,
  deny capability net_broadcast,
  deny capability net_raw,
  deny capability ipc_lock,
  deny capability ipc_owner,
  deny capability lease,
  deny capability linux_immutable,
  deny capability mac_admin,
  deny capability mac_override,
  deny capability setpcap,
  deny capability audit_control,
  deny capability audit_write,

  # Binary execution
  /usr/local/bin/agent-runner mr,
  /usr/bin/** mr,
  /usr/local/bin/** mr,
  /bin/** mr,
  /sbin/** mr,
  /home/agent/.local/bin/** mr,

  # Libraries
  /lib/** mr,
  /lib64/** mr,
  /usr/lib/** mr,
  /usr/lib64/** mr,
  /usr/local/lib/** mr,
  /usr/share/** mr,

  # Agent workspace
  /home/agent/ r,
  /home/agent/** rwk,
  /tmp/** rwk,
  /var/tmp/** rwk,

  # Read-only system files
  /etc/ r,
  /etc/** r,
  deny /etc/shadow r,
  deny /etc/shadow- r,
  deny /etc/gshadow r,
  deny /etc/gshadow- r,
  deny /etc/passwd- r,
  deny /etc/group- r,
  deny /etc/ssh/** r,

  # Device access
  /dev/null rw,
  /dev/zero rw,
  /dev/random r,
  /dev/urandom r,
  /dev/tty rw,
  /dev/pts/** rw,
  /dev/ptmx rw,
  deny /dev/sd* rw,
  deny /dev/hd* rw,
  deny /dev/mem rw,
  deny /dev/kmem rw,
  deny /dev/port rw,

  # Proc filesystem (read-only)
  /proc/ r,
  /proc/** r,
  /proc/[0-9]*/** r,
  /proc/[0-9]*/fd/ w,
  /proc/[0-9]*/task/[0-9]*/comm rw,

  # Sys filesystem (read-only)
  /sys/ r,
  /sys/** r,
  deny /sys/firmware/** r,
  deny /sys/kernel/** r,
  deny /sys/power/** r,

  # Network access
  network inet stream,
  network inet6 stream,
  network inet dgram,
  network inet6 dgram,
  network unix stream,
  network unix dgram,

  # Deny raw sockets
  deny network raw,
  deny network packet,

  # Deny specific paths
  deny /boot/** rwklx,
  deny /media/** rwklx,
  deny /mnt/** rwklx,
  deny /opt/** rwklx,
  deny /root/** rwklx,
  deny /srv/** rwklx,
  deny /var/backups/** rwklx,
  deny /var/cache/apt/archives/** rwklx,
  deny /var/lib/dpkg/** rwklx,
  deny /var/log/** rwklx,
  deny /var/mail/** rwklx,
  deny /var/spool/** rwklx,

  # Browser profiles
  /home/agent/.config/chromium/** rwk,
  /home/agent/.config/firefox/** rwk,

  # Cache directories
  /home/agent/.cache/** rwk,

  # Deny writing to executables
  deny /usr/bin/** w,
  deny /usr/local/bin/** w,
  deny /bin/** w,
  deny /sbin/** w,

  # Pivot root for chroot
  pivot_root,

  # Mount operations (restricted)
  mount fstype=tmpfs -> /tmp/**,
  mount fstype=proc -> /proc/,
  mount fstype=sysfs -> /sys/,
  mount fstype=devpts -> /dev/pts/,
  deny mount -> /boot/**,
  deny mount -> /media/**,
  deny mount -> /mnt/**,

  # Unmount
  umount,

  # ptrace
  ptrace trace peer=@{profile_name},
  deny ptrace (read, trace) peer=/usr/local/bin/agent-runner,
}
