# ============================================================================
# A2R Agent Workspace - Environment Configuration
# Copy this file to .env and customize for your deployment
# ============================================================================

# Agent Configuration
AGENT_ID=default
AGENT_NAME="A2R Agent"
AGENT_VERSION=1.0.0

# Resource Limits
MAX_CPU=2
MAX_MEMORY=4G
TASK_TIMEOUT=3600

# Network Configuration
ENABLE_NETWORK=true
DNS_PRIMARY=1.1.1.1
DNS_SECONDARY=8.8.8.8

# Port Configuration
AGENT_PORT=3000
AGENT_DEBUG_PORT=9222
HEALTH_PORT=3000

# Security Settings
SANDBOX_ENABLED=true
FIREJAIL_PROFILE=a2r-agent

# Vector Database
CHROMADB_HOST=vector-db
CHROMADB_PORT=8000

# File Store (MinIO)
MINIO_ROOT_USER=a2radmin
MINIO_ROOT_PASSWORD=a2rsecretkey

# Logging
LOG_LEVEL=info

# Monitoring (Optional)
# WEBHOOK_URL=https://hooks.example.com/alerts
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Docker Configuration
DOCKER_GID=999
COMPOSE_PROJECT_NAME=a2r-agent

# Task Directories
TASK_INPUT_DIR=./tasks/input
TASK_OUTPUT_DIR=./tasks/output
