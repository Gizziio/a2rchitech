{
  "id": "chatbotcard-plugin",
  "name": "ChatbotcardPlugin",
  "version": "1.0.0",
  "runtime": "allternit-plugin-v1",
  "description": "Plugin based on ChatbotCard.tsx template",
  "category": "custom",
  "requires": {
    "llm": {
      "capabilities": [
        "reasoning"
      ]
    }
  },
  "provides": {
    "functions": [
      {
        "name": "execute",
        "description": "Execute ChatbotCard.tsx logic",
        "parameters": {
          "type": "object",
          "properties": {
            "input": {
              "type": "string",
              "description": "Input text"
            }
          },
          "required": [
            "input"
          ]
        },
        "returns": {
          "type": "object"
        }
      }
    ]
  },
  "adapters": {
    "mcp": "./adapters/mcp.js",
    "http": "./adapters/http.js",
    "cli": "./adapters/cli.js"
  }
}