{
  "name": "@a2r/governor",
  "version": "1.0.0",
  "description": "A2R Governor - Work-In-Hand management and routing for runtime integration",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./routing": {
      "import": "./dist/routing/index.js",
      "types": "./dist/routing/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src/schemas"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "a2r",
    "governor",
    "wih",
    "routing"
  ],
  "author": "A2rchitect Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {},
  "engines": {
    "node": ">=18.0.0"
  }
}
