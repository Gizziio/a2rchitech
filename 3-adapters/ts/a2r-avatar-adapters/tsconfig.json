{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@a2r/visual-state": ["../a2r-visual-state/src/index.ts"],
      "@a2r/visual-state/*": ["../a2r-visual-state/src/*"],
      "@a2r/avatar-adapters": ["./src/index.ts"],
      "@a2r/avatar-adapters/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"]
}
