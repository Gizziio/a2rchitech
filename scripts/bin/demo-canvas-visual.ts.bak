  await page.evaluate(() => {
    const headers = Array.from(document.querySelectorAll(".context_module .header"));
    const target = headers.find(el => el.textContent?.includes("Summit Academy"));
    if (target) (target as HTMLElement).scrollIntoView({ behavior: "smooth", block: "center" });
  });
  await sleep(1200);

  try {
    const lesson2 = page.locator(`.context_module_item a.title`).filter({ hasText: "Lab 1" }).first();
    if (await lesson2.count() > 0) {
      await lesson2.scrollIntoViewIfNeeded();
      await sleep(500);
      await lesson2.click();
      await page.waitForLoadState("load");
    } else {
      await page.goto(`${BASE_URL}/courses/${COURSE_ID}/pages/${page2.url}`, { waitUntil: "load" });
    }
  } catch {
    await page.goto(`${BASE_URL}/courses/${COURSE_ID}/pages/${page2.url}`, { waitUntil: "load" });
  }
  await sleep(3500);

  // Final — back to modules full layout
  w(`  ${C.bold}${C.blue}[ Browser ]${C.reset} Final — full module layout\n`);
  await page.goto(MODULES_URL, { waitUntil: "load" });
  await sleep(2500);
  await page.evaluate(() => {
    const headers = Array.from(document.querySelectorAll(".context_module .header"));
    const target = headers.find(el => el.textContent?.includes("Summit Academy"));
    if (target) (target as HTMLElement).scrollIntoView({ behavior: "smooth", block: "center" });
  });
  await sleep(3000);

  // ── A2R agent reply in terminal ─────────────────────────────────────────────
  nl();
  w(`${C.dim}  ────────────────────────────────────────────────────────────${C.reset}\n`);
  nl();
  w(`  ${C.magenta}${C.bold}A2R${C.reset}  `);
  await typeText(`Done. Here's what I created in Canvas:`, 28);
  nl(); nl();

  w(`  ${C.dim}  Course     ${C.reset}Your Guided Course Template\n`);
  w(`  ${C.dim}  Module     ${C.reset}${C.bold}Summit Academy: Applied IT — Week 1: Project Kickoff${C.reset}${C.green}  ✓ published${C.reset}\n`);
  w(`  ${C.dim}  Lesson 1   ${C.reset}Welcome to Applied IT — What You're Building This Semester\n`);
  w(`  ${C.dim}  Lesson 2   ${C.reset}Your Toolkit — Resources & Tools\n`);
  w(`  ${C.dim}  Assignment ${C.reset}Requirements Gathering — Client Discovery  ${C.dim}(20 pts)${C.reset}\n`);
  nl();

  w(`  ${C.magenta}${C.bold}A2R${C.reset}  `);
  await typeText(
    `Content rewritten from Ian's Sandbox export for higher engagement — same structure, new lessons, graded assignment with rubric. Live in Canvas now.`,
    26
  );
  nl(); nl();

  // ── Final banner ────────────────────────────────────────────────────────────
  w(`${C.bold}${C.green}`);
  w(`  ╔══════════════════════════════════════════════════════════╗\n`);
  w(`  ║   ✓  MODULE + LESSONS CREATED AUTONOMOUSLY BY A2R       ║\n`);
  w(`  ╚══════════════════════════════════════════════════════════╝\n`);
  w(`${C.reset}\n`);
  w(`  ${C.dim}${MODULES_URL}${C.reset}\n\n`);

  w(`  ${C.dim}Press Enter to close browser...${C.reset}`);
  await new Promise<void>((r) => process.stdin.once("data", () => r()));
  await browser.close();
}

main().catch((e) => {
  process.stderr.write(`\n  ERROR: ${e.message}\n`);
  process.exit(1);
});
