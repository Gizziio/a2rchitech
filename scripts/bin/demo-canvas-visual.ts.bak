  const page = await context.newPage();

  // ── Login to Canvas ─────────────────────────────────────────────────────────
  w(`  ${C.bold}${C.blue}[ Browser ]${C.reset} Navigating to Canvas login...\n`);
  await page.goto(LOGIN_URL, { waitUntil: "load" });
  await sleep(800);

  if (EMAIL && PASSWORD) {
    w(`  ${C.bold}${C.blue}[ Browser ]${C.reset} Logging in...\n`);

    // Fill email
    await page.fill('#IDToken2', EMAIL);
    await sleep(400);

    // Fill password
    await page.fill('#IDToken3', PASSWORD);
    await sleep(400);

    // Submit
    await page.click('button[type="submit"]');
    await page.waitForNavigation({ waitUntil: "load", timeout: 15000 }).catch(() => {});
    await sleep(1200);

    w(`  ${C.green}  ✓${C.reset} Logged in as ${EMAIL}\n`);
  } else {
    w(`  ${C.yellow}  ⚠${C.reset}  No credentials — assuming already logged in\n`);
    await sleep(1000);
  }

  // ── Navigate to course modules ──────────────────────────────────────────────
  w(`  ${C.bold}${C.blue}[ Browser ]${C.reset} Opening Canvas course modules...\n`);
  await page.goto(MODULES_URL, { waitUntil: "load" });
