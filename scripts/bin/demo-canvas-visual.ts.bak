  const steps = [
    "Loading Ian's Sandbox course export",
    "Extracting Class Introduction content",
    "Scaffolding IT Fundamentals module structure",
    "Connecting to Canvas LMS",
    "Creating module: Summit Academy IT Fundamentals — Week 1",
    "Creating lesson: Course Overview — Applied IT",
    "Creating lesson: Lab 1 — VirtualBox Hypervisor Setup",
    "Publishing module to course",
