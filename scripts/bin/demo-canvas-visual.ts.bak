  for (const [i, s] of steps.entries()) {
    w(`  ${C.dim}  ${String(i + 1).padStart(2)}.${C.reset} `);
    await typeText(s, 20);
    nl();
    await sleep(100);
  }
  nl();
  w(`  ${C.magenta}${C.bold}A2R${C.reset}  ${C.green}Ready. Starting now.${C.reset}\n\n`);
  w(`${C.dim}  ────────────────────────────────────────────────────────────${C.reset}\n`);
  await sleep(800);

  // ── Launch Playwright browser ───────────────────────────────────────────────
  nl();
  w(`  ${C.bold}${C.blue}[ Browser ]${C.reset} Launching browser...\n`);

