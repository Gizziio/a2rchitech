#!/usr/bin/env bun
/**
 * A2R Summit Academy — VISUAL Canvas Demo
 *
 * Shows:
 *   1. Animated "prompt" typed into A2R in the terminal
 *   2. Playwright browser opens, logs into Canvas automatically
 *   3. API creates the module + lessons while you watch
 *   4. Browser navigates to show each piece appearing live
 *
 * Usage:
 *   CANVAS_EMAIL=you@email.com CANVAS_PASSWORD=yourpass bun scripts/bin/demo-canvas-visual.ts
 */

import { execSync } from "child_process";
import * as fs from "fs";
import * as path from "path";
import * as os from "os";
import { chromium } from "playwright";

// ─── Credentials ─────────────────────────────────────────────────────────────

const TOKEN   = process.env.CANVAS_API_TOKEN || "7~3HMV8tGX6fLJzHNNfkxBRrGWTv744BMxvx4uFCUC2AaLvWhUXhuBx8TY6JKCEL2w";
const BASE_URL  = process.env.CANVAS_BASE_URL  || "https://canvas.instructure.com";
const COURSE_ID = process.env.CANVAS_COURSE_ID || "14389375";
const EMAIL    = process.env.CANVAS_EMAIL    || "";
const PASSWORD  = process.env.CANVAS_PASSWORD  || "";
const EXPORT_ZIP = process.env.CANVAS_EXPORT_ZIP ||
  path.join(os.homedir(), "Downloads/Ian-s-Sandbox-2026-Mar-24_00-51-39-274.zip");

const MODULES_URL = `${BASE_URL}/courses/${COURSE_ID}/modules`;
const LOGIN_URL   = `${BASE_URL}/login/canvas`;

// ─── Colors ──────────────────────────────────────────────────────────────────

const C = {
  reset:   "\x1b[0m",
  bold:    "\x1b[1m",
  dim:     "\x1b[2m",
  cyan:    "\x1b[36m",
  green:   "\x1b[32m",
  yellow:  "\x1b[33m",
  blue:    "\x1b[34m",
  magenta: "\x1b[35m",
  red:     "\x1b[31m",
  white:   "\x1b[97m",
  bg_dark: "\x1b[48;5;235m",
};

const w  = (s: string) => process.stdout.write(s);
const nl = () => w("\n");

async function sleep(ms: number) {
  return new Promise<void>((r) => setTimeout(r, ms));
}

async function typeText(text: string, delay = 42) {
  for (const ch of text) {
    w(ch);
    await sleep(delay + Math.random() * 18);
  }
}

async function thinkDots(msg: string, ms = 1800) {
  const frames = ["⠋","⠙","⠹","⠸","⠼","⠴","⠦","⠧","⠇","⠏"];
  const end = Date.now() + ms;
  let i = 0;
  w(`  ${C.dim}${msg}${C.reset} `);
  while (Date.now() < end) {
    w(`\r  ${C.dim}${msg}${C.reset} ${C.cyan}${frames[i++ % frames.length]}${C.reset}`);
    await sleep(90);
  }
  w(`\r  ${C.dim}${msg}${C.reset} ${C.green}✓${C.reset}\n`);
}

// ─── Canvas REST API ──────────────────────────────────────────────────────────

async function api(method: string, endpoint: string, body?: object) {
  const res = await fetch(`${BASE_URL}/api/v1${endpoint}`, {
    method,
    headers: {
      Authorization: `Bearer ${TOKEN}`,
      "Content-Type": "application/json",
    },
    body: body ? JSON.stringify(body) : undefined,
  });
  if (!res.ok) throw new Error(`${method} ${endpoint} → ${res.status}: ${await res.text()}`);
  return res.json();
}

// ─── Course export ────────────────────────────────────────────────────────────

function loadExport(): any {
  if (!fs.existsSync(EXPORT_ZIP)) return null;
  try {
    const tmp = fs.mkdtempSync(path.join(os.tmpdir(), "a2r-"));
    execSync(`unzip -p "${EXPORT_ZIP}" "*/viewer/course-data.js" > "${tmp}/cd.js"`, { stdio: "pipe" });
    const raw = fs.readFileSync(`${tmp}/cd.js`, "utf8");
    const m = raw.match(/window\.COURSE_DATA\s*=\s*(\{[\s\S]*\});?\s*$/);
    if (!m) return null;
    fs.rmSync(tmp, { recursive: true, force: true });
    return JSON.parse(m[1]);
  } catch { return null; }
}

// ─── Main ─────────────────────────────────────────────────────────────────────

async function main() {
  console.clear();
  await sleep(300);

  // ── Banner ──────────────────────────────────────────────────────────────────
  w(`\n${C.bold}${C.magenta}`);
  w(`  ╔══════════════════════════════════════════════════════════╗\n`);
  w(`  ║     A2R PLATFORM  ·  SUMMIT ACADEMY  ·  CANVAS AGENT    ║\n`);
  w(`  ╚══════════════════════════════════════════════════════════╝\n`);
  w(`${C.reset}\n`);
  await sleep(700);

  // ── Simulated prompt ────────────────────────────────────────────────────────
  w(`${C.bg_dark}${C.bold}${C.white}  A2R AGENT CONSOLE${C.reset}${C.dim}  summit_oic · canvas${C.reset}\n`);
  w(`${C.dim}  ────────────────────────────────────────────────────────────${C.reset}\n\n`);

  w(`  ${C.cyan}${C.bold}You${C.reset}  `);
