{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ToolResponse",
  "description": "ToolResponse represents the result of a tool execution.",
  "type": "object",
  "required": [
    "execution_time_ms",
    "metadata",
    "resource_usage",
    "result",
    "tool_id"
  ],
  "properties": {
    "execution_time_ms": {
      "description": "Execution time in milliseconds",
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "metadata": {
      "description": "Metadata for the response",
      "type": "object",
      "additionalProperties": true
    },
    "resource_usage": {
      "description": "Resource usage during execution",
      "allOf": [
        {
          "$ref": "#/definitions/ResourceUsage"
        }
      ]
    },
    "result": {
      "description": "Result of the tool execution",
      "allOf": [
        {
          "$ref": "#/definitions/ToolResult"
        }
      ]
    },
    "tool_id": {
      "description": "ID of the tool that was executed",
      "type": "string"
    }
  },
  "definitions": {
    "ResourceUsage": {
      "type": "object",
      "required": [
        "cpu_millicores",
        "memory_mb",
        "network_bytes",
        "storage_mb"
      ],
      "properties": {
        "cpu_millicores": {
          "description": "CPU used (in millicores)",
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "memory_mb": {
          "description": "Memory used (in MB)",
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "network_bytes": {
          "description": "Network bytes transferred",
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "storage_mb": {
          "description": "Storage used (in MB)",
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        }
      }
    },
    "ToolResult": {
      "oneOf": [
        {
          "description": "Tool executed successfully",
          "type": "object",
          "required": [
            "Success"
          ],
          "properties": {
            "Success": {
              "type": "object",
              "required": [
                "output"
              ],
              "properties": {
                "output": true
              }
            }
          },
          "additionalProperties": false
        },
        {
          "description": "Tool execution failed",
          "type": "object",
          "required": [
            "Failure"
          ],
          "properties": {
            "Failure": {
              "type": "object",
              "required": [
                "error"
              ],
              "properties": {
                "error": {
                  "type": "string"
                }
              }
            }
          },
          "additionalProperties": false
        },
        {
          "description": "Tool execution was denied by policy",
          "type": "object",
          "required": [
            "Denied"
          ],
          "properties": {
            "Denied": {
              "type": "object",
              "required": [
                "reason"
              ],
              "properties": {
                "reason": {
                  "type": "string"
                }
              }
            }
          },
          "additionalProperties": false
        },
        {
          "description": "Tool execution timed out",
          "type": "string",
          "enum": [
            "Timeout"
          ]
        },
        {
          "description": "Tool execution was cancelled",
          "type": "string",
          "enum": [
            "Cancelled"
          ]
        }
      ]
    }
  }
}