{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RunModel",
  "description": "RunModel represents a single execution run with its state and metadata.",
  "type": "object",
  "required": [
    "created_at",
    "created_by",
    "metadata",
    "run_id",
    "session_id",
    "state",
    "tenant_id",
    "updated_at"
  ],
  "properties": {
    "completed_at": {
      "description": "Unix timestamp when the run was completed (if applicable)",
      "type": [
        "integer",
        "null"
      ],
      "format": "uint64",
      "minimum": 0.0
    },
    "created_at": {
      "description": "Unix timestamp when the run was created",
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "created_by": {
      "description": "Identity of the actor that initiated the run",
      "type": "string"
    },
    "error_message": {
      "description": "Optional error message if the run failed",
      "type": [
        "string",
        "null"
      ]
    },
    "metadata": {
      "description": "Metadata associated with the run",
      "type": "object",
      "additionalProperties": true
    },
    "run_id": {
      "description": "Unique identifier for this run",
      "type": "string"
    },
    "session_id": {
      "description": "Session identifier",
      "type": "string"
    },
    "state": {
      "description": "Current state of the run",
      "allOf": [
        {
          "$ref": "#/definitions/RunState"
        }
      ]
    },
    "tenant_id": {
      "description": "Tenant identifier for isolation",
      "type": "string"
    },
    "updated_at": {
      "description": "Unix timestamp when the run was last updated",
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    }
  },
  "definitions": {
    "RunState": {
      "description": "RunModel defines the state machine for execution runs.",
      "oneOf": [
        {
          "description": "Run has been created but not yet started",
          "type": "string",
          "enum": [
            "Created"
          ]
        },
        {
          "description": "Run is currently executing",
          "type": "string",
          "enum": [
            "Running"
          ]
        },
        {
          "description": "Run is in verification phase",
          "type": "string",
          "enum": [
            "Verifying"
          ]
        },
        {
          "description": "Run completed successfully",
          "type": "string",
          "enum": [
            "Completed"
          ]
        },
        {
          "description": "Run failed",
          "type": "string",
          "enum": [
            "Failed"
          ]
        },
        {
          "description": "Run was cancelled",
          "type": "string",
          "enum": [
            "Cancelled"
          ]
        }
      ]
    }
  }
}