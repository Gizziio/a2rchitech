{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PolicyDecision",
  "description": "PolicyDecisionArtifact represents a policy decision with constraints.",
  "type": "object",
  "required": [
    "action",
    "constraints",
    "decision",
    "identity_id",
    "resource",
    "timestamp"
  ],
  "properties": {
    "action": {
      "description": "Action being requested",
      "type": "string"
    },
    "constraints": {
      "description": "Constraints that apply to the decision",
      "type": "array",
      "items": {
        "$ref": "#/definitions/PolicyConstraint"
      }
    },
    "decision": {
      "description": "Whether the action is allowed",
      "allOf": [
        {
          "$ref": "#/definitions/PolicyEffect"
        }
      ]
    },
    "expires_at": {
      "description": "Expiration time for the decision (if applicable)",
      "type": [
        "integer",
        "null"
      ],
      "format": "uint64",
      "minimum": 0.0
    },
    "identity_id": {
      "description": "Identity that made the request",
      "type": "string"
    },
    "reason": {
      "description": "Reason for the decision",
      "type": [
        "string",
        "null"
      ]
    },
    "resource": {
      "description": "Resource being accessed",
      "type": "string"
    },
    "timestamp": {
      "description": "Unix timestamp when the decision was made",
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    }
  },
  "definitions": {
    "PolicyConstraint": {
      "oneOf": [
        {
          "description": "Time-based constraint",
          "type": "object",
          "required": [
            "TimeBased"
          ],
          "properties": {
            "TimeBased": {
              "type": "object",
              "required": [
                "end_time",
                "start_time"
              ],
              "properties": {
                "end_time": {
                  "type": "integer",
                  "format": "uint64",
                  "minimum": 0.0
                },
                "start_time": {
                  "type": "integer",
                  "format": "uint64",
                  "minimum": 0.0
                }
              }
            }
          },
          "additionalProperties": false
        },
        {
          "description": "Resource-based constraint",
          "type": "object",
          "required": [
            "ResourceBased"
          ],
          "properties": {
            "ResourceBased": {
              "type": "object",
              "required": [
                "max_usage"
              ],
              "properties": {
                "max_usage": {
                  "$ref": "#/definitions/ResourceRequirements"
                }
              }
            }
          },
          "additionalProperties": false
        },
        {
          "description": "Tenant-based constraint",
          "type": "object",
          "required": [
            "TenantBased"
          ],
          "properties": {
            "TenantBased": {
              "type": "object",
              "required": [
                "allowed_tenants"
              ],
              "properties": {
                "allowed_tenants": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "additionalProperties": false
        },
        {
          "description": "Rate limiting constraint",
          "type": "object",
          "required": [
            "RateLimit"
          ],
          "properties": {
            "RateLimit": {
              "type": "object",
              "required": [
                "max_requests",
                "window_seconds"
              ],
              "properties": {
                "max_requests": {
                  "type": "integer",
                  "format": "uint32",
                  "minimum": 0.0
                },
                "window_seconds": {
                  "type": "integer",
                  "format": "uint64",
                  "minimum": 0.0
                }
              }
            }
          },
          "additionalProperties": false
        },
        {
          "description": "Custom constraint",
          "type": "object",
          "required": [
            "Custom"
          ],
          "properties": {
            "Custom": {
              "type": "object",
              "required": [
                "constraint_type",
                "parameters"
              ],
              "properties": {
                "constraint_type": {
                  "type": "string"
                },
                "parameters": true
              }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "PolicyEffect": {
      "type": "string",
      "enum": [
        "Allow",
        "Deny"
      ]
    },
    "ResourceRequirements": {
      "type": "object",
      "required": [
        "cpu_millicores",
        "memory_mb",
        "storage_mb"
      ],
      "properties": {
        "cpu_millicores": {
          "description": "CPU requirements (in millicores)",
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "memory_mb": {
          "description": "Memory requirements (in MB)",
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "storage_mb": {
          "description": "Storage requirements (in MB)",
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        }
      }
    }
  }
}