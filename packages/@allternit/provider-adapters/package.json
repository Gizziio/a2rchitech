{
  "name": "@allternit/provider-adapters",
  "version": "1.0.0",
  "description": "Allternit Replies API provider adapters — maps raw provider bus events to canonical ReplyEvents",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./gizzi": {
      "import": "./src/gizzi.ts",
      "types": "./src/gizzi.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@allternit/replies-contract": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^1.6.0"
  }
}
