{
  "name": "@allternit/browser-tools",
  "version": "0.1.0",
  "description": "Browser automation toolkit for A2R agent task execution",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "browser",
    "automation",
    "playwright",
    "agent",
    "a2r"
  ],
  "dependencies": {
    "playwright": "^1.42.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "eslint": "^8.55.0"
  },
  "peerDependencies": {
    "@allternit/mcp-apps-adapter": "workspace:*"
  }
}
