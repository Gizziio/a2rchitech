{
  "id": "allternit-computer-use",
  "name": "Allternit Computer Use",
  "version": "1.0.0",
  "runtime": "allternit-plugin-v1",
  "description": "Full-stack computer automation: browser, desktop, and autonomous planning-loop execution with vision grounding, session recording, GIF replay, and approval gates.",
  "author": "Allternit Platform Team",
  "category": "automate",
  "keywords": ["computer-use", "browser-automation", "desktop-automation", "vision", "planning-loop", "screen-recording"],

  "families": ["browser", "desktop", "hybrid"],
  "modes": ["execute", "inspect", "assist", "direct"],

  "requires": {
    "llm": {
      "context_window": "200k",
      "capabilities": ["reasoning", "tool_use", "vision", "code_execution"]
    },
    "tools": [
      { "tool": "browser_navigate", "required": true, "fallback": "degrade" },
      { "tool": "browser_extract",  "required": true, "fallback": "degrade" },
      { "tool": "code_execute",     "required": false, "fallback": "simulate" }
    ],
    "ui": {
      "renderers": ["markdown", "image", "code", "table", "interactive"],
      "streaming": true,
      "panels": true
    },
    "storage": {
      "persistent": true,
      "estimated_size": 52428800
    }
  },

  "provides": {
    "functions": [
      {
        "name": "automate",
        "description": "Run a natural-language task through the full Plan→Act→Observe→Reflect planning loop with vision grounding.",
        "parameters": {
          "type": "object",
          "properties": {
            "task":            { "type": "string",  "description": "Natural language task description" },
            "session_id":      { "type": "string",  "description": "Existing session ID to reuse, or omit to create one" },
            "scope":           { "type": "string",  "description": "browser | desktop | hybrid | auto", "enum": ["browser","desktop","hybrid","auto"], "default": "browser" },
            "max_steps":       { "type": "number",  "description": "Max planning loop iterations", "default": 20 },
            "approval_policy": { "type": "string",  "description": "never | on-risk | always", "enum": ["never","on-risk","always"], "default": "on-risk" },
            "record_gif":      { "type": "boolean", "description": "Produce a GIF replay of the session", "default": true }
          },
          "required": ["task"]
        },
        "returns": { "type": "object" },
        "mode": "streaming",
        "estimated_duration": 120,
        "side_effects": true
      },
      {
        "name": "browse",
        "description": "Navigate to a URL and optionally perform a task on that page.",
        "parameters": {
          "type": "object",
          "properties": {
            "url":        { "type": "string",  "description": "URL to navigate to" },
            "task":       { "type": "string",  "description": "Optional task to perform after navigation" },
            "session_id": { "type": "string",  "description": "Session to reuse" }
          },
          "required": ["url"]
        },
        "returns": { "type": "object" },
        "mode": "async",
        "estimated_duration": 15,
        "side_effects": false
      },
      {
        "name": "desktop",
        "description": "Control a native desktop application using accessibility tree + PyAutoGUI.",
        "parameters": {
          "type": "object",
          "properties": {
            "task":       { "type": "string", "description": "Task to perform on desktop" },
            "app_name":   { "type": "string", "description": "Target application name (e.g. 'Finder', 'Calculator')" },
            "record_gif": { "type": "boolean", "default": true }
          },
          "required": ["task"]
        },
        "returns": { "type": "object" },
        "mode": "streaming",
        "estimated_duration": 60,
        "side_effects": true
      },
      {
        "name": "screenshot",
        "description": "Capture the current screen state and return a base64 PNG with metadata.",
        "parameters": {
          "type": "object",
          "properties": {
            "session_id": { "type": "string" },
            "annotate":   { "type": "boolean", "description": "Overlay step/timestamp annotation", "default": false }
          },
          "required": ["session_id"]
        },
        "returns": { "type": "object" },
        "mode": "sync",
        "estimated_duration": 2,
        "side_effects": false
      },
      {
        "name": "extract",
        "description": "Extract structured data from the current page using text, accessibility, selector, or vision strategy.",
        "parameters": {
          "type": "object",
          "properties": {
            "session_id": { "type": "string" },
            "what":       { "type": "string",  "description": "What to extract (e.g. 'all product prices', 'table of results')" },
            "strategy":   { "type": "string",  "enum": ["text","accessibility","selector","vision"], "default": "accessibility" },
            "format":     { "type": "string",  "enum": ["json","csv","markdown","raw"], "default": "json" }
          },
          "required": ["session_id","what"]
        },
        "returns": { "type": "object" },
        "mode": "sync",
        "estimated_duration": 5,
        "side_effects": false
      },
      {
        "name": "record",
        "description": "Start or stop a workflow recording. Recordings can be replayed and exported as GIF.",
        "parameters": {
          "type": "object",
          "properties": {
            "action":       { "type": "string", "enum": ["start","stop"], "description": "start or stop" },
            "session_id":   { "type": "string" },
            "recording_id": { "type": "string", "description": "Required when action=stop" },
            "name":         { "type": "string", "description": "Human label for this recording" }
          },
          "required": ["action","session_id"]
        },
        "returns": { "type": "object" },
        "mode": "sync",
        "estimated_duration": 1,
        "side_effects": true
      },
      {
        "name": "replay",
        "description": "Replay a recorded workflow or export it as a GIF.",
        "parameters": {
          "type": "object",
          "properties": {
            "recording_id": { "type": "string" },
            "export_gif":   { "type": "boolean", "default": false },
            "speed":        { "type": "number",  "description": "Playback speed multiplier (1.0 = realtime)", "default": 1.0 }
          },
          "required": ["recording_id"]
        },
        "returns": { "type": "object" },
        "mode": "async",
        "estimated_duration": 30,
        "side_effects": true
      },
      {
        "name": "assist",
        "description": "Co-pilot mode: read the current screen and suggest or take the next action based on user intent.",
        "parameters": {
          "type": "object",
          "properties": {
            "session_id":  { "type": "string" },
            "intent":      { "type": "string", "description": "What the user is trying to do" },
            "auto_execute":{ "type": "boolean", "description": "Execute suggestion automatically vs show for approval", "default": false }
          },
          "required": ["session_id","intent"]
        },
        "returns": { "type": "object" },
        "mode": "streaming",
        "estimated_duration": 10,
        "side_effects": false
      }
    ],
    "events": [
      { "name": "step.completed",      "description": "Emitted after each planning loop step",            "payload": { "step": "number", "action_type": "string", "screenshot_b64": "string" } },
      { "name": "approval.required",   "description": "Emitted when an action requires human approval",   "payload": { "step": "number", "action_preview": "object", "risk_level": "string" } },
      { "name": "recording.frame",     "description": "Emitted for each GIF frame captured",              "payload": { "frame_index": "number", "timestamp_ms": "number" } },
      { "name": "session.completed",   "description": "Emitted when a run finishes",                      "payload": { "run_id": "string", "status": "string", "gif_path": "string" } },
      { "name": "error.occurred",      "description": "Emitted on recoverable error before retry",        "payload": { "step": "number", "error": "string", "retry_count": "number" } }
    ]
  },

  "adapters": {
    "mcp":  "./adapters/mcp.js",
    "http": "./adapters/http.js"
  },

  "config": {
    "type": "object",
    "properties": {
      "gateway_url":       { "type": "string",  "description": "ACU gateway base URL",           "default": "http://localhost:8760" },
      "vision_provider":   { "type": "string",  "description": "Vision provider override",       "default": "auto" },
      "max_steps":         { "type": "number",  "description": "Default max planning loop steps", "default": 20 },
      "approval_policy":   { "type": "string",  "description": "Default approval policy",         "default": "on-risk" },
      "gif_fps":           { "type": "number",  "description": "GIF recording frame rate",        "default": 2 },
      "gif_max_frames":    { "type": "number",  "description": "Max frames per GIF",              "default": 600 },
      "gif_scale":         { "type": "number",  "description": "GIF output scale (0.0–1.0)",      "default": 0.5 },
      "record_by_default": { "type": "boolean", "description": "Auto-record all sessions",        "default": true },
      "anthropic_api_key": { "type": "string",  "description": "Direct Anthropic key (dev mode)", "secret": true },
      "openai_api_key":    { "type": "string",  "description": "Direct OpenAI key (dev mode)",    "secret": true }
    }
  },

  "permissions": [
    "browser.navigate",
    "browser.click",
    "browser.type",
    "browser.scroll",
    "browser.screenshot",
    "browser.extract",
    "browser.key",
    "browser.fill",
    "browser.record",
    "desktop.screenshot",
    "desktop.click",
    "desktop.type",
    "desktop.key",
    "desktop.scroll",
    "desktop.accessibility_read",
    "code.execute_python",
    "code.execute_javascript",
    "storage.read",
    "storage.write",
    "session.create",
    "session.read",
    "session.delete",
    "auth.read_session"
  ],

  "golden_paths": ["GP-01","GP-02","GP-03","GP-04","GP-05","GP-06","GP-07","GP-08","GP-09","GP-10"],

  "cookbooks": [
    "web-scraping",
    "form-automation",
    "login-flow",
    "multi-step-workflow",
    "desktop-app-automation",
    "data-pipeline",
    "invoice-processing",
    "job-application"
  ],

  "subagents": [
    "planning-agent",
    "verification-agent",
    "recovery-agent"
  ],

  "policy_profile": {
    "max_destructive_actions": 5,
    "requires_approval": true,
    "approval_policy": "on-risk",
    "risk_actions": ["fill","submit","click_submit","delete","close_tab","navigate_away"],
    "blocked_actions": [
      "delete_account",
      "payment_submit",
      "force_push",
      "rm_rf",
      "drop_database"
    ],
    "allowed_domains": ["*"],
    "max_session_duration_ms": 600000,
    "max_cost_usd": 2.0
  },

  "production_status": "beta",
  "conformance_suite": "plugin-computer-use-v1",
  "homepage": "https://github.com/allternit/computer-use",
  "tags": ["automation","computer-use","browser","desktop","vision","planning","recording"]
}
