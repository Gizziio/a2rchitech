{
  "id": "gmail",
  "name": "Gmail Plugin",
  "version": "0.1.0",
  "description": "Automates Gmail workflows: reading unread inbox messages, summarising email threads, and composing structured responses via browser automation.",
  "families": ["browser"],
  "modes": ["execute", "inspect", "assist"],
  "permissions": [
    "browser.navigate",
    "browser.click",
    "browser.type",
    "browser.screenshot",
    "browser.extract",
    "auth.read_session"
  ],
  "golden_paths": ["GP-01", "GP-02", "GP-08", "GP-10"],
  "cookbooks": ["read-inbox"],
  "prompts": ["summarize-email"],
  "conformance_suite": "plugin-gmail-v1",
  "production_status": "beta",
  "policy_profile": {
    "max_destructive_actions": 2,
    "requires_approval": true,
    "allowed_domains": ["mail.google.com", "accounts.google.com"],
    "blocked_actions": [
      "delete_all_emails",
      "empty_trash",
      "remove_label_inbox",
      "send_to_all_contacts"
    ]
  },
  "author": "A2R Platform Team",
  "tags": ["email", "gmail", "google", "inbox", "productivity", "browser"],
  "homepage": "https://github.com/a2rchitech/computer-use"
}
