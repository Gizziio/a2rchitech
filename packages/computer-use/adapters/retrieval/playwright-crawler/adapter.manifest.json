{
  "adapter_id": "retrieval.playwright-crawler",
  "display_name": "Playwright Crawler",
  "version": "0.2.0",
  "family": "retrieval",
  "pattern": "deterministic",
  "modes_supported": ["crawl", "execute", "inspect"],
  "capability_classes": ["retrieval-crawl", "deterministic-web"],
  "traits": {
    "headed": "no",
    "headless": "yes",
    "parallel": "yes",
    "persistent_session": "no",
    "visual_reasoning": "no",
    "low_level_debug": "no",
    "checkpointable": "yes",
    "current_session_attach": "no",
    "artifact_handoff": "yes",
    "network_inspection": "no",
    "multi_tab": "partial",
    "file_upload": "no",
    "file_download": "yes"
  },
  "guarantees": {
    "semantic": "A",
    "policy": "A",
    "receipt": "A",
    "conformance": "B",
    "routing_confidence": "A"
  },
  "production_status": "experimental",
  "policy_profile": "standard-browser",
  "risk_level": "low",
  "conformance_suite": "retrieval-v1",
  "fallback_rank": 10,
  "default_for_modes": ["crawl"],
  "dependencies": [
    { "name": "playwright", "kind": "python-package", "required": true },
    { "name": "chromium", "kind": "browser-runtime", "required": true }
  ],
  "limits": {
    "max_parallel_sessions": 16,
    "supports_remote": "no",
    "supports_local": "yes",
    "supports_user_present": "no"
  },
  "notes": "Batch-oriented crawl and extraction. No interactive sessions. Promotes to beta after retrieval-v1 conformance passes."
}
