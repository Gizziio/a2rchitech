{
  "adapter_id": "browser.playwright",
  "display_name": "Playwright Adapter",
  "version": "0.1.0",
  "family": "browser",
  "pattern": "deterministic",
  "modes_supported": ["execute", "inspect", "parallel"],
  "capability_classes": ["deterministic-web"],
  "traits": {
    "headed": "yes",
    "headless": "yes",
    "parallel": "yes",
    "persistent_session": "yes",
    "visual_reasoning": "no",
    "low_level_debug": "partial",
    "checkpointable": "partial",
    "current_session_attach": "no",
    "artifact_handoff": "partial",
    "network_inspection": "yes",
    "multi_tab": "yes",
    "file_upload": "yes",
    "file_download": "yes"
  },
  "guarantees": {
    "semantic": "A",
    "policy": "A",
    "receipt": "A",
    "conformance": "A",
    "routing_confidence": "A"
  },
  "production_status": "production",
  "policy_profile": "standard-browser",
  "risk_level": "medium",
  "conformance_suite": "browser-deterministic-v1",
  "fallback_rank": 10,
  "default_for_modes": ["execute", "parallel"],
  "dependencies": [
    { "name": "playwright", "kind": "python-package", "required": true },
    { "name": "chromium", "kind": "browser-runtime", "required": true }
