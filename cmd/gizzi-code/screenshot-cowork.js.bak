const { chromium } = require('playwright');

(async () => {
  const browser = await chromium.launch();
  const page = await browser.newPage({
    viewport: { width: 1400, height: 900 }
  });
  
  await page.goto('file:///Users/macbook/Desktop/allternit-workspace/allternit/cmd/gizzi-code/cowork-mode-mockup.html');
  await page.waitForTimeout(500);
  
  await page.screenshot({ 
    path: 'cowork-mode-preview.png',
    fullPage: false
  });
  
  await browser.close();
  console.log('Screenshot saved to cowork-mode-preview.png');
})();
