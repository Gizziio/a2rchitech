import { describe, test, expect, beforeEach, afterEach } from "bun:test"
import { SessionTemplate } from "@/runtime/session/template"
import { mkdir, rm, readdir, unlink } from "fs/promises"
import { homedir } from "os"
import path from "path"

const TEMPLATES_DIR = path.join(homedir(), ".gizzi", "templates")

describe("SessionTemplate", () => {
  beforeEach(async () => {
    // Clean up any existing templates
    try {
      const files = await readdir(TEMPLATES_DIR)
      for (const file of files) {
        if (file.endsWith('.json')) {
          await unlink(path.join(TEMPLATES_DIR, file))
        }
      }
    } catch {
      // Directory might not exist
    }
  })

  afterEach(async () => {
    // Clean up templates created during tests
    try {
      const files = await readdir(TEMPLATES_DIR)
      for (const file of files) {
        if (file.endsWith('.json')) {
          await unlink(path.join(TEMPLATES_DIR, file))
        }
      }
    } catch {
      // Ignore cleanup errors
    }
  })

  describe("create", () => {
    test("should create a template with name only", async () => {
      const template = await SessionTemplate.create({
        name: "Test Template",
      })

      expect(template.name).toBe("Test Template")
      expect(template.id).toContain("test-template-")
      expect(template.createdAt).toBeGreaterThan(0)
      expect(template.updatedAt).toBeGreaterThan(0)
    })

    test("should create a template with all fields", async () => {
      const template = await SessionTemplate.create({
        name: "Full Template",
        description: "A test template with all fields",
        systemPrompt: "You are a helpful assistant",
        agentName: "test-agent",
        providerID: "anthropic",
        modelID: "claude-sonnet-4-5",
        tags: ["test", "example"],
        category: "Testing",
      })

      expect(template.name).toBe("Full Template")
      expect(template.description).toBe("A test template with all fields")
      expect(template.systemPrompt).toBe("You are a helpful assistant")
      expect(template.agentName).toBe("test-agent")
      expect(template.providerID).toBe("anthropic")
      expect(template.modelID).toBe("claude-sonnet-4-5")
      expect(template.tags).toEqual(["test", "example"])
      expect(template.category).toBe("Testing")
    })
  })

  describe("get", () => {
    test("should return null for non-existent template", async () => {
      const template = await SessionTemplate.get("non-existent-id")
      expect(template).toBeNull()
    })

    test("should return template by id", async () => {
      const created = await SessionTemplate.create({
        name: "Retrievable Template",
      })

      const retrieved = await SessionTemplate.get(created.id)
      expect(retrieved).not.toBeNull()
      expect(retrieved!.name).toBe("Retrievable Template")
      expect(retrieved!.id).toBe(created.id)
    })
  })

  describe("list", () => {
    test("should return empty array when no templates", async () => {
      const templates = await SessionTemplate.list()
      expect(templates).toEqual([])
    })

    test("should return all templates sorted by updatedAt", async () => {
      await SessionTemplate.create({ name: "Template A" })
      await new Promise(r => setTimeout(r, 10))
      await SessionTemplate.create({ name: "Template B" })

      const templates = await SessionTemplate.list()
      expect(templates.length).toBe(2)
      expect(templates[0].name).toBe("Template B") // Most recent first
      expect(templates[1].name).toBe("Template A")
    })
  })

  describe("remove", () => {
    test("should return false for non-existent template", async () => {
      const success = await SessionTemplate.remove("non-existent-id")
      expect(success).toBe(false)
    })

    test("should delete existing template", async () => {
      const created = await SessionTemplate.create({
        name: "To Be Deleted",
      })

      const success = await SessionTemplate.remove(created.id)
      expect(success).toBe(true)

      const retrieved = await SessionTemplate.get(created.id)
      expect(retrieved).toBeNull()
    })
  })

  describe("update", () => {
    test("should return null for non-existent template", async () => {
      const updated = await SessionTemplate.update("non-existent-id", {
        name: "New Name",
      })
      expect(updated).toBeNull()
    })

    test("should update template fields", async () => {
      const created = await SessionTemplate.create({
        name: "Original Name",
        description: "Original description",
      })

      const updated = await SessionTemplate.update(created.id, {
        name: "Updated Name",
        description: "Updated description",
      })

      expect(updated).not.toBeNull()
      expect(updated!.name).toBe("Updated Name")
      expect(updated!.description).toBe("Updated description")
      expect(updated!.updatedAt).toBeGreaterThanOrEqual(created.updatedAt)
    })
  })

  describe("exportTemplates", () => {
    test("should export all templates as JSON", async () => {
      await SessionTemplate.create({ name: "Export A" })
      await SessionTemplate.create({ name: "Export B" })

      const json = await SessionTemplate.exportTemplates()
      const exported = JSON.parse(json)

      expect(exported.length).toBe(2)
      expect(exported.map((t: any) => t.name).sort()).toEqual(["Export A", "Export B"])
    })

    test("should export specific templates only", async () => {
      const a = await SessionTemplate.create({ name: "Include A" })
      await SessionTemplate.create({ name: "Exclude B" })

      const json = await SessionTemplate.exportTemplates([a.id])
      const exported = JSON.parse(json)

      expect(exported.length).toBe(1)
      expect(exported[0].name).toBe("Include A")
    })
  })

  describe("importTemplates", () => {
    test("should import templates from JSON", async () => {
      const templates = [
        {
          name: "Imported A",
          description: "Description A",
          tags: ["tag1"],
        },
        {
          name: "Imported B",
          description: "Description B",
          tags: ["tag2"],
        },
      ]

      const count = await SessionTemplate.importTemplates(JSON.stringify(templates))
      expect(count).toBe(2)

      const list = await SessionTemplate.list()
      expect(list.length).toBe(2)
    })

    test("should skip invalid templates", async () => {
      const templates = [
        { name: "Valid Template" },
        { description: "Missing name" }, // Invalid - no name
      ]

      const count = await SessionTemplate.importTemplates(JSON.stringify(templates))
      expect(count).toBe(1) // Only one valid template imported
    })
  })
})
