// @ts-nocheck
/**
 * Phase 0 gate: deterministic session dock state seeding via the /e2e route.
 *
 * Verifies that the E2E test harness can reliably put a session into each
 * dock state (question / permission / todo) and clear it — without relying on
 * model output.  These tests must stay green before any session-composer
 * refactor work proceeds (see specs/session-composer-refactor-plan.md §0.3).
 */
import { describe, expect, test } from "bun:test"
import { Instance } from "../../src/runtime/context/project/instance"
import { Question } from "../../src/runtime/integrations/question"
import { PermissionNext } from "../../src/runtime/tools/guard/permission/next"
import { Todo } from "../../src/runtime/session/todo"
import { Session } from "../../src/session"
import { E2ERoutes } from "../../src/runtime/server/routes/e2e"
import { Identifier } from "../../src/shared/id/id"
import { tmpdir } from "../fixture/fixture"

// ---------------------------------------------------------------------------
// Helpers
// ---------------------------------------------------------------------------

async function post(path: string, body: unknown) {
  return E2ERoutes().request(path, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify(body),
  })
}

async function del(path: string) {
  return E2ERoutes().request(path, { method: "DELETE" })
}

// ---------------------------------------------------------------------------
// Question seeding
// ---------------------------------------------------------------------------

describe("E2E harness — question dock", () => {
  test("seeding a question shows it in the pending list", async () => {
    await using dir = await tmpdir({ git: true })
    await Instance.provide({
      directory: dir.path,
      fn: async () => {
        // Use a proper session ID format (starts with "ses")
        const sessionID = Identifier.ascending("session")

        const res = await post("/question", {
          sessionID,
          questions: [
            {
              header: "Approach",
              question: "Which approach should I use?",
              options: [
                { label: "Fast", description: "Optimise for speed" },
                { label: "Safe", description: "Optimise for correctness" },
              ],
            },
          ],
        })

        expect(res.status).toBe(200)
        const body = await res.json()
        expect(body.requestID).toBeTruthy()

        const pending = await Question.list()
        const entry = pending.find((q) => q.sessionID === sessionID)
        expect(entry).toBeDefined()
        expect(entry?.questions[0].header).toBe("Approach")

        // Clean up via specific requestID
        await del(`/question/${body.requestID}`)
        const after = await Question.list()
        expect(after.find((q) => q.sessionID === sessionID)).toBeUndefined()

        await Instance.dispose()
      },
    })
  })

  test("clearing a session removes all its pending questions", async () => {
    await using dir = await tmpdir({ git: true })
    await Instance.provide({
      directory: dir.path,
      fn: async () => {
        const sessionID = Identifier.ascending("session")

        await post("/question", {
          sessionID,
          questions: [{ header: "Q1", question: "First question?", options: [] }],
        })
        await post("/question", {
          sessionID,
          questions: [{ header: "Q2", question: "Second question?", options: [] }],
        })

        const before = await Question.list()
        expect(before.filter((q) => q.sessionID === sessionID)).toHaveLength(2)

        const clearRes = await del(`/session/${sessionID}`)
        expect(clearRes.status).toBe(200)

        const after = await Question.list()
        expect(after.filter((q) => q.sessionID === sessionID)).toHaveLength(0)

        await Instance.dispose()
      },
    })
  })
})

// ---------------------------------------------------------------------------
// Permission seeding
// ---------------------------------------------------------------------------

describe("E2E harness — permission dock", () => {
  test("seeding a permission shows it in the pending list", async () => {
    await using dir = await tmpdir({ git: true })
    await Instance.provide({
      directory: dir.path,
      fn: async () => {
        const sessionID = Identifier.ascending("session")

        const res = await post("/permission", {
          sessionID,
          permission: "write",
          patterns: ["/tmp/test-file.txt"],
          metadata: { tool: "write" },
          always: ["/tmp/test-file.txt"],
        })

        expect(res.status).toBe(200)
        const body = await res.json()
        expect(body.requestID).toBeTruthy()

        const pending = await PermissionNext.list()
        const entry = pending.find((p) => p.sessionID === sessionID)
        expect(entry).toBeDefined()
        expect(entry?.permission).toBe("write")
        expect(entry?.patterns).toContain("/tmp/test-file.txt")

        // Clear via specific requestID
        await del(`/permission/${body.requestID}`)
        const after = await PermissionNext.list()
        expect(after.find((p) => p.sessionID === sessionID)).toBeUndefined()

        await Instance.dispose()
      },
    })
  })

  test("clearing a session rejects all pending permissions for it", async () => {
    await using dir = await tmpdir({ git: true })
    await Instance.provide({
      directory: dir.path,
      fn: async () => {
        const sessionID = Identifier.ascending("session")

        await post("/permission", {
          sessionID,
          permission: "bash",
          patterns: ["rm -rf /tmp/x"],
          metadata: {},
        })

        const before = await PermissionNext.list()
        expect(before.filter((p) => p.sessionID === sessionID)).toHaveLength(1)

        await del(`/session/${sessionID}`)

        const after = await PermissionNext.list()
        expect(after.filter((p) => p.sessionID === sessionID)).toHaveLength(0)

        await Instance.dispose()
      },
    })
  })
})

// ---------------------------------------------------------------------------
// Todo seeding
// ---------------------------------------------------------------------------

describe("E2E harness — todo dock", () => {
  test("seeding todos updates the session todo list", async () => {
    await using dir = await tmpdir({ git: true })
    await Instance.provide({
      directory: dir.path,
      fn: async () => {
        // Todos require a real session row in the DB (FK constraint)
        const session = await Session.create({})

        const res = await post("/todo", {
          sessionID: session.id,
          todos: [
            { content: "Write tests", status: "pending", priority: "high" },
            { content: "Refactor composer", status: "in_progress", priority: "medium" },
          ],
        })

        expect(res.status).toBe(200)

        const todos = Todo.get(session.id)
        expect(todos).toHaveLength(2)
        expect(todos[0].content).toBe("Write tests")
        expect(todos[0].status).toBe("pending")
        expect(todos[1].content).toBe("Refactor composer")
        expect(todos[1].status).toBe("in_progress")

        await Session.remove(session.id)
        await Instance.dispose()
      },
    })
  })

  test("seeding todos replaces existing todos for the session", async () => {
    await using dir = await tmpdir({ git: true })
    await Instance.provide({
      directory: dir.path,
      fn: async () => {
        const session = await Session.create({})

        await post("/todo", {
          sessionID: session.id,
          todos: [{ content: "Old task", status: "pending", priority: "low" }],
        })

        await post("/todo", {
          sessionID: session.id,
          todos: [
            { content: "New task A", status: "completed", priority: "high" },
            { content: "New task B", status: "completed", priority: "high" },
          ],
        })

        const todos = Todo.get(session.id)
        expect(todos).toHaveLength(2)
        expect(todos.every((t) => t.status === "completed")).toBe(true)

        await Session.remove(session.id)
        await Instance.dispose()
      },
    })
  })

  test("clearing a session removes its todos", async () => {
    await using dir = await tmpdir({ git: true })
    await Instance.provide({
      directory: dir.path,
      fn: async () => {
        const session = await Session.create({})

        await post("/todo", {
          sessionID: session.id,
          todos: [{ content: "Task to clear", status: "pending", priority: "medium" }],
        })

        expect(Todo.get(session.id)).toHaveLength(1)

        await del(`/session/${session.id}`)

        expect(Todo.get(session.id)).toHaveLength(0)

        await Session.remove(session.id)
        await Instance.dispose()
      },
    })
  })
})

// ---------------------------------------------------------------------------
// Session-level clear (combined)
// ---------------------------------------------------------------------------

describe("E2E harness — clear all dock state", () => {
  test("DELETE /session/:id clears questions, permissions, and todos together", async () => {
    await using dir = await tmpdir({ git: true })
    await Instance.provide({
      directory: dir.path,
      fn: async () => {
        const session = await Session.create({})
        const sessionID = session.id

        await post("/question", {
          sessionID,
          questions: [{ header: "Test", question: "Proceed?", options: [] }],
        })
        await post("/permission", {
          sessionID,
          permission: "write",
          patterns: ["/tmp/x"],
          metadata: {},
        })
        await post("/todo", {
          sessionID,
          todos: [{ content: "Some task", status: "pending", priority: "low" }],
        })

        // Verify all seeded
        expect((await Question.list()).filter((q) => q.sessionID === sessionID)).toHaveLength(1)
        expect((await PermissionNext.list()).filter((p) => p.sessionID === sessionID)).toHaveLength(1)
        expect(Todo.get(sessionID)).toHaveLength(1)

        // Clear all
        const clearRes = await del(`/session/${sessionID}`)
        expect(clearRes.status).toBe(200)

        expect((await Question.list()).filter((q) => q.sessionID === sessionID)).toHaveLength(0)
        expect((await PermissionNext.list()).filter((p) => p.sessionID === sessionID)).toHaveLength(0)
        expect(Todo.get(sessionID)).toHaveLength(0)

        await Session.remove(session.id)
        await Instance.dispose()
      },
    })
  })
})
