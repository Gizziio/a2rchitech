import { describe, expect, test } from "bun:test"
import {
  A2RComputerUseClient,
  createComputerUseClient,
  resolveComputerUseBaseUrl,
} from "@allternit/sdk/computer-use"

describe("@allternit/sdk/computer-use", () => {
  test("createComputerUseClient returns an A2RComputerUseClient", () => {
    const client = createComputerUseClient({ baseUrl: "http://localhost:3010" })
    expect(client).toBeInstanceOf(A2RComputerUseClient)
  })

  test("resolveComputerUseBaseUrl trims trailing slashes", () => {
    expect(resolveComputerUseBaseUrl("http://localhost:3010///")).toBe("http://localhost:3010")
  })

  test("execute posts the canonical request payload", async () => {
    let seenPath: string | null = null
    let seenBody: unknown = null

    const client = createComputerUseClient({
      baseUrl: "http://localhost:3010",
      fetch: (async (input: RequestInfo | URL, init?: RequestInit) => {
        const request = input instanceof Request ? input : new Request(input, init)
        seenPath = new URL(request.url).pathname
        seenBody = await request.json()
        return new Response(JSON.stringify({ run_id: "run-sdk-1" }), {
          status: 200,
          headers: { "Content-Type": "application/json" },
        })
      }) as typeof fetch,
    })

    const result = await client.execute({
      mode: "intent",
      task: "Open example.com",
      target_scope: "browser",
      metadata: { source: "sdk-test" },
    })

    expect(seenPath!).toBe("/v1/engine/execute")
    expect(seenBody).toEqual({
      mode: "intent",
      task: "Open example.com",
      target_scope: "browser",
      metadata: { source: "sdk-test" },
    })
    expect(result).toEqual({ run_id: "run-sdk-1" })
  })

  test("approval helpers hit the normalized approval endpoints", async () => {
    const seen: Array<{ path: string; body: unknown }> = []

    const client = createComputerUseClient({
      baseUrl: "http://localhost:3010",
      fetch: (async (input: RequestInfo | URL, init?: RequestInit) => {
        const request = input instanceof Request ? input : new Request(input, init)
        seen.push({
          path: new URL(request.url).pathname,
          body: await request.json(),
        })
        return new Response(JSON.stringify({ ok: true }), {
          status: 200,
          headers: { "Content-Type": "application/json" },
        })
      }) as typeof fetch,
    })

    await client.approveRun("run-approval-1", { approver_id: "sdk" })
    await client.denyRun("run-approval-1", { approver_id: "sdk", comment: "deny" })
    await client.cancelRun("run-approval-1", { approver_id: "sdk", comment: "cancel" })
    await client.pauseRun("run-approval-1", { approver_id: "sdk", comment: "pause" })
    await client.resumeRun("run-approval-1", { approver_id: "sdk", comment: "resume" })

    expect(seen).toEqual([
      {
        path: "/v1/engine/runs/run-approval-1/approval",
        body: { decision: "approve", approver_id: "sdk" },
      },
      {
        path: "/v1/engine/runs/run-approval-1/approval",
        body: { decision: "deny", approver_id: "sdk", comment: "deny" },
      },
      {
        path: "/v1/engine/runs/run-approval-1/cancel",
        body: { approver_id: "sdk", comment: "cancel" },
      },
      {
        path: "/v1/engine/runs/run-approval-1/pause",
        body: { approver_id: "sdk", comment: "pause" },
      },
      {
        path: "/v1/engine/runs/run-approval-1/resume",
        body: { approver_id: "sdk", comment: "resume" },
      },
    ])
  })

  test("watchRun yields event batches until completion", async () => {
    let calls = 0

    const client = createComputerUseClient({
      baseUrl: "http://localhost:3010",
      fetch: (async (input: RequestInfo | URL, init?: RequestInit) => {
        const request = input instanceof Request ? input : new Request(input, init)
        const url = new URL(request.url)

        if (url.pathname === "/v1/engine/runs/run-watch-1/events") {
          calls += 1
          if (calls === 1) {
            return new Response(JSON.stringify({
              run_id: "run-watch-1",
              status: "running",
              completed: false,
              next_index: 1,
              events: [
                { event_type: "step.started", message: "first step" },
              ],
            }), {
              status: 200,
              headers: { "Content-Type": "application/json" },
            })
          }

          return new Response(JSON.stringify({
            run_id: "run-watch-1",
            status: "completed",
            completed: true,
            next_index: 2,
            events: [
              { event_type: "run.completed", message: "done" },
            ],
          }), {
            status: 200,
            headers: { "Content-Type": "application/json" },
          })
        }

        return new Response(JSON.stringify({ detail: `Unhandled path ${url.pathname}` }), {
          status: 404,
          headers: { "Content-Type": "application/json" },
        })
      }) as typeof fetch,
    })

    const batches = []
    for await (const batch of client.watchRun("run-watch-1", { intervalMs: 0 })) {
      batches.push(batch)
    }

    expect(batches).toHaveLength(2)
    expect(batches[0]).toMatchObject({
      run_id: "run-watch-1",
      status: "running",
    })
    expect(batches[1]).toMatchObject({
      run_id: "run-watch-1",
      status: "completed",
    })
  })

  test("waitForRun returns once the run reaches needs_approval", async () => {
    let calls = 0

    const client = createComputerUseClient({
      baseUrl: "http://localhost:3010",
      fetch: (async (input: RequestInfo | URL, init?: RequestInit) => {
        const request = input instanceof Request ? input : new Request(input, init)
        const url = new URL(request.url)
        if (url.pathname === "/v1/engine/snapshot/run-wait-1") {
          calls += 1
          const status = calls >= 2 ? "needs_approval" : "running"
          return new Response(JSON.stringify({
            run_id: "run-wait-1",
            status,
          }), {
            status: 200,
            headers: { "Content-Type": "application/json" },
          })
        }

        return new Response(JSON.stringify({ detail: `Unhandled path ${url.pathname}` }), {
          status: 404,
          headers: { "Content-Type": "application/json" },
        })
      }) as typeof fetch,
    })

    const snapshot = await client.waitForRun("run-wait-1", { intervalMs: 0 })
    expect(snapshot).toEqual({
      run_id: "run-wait-1",
      status: "needs_approval",
    })
  })
})
