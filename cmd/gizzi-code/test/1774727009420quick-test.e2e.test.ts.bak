/**
 * E2E Test 1774727009420quick test
 *
 * Quick test suite for basic end-to-end verification.
 */

import { describe, expect, test, beforeAll, afterAll } from "bun:test"
import { Hono } from "hono"
import { serve } from "bun"
import type { Server } from "bun"
import { tmpdir } from "./fixture/fixture"

// ── Test Setup ─────────────────────────────────────────────────────────────────

describe("1774727009420quick test - E2E", () => {
  test("basic health check passes", async () => {
    expect(true).toBe(true)
  })

  test("temporary directory fixture works", async () => {
    await using tmp = await tmpdir()
    expect(tmp.path).toBeTruthy()
    expect(tmp.path).toContain("opencode-test-")
  })

  test("temporary directory with git initialization", async () => {
    await using tmp = await tmpdir({ git: true })
    const fs = await import("fs/promises")
    const path = await import("path")
    
    // Check that .git directory exists
    const gitDir = path.join(tmp.path, ".git")
    const stat = await fs.stat(gitDir)
    expect(stat.isDirectory()).toBe(true)
  })

  test("async operations complete successfully", async () => {
    const result = await Promise.resolve(42)
    expect(result).toBe(42)
  })

  test("fetch mock server responds correctly", async () => {
    const app = new Hono()
    app.get("/health", (c) => c.json({ status: "ok" }))

    const server = serve({
      port: 0,
      fetch: app.fetch,
    })

    try {
      const url = `http://localhost:${server.port}/health`
      const res = await fetch(url)
      expect(res.ok).toBe(true)
      
      const data = await res.json() as { status: string }
      expect(data.status).toBe("ok")
    } finally {
      server.stop()
    }
  })

  test("environment variables are accessible", () => {
    expect(process.env).toBeDefined()
    expect(typeof process.env.PATH).toBe("string")
  })

  test("Bun APIs are available", () => {
    expect(typeof Bun.version).toBe("string")
    expect(typeof Bun.SHA256).toBe("function")
  })
})
