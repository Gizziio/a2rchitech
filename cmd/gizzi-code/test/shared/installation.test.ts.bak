// @ts-nocheck
import { afterEach, expect, test } from "bun:test"
import { Installation } from "../../src/shared/installation"

const originalFetch = global.fetch

afterEach(() => {
  global.fetch = originalFetch
})

test("github release repos prefer gizziio first and keep current compatibility fallbacks", () => {
  expect(Installation.githubReleaseRepos()).toEqual([
    "gizziio/gizzi-code",
    "a2r/gizzi-code",
    "gizzi/gizzi-code",
    "anomalyco/gizzi",
  ])
})

test("latest() parses the preferred GitHub release tag", async () => {
  const calls: string[] = []
  global.fetch = async (input: RequestInfo | URL) => {
    const url = String(input)
    calls.push(url)
    if (url.includes("/repos/gizziio/gizzi-code/releases/latest")) {
      return new Response(JSON.stringify({ tag_name: "v2.3.4" }), { status: 200 })
    }
    return new Response("not found", { status: 404 })
  }

  await expect(Installation.latest("unknown")).resolves.toBe("2.3.4")
  expect(calls[0]).toContain("/repos/gizziio/gizzi-code/releases/latest")
})

test("latest() falls back through current GitHub release repos", async () => {
  const calls: string[] = []
  global.fetch = async (input: RequestInfo | URL) => {
    const url = String(input)
    calls.push(url)
    if (url.includes("/repos/anomalyco/gizzi/releases/latest")) {
      return new Response(JSON.stringify({ tag_name: "v9.9.9" }), { status: 200 })
    }
    return new Response("not found", { status: 404 })
  }

  await expect(Installation.latest("unknown")).resolves.toBe("9.9.9")
  expect(calls).toEqual([
    "https://api.github.com/repos/gizziio/gizzi-code/releases/latest",
    "https://api.github.com/repos/a2r/gizzi-code/releases/latest",
    "https://api.github.com/repos/gizzi/gizzi-code/releases/latest",
    "https://api.github.com/repos/anomalyco/gizzi/releases/latest",
  ])
})
