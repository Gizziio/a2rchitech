import { describe, expect, test } from "bun:test"
import {
  sdkData,
  sdkDataOr,
  sdkErrorMessage,
  sdkRequireData,
} from "../src/cli/ui/tui/context/sdk-result"

describe("tui sdk helpers", () => {
  test("sdkData unwraps request results without touching plain objects", () => {
    expect(
      sdkData<string[]>({
        data: ["session-1"],
        request: new Request("http://localhost/v1/session/list"),
        response: new Response(),
      }),
    ).toEqual(["session-1"])

    expect(sdkData<any>({ data: { nested: true } })).toEqual({ data: { nested: true } })
  })

  test("sdkDataOr falls back when request results have no data", () => {
    expect(sdkDataOr({ error: { message: "boom" } }, [])).toEqual([])
  })

  test("sdkRequireData throws a readable SDK error", () => {
    expect(() => sdkRequireData({ error: { message: "Missing session" } }, "fallback")).toThrow(
      "Missing session",
    )
    expect(() => sdkRequireData(undefined, "fallback")).toThrow("fallback")
  })

  test("sdkErrorMessage normalizes unknown errors", () => {
    expect(sdkErrorMessage(new Error("bad"))).toBe("bad")
    expect(sdkErrorMessage({ message: "worse" })).toBe("worse")
    expect(sdkErrorMessage({ error: "worst" })).toBe("worst")
  })
})
