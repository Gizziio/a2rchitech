// @ts-nocheck
import { describe, expect, test } from "bun:test"
import * as fs from "fs/promises"
import path from "path"
import { Instance } from "../../src/runtime/context/project/instance"
import {
  MemoryService,
  parseFrontmatter,
  serializeFrontmatter,
  projectHash,
  globalProjectMemoryDir,
} from "../../src/runtime/memory/memory-service"
import { tmpdir } from "../fixture/fixture"

// ── parseFrontmatter ──────────────────────────────────────────────────────────

describe("parseFrontmatter", () => {
  test("parses all three fields", () => {
    const content = `---\nname: my memory\ndescription: a test\ntype: user\n---\n\nbody here`
    const { fm, body } = parseFrontmatter(content)
    expect(fm.name).toBe("my memory")
    expect(fm.description).toBe("a test")
    expect(fm.type).toBe("user")
    expect(body).toBe("body here")
  })

  test("returns empty fm when no frontmatter", () => {
    const content = `just plain content`
    const { fm, body } = parseFrontmatter(content)
    expect(fm.name).toBeUndefined()
    expect(body).toBe("just plain content")
  })

  test("handles frontmatter with extra whitespace", () => {
    const content = `---\nname:  spaced  \ndescription: desc\ntype: feedback\n---\n\ncontent`
    const { fm } = parseFrontmatter(content)
    expect(fm.name).toBe("spaced")
  })
})

// ── serializeFrontmatter ──────────────────────────────────────────────────────

describe("serializeFrontmatter", () => {
  test("round-trips through parseFrontmatter", () => {
    const fm = { name: "my memory", description: "a desc", type: "project" as const }
    const body = "some content"
    const serialized = serializeFrontmatter(fm, body)
    const { fm: parsed, body: parsedBody } = parseFrontmatter(serialized)
    expect(parsed.name).toBe(fm.name)
    expect(parsed.description).toBe(fm.description)
    expect(parsed.type).toBe(fm.type)
    expect(parsedBody).toBe(body)
  })
})

// ── projectHash ───────────────────────────────────────────────────────────────

describe("projectHash", () => {
  test("strips leading slash and replaces separators", () => {
    expect(projectHash("/home/user/project")).toBe("home-user-project")
  })

  test("produces same result for same path", () => {
    const p = "/workspace/myproject/subdir"
    expect(projectHash(p)).toBe(projectHash(p))
  })

  test("produces different results for different paths", () => {
    expect(projectHash("/a/b")).not.toBe(projectHash("/a/c"))
  })
})

// ── MemoryService CRUD ────────────────────────────────────────────────────────

describe("MemoryService.save + get", () => {
  test("saves a memory and retrieves it by filename", async () => {
    await using dir = await tmpdir({ git: true })
    await Instance.provide({
      directory: dir.path,
      fn: async () => {
        const entry = await MemoryService.save(
          { name: "test_memory", description: "a test memory", type: "user" },
          "remember this",
        )

        expect(entry.filename).toBe("test_memory.md")
        expect(entry.body).toBe("remember this")
        expect(entry.type).toBe("user")

        const fetched = await MemoryService.get("test_memory.md")
        expect(fetched).not.toBeNull()
        expect(fetched!.name).toBe("test_memory")
        expect(fetched!.body).toBe("remember this")

        await Instance.dispose()
      },
    })
  })

  test("get returns null for non-existent memory", async () => {
    await using dir = await tmpdir({ git: true })
    await Instance.provide({
      directory: dir.path,
      fn: async () => {
        const result = await MemoryService.get("nonexistent.md")
        expect(result).toBeNull()
        await Instance.dispose()
      },
    })
  })

  test("save overwrites existing memory with same name", async () => {
    await using dir = await tmpdir({ git: true })
    await Instance.provide({
      directory: dir.path,
      fn: async () => {
        await MemoryService.save(
          { name: "overwrite_me", description: "v1", type: "feedback" },
          "first version",
        )
        await MemoryService.save(
          { name: "overwrite_me", description: "v2", type: "feedback" },
          "second version",
        )

        const fetched = await MemoryService.get("overwrite_me.md")
        expect(fetched!.body).toBe("second version")
        expect(fetched!.description).toBe("v2")

        await Instance.dispose()
      },
    })
  })
})

describe("MemoryService.list", () => {
  test("lists saved memories", async () => {
    await using dir = await tmpdir({ git: true })
    await Instance.provide({
      directory: dir.path,
      fn: async () => {
        await MemoryService.save({ name: "alpha", description: "first", type: "user" }, "alpha body")
        await MemoryService.save({ name: "beta", description: "second", type: "project" }, "beta body")

        const entries = await MemoryService.list()
        const names = entries.map((e) => e.name)
        expect(names).toContain("alpha")
        expect(names).toContain("beta")

        await Instance.dispose()
      },
    })
  })

  test("deduplicates by filename across multiple dirs", async () => {
    await using dir = await tmpdir({ git: true })
    await Instance.provide({
      directory: dir.path,
      fn: async () => {
        // Write the same filename to two memory dirs
        const memDir1 = path.join(dir.path, ".gizzi", "L1-COGNITIVE", "memory")
        const memDir2 = path.join(dir.path, ".openclaw", "L1-COGNITIVE", "memory")
        await fs.mkdir(memDir1, { recursive: true })
        await fs.mkdir(memDir2, { recursive: true })

        const content = `---\nname: shared\ndescription: in both\ntype: user\n---\n\nbody`
        await fs.writeFile(path.join(memDir1, "shared.md"), content)
        await fs.writeFile(path.join(memDir2, "shared.md"), content)

        const entries = await MemoryService.list()
        const shared = entries.filter((e) => e.filename === "shared.md")
        expect(shared).toHaveLength(1)

        await Instance.dispose()
      },
    })
  })
})

describe("MemoryService.remove", () => {
  test("deletes an existing memory and returns true", async () => {
    await using dir = await tmpdir({ git: true })
    await Instance.provide({
      directory: dir.path,
      fn: async () => {
        await MemoryService.save({ name: "to_delete", description: "bye", type: "reference" }, "content")
        const ok = await MemoryService.remove("to_delete.md")
        expect(ok).toBe(true)

        const fetched = await MemoryService.get("to_delete.md")
        expect(fetched).toBeNull()

        await Instance.dispose()
      },
    })
  })

  test("returns false for non-existent memory", async () => {
    await using dir = await tmpdir({ git: true })
    await Instance.provide({
      directory: dir.path,
      fn: async () => {
        const ok = await MemoryService.remove("ghost.md")
        expect(ok).toBe(false)
        await Instance.dispose()
      },
    })
  })

  test("removes entry from MEMORY.md index", async () => {
    await using dir = await tmpdir({ git: true })
    await Instance.provide({
      directory: dir.path,
      fn: async () => {
        await MemoryService.save({ name: "indexed", description: "in index", type: "user" }, "body")

        const memDir = globalProjectMemoryDir()
        const indexBefore = await fs.readFile(path.join(memDir, "MEMORY.md"), "utf8")
        expect(indexBefore).toContain("indexed.md")

        await MemoryService.remove("indexed.md")

        const indexAfter = await fs.readFile(path.join(memDir, "MEMORY.md"), "utf8")
        expect(indexAfter).not.toContain("indexed.md")

        await Instance.dispose()
      },
    })
  })
})

describe("MemoryService.search", () => {
  test("finds memories by name", async () => {
    await using dir = await tmpdir({ git: true })
    await Instance.provide({
      directory: dir.path,
      fn: async () => {
        await MemoryService.save({ name: "typescript_preferences", description: "ts config", type: "feedback" }, "body")
        await MemoryService.save({ name: "python_notes", description: "python stuff", type: "project" }, "body")

        const results = await MemoryService.search("typescript")
        expect(results.map((e) => e.name)).toContain("typescript_preferences")
        expect(results.map((e) => e.name)).not.toContain("python_notes")

        await Instance.dispose()
      },
    })
  })

  test("finds memories by body content", async () => {
    await using dir = await tmpdir({ git: true })
    await Instance.provide({
      directory: dir.path,
      fn: async () => {
        await MemoryService.save(
          { name: "codebase_note", description: "note", type: "project" },
          "always use bun for package management",
        )

        const results = await MemoryService.search("bun package")
        expect(results).toHaveLength(1)
        expect(results[0].name).toBe("codebase_note")

        await Instance.dispose()
      },
    })
  })

  test("returns empty array when nothing matches", async () => {
    await using dir = await tmpdir({ git: true })
    await Instance.provide({
      directory: dir.path,
      fn: async () => {
        await MemoryService.save({ name: "something", description: "desc", type: "user" }, "body")

        const results = await MemoryService.search("zzz-no-match-zzz")
        expect(results).toHaveLength(0)

        await Instance.dispose()
      },
    })
  })

  test("empty query returns all memories", async () => {
    await using dir = await tmpdir({ git: true })
    await Instance.provide({
      directory: dir.path,
      fn: async () => {
        await MemoryService.save({ name: "mem_a", description: "a", type: "user" }, "body a")
        await MemoryService.save({ name: "mem_b", description: "b", type: "project" }, "body b")

        const all = await MemoryService.list()
        expect(all.length).toBeGreaterThanOrEqual(2)

        await Instance.dispose()
      },
    })
  })
})

// ── MEMORY.md index management ────────────────────────────────────────────────

describe("MEMORY.md index", () => {
  test("index is created on first save", async () => {
    await using dir = await tmpdir({ git: true })
    await Instance.provide({
      directory: dir.path,
      fn: async () => {
        await MemoryService.save({ name: "first_entry", description: "creates index", type: "user" }, "body")

        const memDir = globalProjectMemoryDir()
        const indexExists = await fs.access(path.join(memDir, "MEMORY.md")).then(() => true).catch(() => false)
        expect(indexExists).toBe(true)

        await Instance.dispose()
      },
    })
  })

  test("index lists all saved entries", async () => {
    await using dir = await tmpdir({ git: true })
    await Instance.provide({
      directory: dir.path,
      fn: async () => {
        await MemoryService.save({ name: "entry_one", description: "one", type: "user" }, "body")
        await MemoryService.save({ name: "entry_two", description: "two", type: "feedback" }, "body")

        const memDir = globalProjectMemoryDir()
        const index = await fs.readFile(path.join(memDir, "MEMORY.md"), "utf8")
        expect(index).toContain("entry_one.md")
        expect(index).toContain("entry_two.md")

        await Instance.dispose()
      },
    })
  })
})
