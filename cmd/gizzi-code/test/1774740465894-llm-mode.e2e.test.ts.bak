/**
 * E2E Test 1774740465894 - LLM-mode
 *
 * End-to-end tests for LLM mode functionality including streaming,
 * tool calls, and provider integration.
 */

import { describe, expect, test, beforeAll, afterAll, beforeEach } from "bun:test"
import { Hono } from "hono"
import { serve } from "bun"
import type { Server } from "bun"
import { tmpdir } from "./fixture/fixture"
import path from "path"

// ── Mock LLM Server ────────────────────────────────────────────────────────────

interface MockRequest {
  url: URL
  headers: Headers
  body: Record<string, unknown>
}

const mockState = {
  server: null as Server<undefined> | null,
  requests: [] as MockRequest[],
  responses: new Map<string, Response>(),
}

function createEventStream(chunks: unknown[], includeDone = false): ReadableStream<Uint8Array> {
  const lines = chunks.map((chunk) => `data: ${typeof chunk === "string" ? chunk : JSON.stringify(chunk)}`)
  if (includeDone) lines.push("data: [DONE]")
  const payload = lines.join("\n\n") + "\n\n"
  const encoder = new TextEncoder()
  return new ReadableStream({
    start(controller) {
      controller.enqueue(encoder.encode(payload))
      controller.close()
    },
  })
}

function buildMockLLMServer(): Hono {
  const app = new Hono()

  // OpenAI-compatible chat completions endpoint
  app.post("/v1/chat/completions", async (c) => {
    const body = await c.req.json()
    mockState.requests.push({
      url: new URL(c.req.url),
      headers: new Headers(c.req.header()),
      body,
    })

    const stream = createEventStream(
      [
        { id: "chat-1", choices: [{ delta: { role: "assistant" } }] },
        { id: "chat-1", choices: [{ delta: { content: "Hello from LLM" } }] },
        { id: "chat-1", choices: [{ delta: {}, finish_reason: "stop" }] },
      ],
      true,
    )

    return new Response(stream, {
      headers: { "Content-Type": "text/event-stream" },
    })
  })

  // Anthropic messages endpoint
  app.post("/v1/messages", async (c) => {
    const body = await c.req.json()
    mockState.requests.push({
      url: new URL(c.req.url),
      headers: new Headers(c.req.header()),
      body,
    })

    const stream = createEventStream([
      { type: "message_start", message: { id: "msg-1", model: body.model } },
      { type: "content_block_start", index: 0, content_block: { type: "text", text: "" } },
      { type: "content_block_delta", index: 0, delta: { type: "text_delta", text: "Hello from Claude" } },
      { type: "content_block_stop", index: 0 },
      { type: "message_delta", delta: { stop_reason: "end_turn" } },
      { type: "message_stop" },
    ])

    return new Response(stream, {
      headers: { "Content-Type": "text/event-stream" },
    })
  })

  // Google Gemini endpoint
  app.post("/v1beta/models/:modelId:streamGenerateContent", async (c) => {
    const body = await c.req.json()
    mockState.requests.push({
      url: new URL(c.req.url),
      headers: new Headers(c.req.header()),
      body,
    })

    const stream = createEventStream([
      {
        candidates: [{ content: { parts: [{ text: "Hello from Gemini" }] }, finishReason: "STOP" }],
        usageMetadata: { promptTokenCount: 1, candidatesTokenCount: 1, totalTokenCount: 2 },
      },
    ])

    return new Response(stream, {
      headers: { "Content-Type": "text/event-stream" },
    })
  })

  // Health check
  app.get("/health", (c) => c.json({ status: "ok", mode: "llm-mock" }))

  return app
}

// ── Test Setup ─────────────────────────────────────────────────────────────────

beforeAll(async () => {
  const app = buildMockLLMServer()
  mockState.server = serve({
    port: 0,
    fetch: app.fetch,
  })
})

afterAll(() => {
  mockState.server?.stop()
})

beforeEach(() => {
  mockState.requests.length = 0
  mockState.responses.clear()
})

// ── LLM Mode E2E Tests ─────────────────────────────────────────────────────────

describe("1774740465894 - LLM-mode E2E", () => {
  const getMockUrl = () => `http://localhost:${mockState.server?.port}`

  test("mock LLM server is running", async () => {
    const res = await fetch(`${getMockUrl()}/health`)
    expect(res.ok).toBe(true)
    const data = await res.json()
    expect(data.mode).toBe("llm-mock")
  })

  test("OpenAI-compatible chat completion streams correctly", async () => {
    const res = await fetch(`${getMockUrl()}/v1/chat/completions`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        Authorization: "Bearer test-key",
      },
      body: JSON.stringify({
        model: "gpt-4",
        messages: [{ role: "user", content: "Hello" }],
        stream: true,
        temperature: 0.7,
        max_tokens: 100,
      }),
    })

    expect(res.ok).toBe(true)
    expect(res.headers.get("Content-Type")).toContain("text/event-stream")

    // Verify request was captured
    expect(mockState.requests.length).toBe(1)
    expect(mockState.requests[0].body.model).toBe("gpt-4")
    expect(mockState.requests[0].body.temperature).toBe(0.7)
    expect(mockState.requests[0].body.max_tokens).toBe(100)
  })

  test("Anthropic messages endpoint streams correctly", async () => {
    const res = await fetch(`${getMockUrl()}/v1/messages`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "x-api-key": "test-anthropic-key",
      },
      body: JSON.stringify({
        model: "claude-3-5-sonnet",
        messages: [{ role: "user", content: "Hello Claude" }],
        max_tokens: 1024,
        temperature: 0.5,
      }),
    })

    expect(res.ok).toBe(true)

    const request = mockState.requests[0]
    expect(request.body.model).toBe("claude-3-5-sonnet")
    expect(request.body.max_tokens).toBe(1024)
    expect(request.body.temperature).toBe(0.5)
  })

  test("Google Gemini endpoint streams correctly", async () => {
    const res = await fetch(`${getMockUrl()}/v1beta/models/gemini-2.5-flash:streamGenerateContent`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "x-goog-api-key": "test-google-key",
      },
      body: JSON.stringify({
        contents: [{ role: "user", parts: [{ text: "Hello Gemini" }] }],
        generationConfig: { temperature: 0.3, maxOutputTokens: 200 },
      }),
    })

    expect(res.ok).toBe(true)

    const request = mockState.requests[0]
    expect(request.url.pathname).toContain("gemini-2.5-flash")
    expect((request.body as any).generationConfig?.temperature).toBe(0.3)
  })

  test("concurrent LLM requests are handled independently", async () => {
    const promises = [
      fetch(`${getMockUrl()}/v1/chat/completions`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ model: "gpt-4", messages: [{ role: "user", content: "Request 1" }] }),
      }),
      fetch(`${getMockUrl()}/v1/messages`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ model: "claude-3", messages: [{ role: "user", content: "Request 2" }] }),
      }),
      fetch(`${getMockUrl()}/v1beta/models/gemini:streamGenerateContent`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ contents: [] }),
      }),
    ]

    const results = await Promise.all(promises)
    results.forEach((res) => expect(res.ok).toBe(true))

    expect(mockState.requests.length).toBe(3)
  })

  test("LLM mode with temporary workspace", async () => {
    await using tmp = await tmpdir({
      init: async (dir) => {
        await Bun.write(
          path.join(dir, "opencode.json"),
          JSON.stringify({
            $schema: "https://opencode.ai/config.json",
            enabled_providers: ["openai"],
            provider: {
              openai: {
                options: {
                  apiKey: "test-key",
                  baseURL: `${getMockUrl()}/v1`,
                },
              },
            },
          }),
        )
      },
    })

    // Verify config was written
    const configPath = path.join(tmp.path, "opencode.json")
    const config = await Bun.file(configPath).json()
    expect(config.enabled_providers).toContain("openai")
    expect(config.provider.openai.options.baseURL).toBe(`${getMockUrl()}/v1`)
  })

  test("LLM streaming with tool call simulation", async () => {
    const toolCallStream = [
      { id: "chat-2", choices: [{ delta: { role: "assistant" } }] },
      {
        id: "chat-2",
        choices: [
          {
            delta: {
              tool_calls: [
                {
                  id: "call-123",
                  type: "function",
                  function: { name: "read", arguments: '{"file": "test.txt"}' },
                },
              ],
            },
          },
        ],
      },
      { id: "chat-2", choices: [{ delta: {}, finish_reason: "tool_calls" }] },
    ]

    // Override the mock server for this specific test
    const app = new Hono()
    app.post("/v1/chat/completions", async (c) => {
      const body = await c.req.json()
      mockState.requests.push({ url: new URL(c.req.url), headers: new Headers(c.req.header()), body })

      const stream = createEventStream(toolCallStream, true)
      return new Response(stream, { headers: { "Content-Type": "text/event-stream" } })
    })

    const testServer = serve({ port: 0, fetch: app.fetch })

    try {
      const res = await fetch(`http://localhost:${testServer.port}/v1/chat/completions`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "gpt-4",
          messages: [{ role: "user", content: "Read test.txt" }],
          tools: [{ type: "function", function: { name: "read", description: "Read a file" } }],
        }),
      })

      expect(res.ok).toBe(true)

      const request = mockState.requests[mockState.requests.length - 1]
      expect((request.body as any).tools).toBeDefined()
      expect((request.body as any).tools.length).toBe(1)
    } finally {
      testServer.stop()
    }
  })

  test("LLM mode error handling - invalid model", async () => {
    const app = new Hono()
    app.post("/v1/chat/completions", () => {
      return new Response(
        JSON.stringify({ error: { message: "Invalid model", type: "invalid_request_error" } }),
        { status: 400, headers: { "Content-Type": "application/json" } },
      )
    })

    const errorServer = serve({ port: 0, fetch: app.fetch })

    try {
      const res = await fetch(`http://localhost:${errorServer.port}/v1/chat/completions`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ model: "invalid-model", messages: [] }),
      })

      expect(res.status).toBe(400)
      const data = await res.json()
      expect(data.error.message).toBe("Invalid model")
    } finally {
      errorServer.stop()
    }
  })

  test("LLM mode with different temperature settings", async () => {
    const temperatures = [0, 0.5, 1, 1.5]

    for (const temp of temperatures) {
      await fetch(`${getMockUrl()}/v1/chat/completions`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "gpt-4",
          messages: [{ role: "user", content: `Test with temp ${temp}` }],
          temperature: temp,
        }),
      })
    }

    const requests = mockState.requests.slice(-temperatures.length)
    requests.forEach((req, i) => {
      expect(req.body.temperature).toBe(temperatures[i])
    })
  })
})
