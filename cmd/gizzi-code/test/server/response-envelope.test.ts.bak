// @ts-nocheck
import { describe, expect, test } from "bun:test"
import { Server } from "../../src/runtime/server/server"
import { tmpdir } from "../fixture/fixture"

describe("runtime response envelopes", () => {
  test("/v1/verification/stats returns the canonical success envelope", async () => {
    const response = await Server.App().request("/v1/verification/stats")
    expect(response.status).toBe(200)

    const body = await response.json()
    expect(body).toHaveProperty("data")
    expect(body).not.toHaveProperty("success")
    expect(body).not.toHaveProperty("error")
  })

  test("/v1/verification/query returns the canonical success envelope while /verification/query preserves the legacy shape", async () => {
    const app = Server.App()
    const canonical = await app.request("/v1/verification/query")
    const legacy = await app.request("/verification/query")

    expect(canonical.status).toBe(200)
    expect(legacy.status).toBe(200)

    const canonicalBody = await canonical.json()
    const legacyBody = await legacy.json()

    expect(canonicalBody).toHaveProperty("data")
    expect(canonicalBody.data).toHaveProperty("results")
    expect(legacyBody).toHaveProperty("results")
    expect(canonicalBody.data).toEqual(legacyBody)
  })

  test("/v1/config returns the canonical success envelope while /config preserves the legacy shape", async () => {
    const app = Server.App()
    const canonical = await app.request("/v1/config")
    const legacy = await app.request("/config")

    expect(canonical.status).toBe(200)
    expect(legacy.status).toBe(200)

    const canonicalBody = await canonical.json()
    const legacyBody = await legacy.json()

    expect(canonicalBody).toHaveProperty("data")
    expect(legacyBody).not.toHaveProperty("data")
    expect(canonicalBody.data).toEqual(legacyBody)
  })

  test("/v1/provider/auth returns the canonical success envelope while /provider/auth preserves the legacy shape", async () => {
    const app = Server.App()
    const canonical = await app.request("/v1/provider/auth")
    const legacy = await app.request("/provider/auth")

    expect(canonical.status).toBe(200)
    expect(legacy.status).toBe(200)

    const canonicalBody = await canonical.json()
    const legacyBody = await legacy.json()

    expect(canonicalBody).toHaveProperty("data")
    expect(legacyBody).not.toHaveProperty("data")
    expect(canonicalBody.data).toEqual(legacyBody)
  })

  test("/v1/plugin returns the canonical success envelope while /plugin preserves the legacy shape", async () => {
    const app = Server.App()
    const canonical = await app.request("/v1/plugin")
    const legacy = await app.request("/plugin")

    expect(canonical.status).toBe(200)
    expect(legacy.status).toBe(200)

    const canonicalBody = await canonical.json()
    const legacyBody = await legacy.json()

    expect(canonicalBody).toHaveProperty("data")
    expect(canonicalBody.data).toEqual(legacyBody)
  })

  test("/v1/memory returns the canonical success envelope while /memory preserves the legacy shape", async () => {
    const app = Server.App()
    const canonical = await app.request("/v1/memory")
    const legacy = await app.request("/memory")

    expect(canonical.status).toBe(200)
    expect(legacy.status).toBe(200)

    const canonicalBody = await canonical.json()
    const legacyBody = await legacy.json()

    expect(canonicalBody).toHaveProperty("data")
    expect(canonicalBody.data).toEqual(legacyBody)
  })

  test("/v1/session/list returns the canonical success envelope while /session/list preserves the legacy shape", async () => {
    const app = Server.App()
    const canonical = await app.request("/v1/session/list")
    const legacy = await app.request("/session/list")

    expect(canonical.status).toBe(200)
    expect(legacy.status).toBe(200)

    const canonicalBody = await canonical.json()
    const legacyBody = await legacy.json()

    expect(canonicalBody).toHaveProperty("data")
    expect(legacyBody).not.toHaveProperty("data")
    expect(canonicalBody.data).toEqual(legacyBody)
  })

  test("/v1/agent/list returns the canonical success envelope while /agent/list preserves the legacy shape", async () => {
    const app = Server.App()
    const canonical = await app.request("/v1/agent/list")
    const legacy = await app.request("/agent/list")

    expect(canonical.status).toBe(200)
    expect(legacy.status).toBe(200)

    const canonicalBody = await canonical.json()
    const legacyBody = await legacy.json()

    expect(canonicalBody).toHaveProperty("data")
    expect(canonicalBody.data).toEqual(legacyBody)
  })

  test("/v1/global/health returns the canonical success envelope while /global/health preserves the legacy shape", async () => {
    const app = Server.App()
    const canonical = await app.request("/v1/global/health")
    const legacy = await app.request("/global/health")

    expect(canonical.status).toBe(200)
    expect(legacy.status).toBe(200)

    const canonicalBody = await canonical.json()
    const legacyBody = await legacy.json()

    expect(canonicalBody).toHaveProperty("data")
    expect(canonicalBody.data).toEqual(legacyBody)
  })

  test("/v1/path returns the canonical success envelope while /path preserves the legacy shape", async () => {
    await using tmp = await tmpdir()
    const app = Server.App()
    const directory = encodeURIComponent(tmp.path)
    const canonical = await app.request(`/v1/path?directory=${directory}`)
    const legacy = await app.request(`/path?directory=${directory}`)

    expect(canonical.status).toBe(200)
    expect(legacy.status).toBe(200)

    const canonicalBody = await canonical.json()
    const legacyBody = await legacy.json()

    expect(canonicalBody).toHaveProperty("data")
    expect(canonicalBody.data).toEqual(legacyBody)
  })

  test("/v1/verification/:id returns the canonical error envelope for missing resources", async () => {
    const response = await Server.App().request("/v1/verification/does-not-exist")
    expect(response.status).toBe(404)

    const body = await response.json()
    expect(body).toEqual({
      error: {
        code: "VERIFICATION_NOT_FOUND",
        message: "Verification not found",
      },
    })
  })

  test("/v1/memory/:filename normalizes legacy named errors into the canonical error envelope", async () => {
    const response = await Server.App().request("/v1/memory/does-not-exist")
    expect(response.status).toBe(404)

    const body = await response.json()
    expect(body).toEqual({
      error: {
        code: "NOT_FOUND",
        message: "Memory not found: does-not-exist",
        details: {},
      },
    })
  })

  test("canonical /v1 errors are wrapped even when they come from the server error layer", async () => {
    const response = await Server.App().request("/v1/session/invalid_session_id")

    expect(response.status).toBe(400)

    const body = await response.json()
    expect(body).toHaveProperty("error")
    expect(typeof body.error.code).toBe("string")
    expect(typeof body.error.message).toBe("string")
  })
})
