// @ts-nocheck
import { afterEach, beforeEach, describe, expect, mock, spyOn, test } from "bun:test"
import { TokensRoutes } from "../../src/runtime/server/routes/tokens"
import { Provider } from "../../src/runtime/providers/provider"
import { Config } from "../../src/runtime/context/config/config"

describe("tokens.count route", () => {
  let fetchMock: any
  let parseModelSpy: any
  let getModelSpy: any
  let getProviderSpy: any
  let configGetSpy: any

  beforeEach(() => {
    fetchMock = mock()
    globalThis.fetch = fetchMock as typeof fetch
    parseModelSpy = spyOn(Provider, "parseModel")
    getModelSpy = spyOn(Provider, "getModel")
    getProviderSpy = spyOn(Provider, "getProvider")
    configGetSpy = spyOn(Config, "get")
  })

  afterEach(() => {
    fetchMock.mockRestore?.()
    parseModelSpy.mockRestore()
    getModelSpy.mockRestore()
    getProviderSpy.mockRestore()
    configGetSpy.mockRestore()
  })

  test("uses Anthropic native count endpoint when available", async () => {
    parseModelSpy.mockReturnValue({ providerID: "anthropic", modelID: "claude-sonnet-4-5" })
    getModelSpy.mockResolvedValue({
      providerID: "anthropic",
      api: {
        id: "claude-sonnet-4-5",
        url: "https://api.anthropic.com/v1",
        npm: "@ai-sdk/anthropic",
      },
      headers: {},
    })
    getProviderSpy.mockResolvedValue({
      key: "anthropic-test-key",
      options: {},
    })
    configGetSpy.mockResolvedValue({ provider: {} })
    fetchMock.mockResolvedValue(
      new Response(
        JSON.stringify({
          input_tokens: 321,
          cache_read_input_tokens: 12,
          cache_creation_input_tokens: 34,
        }),
        { status: 200, headers: { "Content-Type": "application/json" } },
      ),
    )

    const response = await TokensRoutes().fetch(
      new Request("http://localhost/count", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "anthropic/claude-sonnet-4-5",
          system: "You are precise.",
          messages: [{ role: "user", content: "Count these tokens." }],
        }),
      }),
    )

    expect(response.status).toBe(200)
    expect(fetchMock).toHaveBeenCalledTimes(1)
    expect(fetchMock.mock.calls[0][0]).toBe("https://api.anthropic.com/v1/messages/count_tokens")
    expect(await response.json()).toEqual({
      input_tokens: 321,
      cache_read_tokens: 12,
      cache_write_tokens: 34,
    })
  })

  test("uses exact tokenizer counting for OpenAI-compatible models", async () => {
    parseModelSpy.mockReturnValue({ providerID: "openai", modelID: "gpt-4o-mini" })
    getModelSpy.mockResolvedValue({
      providerID: "openai",
      api: {
        id: "gpt-4o-mini",
        url: "https://api.openai.com/v1",
        npm: "@ai-sdk/openai",
      },
      headers: {},
    })
    getProviderSpy.mockResolvedValue({ key: "openai-test-key", options: {} })

    const response = await TokensRoutes().fetch(
      new Request("http://localhost/count", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "openai/gpt-4o-mini",
          system: "Be concise.",
          messages: [{ role: "user", content: "Hello world" }],
          tools: [{ type: "function", function: { name: "ping", parameters: { type: "object", properties: {} } } }],
        }),
      }),
    )

    expect(response.status).toBe(200)
    expect(fetchMock).not.toHaveBeenCalled()
    const body = await response.json()
    expect(body.input_tokens).toBeGreaterThan(0)
    expect(body.cache_read_tokens).toBeUndefined()
    expect(body.cache_write_tokens).toBeUndefined()
  })

  test("returns cache-aware approximate counts for unsupported providers", async () => {
    parseModelSpy.mockReturnValue({ providerID: "mistral", modelID: "mistral-large" })
    getModelSpy.mockResolvedValue({
      providerID: "mistral",
      api: {
        id: "mistral-large",
        url: "https://api.mistral.ai/v1",
        npm: "@ai-sdk/mistral",
      },
      headers: {},
    })
    getProviderSpy.mockResolvedValue({ key: "mistral-test-key", options: {} })

    const response = await TokensRoutes().fetch(
      new Request("http://localhost/count", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "mistral/mistral-large",
          messages: [
            {
              role: "user",
              content: [
                {
                  type: "text",
                  text: "Cache me if you can",
                  cache_control: { type: "ephemeral" },
                },
              ],
            },
          ],
        }),
      }),
    )

    expect(response.status).toBe(200)
    expect(fetchMock).not.toHaveBeenCalled()
    expect(await response.json()).toMatchObject({
      cache_read_tokens: 0,
      cache_write_tokens: 0,
    })
  })
})
