// @ts-nocheck
/**
 * Project routes integration test.
 *
 * Verifies the multi-project API from specs/project.md:
 *   GET  /                             → Project[]
 *   POST /init                         → Project
 *   GET  /:projectID/session           → Session[]
 *   POST /:projectID/session           → Session
 *   GET  /:projectID/session/:id       → Session
 *   DELETE /:projectID/session/:id     → true
 *   GET  /:projectID/session/:id/message         → Message[]
 *   GET  /:projectID/session/:id/file/status     → FileDiff[]
 *   GET  /:projectID/session/:id/find/file       → string[]
 *
 * Routes are called in-process via ProjectRoutes().fetch() to bypass auth.
 */
import { describe, expect, test } from "bun:test"
import { ProjectRoutes } from "../../src/runtime/server/routes/project"
import { tmpdir } from "../fixture/fixture"

function makeProjectFetch() {
  return async (path: string, init?: RequestInit) => {
    const res = await ProjectRoutes().fetch(new Request(`http://localhost${path}`, init))
    return res
  }
}

async function json(res: Response) {
  const text = await res.text()
  try {
    return JSON.parse(text)
  } catch {
    throw new Error(`Non-JSON response (${res.status}): ${text}`)
  }
}

describe("Project routes — multi-project API", () => {
  test("POST /init initializes a project from directory", async () => {
    await using tmp = await tmpdir({ git: true })
    const fetch = makeProjectFetch()

    const res = await fetch("/init", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ directory: tmp.path }),
    })

    expect(res.status).toBe(200)
    const project = await json(res)
    expect(project).toHaveProperty("id")
    expect(typeof project.id).toBe("string")
    expect(project).toHaveProperty("worktree")
  })

  test("GET / lists all projects", async () => {
    await using tmp = await tmpdir({ git: true })
    const fetch = makeProjectFetch()

    // Initialize the project first so it exists in the DB
    await fetch("/init", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ directory: tmp.path }),
    })

    const res = await fetch("/")
    expect(res.status).toBe(200)
    const projects = await json(res)
    expect(Array.isArray(projects)).toBe(true)
    expect(projects.some((p: any) => p.worktree === tmp.path || p.id != null)).toBe(true)
  })

  test("GET /list lists all projects (legacy alias)", async () => {
    await using tmp = await tmpdir({ git: true })
    const fetch = makeProjectFetch()

    await fetch("/init", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ directory: tmp.path }),
    })

    const res = await fetch("/list")
    expect(res.status).toBe(200)
    const projects = await json(res)
    expect(Array.isArray(projects)).toBe(true)
  })

  test("GET /:projectID/session lists sessions for a project", async () => {
    await using tmp = await tmpdir({ git: true })
    const fetch = makeProjectFetch()

    const initRes = await fetch("/init", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ directory: tmp.path }),
    })
    const project = await json(initRes)

    const res = await fetch(`/${project.id}/session`)
    expect(res.status).toBe(200)
    const sessions = await json(res)
    expect(Array.isArray(sessions)).toBe(true)
  })

  test("POST /:projectID/session creates a session", async () => {
    await using tmp = await tmpdir({ git: true })
    const fetch = makeProjectFetch()

    const initRes = await fetch("/init", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ directory: tmp.path }),
    })
    const project = await json(initRes)

    const res = await fetch(`/${project.id}/session`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ directory: tmp.path }),
    })

    expect(res.status).toBe(200)
    const session = await json(res)
    expect(session).toHaveProperty("id")
    expect(session.projectID).toBe(project.id)
    expect(session.directory).toBe(tmp.path)
  })

  test("GET /:projectID/session/:sessionID retrieves a session", async () => {
    await using tmp = await tmpdir({ git: true })
    const fetch = makeProjectFetch()

    const initRes = await fetch("/init", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ directory: tmp.path }),
    })
    const project = await json(initRes)

    const createRes = await fetch(`/${project.id}/session`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ directory: tmp.path }),
    })
    const session = await json(createRes)

    const res = await fetch(`/${project.id}/session/${session.id}`)
    expect(res.status).toBe(200)
    const fetched = await json(res)
    expect(fetched.id).toBe(session.id)
  })

  test("GET /:projectID/session/:sessionID/message returns empty list for new session", async () => {
    await using tmp = await tmpdir({ git: true })
    const fetch = makeProjectFetch()

    const initRes = await fetch("/init", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ directory: tmp.path }),
    })
    const project = await json(initRes)

    const createRes = await fetch(`/${project.id}/session`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ directory: tmp.path }),
    })
    const session = await json(createRes)

    const res = await fetch(`/${project.id}/session/${session.id}/message`)
    expect(res.status).toBe(200)
    const msgs = await json(res)
    expect(Array.isArray(msgs)).toBe(true)
    expect(msgs.length).toBe(0)
  })

  test("GET /:projectID/session/:sessionID/file/status returns diff list", async () => {
    await using tmp = await tmpdir({ git: true })
    const fetch = makeProjectFetch()

    const initRes = await fetch("/init", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ directory: tmp.path }),
    })
    const project = await json(initRes)

    const createRes = await fetch(`/${project.id}/session`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ directory: tmp.path }),
    })
    const session = await json(createRes)

    const res = await fetch(`/${project.id}/session/${session.id}/file/status`)
    expect(res.status).toBe(200)
    const status = await json(res)
    // New session has no diffs — result is null or empty array
    expect(status === null || Array.isArray(status)).toBe(true)
  })

  test("GET /:projectID/session/:sessionID/find/file searches files", async () => {
    await using tmp = await tmpdir({ git: true })
    const fetch = makeProjectFetch()

    const initRes = await fetch("/init", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ directory: tmp.path }),
    })
    const project = await json(initRes)

    const createRes = await fetch(`/${project.id}/session`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ directory: tmp.path }),
    })
    const session = await json(createRes)

    const res = await fetch(`/${project.id}/session/${session.id}/find/file?query=*.ts`)
    expect(res.status).toBe(200)
    const files = await json(res)
    expect(Array.isArray(files)).toBe(true)
  })

  test("DELETE /:projectID/session/:sessionID removes a session", async () => {
    await using tmp = await tmpdir({ git: true })
    const fetch = makeProjectFetch()

    const initRes = await fetch("/init", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ directory: tmp.path }),
    })
    const project = await json(initRes)

    const createRes = await fetch(`/${project.id}/session`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ directory: tmp.path }),
    })
    const session = await json(createRes)

    const deleteRes = await fetch(`/${project.id}/session/${session.id}`, { method: "DELETE" })
    expect(deleteRes.status).toBe(200)
    const deleted = await json(deleteRes)
    expect(deleted).toBe(true)

    // Verify session is gone — NotFoundError is raised; Server.App() maps it to 404
    // but ProjectRoutes() in isolation has no onError handler so expect any error status
    const getRes = await fetch(`/${project.id}/session/${session.id}`)
    expect(getRes.status).toBeGreaterThanOrEqual(400)
  })

  test("GET /:projectID returns an error for unknown project", async () => {
    // NotFoundError is thrown; Server.App()'s onError converts it to 404.
    // When calling ProjectRoutes() directly it surfaces as 500 (no handler mounted).
    const fetch = makeProjectFetch()
    const res = await fetch("/nonexistent-project-id-xyz")
    expect(res.status).toBeGreaterThanOrEqual(400)
  })
})
