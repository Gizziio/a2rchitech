/**
 * Message Edit E2E Tests
 * 
 * Tests the message editing feature end-to-end:
 * 1. Revert conversation to before a message
 * 2. Submit edited message with new content
 * 3. Preserve file attachments
 * 4. Handle errors gracefully
 */

import { describe, expect, test, beforeAll, afterAll } from "bun:test"
import { Hono } from "hono"

type WebSocketData = unknown
import type { Server } from "bun"

describe("Message Edit E2E", () => {
  let mockServer: Server<WebSocketData>
  let baseUrl: string
  
  // Mock session state
  const mockSession = {
    id: "test-session-123",
    model: { providerID: "openai", modelID: "gpt-4o" },
    agent: "default",
    messages: [
      { id: "msg-1", role: "user", content: "Original message" },
      { id: "msg-2", role: "assistant", content: "Assistant response" },
    ],
    parts: {
      "msg-1": [
        { id: "part-1", type: "text", text: "Original message" }
      ],
      "msg-2": [
        { id: "part-2", type: "text", text: "Assistant response" }
      ]
    }
  }
  
  // Track API calls for assertions
  const apiCalls = {
    revert: [] as any[],
    prompt: [] as any[],
  }

  beforeAll(async () => {
    // Create mock API server
    const app = new Hono()
    
    // Reset tracking
    apiCalls.revert = []
    apiCalls.prompt = []
    
    // Mock session revert endpoint
    app.post("/v1/sessions/:sessionID/revert", async (c) => {
      const sessionID = c.req.param("sessionID")
      const body = await c.req.json()
      
      apiCalls.revert.push({ sessionID, body })
      
      return c.json({
        success: true,
        data: {
          sessionID,
          revertedTo: body.messageID,
          timestamp: Date.now(),
        }
      })
    })
    
    // Mock session prompt endpoint
    app.post("/v1/sessions/:sessionID/prompt", async (c) => {
      const sessionID = c.req.param("sessionID")
      const body = await c.req.json()
      
      apiCalls.prompt.push({ sessionID, body })
      
      return c.json({
        success: true,
        data: {
          messageID: body.messageID || `msg-${Date.now()}`,
          runId: `run-${Date.now()}`,
          status: "accepted",
        }
      })
    })
    
    // Mock session get endpoint
    app.get("/v1/sessions/:sessionID", async (c) => {
      return c.json({
        success: true,
        data: mockSession
      })
    })
    
    mockServer = Bun.serve({
      port: 0, // Random port
      fetch: app.fetch,
    })
    
    baseUrl = `http://localhost:${mockServer.port}`
  })

  afterAll(async () => {
    mockServer.stop()
  })

  test("should revert conversation and submit edited message", async () => {
    // Simulate the edit flow
    const sessionID = "test-session-123"
    const messageID = "msg-1"
    const editedText = "Edited message content"
    
    // Step 1: Revert to before the message
    const revertResponse = await fetch(`${baseUrl}/v1/sessions/${sessionID}/revert`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ messageID })
    })
    
    expect(revertResponse.status).toBe(200)
    const revertResult = await revertResponse.json()
    expect(revertResult.success).toBe(true)
    expect(revertResult.data.revertedTo).toBe(messageID)
    
    // Step 2: Submit edited message as prompt
    const promptResponse = await fetch(`${baseUrl}/v1/sessions/${sessionID}/prompt`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        providerID: "openai",
        modelID: "gpt-4o",
        messageID: `msg-${Date.now()}`,
        agent: "default",
        model: { providerID: "openai", modelID: "gpt-4o" },
        parts: [
          { id: "part-new", type: "text", text: editedText }
        ]
      })
    })
    
    expect(promptResponse.status).toBe(200)
    const promptResult = await promptResponse.json()
    expect(promptResult.success).toBe(true)
    expect(promptResult.data.runId).toBeDefined()
    
    // Verify API calls were made correctly
    expect(apiCalls.revert).toHaveLength(1)
    expect(apiCalls.revert[0].body.messageID).toBe(messageID)
    
    expect(apiCalls.prompt).toHaveLength(1)
    expect(apiCalls.prompt[0].body.parts[0].text).toBe(editedText)
  })

  test("should preserve file attachments when editing", async () => {
    const sessionID = "test-session-123"
    const messageID = "msg-with-attachments"
    const editedText = "Edited with attachments"
    
    // Mock message with file attachments
    const messageWithFiles = {
      id: messageID,
      parts: [
        { id: "part-text", type: "text", text: "Original" },
        { id: "part-file", type: "file", file: { name: "test.txt", mime: "text/plain" } }
      ]
    }
    
    // Extract file parts (simulating DialogMessageEdit logic)
    const fileParts = messageWithFiles.parts.filter(p => p.type === "file")
    
    // Submit edited message with file attachments preserved
    const promptResponse = await fetch(`${baseUrl}/v1/sessions/${sessionID}/prompt`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        providerID: "openai",
        modelID: "gpt-4o",
        messageID: `msg-${Date.now()}`,
        agent: "default",
        model: { providerID: "openai", modelID: "gpt-4o" },
        parts: [
          { id: "part-new-text", type: "text", text: editedText },
          ...fileParts.map(p => ({ ...p, id: `part-${Date.now()}-${p.id}` }))
        ]
      })
    })
    
    expect(promptResponse.status).toBe(200)
    
    // Verify file parts were included
    const lastCall = apiCalls.prompt[apiCalls.prompt.length - 1]
    expect(lastCall.body.parts).toHaveLength(2)
    expect(lastCall.body.parts[1].type).toBe("file")
  })

  test("should handle revert API errors gracefully", async () => {
    // Create error-throwing server for this test
    const errorApp = new Hono()
    errorApp.post("/v1/sessions/:sessionID/revert", async () => {
      return new Response(JSON.stringify({
        success: false,
        error: "Session not found",
        code: "SESSION_NOT_FOUND"
      }), { status: 404 })
    })
    
    const errorServer = Bun.serve({
      port: 0,
      fetch: errorApp.fetch,
    })
    
    try {
      const response = await fetch(`http://localhost:${errorServer.port}/v1/sessions/invalid/revert`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ messageID: "msg-1" })
      })
      
      expect(response.status).toBe(404)
      const result = await response.json()
      expect(result.success).toBe(false)
      expect(result.code).toBe("SESSION_NOT_FOUND")
    } finally {
      errorServer.stop()
    }
  })

  test("should handle empty message validation", async () => {
    // This tests the client-side validation in DialogMessageEdit
    // The component should prevent submission of empty messages
    const editedText = "   " // Whitespace-only
    
    const isEmpty = editedText.trim().length === 0
    expect(isEmpty).toBe(true)
    
    // In the actual UI, this would show a toast warning
    // and not make the API call
  })

  test("should include correct model and agent settings", async () => {
    const sessionID = "test-session-123"
    const customModel = { providerID: "anthropic", modelID: "claude-3-opus" }
    const customAgent = "code-review"
    
    await fetch(`${baseUrl}/v1/sessions/${sessionID}/prompt`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        providerID: customModel.providerID,
        modelID: customModel.modelID,
        messageID: `msg-${Date.now()}`,
        agent: customAgent,
        model: customModel,
        variant: "test-variant",
        parts: [{ id: "part-1", type: "text", text: "Test" }]
      })
    })
    
    const lastCall = apiCalls.prompt[apiCalls.prompt.length - 1]
    expect(lastCall.body.providerID).toBe("anthropic")
    expect(lastCall.body.modelID).toBe("claude-3-opus")
    expect(lastCall.body.agent).toBe("code-review")
    expect(lastCall.body.variant).toBe("test-variant")
  })
})

describe("Message Edit Component Integration", () => {
  test("should extract text from message parts correctly", () => {
    // Simulates the text extraction logic from DialogMessageEdit
    const parts = [
      { type: "text", text: "Hello " },
      { type: "text", text: "world", synthetic: true }, // Should be filtered
      { type: "text", text: "!" },
      { type: "file", file: { name: "test.txt" } }
    ]
    
    const text = parts.reduce((agg: string, part: any) => {
      if (part.type === "text" && !part.synthetic) {
        agg += part.text
      }
      return agg
    }, "")
    
    expect(text).toBe("Hello !")
  })

  test("should generate unique part IDs", () => {
    // Simulates Identifier.ascending usage
    const generateId = (prefix: string) => `${prefix}-${Date.now()}-${Math.random().toString(36).slice(2, 7)}`
    
    const ids = new Set()
    for (let i = 0; i < 100; i++) {
      ids.add(generateId("part"))
    }
    
    expect(ids.size).toBe(100) // All unique
  })
})
