import { expect, test } from "bun:test"
import path from "path"
import { Global } from "../../src/runtime/context/global"

test("global paths are rooted under canonical gizzi XDG directories", () => {
  expect(Global.Path.data).toBe(path.join(process.env["XDG_DATA_HOME"]!, "gizzi"))
  expect(Global.Path.cache).toBe(path.join(process.env["XDG_CACHE_HOME"]!, "gizzi"))
  expect(Global.Path.config).toBe(path.join(process.env["XDG_CONFIG_HOME"]!, "gizzi"))
  expect(Global.Path.state).toBe(path.join(process.env["XDG_STATE_HOME"]!, "gizzi"))
})
