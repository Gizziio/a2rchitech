// @ts-nocheck
import { describe, expect, test } from "bun:test"
import { Instance } from "../../src/runtime/context/project/instance"
import { RunRegistry } from "../../src/runtime/session/run-registry"
import { Bus } from "../../src/shared/bus"
import { tmpdir } from "../fixture/fixture"

describe("RunRegistry lifecycle", () => {
  test("create emits run.started and records the run", async () => {
    await using dir = await tmpdir({ git: true })

    const events: any[] = []
    await Instance.provide({
      directory: dir.path,
      fn: async () => {
        const unsub = Bus.subscribe(RunRegistry.Events.Started, (e) => events.push(e))

        const { runId } = RunRegistry.create("session-1", "code", "write hello world")

        unsub()

        const run = RunRegistry.get(runId)
        expect(run).toBeDefined()
        expect(run!.runId).toBe(runId)
        expect(run!.sessionID).toBe("session-1")
        expect(run!.agent).toBe("code")
        expect(run!.prompt).toBe("write hello world")
        expect(run!.status).toBe("pending")

        await Instance.dispose()
      },
    })

    expect(events).toHaveLength(1)
    expect(events[0].type).toBe("run.started")
    expect(events[0].properties.agent).toBe("code")
  })

  test("start transitions to running and emits run.updated", async () => {
    await using dir = await tmpdir({ git: true })

    const updateEvents: any[] = []
    await Instance.provide({
      directory: dir.path,
      fn: async () => {
        const unsub = Bus.subscribe(RunRegistry.Events.Updated, (e) => updateEvents.push(e))

        const { runId } = RunRegistry.create("session-2", "ask", "what is 2+2")

        let resolveWork!: () => void
        const work = new Promise<void>((res) => (resolveWork = res))
        RunRegistry.start(runId, work)

        const run = RunRegistry.get(runId)
        expect(run!.status).toBe("running")

        // Resolve and wait for completion
        resolveWork()
        await RunRegistry.wait(runId)

        unsub()
        await Instance.dispose()
      },
    })

    // First update: running; second update: completed
    expect(updateEvents.length).toBeGreaterThanOrEqual(2)
    expect(updateEvents[0].properties.status).toBe("running")
    expect(updateEvents[1].properties.status).toBe("completed")
  })

  test("complete emits run.finished with correct status", async () => {
    await using dir = await tmpdir({ git: true })

    const finishedEvents: any[] = []
    await Instance.provide({
      directory: dir.path,
      fn: async () => {
        const unsub = Bus.subscribe(RunRegistry.Events.Finished, (e) => finishedEvents.push(e))

        const { runId } = RunRegistry.create("session-3", "code", "refactor")
        RunRegistry.complete(runId, "completed")

        unsub()
        await Instance.dispose()
      },
    })

    expect(finishedEvents).toHaveLength(1)
    expect(finishedEvents[0].properties.status).toBe("completed")
    expect(finishedEvents[0].properties.runId).toBeTruthy()
  })

  test("abort emits run.aborted and transitions to aborted", async () => {
    await using dir = await tmpdir({ git: true })

    const abortedEvents: any[] = []
    await Instance.provide({
      directory: dir.path,
      fn: async () => {
        const unsub = Bus.subscribe(RunRegistry.Events.Aborted, (e) => abortedEvents.push(e))

        const { runId } = RunRegistry.create("session-4", "code", "long task")

        // Start with a never-resolving promise so the run stays running
        const neverResolves = new Promise<void>(() => {})
        RunRegistry.start(runId, neverResolves)

        const aborted = RunRegistry.abort(runId)
        expect(aborted).toBe(true)

        const run = RunRegistry.get(runId)
        expect(run!.status).toBe("aborted")

        unsub()
        await Instance.dispose()
      },
    })

    expect(abortedEvents).toHaveLength(1)
    expect(abortedEvents[0].properties.runId).toBeTruthy()
  })

  test("complete with error records the error message", async () => {
    await using dir = await tmpdir({ git: true })

    await Instance.provide({
      directory: dir.path,
      fn: async () => {
        const { runId } = RunRegistry.create("session-5", "code", "risky task")
        RunRegistry.complete(runId, "errored", "provider timeout")

        const run = RunRegistry.get(runId)
        expect(run!.status).toBe("errored")
        expect(run!.error).toBe("provider timeout")
        expect(run!.finishedAt).toBeTruthy()

        await Instance.dispose()
      },
    })
  })

  test("list filters by sessionID", async () => {
    await using dir = await tmpdir({ git: true })

    await Instance.provide({
      directory: dir.path,
      fn: async () => {
        RunRegistry.create("session-A", "code", "task 1")
        RunRegistry.create("session-A", "code", "task 2")
        RunRegistry.create("session-B", "ask", "question")

        const sessionARuns = RunRegistry.list("session-A")
        const sessionBRuns = RunRegistry.list("session-B")
        const allRuns = RunRegistry.list()

        expect(sessionARuns).toHaveLength(2)
        expect(sessionBRuns).toHaveLength(1)
        expect(allRuns).toHaveLength(3)

        await Instance.dispose()
      },
    })
  })

  test("cleanup removes old finished runs and keeps recent ones", async () => {
    await using dir = await tmpdir({ git: true })

    await Instance.provide({
      directory: dir.path,
      fn: async () => {
        const { runId: oldRun } = RunRegistry.create("session-C", "code", "old task")
        RunRegistry.complete(oldRun, "completed")

        // Backdate the run to appear old
        const entry = RunRegistry.get(oldRun)!
        ;(entry as any).updatedAt = Date.now() - 48 * 60 * 60 * 1000

        const { runId: freshRun } = RunRegistry.create("session-C", "code", "fresh task")
        RunRegistry.complete(freshRun, "completed")

        const cleaned = RunRegistry.cleanup(24 * 60 * 60 * 1000)
        // freshRun should survive (too recent); oldRun may be cleaned
        const remaining = RunRegistry.list()
        expect(remaining.some((r) => r.runId === freshRun)).toBe(true)

        await Instance.dispose()
      },
    })
  })
})
