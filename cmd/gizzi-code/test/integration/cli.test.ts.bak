import { describe, test, expect, beforeAll } from "bun:test"
import { $ } from "bun"

const CLI_PATH = "./dist/gizzi-code"

describe("CLI Integration Tests", () => {
  beforeAll(async () => {
    // Ensure binary exists
    const exists = await Bun.file(CLI_PATH).exists()
    if (!exists) {
      throw new Error(`Binary not found: ${CLI_PATH}. Run: bun run script/build-production.ts`)
    }
  })

  describe("Basic Commands", () => {
    test("should show help", async () => {
      const result = await $`${CLI_PATH} --help`.text()
      expect(result).toContain("gizzi-code")
      expect(result).toContain("Commands:")
      expect(result).toContain("session")
      expect(result).toContain("provider")
    })

    test("should show version", async () => {
      const result = await $`${CLI_PATH} --version`.text()
      expect(result).toMatch(/^\d+\.\d+\.\d+/)
    })
  })

  describe("Session Commands", () => {
    test("should show session help", async () => {
      const result = await $`${CLI_PATH} session --help`.text()
      expect(result).toContain("list")
      expect(result).toContain("delete")
      expect(result).toContain("templates")
      expect(result).toContain("template-save")
      expect(result).toContain("template-delete")
      expect(result).toContain("template-export")
      expect(result).toContain("template-import")
    })

    test("should list sessions", async () => {
      const proc = Bun.spawn({
        cmd: [CLI_PATH, "session", "list"],
        stdout: "pipe",
        stderr: "pipe",
      })
      
      const exitCode = await proc.exited
      expect(exitCode).toBe(0)
    })

    test("should list templates (empty)", async () => {
      const proc = Bun.spawn({
        cmd: [CLI_PATH, "session", "templates"],
        stdout: "pipe",
        stderr: "pipe",
      })
      
      const stdout = await new Response(proc.stdout).text()
      const exitCode = await proc.exited
      
      expect(exitCode).toBe(0)
      expect(stdout).toContain("No templates found")
    })
  })

  describe("Provider Commands", () => {
    test("should show connect help", async () => {
      const result = await $`${CLI_PATH} connect --help`.text()
      expect(result).toContain("connect")
    })
  })

  describe("Models Command", () => {
    test("should show models help", async () => {
      const result = await $`${CLI_PATH} models --help`.text()
      expect(result).toContain("models")
    })
  })

  describe("Stats Command", () => {
    test("should show stats help", async () => {
      const result = await $`${CLI_PATH} stats --help`.text()
      expect(result).toContain("stats")
    })
  })

  describe("Export Command", () => {
    test("should show export help", async () => {
      const result = await $`${CLI_PATH} export --help`.text()
      expect(result).toContain("export")
    })
  })

  describe("Import Command", () => {
    test("should show import help", async () => {
      const result = await $`${CLI_PATH} import --help`.text()
      expect(result).toContain("import")
    })
  })
})
