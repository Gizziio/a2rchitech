{
  "name": "@a2r/gizzi-code",
  "version": "1.0.0",
  "description": "Gizzi Code - AI-powered terminal interface and runtime for the A2R ecosystem",
  "keywords": [
    "gizzi",
    "gizzi-code",
    "ai",
    "terminal",
    "tui",
    "cli",
    "agent",
    "shell",
    "a2r"
  ],
  "homepage": "https://gizzi.sh",
  "repository": {
    "type": "git",
    "url": "https://github.com/a2r/gizzi-code.git"
  },
  "license": "MIT",
  "author": "A2R Technologies <team@a2r.io>",
  "type": "module",
  "main": "./dist/gizzi.js",
  "bin": {
    "gizzi": "./bin/gizzi"
  },
  "files": [
    "bin/",
    "dist/",
    "scripts/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "scripts": {
    "build": "bun build ./src/cli/main.ts --outfile ./dist/gizzi.js --target node --conditions=browser",
    "build:all": "npm run build:mac && npm run build:linux && npm run build:win",
    "build:mac": "bun build ./src/cli/main.ts --outfile ./dist/gizzi-code-macos --target bun-darwin-arm64,bun-darwin-x64 --conditions=browser",
    "build:linux": "bun build ./src/cli/main.ts --outfile ./dist/gizzi-code-linux --target bun-linux-arm64,bun-linux-x64 --conditions=browser",
    "build:win": "bun build ./src/cli/main.ts --outfile ./dist/gizzi-code-win.exe --target bun-windows-x64 --conditions=browser",
    "prepublishOnly": "npm run build",
    "test": "bun test",
    "version": "echo $npm_package_version"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "conf": "^12.0.0",
    "ora": "^8.0.1",
    "update-notifier": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "bun-types": "latest",
    "typescript": "^5.3.0"
  }
}
