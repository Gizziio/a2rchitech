import { type Content as OpenAPIContent, resolver } from "hono-openapi"
import z from "zod/v4"
import { NotFoundError } from "@/runtime/session/storage/db"

export const ERRORS: Record<number, { description: string; content: OpenAPIContent }> = {
  400: {
    description: "Bad request",
    content: {
      "application/json": {
        schema: resolver(
          z.object({
            data: z.any(),
            errors: z.array(z.record(z.string(), z.any())),
            success: z.literal(false),
          }),
        ),
      },
    },
  },
  404: {
    description: "Not found",
    content: {
      "application/json": {
        schema: resolver(NotFoundError.Schema),
      },
    },
  },
}

export function errors(...codes: number[]): Record<number, { description: string; content: OpenAPIContent }> {
  return Object.fromEntries(codes.map((code) => [code, ERRORS[code as keyof typeof ERRORS]]))
}
