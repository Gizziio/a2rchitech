import { Hono } from "hono"
import { validator } from "hono-openapi"
import z from "zod/v4"
import { TerminalSidecar } from "@/runtime/sidecar/terminal"

const createSessionSchema = z.object({
  session_id: z.string().min(1),
  owner_id: z.string().min(1),
  shell: z.string().optional(),
  cols: z.number().int().positive(),
  rows: z.number().int().positive(),
  env: z.record(z.string(), z.string()).default({}),
  workdir: z.string().nullable().optional(),
})

const sessionIdParamSchema = z.object({
  sessionID: z.string().min(1),
})

const writeSchema = z.object({
  session_id: z.string().min(1),
  data: z.array(z.number().int().min(0).max(255)),
})

const resizeSchema = z.object({
  session_id: z.string().min(1),
  cols: z.number().int().positive(),
  rows: z.number().int().positive(),
})

const sessionRefSchema = z.object({
  session_id: z.string().min(1),
})

const connectSchema = z.object({
  session_id: z.string().min(1),
  client_id: z.string().min(1),
  mode: z.enum(["read_only", "read_write"]),
})

const disconnectSchema = z.object({
  session_id: z.string().min(1),
  client_id: z.string().nullable().optional(),
})

const ownerSchema = z.object({
  session_id: z.string().min(1),
  owner_id: z.string().min(1),
})

const canWriteSchema = z.object({
  session_id: z.string().min(1),
  client_id: z.string().min(1),
})

const auditSchema = z.object({
  session_id: z.string().min(1),
  event: z.string().min(1),
  details: z.record(z.string(), z.any()),
  client_id: z.string().nullable().optional(),
})

const snapshotSchema = z.object({
  session_id: z.string().min(1),
  snapshot: z.string(),
  cols: z.number().int().positive(),
  rows: z.number().int().positive(),
})

function noContent() {
  return new Response(null, { status: 204 })
}

function errorStatus(error: unknown) {
  const message = error instanceof Error ? error.message : String(error)
  if (message.includes("not found")) return 404
  if (message.includes("already exists") || message.includes("belongs to a different owner")) return 409
  return 500
}

function withErrors<T>(handler: () => Promise<T>) {
  return async (c: any) => {
    try {
      const result = await handler()
      return c.json(result)
    } catch (error) {
      return c.json({ error: error instanceof Error ? error.message : String(error) }, errorStatus(error))
    }
  }
}

export const TerminalSidecarRoutes = () =>
  new Hono()
    .get("/health", withErrors(async () => ({ health: await TerminalSidecar.health() })))
    .get("/sessions", withErrors(async () => await TerminalSidecar.listSessions()))
    .post(
      "/sessions",
      validator("json", createSessionSchema),
      async (c) => {
        try {
          const input = c.req.valid("json")
          const info = await TerminalSidecar.createSession(input)
          return c.json(info)
        } catch (error) {
          return c.json({ error: error instanceof Error ? error.message : String(error) }, errorStatus(error))
        }
      },
    )
    .get(
      "/sessions/:sessionID",
      validator("param", sessionIdParamSchema),
      async (c) => {
        const { sessionID } = c.req.valid("param")
        const info = await TerminalSidecar.getSession(sessionID)
        if (!info) return c.json({ error: `terminal session '${sessionID}' not found` }, 404)
        return c.json(info)
      },
    )
    .delete(
      "/sessions/:sessionID",
      validator("param", sessionIdParamSchema),
      async (c) => {
        try {
          const { sessionID } = c.req.valid("param")
          await TerminalSidecar.closeSession(sessionID)
          return noContent()
        } catch (error) {
          return c.json({ error: error instanceof Error ? error.message : String(error) }, errorStatus(error))
        }
      },
    )
    .post(
      "/sessions/input",
      validator("json", writeSchema),
      async (c) => {
        try {
          const { session_id, data } = c.req.valid("json")
          await TerminalSidecar.write(session_id, data)
          return noContent()
        } catch (error) {
          return c.json({ error: error instanceof Error ? error.message : String(error) }, errorStatus(error))
        }
      },
    )
    .post(
      "/sessions/resize",
      validator("json", resizeSchema),
      async (c) => {
        try {
          const { session_id, cols, rows } = c.req.valid("json")
          await TerminalSidecar.resize(session_id, cols, rows)
          return noContent()
        } catch (error) {
          return c.json({ error: error instanceof Error ? error.message : String(error) }, errorStatus(error))
        }
      },
    )
    .post(
      "/sessions/keepalive",
      validator("json", sessionRefSchema),
      async (c) => {
        try {
          const { session_id } = c.req.valid("json")
          await TerminalSidecar.keepalive(session_id)
          return noContent()
        } catch (error) {
          return c.json({ error: error instanceof Error ? error.message : String(error) }, errorStatus(error))
        }
      },
    )
    .post(
      "/sessions/connect",
      validator("json", connectSchema),
      async (c) => {
        try {
          const { session_id, client_id, mode } = c.req.valid("json")
          const info = await TerminalSidecar.markConnected(session_id, client_id, mode)
          return c.json(info)
        } catch (error) {
          return c.json({ error: error instanceof Error ? error.message : String(error) }, errorStatus(error))
        }
      },
    )
    .post(
      "/sessions/disconnect",
      validator("json", disconnectSchema),
      async (c) => {
        try {
          const { session_id, client_id } = c.req.valid("json")
          const info = await TerminalSidecar.markDisconnected(session_id, client_id)
          return c.json(info)
        } catch (error) {
          return c.json({ error: error instanceof Error ? error.message : String(error) }, errorStatus(error))
        }
      },
    )
    .get(
      "/sessions/:sessionID/can-reconnect",
      validator("param", sessionIdParamSchema),
      async (c) => {
        const { sessionID } = c.req.valid("param")
        return c.json({ value: await TerminalSidecar.canReconnect(sessionID) })
      },
    )
    .post(
      "/sessions/verify-owner",
      validator("json", ownerSchema),
      async (c) => {
        try {
          const { session_id, owner_id } = c.req.valid("json")
          const info = await TerminalSidecar.verifyOwner(session_id, owner_id)
          return c.json(info)
        } catch (error) {
          return c.json({ error: error instanceof Error ? error.message : String(error) }, errorStatus(error))
        }
      },
    )
    .post(
      "/sessions/can-write",
      validator("json", canWriteSchema),
      async (c) => {
        const { session_id, client_id } = c.req.valid("json")
        return c.json({ value: await TerminalSidecar.canWrite(session_id, client_id) })
      },
    )
    .get(
      "/sessions/:sessionID/timeout-warning",
      validator("param", sessionIdParamSchema),
      async (c) => {
        const { sessionID } = c.req.valid("param")
        return c.json({ value: await TerminalSidecar.timeoutWarning(sessionID) })
      },
    )
    .post("/sessions/cleanup-expired", async (c) => c.json(await TerminalSidecar.cleanupExpiredSessions()))
    .get(
      "/sessions/:sessionID/subscribe",
      validator("param", sessionIdParamSchema),
      async (c) => {
        try {
          const { sessionID } = c.req.valid("param")
          const result = await TerminalSidecar.subscribe(sessionID)
          return c.json(result)
        } catch (error) {
          return c.json({ error: error instanceof Error ? error.message : String(error) }, errorStatus(error))
        }
      },
    )
    .post(
      "/sessions/snapshot",
      validator("json", snapshotSchema),
      async (c) => {
        try {
          const { session_id, snapshot, cols, rows } = c.req.valid("json")
          await TerminalSidecar.updateSnapshot(session_id, snapshot, cols, rows)
          return noContent()
        } catch (error) {
          return c.json({ error: error instanceof Error ? error.message : String(error) }, errorStatus(error))
        }
      },
    )
    .post(
      "/sessions/audit",
      validator("json", auditSchema),
      async (c) => {
        try {
          const { session_id, event, details, client_id } = c.req.valid("json")
          await TerminalSidecar.recordAuditEvent(session_id, event, details, client_id)
          return noContent()
        } catch (error) {
          return c.json({ error: error instanceof Error ? error.message : String(error) }, errorStatus(error))
        }
      },
    )
