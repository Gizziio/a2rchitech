/**
 * MCP (Model Context Protocol) Server Routes
 * 
 * Provides HTTP endpoints for the platform to:
 * - Manage MCP servers (add, remove, list)
 * - Execute MCP tools
 * - Access MCP resources and prompts
 * - Handle OAuth authentication
 */

import { Hono } from "hono"
import { describeRoute, validator, resolver } from "hono-openapi"
import z from "zod/v4"
import { MCP } from "@/runtime/tools/mcp/mcp"
import { errors } from "@/runtime/server/error"
import { lazy } from "@/runtime/util/lazy"
import { Log } from "@/runtime/util/log"

const log = Log.create({ service: "mcp-server-routes" })

// MCP Registry types
interface McpRegistryServer {
  id: string
  name: string
  description: string
  homepage: string
  repository?: string
  license?: string
  runtime: "stdio" | "sse" | "websocket"
  command?: string
  args?: string[]
  url?: string
  env?: Record<string, string>
  tools?: string[]
}

export const McpRoutes = lazy(() =>
  new Hono()
    // Get MCP status
    .get(
      "/",
      describeRoute({
        summary: "Get MCP status",
        description: "Retrieve the current status of all configured and connected MCP servers.",
        operationId: "mcp.status",
        responses: {
          200: {
            description: "MCP status",
            content: {
              "application/json": {
                schema: resolver(z.any()),
              },
            },
          },
        },
      }),
      async (c) => {
        const status = await MCP.status()
        return c.json(status)
      },
    )

    // List MCP servers
    .get(
      "/list",
      describeRoute({
        summary: "List MCP servers",
        description: "Retrieve a list of all configured and active MCP (Model Context Protocol) servers.",
        operationId: "mcp.list",
        responses: {
          200: {
            description: "List of MCP servers",
            content: {
              "application/json": {
                schema: resolver(z.any()),
              },
            },
          },
        },
      }),
      async (c) => {
        const status = await MCP.status()
        return c.json(status)
      },
    )

    // Get MCP registry (from external sources)
    .get(
      "/registry",
      describeRoute({
        summary: "Get MCP Registry",
        description: "Retrieve available MCP servers from registries (Smithery, Glama, etc.)",
        operationId: "mcp.registry",
        responses: {
          200: {
            description: "MCP registry servers",
            content: {
              "application/json": {
                schema: resolver(z.object({
                  servers: z.array(z.any()),
                })),
              },
            },
          },
        },
      }),
      async (c) => {
        // For now, return a curated list of common MCP servers
        // In the future, this could fetch from Smithery, Glama, etc.
        const servers: McpRegistryServer[] = [
          {
            id: "github",
            name: "GitHub MCP Server",
            description: "MCP server for GitHub API integration - issues, PRs, repositories",
            homepage: "https://github.com/modelcontextprotocol/servers",
            runtime: "stdio",
            command: "npx",
            args: ["-y", "@modelcontextprotocol/server-github"],
            env: { GITHUB_PERSONAL_ACCESS_TOKEN: "" },
            tools: ["search_repositories", "create_issue", "get_issue", "list_issues", "update_issue", "add_issue_comment", "search_code", "search_issues", "search_commits", "list_commits"],
          },
          {
            id: "postgres",
            name: "PostgreSQL MCP Server",
            description: "Read-only PostgreSQL database access with schema inspection",
            homepage: "https://github.com/modelcontextprotocol/servers",
            runtime: "stdio",
            command: "npx",
            args: ["-y", "@modelcontextprotocol/server-postgres"],
            env: { POSTGRES_URL: "" },
            tools: ["query", "schema"],
          },
          {
            id: "fetch",
            name: "Fetch MCP Server",
            description: "Web content fetching and conversion for LLM usage",
            homepage: "https://github.com/modelcontextprotocol/servers",
            runtime: "stdio",
            command: "npx",
            args: ["-y", "@modelcontextprotocol/server-fetch"],
            tools: ["fetch"],
          },
          {
            id: "puppeteer",
            name: "Puppeteer MCP Server",
            description: "Browser automation for web scraping and interaction",
            homepage: "https://github.com/modelcontextprotocol/servers",
            runtime: "stdio",
            command: "npx",
            args: ["-y", "@modelcontextprotocol/server-puppeteer"],
            tools: ["puppeteer_navigate", "puppeteer_screenshot", "puppeteer_click", "puppeteer_fill", "puppeteer_evaluate"],
          },
          {
            id: "filesystem",
            name: "Filesystem MCP Server",
            description: "Secure file operations with configurable access controls",
            homepage: "https://github.com/modelcontextprotocol/servers",
            runtime: "stdio",
            command: "npx",
            args: ["-y", "@modelcontextprotocol/server-filesystem", "/path/to/allowed/dir"],
            tools: ["read_file", "read_multiple_files", "write_file", "create_directory", "list_directory", "move_file", "search_files", "get_file_info"],
          },
          {
            id: "context7",
            name: "Context7 MCP Server",
            description: "Documentation indexing and semantic search for codebases",
            homepage: "https://context7.com",
            runtime: "stdio",
            command: "npx",
            args: ["-y", "@upstash/context7-mcp@latest"],
            tools: ["resolve-library-id", "get-library-documentation"],
          },
        ]

        return c.json({ servers })
      },
    )

    // Add MCP server
    .post(
      "/add",
      describeRoute({
        summary: "Add MCP server",
        description: "Configure and add a new MCP server to the system.",
        operationId: "mcp.add",
        responses: {
          200: {
            description: "MCP server added successfully",
            content: {
              "application/json": {
                schema: resolver(z.any()),
              },
            },
          },
          ...errors(400),
        },
      }),
      validator("json", z.object({
        name: z.string(),
        type: z.enum(["stdio", "remote"]),
        command: z.string().optional(),
        args: z.array(z.string()).optional(),
        url: z.string().optional(),
        env: z.record(z.string()).optional(),
        headers: z.record(z.string()).optional(),
        oauth: z.union([z.boolean(), z.object({
          clientId: z.string(),
          clientSecret: z.string().optional(),
          scope: z.string().optional(),
        })]).optional(),
      })),
      async (c) => {
        const input = c.req.valid("json")
        const { name, ...config } = input
        const status = await MCP.add(name, config as any)
        return c.json(status)
      },
    )

    // List MCP resources
    .get(
      "/resources",
      describeRoute({
        summary: "List MCP resources",
        description: "Retrieve a list of all available resources across all registered MCP servers.",
        operationId: "mcp.resources",
        responses: {
          200: {
            description: "MCP resources",
            content: { "application/json": { schema: resolver(z.any()) } },
          },
        },
      }),
      async (c) => {
        const resources = await MCP.resources()
        return c.json(resources)
      },
    )

    // Get MCP tools
    .get(
      "/tools",
      describeRoute({
        summary: "Get MCP Tools",
        description: "Retrieve available tools from all connected MCP servers.",
        operationId: "mcp.tools",
        responses: {
          200: {
            description: "MCP tools",
            content: {
              "application/json": {
                schema: resolver(z.any()),
              },
            },
          },
        },
      }),
      async (c) => {
        const tools = await MCP.tools()
        return c.json({ tools: Object.keys(tools) })
      },
    )

    // Execute MCP tool
    .post(
      "/tools/:name/execute",
      describeRoute({
        summary: "Execute MCP Tool",
        description: "Execute a specific MCP tool with the provided arguments.",
        operationId: "mcp.executeTool",
        responses: {
          200: {
            description: "Tool execution result",
            content: {
              "application/json": {
                schema: resolver(z.any()),
              },
            },
          },
          ...errors(404, 500),
        },
      }),
      validator("param", z.object({
        name: z.string(),
      })),
      validator("json", z.object({
        arguments: z.record(z.unknown()).optional(),
      })),
      async (c) => {
        try {
          const { name } = c.req.valid("param")
          const { arguments: args } = c.req.valid("json")

          log.info("executing_mcp_tool", { name, args })

          // Get all tools and find the requested one
          const tools = await MCP.tools()
          const tool = tools[name]

          if (!tool) {
            return c.json({ error: `Tool '${name}' not found` }, 404)
          }

          // Execute the tool
          const result = await tool.execute(args || {}, {
            toolCallId: `mcp-${Date.now()}`,
            messages: [],
          })

          return c.json({
            success: true,
            result,
            tool: name,
          })
        } catch (error) {
          log.error("mcp_tool_execution_failed", { error })
          return c.json({
            success: false,
            error: error instanceof Error ? error.message : "Tool execution failed",
          }, 500)
        }
      },
    )

    // Get MCP prompts
    .get(
      "/prompts",
      describeRoute({
        summary: "Get MCP Prompts",
        description: "Retrieve available prompts from all connected MCP servers.",
        operationId: "mcp.prompts",
        responses: {
          200: {
            description: "MCP prompts",
            content: {
              "application/json": {
                schema: resolver(z.any()),
              },
            },
          },
        },
      }),
      async (c) => {
        const prompts = await MCP.prompts()
        return c.json({ prompts })
      },
    )

    // Get specific prompt
    .post(
      "/prompts/:client/:name",
      describeRoute({
        summary: "Get MCP Prompt",
        description: "Get a specific prompt from an MCP server.",
        operationId: "mcp.getPrompt",
        responses: {
          200: {
            description: "Prompt result",
            content: {
              "application/json": {
                schema: resolver(z.any()),
              },
            },
          },
          ...errors(404, 500),
        },
      }),
      validator("param", z.object({
        client: z.string(),
        name: z.string(),
      })),
      validator("json", z.object({
        args: z.record(z.string()).optional(),
      })),
      async (c) => {
        const { client, name } = c.req.valid("param")
        const { args } = c.req.valid("json")

        const result = await MCP.getPrompt(client, name, args)

        if (!result) {
          return c.json({ error: "Prompt not found" }, 404)
        }

        return c.json({ success: true, result })
      },
    )

    // Read MCP resource
    .get(
      "/resources/:client/read",
      describeRoute({
        summary: "Read MCP Resource",
        description: "Read a specific resource from an MCP server.",
        operationId: "mcp.readResource",
        responses: {
          200: {
            description: "Resource content",
            content: {
              "application/json": {
                schema: resolver(z.any()),
              },
            },
          },
          ...errors(404, 500),
        },
      }),
      async (c) => {
        const client = c.req.param("client")
        const uri = c.req.query("uri")

        if (!uri) {
          return c.json({ error: "URI parameter required" }, 400)
        }

        const result = await MCP.readResource(client, uri)

        if (!result) {
          return c.json({ error: "Resource not found" }, 404)
        }

        return c.json({ success: true, result })
      },
    )

    // Start OAuth authentication
    .post(
      "/:name/auth/start",
      describeRoute({
        summary: "Start MCP OAuth",
        description: "Start OAuth authentication flow for an MCP server.",
        operationId: "mcp.startAuth",
        responses: {
          200: {
            description: "OAuth URL",
            content: {
              "application/json": {
                schema: resolver(z.object({
                  authorizationUrl: z.string(),
                })),
              },
            },
          },
          ...errors(400, 404),
        },
      }),
      validator("param", z.object({
        name: z.string(),
      })),
      async (c) => {
        const { name } = c.req.valid("param")

        try {
          const result = await MCP.startAuth(name)
          return c.json(result)
        } catch (error) {
          return c.json({
            error: error instanceof Error ? error.message : "Auth failed",
          }, 400)
        }
      },
    )

    // Disconnect MCP server
    .delete(
      "/:name",
      describeRoute({
        summary: "Remove MCP server",
        description: "Remove a configured MCP server by its name.",
        operationId: "mcp.remove",
        responses: {
          200: {
            description: "MCP server removed successfully",
            content: {
              "application/json": {
                schema: resolver(z.any()),
              },
            },
          },
          ...errors(404),
        },
      }),
      validator("param", z.object({
        name: z.string(),
      })),
      async (c) => {
        const { name } = c.req.valid("param")
        await MCP.disconnect(name)
        return c.json({ success: true })
      },
    ),
)
