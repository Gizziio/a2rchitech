import path from "path"
import { Hono } from "hono"
import { validator } from "hono-openapi"
import z from "zod/v4"
import { Bus } from "@/runtime/bus/bus"
import { BusEvent } from "@/runtime/bus/bus-event"
import { MemoryService } from "@/runtime/memory/memory-service"
import { AgentWorkspace } from "@/runtime/memory/memory"
import { Instance } from "@/runtime/context/project/instance"
import { Filesystem } from "@/runtime/util/filesystem"
import { errors } from "@/runtime/server/error"

const MemoryL2UpdatedEvent = BusEvent.define("memory.l2.updated", z.object({ type: z.string(), label: z.string() }))
const MemoryL1UpdatedEvent = BusEvent.define("memory.l1.updated", z.object({ sessionID: z.string() }))
const MemoryUpdatedEvent = BusEvent.define("memory.updated", z.object({ filename: z.string(), name: z.string(), type: z.string() }))
const MemoryDeletedEvent = BusEvent.define("memory.deleted", z.object({ filename: z.string() }))

// ── L2 Identity type → file path ─────────────────────────────────────────────

const L2_TYPE_LABELS: Record<string, string> = {
  soul: "Core Values",
  identity: "Agent Identity",
  voice: "Communication Style",
  conventions: "Project Conventions",
  user: "User Preferences",
  policy: "Base Policy",
}

function l2TypeToPath(paths: AgentWorkspace.WorkspacePaths, type: string): string | null {
  switch (type) {
    case "soul":        return paths.l2_soul_md
    case "identity":    return paths.l2_identity_md
    case "voice":       return paths.l2_voice_md
    case "conventions": return paths.l2_conventions_md
    case "user":        return paths.l2_user_md
    case "policy":      return paths.l2_policy_md
    default:            return null
  }
}

// ── Routes ────────────────────────────────────────────────────────────────────

export function MemoryRoutes() {
  return new Hono()
    // GET /memory — list all memory entries
    .get("/", async (c) => {
      const entries = await MemoryService.list()
      return c.json(
        entries.map((e) => ({
          filename: e.filename,
          name: e.name,
          description: e.description,
          type: e.type,
          filepath: e.filepath,
        })),
      )
    })

    // GET /memory/search?q=<query> — search memories
    .get("/search", validator("query", z.object({ q: z.string().optional() })), async (c) => {
      const { q } = c.req.valid("query")
      const entries = q ? await MemoryService.search(q) : await MemoryService.list()
      return c.json(entries)
    })

    // ── L2: Identity layer (soul/conventions/voice/identity/user/policy) ──────

    // GET /memory/l2 — list L2 identity file availability
    .get("/l2", async (c) => {
      const wsPaths = AgentWorkspace.getPaths(Instance.directory)
      const results = await Promise.all(
        Object.entries(L2_TYPE_LABELS).map(async ([type, label]) => {
          const filePath = l2TypeToPath(wsPaths, type)!
          const exists = await Filesystem.exists(filePath)
          return { type, label, exists }
        }),
      )
      return c.json(results)
    })

    // GET /memory/l2/:type — read a specific L2 identity file
    .get("/l2/:type", async (c) => {
      const { type } = c.req.param()
      const wsPaths = AgentWorkspace.getPaths(Instance.directory)
      const filePath = l2TypeToPath(wsPaths, type)
      if (!filePath) return c.json({ name: "NotFound", message: `Unknown L2 type: ${type}`, data: {} }, 404)
      const content = await Filesystem.readText(filePath).catch(() => null)
      if (content === null) return c.json({ name: "NotFound", message: `L2 file not found: ${type}`, data: {} }, 404)
      return c.json({ type, label: L2_TYPE_LABELS[type], content })
    })

    // PUT /memory/l2/:type — update a specific L2 identity file
    .put("/l2/:type", validator("json", z.object({ content: z.string() })), async (c) => {
      const { type } = c.req.param()
      const wsPaths = AgentWorkspace.getPaths(Instance.directory)
      const filePath = l2TypeToPath(wsPaths, type)
      if (!filePath) return c.json({ name: "NotFound", message: `Unknown L2 type: ${type}`, data: {} }, 404)
      const { content } = c.req.valid("json")
      await Filesystem.mkdir(wsPaths.l2_identity)
      await Filesystem.write(filePath, content)
      await Bus.publish(MemoryL2UpdatedEvent, { type, label: L2_TYPE_LABELS[type] })
      return c.json({ type, label: L2_TYPE_LABELS[type], content })
    })

    // ── L1: Session working memory ────────────────────────────────────────────

    // GET /memory/l1/:sessionID — get working memory for a session
    .get("/l1/:sessionID", async (c) => {
      const { sessionID } = c.req.param()
      const wsPaths = AgentWorkspace.getPaths(Instance.directory)
      const sessDir = path.join(wsPaths.l1_memory, "sessions")
      const filePath = path.join(sessDir, `${sessionID}.md`)
      const content = await Filesystem.readText(filePath).catch(() => null)
      if (content === null)
        return c.json({ name: "NotFound", message: `No working memory for session: ${sessionID}`, data: {} }, 404)
      return c.json({ sessionID, content })
    })

    // PUT /memory/l1/:sessionID — update working memory for a session
    .put("/l1/:sessionID", validator("json", z.object({ content: z.string() })), async (c) => {
      const { sessionID } = c.req.param()
      const wsPaths = AgentWorkspace.getPaths(Instance.directory)
      const sessDir = path.join(wsPaths.l1_memory, "sessions")
      const filePath = path.join(sessDir, `${sessionID}.md`)
      const { content } = c.req.valid("json")
      await Filesystem.mkdir(sessDir)
      await Filesystem.write(filePath, content)
      await Bus.publish(MemoryL1UpdatedEvent, { sessionID })
      return c.json({ sessionID, content })
    })

    // ── Flat memory CRUD ──────────────────────────────────────────────────────

    // GET /memory/:filename — read a specific memory
    .get("/:filename", async (c) => {
      const { filename } = c.req.param()
      const entry = await MemoryService.get(filename.endsWith(".md") ? filename : filename + ".md")
      if (!entry) return c.json({ name: "NotFound", message: `Memory not found: ${filename}`, data: {} }, 404)
      return c.json(entry)
    })

    // PUT /memory/:filename — save / update a memory
    .put(
      "/:filename",
      validator(
        "json",
        z.object({
          name: z.string(),
          description: z.string(),
          type: z.enum(["user", "feedback", "project", "reference"]),
          body: z.string(),
        }),
      ),
      async (c) => {
        const body = c.req.valid("json")
        const entry = await MemoryService.save(
          { name: body.name, description: body.description, type: body.type },
          body.body,
        )
        await Bus.publish(MemoryUpdatedEvent, { filename: entry.filename, name: entry.name, type: entry.type })
        return c.json(entry)
      },
    )

    // DELETE /memory/:filename — delete a memory
    .delete("/:filename", async (c) => {
      const { filename } = c.req.param()
      const normalizedFilename = filename.endsWith(".md") ? filename : filename + ".md"
      const ok = await MemoryService.remove(normalizedFilename)
      if (!ok) return c.json({ name: "NotFound", message: `Memory not found: ${filename}`, data: {} }, 404)
      await Bus.publish(MemoryDeletedEvent, { filename: normalizedFilename })
      return c.json(true)
    })
}
