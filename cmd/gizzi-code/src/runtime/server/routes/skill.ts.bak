import { Hono, type Env } from "hono"
import { describeRoute, resolver, validator } from "hono-openapi"
import z from "zod/v4"
import { Skill } from "@/runtime/skills/skill"
import { Discovery } from "@/runtime/skills/discovery"
import { Evaluator } from "@/runtime/skills/evaluator"
import { EvalStore } from "@/runtime/skills/eval-store"
import { ToolRegistry } from "@/runtime/tools/builtins/registry"
import { zodToJsonSchema } from "zod-to-json-schema"
import { errors } from "@/runtime/server/error"
import { SkillRegistryService, SkillSummarySchema } from "@/runtime/skills/registry-service"

const EvalCriteriaSchema = z.object({
  id: z.string(),
  description: z.string(),
  weight: z.number().optional(),
})

const RunEvalInputSchema = z.object({
  testInput: z.string(),
  criteria: EvalCriteriaSchema.array(),
  runs: z.number().optional(),
  model: z.string().optional(),
  passingScore: z.number().optional(),
})

const SkillRegistryResponseSchema = z.object({
  skills: SkillSummarySchema.array(),
  total: z.number(),
  page: z.number(),
  page_size: z.number(),
})

const SkillPublishBodySchema = z.object({
  manifest: z.record(z.string(), z.any()),
  package_url: z.string(),
  signature: z.string(),
})

const SkillInstallBodySchema = z.object({
  version: z.string().optional(),
})

export function SkillRoutes(): Hono<Env, any, any> {
  return new Hono()
    // ── List tool IDs ─────────────────────────────────────────
    .get(
      "/tool-ids",
      describeRoute({
        summary: "List tool IDs",
        description: "Get a list of all available tool IDs, including built-in and dynamically registered tools.",
        operationId: "skill.tool.ids",
        responses: {
          200: {
            description: "Tool IDs",
            content: { "application/json": { schema: resolver(z.string().array()) } },
          },
        },
      }),
      async (c) => c.json(await ToolRegistry.ids()),
    )

    // ── List tools with schemas ───────────────────────────────
    .get(
      "/tools",
      describeRoute({
        summary: "List tools",
        description: "Get available tools with their JSON schema parameters for a given provider/model.",
        operationId: "skill.tools",
        responses: {
          200: {
            description: "Tools",
            content: { "application/json": { schema: resolver(z.any()) } },
          },
        },
      }),
      validator("query", z.object({ provider: z.string().optional(), model: z.string().optional() })),
      async (c) => {
        const { provider, model } = c.req.valid("query")
        const tools = await ToolRegistry.tools({ providerID: provider ?? "", modelID: model ?? "" })
        return c.json(
          tools.map((t) => ({
            id: t.id,
            description: t.description,
            strict: t.strict ?? false,
            parameters: (t.parameters as any)?._def ? zodToJsonSchema(t.parameters as any) : t.parameters,
          })),
        )
      },
    )

    // ── List all skills ──────────────────────────────────────
    .get(
      "/",
      describeRoute({
        summary: "List skills",
        description: "Get a list of all available skills.",
        operationId: "app.skills",
        responses: {
          200: {
            description: "List of skills",
            content: { "application/json": { schema: resolver(Skill.Info.array()) } },
          },
        },
      }),
      async (c) => c.json(await Skill.all()),
    )

    // ── Add skill from URL ───────────────────────────────────
    .post(
      "/add",
      describeRoute({
        summary: "Add skill from URL",
        description: "Download and register skills from a remote index URL.",
        operationId: "skill.add",
        responses: {
          200: {
            description: "Skills loaded",
            content: { "application/json": { schema: resolver(z.object({ added: z.number(), dirs: z.string().array() })) } },
          },
          ...errors(400),
        },
      }),
      validator("json", z.object({ url: z.string() })),
      async (c) => {
        const { url } = c.req.valid("json")
        const dirs = await Discovery.pull(url)
        return c.json({ added: dirs.length, dirs })
      },
    )

    // ── Run eval on a skill ──────────────────────────────────
    .post(
      "/:name/eval",
      describeRoute({
        summary: "Evaluate skill",
        description: "Run N parallel eval passes of a skill against test input and rubric criteria.",
        operationId: "skill.eval",
        responses: {
          200: {
            description: "Eval report",
            content: { "application/json": { schema: resolver(z.any()) } },
          },
          ...errors(400, 404),
        },
      }),
      validator("param", z.object({ name: z.string() })),
      validator("json", RunEvalInputSchema),
      async (c) => {
        const { name } = c.req.valid("param")
        const input = c.req.valid("json")

        const skill = await Skill.get(name)
        if (!skill) return c.json({ error: `Skill "${name}" not found` }, 404)

        const report = await Evaluator.run({ skillName: name, ...input })
        await EvalStore.save(report)
        return c.json(report)
      },
    )

    // ── List eval reports for a skill ────────────────────────
    .get(
      "/:name/evals",
      describeRoute({
        summary: "List skill evals",
        description: "List all eval reports for a skill.",
        operationId: "skill.evals.list",
        responses: {
          200: {
            description: "Eval reports",
            content: { "application/json": { schema: resolver(z.any()) } },
          },
        },
      }),
      validator("param", z.object({ name: z.string() })),
      async (c) => {
        const { name } = c.req.valid("param")
        const reports = await EvalStore.list(name)
        return c.json(reports)
      },
    )

    // ── Get a specific eval report ───────────────────────────
    .get(
      "/:name/evals/:id",
      describeRoute({
        summary: "Get skill eval",
        description: "Get a specific eval report by ID.",
        operationId: "skill.evals.get",
        responses: {
          200: {
            description: "Eval report",
            content: { "application/json": { schema: resolver(z.any()) } },
          },
          ...errors(404),
        },
      }),
      validator("param", z.object({ name: z.string(), id: z.string() })),
      async (c) => {
        const { name, id } = c.req.valid("param")
        const report = await EvalStore.get(name, id)
        if (!report) return c.json({ error: `Eval "${id}" not found` }, 404)
        return c.json(report)
      },
    )
    .get(
      "/registry",
      describeRoute({
        summary: "List public skill registry entries",
        description: "Return paginated public skill registry entries.",
        operationId: "skill.registry",
        responses: {
          200: {
            description: "Public skill registry",
            content: { "application/json": { schema: resolver(SkillRegistryResponseSchema) } },
          },
        },
      }),
      validator("query", z.object({ page: z.coerce.number().optional(), page_size: z.coerce.number().optional() })),
      async (c) => {
        const { page = 1, page_size = 20 } = c.req.valid("query")
        const skills = await SkillRegistryService.summaries()
        const start = Math.max(0, (page - 1) * page_size)
        return c.json({
          skills: skills.slice(start, start + page_size),
          total: skills.length,
          page,
          page_size,
        })
      },
    )
    .post(
      "/publish",
      describeRoute({
        summary: "Publish skill",
        description: "Publish a skill manifest into the registry.",
        operationId: "skill.publish",
        responses: {
          200: {
            description: "Published skill summary",
            content: { "application/json": { schema: resolver(SkillSummarySchema) } },
          },
          ...errors(400),
        },
      }),
      validator("json", SkillPublishBodySchema),
      async (c) => {
        const { manifest, package_url, signature } = c.req.valid("json")
        if (!signature.trim()) return c.json({ error: "signature is required" }, 400)
        try {
          const record = await SkillRegistryService.publish({
            manifest,
            packageUrl: package_url,
            signature,
          })
          return c.json(record.summary)
        } catch (error) {
          const message = error instanceof Error ? error.message : String(error)
          const status = message.includes("not configured") ? 503 : 400
          return c.json({ error: message }, status as 400)
        }
      },
    )
    .post(
      "/:id/install",
      describeRoute({
        summary: "Install skill from registry",
        description: "Install a published skill into the current workspace namespace.",
        operationId: "skill.install",
        responses: {
          200: {
            description: "Install receipt",
            content: {
              "application/json": {
                schema: resolver(z.object({ installed: z.boolean(), id: z.string(), version: z.string() })),
              },
            },
          },
          ...errors(404),
        },
      }),
      validator("param", z.object({ id: z.string() })),
      validator("json", SkillInstallBodySchema),
      async (c) => {
        const { id } = c.req.valid("param")
        const { version } = c.req.valid("json")
        const skill = await SkillRegistryService.install({ id, version })
        if (!skill) return c.json({ error: `Skill "${id}" not found` }, 404)
        return c.json({ installed: true, id: skill.id, version: skill.version })
      },
    )
}
