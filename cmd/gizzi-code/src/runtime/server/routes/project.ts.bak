import { Hono } from "hono"
import { describeRoute, validator, resolver } from "hono-openapi"
import z from "zod/v4"
import { Project } from "@/runtime/context/project/project"
import { Instance } from "@/runtime/context/project/instance"
import { Session } from "@/runtime/session/session"
import { SessionPrompt } from "@/runtime/session/prompt"
import { SessionCompaction } from "@/runtime/session/compaction"
import { SessionRevert } from "@/runtime/session/revert"
import { MessageV2 } from "@/runtime/session/message-v2"
import { PermissionNext } from "@/runtime/tools/guard/permission/next"
import { File } from "@/runtime/file/file"
import * as AgentWorkspaceLoader from "@/runtime/workspace/workspace-loader"
import { errors } from "@/runtime/server/error"
import { NotFoundError } from "@/runtime/session/storage/db"

async function withProject<R>(
  projectID: string,
  fn: (project: Project.Info) => Promise<R>,
): Promise<R> {
  const project = Project.get(projectID)
  if (!project) throw new NotFoundError({ message: `Project not found: ${projectID}` })
  return Instance.provide({ directory: project.worktree, fn: () => fn(project) })
}

export const ProjectRoutes = () =>
  new Hono()
    // ── GET / — list all projects ──────────────────────────────────────────
    .get(
      "/",
      describeRoute({
        summary: "List projects",
        description: "Retrieve a list of all projects managed by the A2R instance.",
        operationId: "project.listRoot",
        responses: {
          200: {
            description: "List of projects",
            content: { "application/json": { schema: resolver(z.any()) } },
          },
        },
      }),
      async (c) => {
        const projects = Project.list()
        return c.json(projects)
      },
    )
    // ── POST /init — initialize project from directory ─────────────────────
    .post(
      "/init",
      describeRoute({
        summary: "Initialize project",
        description: "Initialize a project from a filesystem directory.",
        operationId: "project.init",
        responses: {
          200: {
            description: "Initialized project",
            content: { "application/json": { schema: resolver(z.any()) } },
          },
          ...errors(400),
        },
      }),
      validator("json", z.any()),
      async (c) => {
        const { directory } = c.req.valid("json") as any
        const { project } = await Project.fromDirectory(directory)
        return c.json(project)
      },
    )
    // ── GET /list — list all projects (legacy alias) ───────────────────────
    .get(
      "/list",
      describeRoute({
        summary: "List projects",
        description: "Retrieve a list of all projects managed by the A2R instance.",
        operationId: "project.list",
        responses: {
          200: {
            description: "List of projects",
            content: { "application/json": { schema: resolver(z.any()) } },
          },
        },
      }),
      async (c) => {
        const projects = Project.list()
        return c.json(projects)
      },
    )
    // ── GET /:projectID/session — list sessions for a project ──────────────
    .get(
      "/:projectID/session",
      describeRoute({
        summary: "List project sessions",
        description: "List all sessions belonging to a specific project.",
        operationId: "project.session.list",
        responses: {
          200: {
            description: "List of sessions",
            content: { "application/json": { schema: resolver(z.any()) } },
          },
          ...errors(404),
        },
      }),
      validator("param", z.any()),
      async (c) => {
        const { projectID } = c.req.valid("param") as any
        return withProject(projectID, async () => {
          const sessions = Array.from(Session.list())
          return c.json(sessions)
        })
      },
    )
    // ── POST /:projectID/session — create session in a project ─────────────
    .post(
      "/:projectID/session",
      describeRoute({
        summary: "Create project session",
        description: "Create a new session within a specific project.",
        operationId: "project.session.create",
        responses: {
          200: {
            description: "Created session",
            content: { "application/json": { schema: resolver(z.any()) } },
          },
          ...errors(400, 404),
        },
      }),
      validator("param", z.any()),
      validator("json", z.any()),
      async (c) => {
        const { projectID } = c.req.valid("param") as any
        const input = c.req.valid("json") as any
        return withProject(projectID, async () => {
          const session = await Session.createNext({
            id: input.id,
            parentID: input.parentID,
            directory: input.directory,
            permission: input.permission,
            agentID: input.agentID,
          })
          return c.json(session)
        })
      },
    )
    // ── GET /:projectID/session/:sessionID — get single session ────────────
    .get(
      "/:projectID/session/:sessionID",
      describeRoute({
        summary: "Get project session",
        description: "Retrieve a specific session belonging to a project.",
        operationId: "project.session.get",
        responses: {
          200: {
            description: "Session details",
            content: { "application/json": { schema: resolver(z.any()) } },
          },
          ...errors(404),
        },
      }),
      validator("param", z.any()),
      async (c) => {
        const { sessionID } = c.req.valid("param") as any
        const session = await Session.get(sessionID)
        return c.json(session)
      },
    )
    // ── DELETE /:projectID/session/:sessionID — delete session ─────────────
    .delete(
      "/:projectID/session/:sessionID",
      describeRoute({
        summary: "Delete project session",
        description: "Delete a session and all its messages.",
        operationId: "project.session.delete",
        responses: {
          200: {
            description: "Session deleted",
            content: { "application/json": { schema: resolver(z.any()) } },
          },
          ...errors(404),
        },
      }),
      validator("param", z.any()),
      async (c) => {
        const { projectID, sessionID } = c.req.valid("param") as any
        return withProject(projectID, async () => {
          await Session.remove(sessionID)
          return c.json(true)
        })
      },
    )
    // ── POST /:projectID/session/:sessionID/init — initialize session ───────
    .post(
      "/:projectID/session/:sessionID/init",
      describeRoute({
        summary: "Initialize project session",
        description: "Initialize a session with a starting message or context.",
        operationId: "project.session.initialize",
        responses: {
          200: {
            description: "Session initialized",
            content: { "application/json": { schema: resolver(z.any()) } },
          },
          ...errors(400, 404),
        },
      }),
      validator("param", z.any()),
      validator("json", z.any()),
      async (c) => {
        const { projectID, sessionID } = c.req.valid("param") as any
        const input = c.req.valid("json") as any
        return withProject(projectID, async () => {
          const session = await Session.initialize({ ...input, sessionID })
          return c.json(session)
        })
      },
    )
    // ── POST /:projectID/session/:sessionID/abort — abort session ───────────
    .post(
      "/:projectID/session/:sessionID/abort",
      describeRoute({
        summary: "Abort project session",
        description: "Abort the currently running agent loop for a session.",
        operationId: "project.session.abort",
        responses: {
          200: {
            description: "Session aborted",
            content: { "application/json": { schema: resolver(z.any()) } },
          },
          ...errors(404),
        },
      }),
      validator("param", z.any()),
      async (c) => {
        const { sessionID } = c.req.valid("param") as any
        SessionPrompt.cancel(sessionID)
        return c.json(true)
      },
    )
    // ── POST /:projectID/session/:sessionID/share — share session ───────────
    .post(
      "/:projectID/session/:sessionID/share",
      describeRoute({
        summary: "Share project session",
        description: "Share a session publicly.",
        operationId: "project.session.share",
        responses: {
          200: {
            description: "Session shared",
            content: { "application/json": { schema: resolver(z.any()) } },
          },
          ...errors(404),
        },
      }),
      validator("param", z.any()),
      async (c) => {
        const { sessionID } = c.req.valid("param") as any
        const result = await Session.share(sessionID)
        return c.json(result)
      },
    )
    // ── DELETE /:projectID/session/:sessionID/share — unshare session ───────
    .delete(
      "/:projectID/session/:sessionID/share",
      describeRoute({
        summary: "Unshare project session",
        description: "Remove public sharing from a session.",
        operationId: "project.session.unshare",
        responses: {
          200: {
            description: "Session unshared",
            content: { "application/json": { schema: resolver(z.any()) } },
          },
          ...errors(404),
        },
      }),
      validator("param", z.any()),
      async (c) => {
        const { sessionID } = c.req.valid("param") as any
        const result = await Session.unshare(sessionID)
        return c.json(result)
      },
    )
    // ── POST /:projectID/session/:sessionID/compact — compact session ────────
    .post(
      "/:projectID/session/:sessionID/compact",
      describeRoute({
        summary: "Compact project session",
        description: "Prune compactable tool outputs from session history.",
        operationId: "project.session.compact",
        responses: {
          200: {
            description: "Session compacted",
            content: { "application/json": { schema: resolver(z.any()) } },
          },
          ...errors(404),
        },
      }),
      validator("param", z.any()),
      async (c) => {
        const { sessionID } = c.req.valid("param") as any
        await SessionCompaction.prune({ sessionID })
        return c.json(true)
      },
    )
    // ── GET /:projectID/session/:sessionID/message — list messages ──────────
    .get(
      "/:projectID/session/:sessionID/message",
      describeRoute({
        summary: "List session messages",
        description: "Retrieve all messages belonging to a specific session.",
        operationId: "project.session.messages",
        responses: {
          200: {
            description: "List of messages",
            content: { "application/json": { schema: resolver(z.any()) } },
          },
          ...errors(404),
        },
      }),
      validator("param", z.any()),
      async (c) => {
        const { sessionID } = c.req.valid("param") as any
        const msgs = await Session.messages({ sessionID })
        return c.json(msgs)
      },
    )
    // ── GET /:projectID/session/:sessionID/message/:messageID — get message ─
    .get(
      "/:projectID/session/:sessionID/message/:messageID",
      describeRoute({
        summary: "Get session message",
        description: "Retrieve a specific message and its parts.",
        operationId: "project.session.message.get",
        responses: {
          200: {
            description: "Message with parts",
            content: { "application/json": { schema: resolver(z.any()) } },
          },
          ...errors(404),
        },
      }),
      validator("param", z.any()),
      async (c) => {
        const { sessionID, messageID } = c.req.valid("param") as any
        const msg = await MessageV2.get({ sessionID, messageID })
        return c.json(msg)
      },
    )
    // ── POST /:projectID/session/:sessionID/message — send message ──────────
    .post(
      "/:projectID/session/:sessionID/message",
      describeRoute({
        summary: "Send message to session",
        description: "Send a prompt message to a session and trigger the agent loop.",
        operationId: "project.session.message.create",
        responses: {
          200: {
            description: "Message sent",
            content: { "application/json": { schema: resolver(z.any()) } },
          },
          ...errors(400, 404),
        },
      }),
      validator("param", z.any()),
      validator("json", z.any()),
      async (c) => {
        const { projectID, sessionID } = c.req.valid("param") as any
        const input = c.req.valid("json") as any
        return withProject(projectID, async () => {
          const result = await SessionPrompt.prompt({ ...input, sessionID })
          return c.json(result)
        })
      },
    )
    // ── POST /:projectID/session/:sessionID/revert — revert session ─────────
    .post(
      "/:projectID/session/:sessionID/revert",
      describeRoute({
        summary: "Revert session",
        description: "Revert file changes made during a session.",
        operationId: "project.session.revert",
        responses: {
          200: {
            description: "Session reverted",
            content: { "application/json": { schema: resolver(z.any()) } },
          },
          ...errors(404),
        },
      }),
      validator("param", z.any()),
      validator("json", z.any()),
      async (c) => {
        const { projectID, sessionID } = c.req.valid("param") as any
        const input = c.req.valid("json") as any
        return withProject(projectID, async () => {
          const result = await SessionRevert.revert({ sessionID, messageID: input.messageID })
          return c.json(result)
        })
      },
    )
    // ── POST /:projectID/session/:sessionID/unrevert — unrevert session ──────
    .post(
      "/:projectID/session/:sessionID/unrevert",
      describeRoute({
        summary: "Unrevert session",
        description: "Undo a revert, restoring the session changes.",
        operationId: "project.session.unrevert",
        responses: {
          200: {
            description: "Session unreverted",
            content: { "application/json": { schema: resolver(z.any()) } },
          },
          ...errors(404),
        },
      }),
      validator("param", z.any()),
      async (c) => {
        const { projectID, sessionID } = c.req.valid("param") as any
        return withProject(projectID, async () => {
          const result = await SessionRevert.unrevert({ sessionID })
          return c.json(result)
        })
      },
    )
    // ── POST /:projectID/session/:sessionID/permission/:permissionID ─────────
    .post(
      "/:projectID/session/:sessionID/permission/:permissionID",
      describeRoute({
        summary: "Reply to permission request",
        description: "Approve or deny a pending permission request for a session.",
        operationId: "project.session.permission.reply",
        responses: {
          200: {
            description: "Permission processed",
            content: { "application/json": { schema: resolver(z.any()) } },
          },
          ...errors(400, 404),
        },
      }),
      validator("param", z.any()),
      validator("json", z.any()),
      async (c) => {
        const { permissionID } = c.req.valid("param") as any
        const json = c.req.valid("json") as any
        await PermissionNext.reply({
          requestID: permissionID,
          reply: json.reply,
          message: json.message,
        })
        return c.json(true)
      },
    )
    // ── GET /:projectID/session/:sessionID/find/file — find files ───────────
    .get(
      "/:projectID/session/:sessionID/find/file",
      describeRoute({
        summary: "Find files in session",
        description: "Search for files by name pattern within the session workspace.",
        operationId: "project.session.file.find",
        responses: {
          200: {
            description: "Matching file paths",
            content: { "application/json": { schema: resolver(z.any()) } },
          },
          ...errors(404),
        },
      }),
      validator("param", z.any()),
      validator("query", z.any()),
      async (c) => {
        const { projectID } = c.req.valid("param") as any
        const query = c.req.valid("query") as any
        return withProject(projectID, async () => {
          const files = await File.search({ query: query.query ?? "", type: "file", limit: query.limit })
          return c.json(files)
        })
      },
    )
    // ── GET /:projectID/session/:sessionID/file/status — file diff status ───
    .get(
      "/:projectID/session/:sessionID/file/status",
      describeRoute({
        summary: "Get session file status",
        description: "Get the diff status of files changed during a session.",
        operationId: "project.session.file.status",
        responses: {
          200: {
            description: "Changed files",
            content: { "application/json": { schema: resolver(z.any()) } },
          },
          ...errors(404),
        },
      }),
      validator("param", z.any()),
      async (c) => {
        const { sessionID } = c.req.valid("param") as any
        const result = await Session.diff(sessionID)
        return c.json(result)
      },
    )
    // ── GET /:projectID/session/:sessionID/file — read file ─────────────────
    .get(
      "/:projectID/session/:sessionID/file",
      describeRoute({
        summary: "Read file in session",
        description: "Read the content of a specific file in the session context.",
        operationId: "project.session.file.read",
        responses: {
          200: {
            description: "File content",
            content: { "application/json": { schema: resolver(z.any()) } },
          },
          ...errors(400, 404),
        },
      }),
      validator("param", z.any()),
      validator("query", z.any()),
      async (c) => {
        const query = c.req.valid("query") as any
        const content = await File.read(query.path)
        return c.json(content)
      },
    )
    // ── GET /:projectID/agent — list agents for project directory ──────────
    .get(
      "/:projectID/agent",
      describeRoute({
        summary: "List agents for project",
        description: "List agents available in a project directory, optionally overriding the directory via query param.",
        operationId: "project.agent.list",
        responses: {
          200: {
            description: "List of agents",
            content: { "application/json": { schema: resolver(z.any()) } },
          },
          ...errors(404),
        },
      }),
      validator("param", z.any()),
      validator("query", z.any()),
      async (c) => {
        const { projectID } = c.req.valid("param") as any
        const query = c.req.valid("query") as any
        return withProject(projectID, async (project) => {
          const directory = query.directory ?? project.worktree
          const agents = await AgentWorkspaceLoader.loadAllAgents(directory)
          return c.json(agents)
        })
      },
    )
    // ── GET /:projectID/find/file — find files in project directory ─────────
    .get(
      "/:projectID/find/file",
      describeRoute({
        summary: "Find files in project",
        description: "Search for files by name pattern within a project directory, optionally overriding via query param.",
        operationId: "project.find.file",
        responses: {
          200: {
            description: "Matching files",
            content: { "application/json": { schema: resolver(z.any()) } },
          },
          ...errors(404),
        },
      }),
      validator("param", z.any()),
      validator("query", z.any()),
      async (c) => {
        const { projectID } = c.req.valid("param") as any
        const query = c.req.valid("query") as any
        return withProject(projectID, async (project) => {
          const directory = query.directory ?? project.worktree
          if (directory !== project.worktree) {
            return Instance.provide({
              directory,
              fn: async () => {
                const files = await File.search({ query: query.query ?? "", type: "file", limit: query.limit })
                return c.json(files)
              },
            })
          }
          const files = await File.search({ query: query.query ?? "", type: "file", limit: query.limit })
          return c.json(files)
        })
      },
    )
    // ── GET /:projectID — get project details ──────────────────────────────
    .get(
      "/:projectID",
      describeRoute({
        summary: "Get project details",
        description: "Retrieve detailed information about a specific project by its ID.",
        operationId: "project.get",
        responses: {
          200: {
            description: "Project details",
            content: { "application/json": { schema: resolver(z.any()) } },
          },
          ...errors(404),
        },
      }),
      validator("param", z.any()),
      async (c) => {
        const { projectID } = c.req.valid("param") as any
        const project = Project.get(projectID)
        if (!project) throw new NotFoundError({ message: `Project not found: ${projectID}` })
        return c.json(project)
      },
    )
    // ── PATCH /:projectID — update project ─────────────────────────────────
    .patch(
      "/:projectID",
      describeRoute({
        summary: "Update project settings",
        description: "Update the configuration and settings for an existing project.",
        operationId: "project.update",
        responses: {
          200: {
            description: "Updated project details",
            content: { "application/json": { schema: resolver(z.any()) } },
          },
          ...errors(400, 404),
        },
      }),
      validator("param", z.any()),
      validator("json", z.any()),
      async (c) => {
        const { projectID } = c.req.valid("param") as any
        const input = c.req.valid("json") as any
        const project = await Project.update({ ...input, projectID })
        return c.json(project)
      },
    )
