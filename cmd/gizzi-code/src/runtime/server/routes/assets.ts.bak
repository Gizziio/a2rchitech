import { Hono } from "hono"
import { describeRoute, resolver } from "hono-openapi"
import z from "zod/v4"
import { FilesService } from "@/runtime/files/files-service"
import { Log } from "@/runtime/util/log"
import { errors } from "@/runtime/server/error"

const log = Log.create({ service: "asset-routes" })

export const AssetObject = z.object({
  id: z.string(),
  filename: z.string(),
  size: z.number(),
  media_type: z.string(),
  created_at: z.number(),
  storage_uri: z.string(),
})

export const AssetUploadBody = z.object({
  filename: z.string().optional(),
})

export const AssetListResponse = z.array(AssetObject)

type StoredAsset = Awaited<ReturnType<typeof FilesService.list>>[number]

function toAssetObject(record: StoredAsset) {
  return {
    id: record.id,
    filename: record.filename,
    size: record.size,
    media_type: record.media_type,
    created_at: record.created_at,
    storage_uri: record.storage_uri,
  }
}

export function AssetsRoutes() {
  return new Hono()
    .post(
      "/upload",
      describeRoute({
        summary: "Upload asset",
        description: "Upload a binary or text asset and receive an asset ID.",
        operationId: "asset.upload",
        responses: {
          200: {
            description: "Uploaded asset metadata",
            content: {
              "application/json": {
                schema: resolver(AssetObject),
              },
            },
          },
          ...errors(400),
        },
      }),
      async (c) => {
        const form = await c.req.formData()
        const file = form.get("file")
        if (!(file instanceof File)) {
          return c.json({ error: "Expected multipart form field named 'file'" }, 400)
        }
        const filenameOverride = form.get("filename")
        const bytes = new Uint8Array(await file.arrayBuffer())
        const record = await FilesService.save({
          bytes,
          filename: typeof filenameOverride === "string" && filenameOverride.trim() ? filenameOverride : file.name,
          mediaType: file.type || undefined,
        })
        log.info("asset uploaded", { id: record.id, filename: record.filename, size: record.size })
        return c.json(toAssetObject(record))
      },
    )
    .get(
      "/",
      describeRoute({
        summary: "List assets",
        description: "List uploaded assets for the current workspace.",
        operationId: "asset.list",
        responses: {
          200: {
            description: "Asset list",
            content: {
              "application/json": {
                schema: resolver(AssetListResponse),
              },
            },
          },
        },
      }),
      async (c) => c.json((await FilesService.list()).map(toAssetObject)),
    )
    .get(
      "/:id",
      describeRoute({
        summary: "Get asset metadata",
        description: "Get metadata for a previously uploaded asset.",
        operationId: "asset.get",
        responses: {
          200: {
            description: "Asset metadata",
            content: {
              "application/json": {
                schema: resolver(AssetObject),
              },
            },
          },
          ...errors(404),
        },
      }),
      async (c) => {
        const id = c.req.param("id")
        const asset = await FilesService.get(id)
        if (!asset) return c.json({ error: `Asset not found: ${id}` }, 404)
        return c.json(toAssetObject(asset))
      },
    )
    .delete(
      "/:id",
      describeRoute({
        summary: "Delete asset",
        description: "Delete an uploaded asset.",
        operationId: "asset.delete",
        responses: {
          200: {
            description: "Deletion result",
            content: {
              "application/json": {
                schema: resolver(z.object({ deleted: z.boolean() })),
              },
            },
          },
          ...errors(404),
        },
      }),
      async (c) => {
        const id = c.req.param("id")
        const deleted = await FilesService.remove(id)
        if (!deleted) return c.json({ error: `Asset not found: ${id}` }, 404)
        return c.json({ deleted: true })
      },
    )
}
