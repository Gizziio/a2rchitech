import { type Content as OpenAPIContent, resolver } from "hono-openapi"
import type { Context } from "hono"
import z from "zod/v4"

export const ErrorEnvelopeSchema = z.object({
  error: z.object({
    code: z.string(),
    message: z.string(),
    details: z.unknown().optional(),
  }),
})

export function ErrorEnvelope(): OpenAPIContent {
  return resolver(ErrorEnvelopeSchema)
}

export function SuccessEnvelope<T extends z.ZodTypeAny>(schema: T): OpenAPIContent {
  return resolver(
    z.object({
      data: schema,
    }),
  )
}

export function toErrorCode(name: string) {
  return name
    .replace(/([a-z0-9])([A-Z])/g, "$1_$2")
    .replace(/[^A-Za-z0-9]+/g, "_")
    .replace(/^_+|_+$/g, "")
    .toUpperCase()
}

function isRecord(value: unknown): value is Record<string, unknown> {
  return !!value && typeof value === "object" && !Array.isArray(value)
}

function defaultErrorCode(status: number) {
  if (status === 400) return "BAD_REQUEST"
  if (status === 401) return "UNAUTHORIZED"
  if (status === 403) return "FORBIDDEN"
  if (status === 404) return "NOT_FOUND"
  if (status === 409) return "CONFLICT"
  if (status === 503) return "SERVICE_UNAVAILABLE"
  if (status >= 500) return "INTERNAL_ERROR"
  return `HTTP_${status}`
}

export function isCanonicalSuccessEnvelope(value: unknown): value is { data: unknown } {
  return isRecord(value) && Object.keys(value).length === 1 && "data" in value
}

export function isCanonicalErrorEnvelope(
  value: unknown,
): value is { error: { code: string; message: string; details?: unknown } } {
  return (
    isRecord(value) &&
    Object.keys(value).length === 1 &&
    "error" in value &&
    isRecord(value.error) &&
    typeof value.error.code === "string" &&
    typeof value.error.message === "string"
  )
}

function normalizeCanonicalErrorPayload(status: number, value: unknown) {
  if (isCanonicalErrorEnvelope(value)) return value

  if (isRecord(value)) {
    if (typeof value.name === "string" && typeof value.message === "string") {
      return {
        error: value.data === undefined
          ? { code: toErrorCode(value.name), message: value.message }
          : { code: toErrorCode(value.name), message: value.message, details: value.data },
      }
    }

    if (typeof value.error === "string") {
      return {
        error: {
          code: defaultErrorCode(status),
          message: value.error,
        },
      }
    }

    if (isRecord(value.error) && typeof value.error.message === "string") {
      return {
        error: value.error.details === undefined
          ? {
              code: typeof value.error.code === "string" ? value.error.code : defaultErrorCode(status),
              message: value.error.message,
            }
          : {
              code: typeof value.error.code === "string" ? value.error.code : defaultErrorCode(status),
              message: value.error.message,
              details: value.error.details,
            },
      }
    }

    if (typeof value.message === "string") {
      return {
        error: {
          code: defaultErrorCode(status),
          message: value.message,
        },
      }
    }
  }

  if (typeof value === "string") {
    return {
      error: {
        code: defaultErrorCode(status),
        message: value,
      },
    }
  }

  return value === undefined
    ? {
        error: {
          code: defaultErrorCode(status),
          message: `Request failed with status ${status}`,
        },
      }
    : {
        error: {
          code: defaultErrorCode(status),
          message: `Request failed with status ${status}`,
          details: value,
        },
      }
}

export function normalizeCanonicalJsonPayload(status: number, value: unknown) {
  if (status >= 200 && status < 300) {
    if (isCanonicalSuccessEnvelope(value) || isCanonicalErrorEnvelope(value)) return value
    return { data: value }
  }

  return normalizeCanonicalErrorPayload(status, value)
}

export function isJsonContentType(contentType?: string | null) {
  return !!contentType && contentType.toLowerCase().includes("application/json")
}

export function ok(c: Context, data: unknown, status: number = 200) {
  return c.json({ data }, status as any)
}

export function isCanonicalRequest(c: Context) {
  return c.req.path === "/v1" || c.req.path.startsWith("/v1/")
}

export function success(c: Context, data: unknown, status: number = 200) {
  if (isCanonicalRequest(c)) {
    return ok(c, data, status)
  }
  return c.json(data, status as any)
}

export function fail(
  c: Context,
  status: number,
  code: string,
  message: string,
  details?: unknown,
) {
  return c.json(
    {
      error: details === undefined ? { code, message } : { code, message, details },
    },
    status as any,
  )
}
