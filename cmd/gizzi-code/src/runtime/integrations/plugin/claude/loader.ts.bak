/**
 * Native Claude plugin loader.
 *
 * Discovers and loads plugins in the .claude-plugin/ format from:
 *   ~/.gizzi/plugins/<name>/        (gizzi-code native install dir)
 *   ~/.claude/plugins/cache/<marketplace>/<name>/<version>/  (Gizzi installs)
 *
 * Each plugin directory must contain .claude-plugin/plugin.json.
 * Loads commands, skills, hooks, and MCP server configs natively.
 */

import fs from "fs/promises"
import path from "path"
import matter from "gray-matter"
import { Filesystem } from "@/runtime/util/filesystem"
import { Global } from "@/runtime/context/global/global"
import { Log } from "@/runtime/util/log"
import { ConfigMarkdown } from "@/runtime/context/config/markdown"
import type {
  LoadedPlugin,
  LoadedCommand,
  LoadedSkill,
  PluginManifest,
  HooksConfig,
  McpServerConfig,
  CommandFrontmatter,
  SkillFrontmatter,
} from "./types"

const log = Log.create({ service: "plugin.claude" })

// ── Install directories ───────────────────────────────────────────────────────

/** Where gizzi-code installs .claude-plugin/ format plugins */
export function gizziPluginDir(): string {
  return path.join(Global.Path.home, ".gizzi", "plugins")
}

/** Where Gizzi caches installed plugins */
export function claudePluginDir(): string {
  return path.join(Global.Path.home, ".claude", "plugins", "cache")
}

/** Where Gizzi stores marketplace plugin listings (browsed but not necessarily cached) */
export function claudeMarketplaceDir(): string {
  return path.join(Global.Path.home, ".claude", "plugins", "marketplaces")
}

/** Built-in knowledge-work plugins shipped with gizzi-code (Anthropic & Partners) */
export function builtinPluginsDir(): string {
  return path.join(import.meta.dir, "../../../plugins/builtin")
}

// ── Top-level plugin discovery ────────────────────────────────────────────────

/** All plugin root directories containing a valid .claude-plugin/plugin.json */
export async function discoverPluginRoots(): Promise<string[]> {
  const roots: string[] = []

  async function scanDir(base: string) {
    if (!(await Filesystem.isDir(base))) return
    let entries: string[]
    try {
      entries = (await fs.readdir(base)).map((e) => path.join(base, e))
    } catch {
      return
    }
    for (const entry of entries) {
      const manifestPath = path.join(entry, ".claude-plugin", "plugin.json")
      if (await Filesystem.exists(manifestPath)) {
        roots.push(entry)
      } else {
        // Gizzi cache nests: cache/<marketplace>/<name>/<version>/
        try {
          const sub = await fs.readdir(entry)
          for (const s of sub) {
            const s2 = path.join(entry, s)
            const m2 = path.join(s2, ".claude-plugin", "plugin.json")
            if (await Filesystem.exists(m2)) {
              roots.push(s2)
            } else {
              // one more level for versioned dirs
              try {
                const sub2 = await fs.readdir(s2)
                for (const v of sub2) {
                  const vDir = path.join(s2, v)
                  const m3 = path.join(vDir, ".claude-plugin", "plugin.json")
                  if (await Filesystem.exists(m3)) roots.push(vDir)
                }
              } catch {}
            }
          }
        } catch {}
      }
    }
  }

  await scanDir(gizziPluginDir())
  await scanDir(claudePluginDir())

  // Also scan Gizzi marketplace listings: ~/.claude/plugins/marketplaces/<mktplace>/plugins/<name>/
  const marketplacesBase = claudeMarketplaceDir()
  if (await Filesystem.isDir(marketplacesBase)) {
    try {
      for (const marketplace of await fs.readdir(marketplacesBase)) {
        const pluginsDir = path.join(marketplacesBase, marketplace, "plugins")
        await scanDir(pluginsDir)
      }
    } catch {}
  }

  return [...new Set(roots)]
}

// ── Single plugin loader ──────────────────────────────────────────────────────

export async function loadPlugin(root: string): Promise<LoadedPlugin | null> {
  const manifestPath = path.join(root, ".claude-plugin", "plugin.json")
  let manifest: PluginManifest

  try {
    const raw = await fs.readFile(manifestPath, "utf8")
    manifest = JSON.parse(raw)
  } catch (e) {
    log.error("failed to read plugin manifest", { root, error: e })
    return null
  }

  log.info("loading claude plugin", { name: manifest.name, root })

  const [commands, skills, hooksConfig, mcpServers] = await Promise.all([
    loadCommands(root, manifest),
    loadSkills(root, manifest),
    loadHooks(root, manifest),
    loadMcp(root, manifest),
  ])

  return { manifest, root, commands, skills, hooksConfig, mcpServers }
}

// ── Commands (commands/*.md) ──────────────────────────────────────────────────

async function loadCommands(root: string, manifest: PluginManifest): Promise<LoadedCommand[]> {
  const cmdPaths = resolvePaths(root, manifest.commands, "commands")
  const commands: LoadedCommand[] = []

  for (const dir of cmdPaths) {
    if (!(await Filesystem.isDir(dir))) continue
    let files: string[]
    try {
      files = (await fs.readdir(dir)).filter((f) => f.endsWith(".md")).map((f) => path.join(dir, f))
    } catch {
      continue
    }

    for (const file of files) {
      const cmd = await parseCommand(file, manifest.name)
      if (cmd) commands.push(cmd)
    }
  }

  return commands
}

async function parseCommand(filePath: string, pluginName: string): Promise<LoadedCommand | null> {
  try {
    const md = await ConfigMarkdown.parse(filePath)
    const fm = md.data as CommandFrontmatter
    const name = path.basename(filePath, ".md")

    const allowedTools = fm["allowed-tools"]
      ? Array.isArray(fm["allowed-tools"])
        ? fm["allowed-tools"]
        : fm["allowed-tools"].split(/[\s,]+/).filter(Boolean)
      : undefined

    return {
      name,
      description: fm.description,
      template: md.content.trim(),
      allowedTools,
      argumentHint: fm["argument-hint"],
      model: fm.model,
      source: filePath,
      pluginName,
    }
  } catch (e) {
    log.error("failed to parse command", { file: filePath, error: e })
    return null
  }
}

// ── Skills (skills/*/SKILL.md) ────────────────────────────────────────────────

async function loadSkills(root: string, manifest: PluginManifest): Promise<LoadedSkill[]> {
  const skillsRoot = path.join(root, "skills")
  const skills: LoadedSkill[] = []
  if (!(await Filesystem.isDir(skillsRoot))) return skills

  let entries: string[]
  try {
    entries = (await fs.readdir(skillsRoot)).map((e) => path.join(skillsRoot, e))
  } catch {
    return skills
  }

  for (const entry of entries) {
    const skillMd = path.join(entry, "SKILL.md")
    if (!(await Filesystem.exists(skillMd))) continue

    try {
      const md = await ConfigMarkdown.parse(skillMd)
      const fm = md.data as SkillFrontmatter
      if (!fm.name || !fm.description) continue

      skills.push({
        name: fm.name,
        description: fm.description,
        content: md.content.trim(),
        location: skillMd,
        pluginName: manifest.name,
      })
    } catch (e) {
      log.error("failed to parse skill", { file: skillMd, error: e })
    }
  }

  return skills
}

// ── Hooks (hooks/hooks.json) ──────────────────────────────────────────────────

async function loadHooks(root: string, manifest: PluginManifest): Promise<HooksConfig | null> {
  if (!manifest.hooks) {
    const defaultPath = path.join(root, "hooks", "hooks.json")
    if (!(await Filesystem.exists(defaultPath))) return null
    return parseHooksFile(defaultPath)
  }

  if (typeof manifest.hooks === "string") {
    const resolved = path.resolve(root, manifest.hooks)
    return parseHooksFile(resolved)
  }

  return manifest.hooks as HooksConfig
}

async function parseHooksFile(filePath: string): Promise<HooksConfig | null> {
  try {
    const raw = await fs.readFile(filePath, "utf8")
    return JSON.parse(raw) as HooksConfig
  } catch (e) {
    log.error("failed to parse hooks config", { file: filePath, error: e })
    return null
  }
}

// ── MCP Servers (.mcp.json) ───────────────────────────────────────────────────

async function loadMcp(root: string, manifest: PluginManifest): Promise<Record<string, McpServerConfig>> {
  if (!manifest.mcpServers) {
    const defaultPath = path.join(root, ".mcp.json")
    if (!(await Filesystem.exists(defaultPath))) return {}
    return parseMcpFile(defaultPath, root)
  }

  if (typeof manifest.mcpServers === "string") {
    const resolved = path.resolve(root, manifest.mcpServers)
    return parseMcpFile(resolved, root)
  }

  return expandMcpVars(manifest.mcpServers as Record<string, McpServerConfig>, root)
}

async function parseMcpFile(filePath: string, root: string): Promise<Record<string, McpServerConfig>> {
  try {
    const raw = await fs.readFile(filePath, "utf8")
    return expandMcpVars(JSON.parse(raw), root)
  } catch (e) {
    log.error("failed to parse mcp config", { file: filePath, error: e })
    return {}
  }
}

function expandMcpVars(servers: Record<string, McpServerConfig>, root: string): Record<string, McpServerConfig> {
  const out: Record<string, McpServerConfig> = {}
  for (const [name, server] of Object.entries(servers)) {
    out[name] = expandVarsInObject(server, root)
  }
  return out
}

// ── Helpers ───────────────────────────────────────────────────────────────────

function resolvePaths(root: string, field: string | string[] | undefined, defaultDir: string): string[] {
  if (!field) return [path.join(root, defaultDir)]
  const raw = Array.isArray(field) ? field : [field]
  return raw.map((p) => path.resolve(root, p))
}

function expandVars(str: string, root: string): string {
  return str
    .replace(/\$\{CLAUDE_PLUGIN_ROOT\}/g, root)
    .replace(/\$CLAUDE_PLUGIN_ROOT/g, root)
    .replace(/\$\{CLAUDE_PROJECT_DIR\}/g, process.cwd())
    .replace(/\$CLAUDE_PROJECT_DIR/g, process.cwd())
}

function expandVarsInObject<T>(obj: T, root: string): T {
  if (typeof obj === "string") return expandVars(obj, root) as unknown as T
  if (Array.isArray(obj)) return obj.map((v) => expandVarsInObject(v, root)) as unknown as T
  if (obj !== null && typeof obj === "object") {
    const out: Record<string, unknown> = {}
    for (const [k, v] of Object.entries(obj as Record<string, unknown>)) {
      out[k] = expandVarsInObject(v, root)
    }
    return out as T
  }
  return obj
}

// ── All plugins ───────────────────────────────────────────────────────────────

let _cache: LoadedPlugin[] | null = null
let _cacheTime = 0
const CACHE_TTL = 30_000 // 30s

export async function all(force = false): Promise<LoadedPlugin[]> {
  if (_cache && !force && Date.now() - _cacheTime < CACHE_TTL) return _cache
  const roots = await discoverPluginRoots()
  const loaded = (await Promise.all(roots.map(loadPlugin))).filter(Boolean) as LoadedPlugin[]
  _cache = loaded
  _cacheTime = Date.now()
  log.info("loaded claude plugins", { count: loaded.length, names: loaded.map((p) => p.manifest.name) })
  return loaded
}

/** Only the bundled knowledge-work plugins shipped with gizzi-code */
let _builtinCache: LoadedPlugin[] | null = null

export async function allBuiltin(force = false): Promise<LoadedPlugin[]> {
  if (_builtinCache && !force) return _builtinCache
  const dir = builtinPluginsDir()
  if (!(await Filesystem.isDir(dir))) return []
  const entries = await fs.readdir(dir).catch(() => [] as string[])
  const roots = (
    await Promise.all(
      entries.map(async (e) => {
        const pluginDir = path.join(dir, e)
        const manifest = path.join(pluginDir, ".claude-plugin", "plugin.json")
        return (await Filesystem.exists(manifest)) ? pluginDir : null
      }),
    )
  ).filter(Boolean) as string[]
  const loaded = (await Promise.all(roots.map(loadPlugin))).filter(Boolean) as LoadedPlugin[]
  _builtinCache = loaded
  log.info("loaded builtin plugins", { count: loaded.length, names: loaded.map((p) => p.manifest.name) })
  return loaded
}

export function invalidate() {
  _cache = null
  _builtinCache = null
}
