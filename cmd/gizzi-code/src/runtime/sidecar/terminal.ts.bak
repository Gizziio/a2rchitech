import fs from "fs/promises"
import path from "path"
import { spawn, type IPty } from "bun-pty"
import { Global } from "@/runtime/context/global/global"
import { Filesystem } from "@/runtime/util/filesystem"
import { Log } from "@/runtime/util/log"

type SessionStatus = "running" | "exited" | "closed"
type ConnectionState = "connected" | "disconnected"
type AccessMode = "read_only" | "read_write"

type SessionInfo = {
  session_id: string
  owner_id: string
  writer_client_id: string | null
  connected_clients: number
  shell: string
  cols: number
  rows: number
  workdir: string | null
  status: SessionStatus
  connection_state: ConnectionState
  exit_code: number | null
  created_at: string
  updated_at: string
  last_activity: string
  disconnected_at: string | null
  log_path: string
}

type SnapshotState = {
  snapshot: string
  cols: number
  rows: number
  updated_at: string
  log_offset: number
}

type ActiveSession = {
  info: SessionInfo
  pty: IPty
}

type CreateSessionInput = {
  session_id: string
  owner_id: string
  shell?: string
  cols: number
  rows: number
  env?: Record<string, string>
  workdir?: string | null
}

const log = Log.create({ service: "terminal-sidecar" })
const sessions = new Map<string, ActiveSession>()
const BUFFER_LIMIT = 256 * 1024
const RECONNECTION_WINDOW_SECONDS = 300
const IDLE_TIMEOUT_SECONDS = 30 * 60
const WARNING_WINDOW_SECONDS = 5 * 60

const paths = {
  get root() {
    return path.join(Global.Path.data, "terminal-sidecar")
  },
  get sessions() {
    return path.join(this.root, "sessions")
  },
  get logs() {
    return path.join(this.root, "logs")
  },
  get snapshots() {
    return path.join(this.root, "snapshots")
  },
  get audit() {
    return path.join(this.root, "audit.log")
  },
}

function nowIso() {
  return new Date().toISOString()
}

function shellDefault() {
  return process.env.SHELL || "/bin/bash"
}

function modeValue(mode: AccessMode) {
  return mode === "read_write" ? "write" : "read"
}

function metadataPath(sessionID: string) {
  return path.join(paths.sessions, `${sessionID}.json`)
}

function logPath(sessionID: string) {
  return path.join(paths.logs, `${sessionID}.log`)
}

function snapshotPath(sessionID: string) {
  return path.join(paths.snapshots, `${sessionID}.json`)
}

async function ensureDirs() {
  await fs.mkdir(paths.sessions, { recursive: true })
  await fs.mkdir(paths.logs, { recursive: true })
  await fs.mkdir(paths.snapshots, { recursive: true })
}

async function persist(info: SessionInfo) {
  await ensureDirs()
  await Filesystem.writeJson(metadataPath(info.session_id), info)
}

async function audit(event: string, info: SessionInfo, details?: Record<string, unknown> | null, clientID?: string | null) {
  await ensureDirs()
  await Filesystem.append(
    paths.audit,
    JSON.stringify({
      ts: nowIso(),
      event,
      session_id: info.session_id,
      owner_id: info.owner_id,
      client_id: clientID ?? null,
      details: details ?? null,
    }) + "\n",
  )
}

async function readTail(filepath: string, maxBytes = BUFFER_LIMIT) {
  try {
    const fh = await fs.open(filepath, "r")
    try {
      const stat = await fh.stat()
      const size = Number(stat.size)
      const start = Math.max(0, size - maxBytes)
      const length = size - start
      if (length <= 0) return ""
      const buffer = Buffer.alloc(length)
      await fh.read(buffer, 0, length, start)
      return buffer.toString("utf8")
    } finally {
      await fh.close()
    }
  } catch {
    return ""
  }
}

async function readFromOffset(filepath: string, offset: number) {
  try {
    const fh = await fs.open(filepath, "r")
    try {
      const stat = await fh.stat()
      const size = Number(stat.size)
      const start = Math.max(0, Math.min(offset, size))
      const length = size - start
      if (length <= 0) return ""
      const buffer = Buffer.alloc(length)
      await fh.read(buffer, 0, length, start)
      return buffer.toString("utf8")
    } finally {
      await fh.close()
    }
  } catch {
    return ""
  }
}

async function logSize(filepath: string) {
  try {
    const stat = await fs.stat(filepath)
    return Number(stat.size)
  } catch {
    return 0
  }
}

async function readSnapshot(sessionID: string): Promise<SnapshotState | null> {
  try {
    return await Filesystem.readJson<SnapshotState>(snapshotPath(sessionID))
  } catch {
    return null
  }
}

async function persistSnapshot(sessionID: string, snapshot: SnapshotState) {
  await ensureDirs()
  await Filesystem.writeJson(snapshotPath(sessionID), snapshot)
}

async function clearSnapshot(sessionID: string) {
  try {
    await fs.rm(snapshotPath(sessionID), { force: true })
  } catch {}
}

function idleSeconds(info: SessionInfo) {
  return Math.floor((Date.now() - Date.parse(info.last_activity)) / 1000)
}

async function existing(sessionID: string) {
  const active = sessions.get(sessionID)?.info
  if (active) return active
  try {
    return await Filesystem.readJson<SessionInfo>(metadataPath(sessionID))
  } catch {
    return null
  }
}

function requireActive(sessionID: string) {
  const session = sessions.get(sessionID)
  if (!session) throw new Error(`terminal session '${sessionID}' not found`)
  return session
}

async function update(session: ActiveSession, patch: Partial<SessionInfo>) {
  session.info = {
    ...session.info,
    ...patch,
    updated_at: patch.updated_at ?? nowIso(),
  }
  await persist(session.info)
  return session.info
}

export namespace TerminalSidecar {
  export async function createSession(input: CreateSessionInput) {
    await ensureDirs()
    if (sessions.has(input.session_id)) {
      throw new Error(`terminal session '${input.session_id}' already exists`)
    }

    const sessionLogPath = logPath(input.session_id)
    await Filesystem.write(sessionLogPath, "")

    const shell = input.shell || shellDefault()
    const args = shell.endsWith("sh") ? ["-l"] : []
    const cwd = input.workdir?.trim() || process.cwd()
    const env = {
      ...process.env,
      ...(input.env || {}),
      TERM: "xterm-256color",
      COLORTERM: "truecolor",
      GIZZI_TERMINAL: "1",
      ALLTERNIT_TERMINAL_SIDECAR: "1",
    } as Record<string, string>

    const ptyProcess = spawn(shell, args, {
      name: "xterm-256color",
      cwd,
      env,
      cols: input.cols,
      rows: input.rows,
    })

    const created = nowIso()
    const info: SessionInfo = {
      session_id: input.session_id,
      owner_id: input.owner_id,
      writer_client_id: null,
      connected_clients: 0,
      shell,
      cols: input.cols,
      rows: input.rows,
      workdir: cwd,
      status: "running",
      connection_state: "disconnected",
      exit_code: null,
      created_at: created,
      updated_at: created,
      last_activity: created,
      disconnected_at: created,
      log_path: sessionLogPath,
    }

    const session: ActiveSession = { info, pty: ptyProcess }
    sessions.set(info.session_id, session)
    await persist(info)
    await audit("session_created", info)

    ptyProcess.onData((chunk) => {
      void Filesystem.append(sessionLogPath, chunk)
    })

    ptyProcess.onExit(({ exitCode }) => {
      const active = sessions.get(info.session_id)
      if (!active) return
      void update(active, {
        status: "exited",
        connection_state: "disconnected",
        exit_code: exitCode,
        disconnected_at: nowIso(),
      })
      void audit("session_exited", active.info, { exit_code: exitCode })
      sessions.delete(info.session_id)
    })

    return info
  }

  export async function listSessions() {
    return Array.from(sessions.values()).map((session) => session.info)
  }

  export async function getSession(sessionID: string) {
    return (await existing(sessionID)) || null
  }

  export async function write(sessionID: string, data: Uint8Array | number[]) {
    const session = requireActive(sessionID)
    const text = Buffer.from(data).toString("utf8")
    session.pty.write(text)
    await update(session, { last_activity: nowIso() })
    await audit("input", session.info, { bytes: Buffer.from(data).length })
  }

  export async function resize(sessionID: string, cols: number, rows: number) {
    const session = requireActive(sessionID)
    session.pty.resize(cols, rows)
    await update(session, { cols, rows, last_activity: nowIso() })
    await audit("resize", session.info, { cols, rows })
  }

  export async function keepalive(sessionID: string) {
    const session = requireActive(sessionID)
    await update(session, { last_activity: nowIso() })
  }

  export async function markConnected(sessionID: string, clientID: string, mode: AccessMode) {
    const session = requireActive(sessionID)
    const nextConnected = session.info.connected_clients + 1
    const writer =
      mode === "read_write" &&
      (!session.info.writer_client_id || session.info.writer_client_id === clientID)
        ? clientID
        : session.info.writer_client_id
    const info = await update(session, {
      connected_clients: nextConnected,
      connection_state: "connected",
      disconnected_at: null,
      writer_client_id: writer,
      last_activity: nowIso(),
    })
    await audit("session_connected", info, { mode: modeValue(mode) }, clientID)
    return info
  }

  export async function markDisconnected(sessionID: string, clientID?: string | null) {
    const session = requireActive(sessionID)
    const connected = Math.max(0, session.info.connected_clients - 1)
    const writerClient =
      clientID && session.info.writer_client_id === clientID ? null : session.info.writer_client_id
    const info = await update(session, {
      connected_clients: connected,
      connection_state: connected === 0 ? "disconnected" : session.info.connection_state,
      disconnected_at: connected === 0 ? nowIso() : session.info.disconnected_at,
      writer_client_id: writerClient,
    })
    await audit("session_disconnected", info, null, clientID ?? null)
    return info
  }

  export async function closeSession(sessionID: string) {
    const session = requireActive(sessionID)
    try {
      session.pty.kill()
    } catch {}
    await update(session, {
      status: "closed",
      connection_state: "disconnected",
      disconnected_at: nowIso(),
    })
    await audit("session_closed", session.info)
    await clearSnapshot(sessionID)
    sessions.delete(sessionID)
  }

  export async function updateSnapshot(sessionID: string, snapshot: string, cols: number, rows: number) {
    const info = await existing(sessionID)
    if (!info) throw new Error(`terminal session '${sessionID}' not found`)
    await persistSnapshot(sessionID, {
      snapshot,
      cols,
      rows,
      updated_at: nowIso(),
      log_offset: await logSize(info.log_path),
    })
    await audit("snapshot_updated", info, { cols, rows, chars: snapshot.length })
  }

  export async function canReconnect(sessionID: string) {
    const info = await existing(sessionID)
    if (!info) return false
    if (info.status !== "running" || info.connection_state !== "disconnected" || !info.disconnected_at) {
      return false
    }
    return Math.floor((Date.now() - Date.parse(info.disconnected_at)) / 1000) <= RECONNECTION_WINDOW_SECONDS
  }

  export async function verifyOwner(sessionID: string, ownerID: string) {
    const info = await existing(sessionID)
    if (!info) throw new Error(`terminal session '${sessionID}' not found`)
    if (info.owner_id !== ownerID) throw new Error(`terminal session '${sessionID}' belongs to a different owner`)
    return info
  }

  export async function canWrite(sessionID: string, clientID: string) {
    const info = await existing(sessionID)
    if (!info) return false
    return !info.writer_client_id || info.writer_client_id === clientID
  }

  export async function timeoutWarning(sessionID: string) {
    const info = await existing(sessionID)
    if (!info || info.status !== "running") return null
    const remaining = IDLE_TIMEOUT_SECONDS - idleSeconds(info)
    if (remaining > 0 && remaining <= WARNING_WINDOW_SECONDS) return remaining
    return null
  }

  export async function cleanupExpiredSessions() {
    const expired: string[] = []
    for (const [sessionID, session] of sessions.entries()) {
      if (
        session.info.status === "running" &&
        session.info.connection_state === "disconnected" &&
        idleSeconds(session.info) > IDLE_TIMEOUT_SECONDS
      ) {
        expired.push(sessionID)
      }
    }
    for (const sessionID of expired) {
      await closeSession(sessionID)
    }
    return expired
  }

  export async function health() {
    const values = Array.from(sessions.values()).map((session) => session.info)
    return {
      tmux_available: false,
      tmux_path: "sidecar:node-pty",
      backend_error: null,
      session_count: values.length,
      running_sessions: values.filter((info) => info.status === "running").length,
      stale_sessions: values.filter(
        (info) =>
          info.status === "running" &&
          info.connection_state === "disconnected" &&
          idleSeconds(info) > IDLE_TIMEOUT_SECONDS,
      ).length,
      state_dir: paths.root,
      audit_log_path: paths.audit,
    }
  }

  export async function subscribe(sessionID: string) {
    const info = await existing(sessionID)
    if (!info) throw new Error(`terminal session '${sessionID}' not found`)
    const snapshot = await readSnapshot(sessionID)
    const backlog = snapshot
      ? await readFromOffset(info.log_path, snapshot.log_offset)
      : await readTail(info.log_path)
    return {
      info,
      snapshot,
      backlog,
      log_path: info.log_path,
    }
  }

  export async function recordAuditEvent(
    sessionID: string,
    event: string,
    details: Record<string, unknown>,
    clientID?: string | null,
  ) {
    const info = await existing(sessionID)
    if (!info) throw new Error(`terminal session '${sessionID}' not found`)
    await audit(event, info, details, clientID ?? null)
  }
}
