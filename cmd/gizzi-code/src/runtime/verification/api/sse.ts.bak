/**
 * Server-Sent Events (SSE) Real-time Updates
 * 
 * Provides real-time verification progress and notifications.
 * Enterprise-friendly: works through any firewall/proxy.
 * 
 * Replaces WebSocket with HTTP-based SSE for unidirectional streaming.
 */

import { Log } from "@/runtime/util/log";
import type { VerificationProgress, OrchestratedVerificationResult } from "../types/types";

interface SSERequest {
  on(event: "close" | "error", listener: (error?: Error) => void): void;
  query: Record<string, unknown>;
  body: Record<string, unknown>;
}

interface SSEResponse {
  setHeader(name: string, value: string): void;
  write(chunk: string): void;
  end(): void;
  status(code: number): SSEResponse;
  json(value: unknown): void;
}

const log = Log.create({ service: "verification.sse" });

// ============================================================================
// Types
// ============================================================================

export interface SSEMessage {
  type: "progress" | "complete" | "error" | "alert" | "connected" | "ping";
  data: unknown;
  timestamp: string;
  sessionId?: string;
}

export interface ProgressUpdate extends VerificationProgress {
  sessionId: string;
}

export interface VerificationComplete {
  sessionId: string;
  result: OrchestratedVerificationResult;
}

export interface VerificationAlert {
  level: "info" | "warning" | "error";
  message: string;
  sessionId?: string;
  verificationId?: string;
}

interface ClientConnection {
  id: string;
  response: SSEResponse;
  sessionIds: Set<string>;
  connectedAt: number;
  lastPing: number;
}

// ============================================================================
// SSE Manager
// ============================================================================

export class VerificationSSEManager {
  private clients: Map<string, ClientConnection> = new Map();
  private sessionSubscriptions: Map<string, Set<string>> = new Map();
  private heartbeatInterval?: NodeJS.Timeout;
  private cleanupInterval?: NodeJS.Timeout;
  private log = Log.create({ service: "verification.sse" });
  
  /**
   * Initialize SSE manager
   */
  initialize(): void {
    // Start heartbeat to keep connections alive
    this.heartbeatInterval = setInterval(() => {
      this.sendHeartbeat();
    }, 30000); // Every 30 seconds
    
    // Start cleanup of stale connections
    this.cleanupInterval = setInterval(() => {
      this.cleanupStaleConnections();
    }, 60000); // Every minute
    
    this.log.info("SSE manager initialized");
  }
  
  /**
   * Handle new SSE connection
   */
  handleConnection(req: SSERequest, res: SSEResponse): void {
    const clientId = this.generateClientId();
    
    // Set SSE headers
    res.setHeader("Content-Type", "text/event-stream");
    res.setHeader("Cache-Control", "no-cache");
    res.setHeader("Connection", "keep-alive");
    res.setHeader("X-Accel-Buffering", "no"); // Disable nginx buffering
    
    // Store client connection
    const connection: ClientConnection = {
      id: clientId,
      response: res,
      sessionIds: new Set(),
      connectedAt: Date.now(),
      lastPing: Date.now(),
    };
    
    this.clients.set(clientId, connection);
    
    this.log.info("SSE client connected", { clientId });
    
    // Send initial connection event
    this.sendEvent(clientId, {
      type: "connected",
      data: { clientId, message: "Connected to verification updates" },
      timestamp: new Date().toISOString(),
    });
    
    // Handle client disconnect
    req.on("close", () => {
      this.handleDisconnect(clientId);
    });
    
    req.on("error", (error?: Error) => {
      this.log.error("SSE connection error", { clientId, error });
      this.handleDisconnect(clientId);
    });
  }
  
  /**
   * Subscribe client to session updates
   */
  subscribeToSession(clientId: string, sessionId: string): void {
    const client = this.clients.get(clientId);
    if (!client) return;
    
    // Add to client's subscriptions
    client.sessionIds.add(sessionId);
    
    // Add to session's subscriber list
    if (!this.sessionSubscriptions.has(sessionId)) {
      this.sessionSubscriptions.set(sessionId, new Set());
    }
    this.sessionSubscriptions.get(sessionId)!.add(clientId);
    
    this.log.debug("Client subscribed to session", { clientId, sessionId });
    
    // Send confirmation
    this.sendEvent(clientId, {
      type: "connected",
      data: { sessionId, message: "Subscribed successfully" },
      timestamp: new Date().toISOString(),
      sessionId,
    });
  }
  
  /**
   * Unsubscribe client from session updates
   */
  unsubscribeFromSession(clientId: string, sessionId: string): void {
    const client = this.clients.get(clientId);
    if (client) {
      client.sessionIds.delete(sessionId);
    }
    
    const subscribers = this.sessionSubscriptions.get(sessionId);
    if (subscribers) {
      subscribers.delete(clientId);
      if (subscribers.size === 0) {
        this.sessionSubscriptions.delete(sessionId);
      }
    }
    
    this.log.debug("Client unsubscribed from session", { clientId, sessionId });
  }
  
  /**
   * Broadcast progress update
   */
  broadcastProgress(sessionId: string, progress: VerificationProgress): void {
    const message: SSEMessage = {
      type: "progress",
      data: { ...progress, sessionId },
      timestamp: new Date().toISOString(),
      sessionId,
    };
    
    this.broadcastToSession(sessionId, message);
  }
  
  /**
   * Broadcast completion
   */
  broadcastComplete(sessionId: string, result: OrchestratedVerificationResult): void {
    const message: SSEMessage = {
      type: "complete",
      data: { sessionId, result },
      timestamp: new Date().toISOString(),
      sessionId,
    };
    
    this.broadcastToSession(sessionId, message);
  }
  
  /**
   * Broadcast error
   */
  broadcastError(sessionId: string, error: Error): void {
    const message: SSEMessage = {
      type: "error",
      data: { sessionId, error: error.message },
      timestamp: new Date().toISOString(),
      sessionId,
    };
    
    this.broadcastToSession(sessionId, message);
  }
  
  /**
   * Send alert to specific client or all clients
   */
  sendAlert(alert: VerificationAlert, clientId?: string): void {
    const message: SSEMessage = {
      type: "alert",
      data: alert,
      timestamp: new Date().toISOString(),
      sessionId: alert.sessionId,
    };
    
    if (clientId) {
      this.sendEvent(clientId, message);
    } else {
      this.broadcast(message);
    }
  }
  
  /**
   * Get connection stats
   */
  getStats(): {
    totalClients: number;
    totalSubscriptions: number;
  } {
    return {
      totalClients: this.clients.size,
      totalSubscriptions: this.sessionSubscriptions.size,
    };
  }
  
  /**
   * Close all connections and cleanup
   */
  close(): void {
    // Close all client connections
    for (const [clientId, client] of this.clients) {
      try {
        client.response.end();
      } catch {
        // Ignore errors during cleanup
      }
    }
    
    this.clients.clear();
    this.sessionSubscriptions.clear();
    
    // Clear intervals
    if (this.heartbeatInterval) {
      clearInterval(this.heartbeatInterval);
    }
    if (this.cleanupInterval) {
      clearInterval(this.cleanupInterval);
    }
    
    this.log.info("SSE manager closed");
  }
  
  // ========================================================================
  // Private Methods
  // ========================================================================
  
  private sendEvent(clientId: string, message: SSEMessage): void {
    const client = this.clients.get(clientId);
    if (!client) return;
    
    try {
      // SSE format: event: type\ndata: json\n\n
      const eventName = message.type;
      const data = JSON.stringify(message);
      
      client.response.write(`event: ${eventName}\n`);
      client.response.write(`data: ${data}\n\n`);
      
      // Update last ping
      client.lastPing = Date.now();
    } catch (error) {
      this.log.error("Failed to send SSE event", { clientId, error });
      this.handleDisconnect(clientId);
    }
  }
  
  private broadcastToSession(sessionId: string, message: SSEMessage): void {
    const subscribers = this.sessionSubscriptions.get(sessionId);
    if (!subscribers) return;
    
    for (const clientId of subscribers) {
      this.sendEvent(clientId, message);
    }
  }
  
  private broadcast(message: SSEMessage): void {
    for (const clientId of this.clients.keys()) {
      this.sendEvent(clientId, message);
    }
  }
  
  private sendHeartbeat(): void {
    const pingMessage: SSEMessage = {
      type: "ping",
      data: { timestamp: Date.now() },
      timestamp: new Date().toISOString(),
    };
    
    for (const clientId of this.clients.keys()) {
      this.sendEvent(clientId, pingMessage);
    }
  }
  
  private cleanupStaleConnections(): void {
    const now = Date.now();
    const STALE_THRESHOLD = 2 * 60 * 1000; // 2 minutes
    
    for (const [clientId, client] of this.clients) {
      if (now - client.lastPing > STALE_THRESHOLD) {
        this.log.warn("Cleaning up stale connection", { clientId });
        this.handleDisconnect(clientId);
      }
    }
  }
  
  private handleDisconnect(clientId: string): void {
    const client = this.clients.get(clientId);
    if (!client) return;
    
    // Remove from all session subscriptions
    for (const sessionId of client.sessionIds) {
      const subscribers = this.sessionSubscriptions.get(sessionId);
      if (subscribers) {
        subscribers.delete(clientId);
        if (subscribers.size === 0) {
          this.sessionSubscriptions.delete(sessionId);
        }
      }
    }
    
    // Remove client
    this.clients.delete(clientId);
    
    // Close response if not already closed
    try {
      client.response.end();
    } catch {
      // Ignore errors
    }
    
    this.log.info("SSE client disconnected", { clientId });
  }
  
  private generateClientId(): string {
    return `sse_${Date.now()}_${Math.random().toString(36).slice(2, 9)}`;
  }
}

// ============================================================================
// Singleton Instance
// ============================================================================

let sseManager: VerificationSSEManager | null = null;

export function getSSEManager(): VerificationSSEManager {
  if (!sseManager) {
    sseManager = new VerificationSSEManager();
  }
  return sseManager;
}

export function initializeSSEManager(): void {
  getSSEManager().initialize();
}

export function closeSSEManager(): void {
  sseManager?.close();
  sseManager = null;
}

// ============================================================================
// Express Route Handler
// ============================================================================

/**
 * Express route handler for SSE endpoint
 * 
 * Usage:
 * ```typescript
 * app.get('/api/v1/verification/stream', sseStreamHandler);
 * ```
 */
export function sseStreamHandler(req: SSERequest, res: SSEResponse): void {
  const manager = getSSEManager();
  manager.handleConnection(req, res);
  
  // Handle subscription query param
  const sessionId = req.query.sessionId as string;
  if (sessionId) {
    // Client ID will be assigned during handleConnection
    // We need to get it from the manager after connection
    const clientId = Array.from(manager["clients"].keys()).pop();
    if (clientId) {
      manager.subscribeToSession(clientId, sessionId);
    }
  }
}

/**
 * Express route handler for subscribing to sessions
 * 
 * Usage:
 * ```typescript
 * app.post('/api/v1/verification/subscribe', sseSubscribeHandler);
 * ```
 */
export function sseSubscribeHandler(req: SSERequest, res: SSEResponse): void {
  const clientId = typeof req.body.clientId === "string" ? req.body.clientId : "";
  const sessionId = typeof req.body.sessionId === "string" ? req.body.sessionId : "";
  
  if (!clientId || !sessionId) {
    res.status(400).json({ error: "clientId and sessionId required" });
    return;
  }
  
  const manager = getSSEManager();
  manager.subscribeToSession(clientId, sessionId);
  
  res.json({ success: true, message: "Subscribed successfully" });
}

// Re-export types for backward compatibility
export type { VerificationProgress, OrchestratedVerificationResult } from "../types/types";
