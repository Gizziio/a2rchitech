import { createPublicKey, verify } from "crypto"
import path from "path"
import z from "zod/v4"
import { Global } from "@/runtime/context/global/global"
import { Filesystem } from "@/runtime/util/filesystem"
import { Instance } from "@/runtime/context/project/instance"

export const SkillSummarySchema = z.object({
  id: z.string(),
  name: z.string(),
  version: z.string(),
  description: z.string(),
  tags: z.array(z.string()),
  author: z.string(),
  risk_tier: z.string(),
  downloads: z.number(),
  package_url: z.string().optional(),
  status: z.string().optional(),
})

export const SkillManifestRecordSchema = z.object({
  summary: SkillSummarySchema,
  manifest: z.record(z.string(), z.any()),
  signature: z.string(),
  published_at: z.number(),
})

export type SkillSummary = z.infer<typeof SkillSummarySchema>
export type SkillManifestRecord = z.infer<typeof SkillManifestRecordSchema>

function registryRoot() {
  return path.join(Global.Path.data, "skill-registry")
}

function manifestsDir() {
  return path.join(registryRoot(), "manifests")
}

function installsDir() {
  return path.join(registryRoot(), "installs")
}

function manifestKey(id: string, version: string) {
  return `${id}@${version}`
}

function manifestPath(id: string, version: string) {
  return path.join(manifestsDir(), `${manifestKey(id, version)}.json`)
}

function installReceiptPath(id: string, version: string) {
  return path.join(installsDir(), `${manifestKey(id, version)}-${Date.now()}.json`)
}

function stableStringify(value: unknown): string {
  if (value === null || typeof value !== "object") return JSON.stringify(value)
  if (Array.isArray(value)) return `[${value.map((item) => stableStringify(item)).join(",")}]`
  const entries = Object.entries(value as Record<string, unknown>).sort(([a], [b]) => a.localeCompare(b))
  return `{${entries.map(([k, v]) => `${JSON.stringify(k)}:${stableStringify(v)}`).join(",")}}`
}

function signingPayload(manifest: Record<string, any>, packageUrl: string) {
  return stableStringify({ manifest, package_url: packageUrl })
}

function summaryFromManifest(manifest: Record<string, any>, package_url?: string, status?: string, downloads = 0): SkillSummary {
  return SkillSummarySchema.parse({
    id: String(manifest.id ?? manifest.name ?? `skill-${Date.now()}`),
    name: String(manifest.name ?? manifest.id ?? "unnamed-skill"),
    version: String(manifest.version ?? "0.0.0"),
    description: String(manifest.description ?? ""),
    tags: Array.isArray(manifest.tags) ? manifest.tags.map(String) : [],
    author: String(manifest.author ?? "unknown"),
    risk_tier: String(manifest.risk_tier ?? "unknown"),
    downloads,
    package_url,
    status,
  })
}

function manifestToSkillMarkdown(summary: SkillSummary, manifest: Record<string, any>) {
  const content =
    typeof manifest.content === "string" ? manifest.content : `# ${summary.name}\n\nInstalled from ${summary.package_url ?? "registry"}`
  return [
    "---",
    `name: ${summary.name}`,
    `description: ${summary.description || summary.name}`,
    "---",
    "",
    content.trim(),
    "",
  ].join("\n")
}

async function readManifest(filePath: string) {
  return Filesystem.readJson<SkillManifestRecord>(filePath).catch(() => null)
}

export namespace SkillRegistryService {
  export const MissingVerificationKeyError = new Error("SKILL_REGISTRY_PUBLIC_KEY is not configured")
  export const InvalidSignatureError = new Error("Skill signature verification failed")

  export async function list() {
    if (!(await Filesystem.exists(manifestsDir()))) return [] as SkillManifestRecord[]
    const entries = await Filesystem.list(manifestsDir())
    const records = await Promise.all(
      entries
        .filter((entry) => entry.isFile && entry.name.endsWith(".json"))
        .map((entry) => readManifest(path.join(manifestsDir(), entry.name))),
    )
    return records.filter((record): record is SkillManifestRecord => !!record).sort((a, b) => b.published_at - a.published_at)
  }

  export async function summaries() {
    return (await list()).map((record) => record.summary)
  }

  export async function get(id: string, version?: string) {
    const records = await list()
    return records.find((record) => record.summary.id === id && (!version || record.summary.version === version))
  }

  export function verifySignature(manifest: Record<string, any>, packageUrl: string, signature: string) {
    const publicKeyPem = process.env.SKILL_REGISTRY_PUBLIC_KEY
    if (!publicKeyPem) throw MissingVerificationKeyError

    const key = createPublicKey(publicKeyPem)
    const payload = Buffer.from(signingPayload(manifest, packageUrl))
    const signatureBuffer = Buffer.from(signature, "base64")
    const ok = verify(null, payload, key, signatureBuffer)
    if (!ok) throw InvalidSignatureError
  }

  export async function publish(input: { manifest: Record<string, any>; packageUrl: string; signature: string }) {
    verifySignature(input.manifest, input.packageUrl, input.signature)
    const existing = await get(String(input.manifest.id ?? input.manifest.name ?? ""), String(input.manifest.version ?? "0.0.0"))
    const downloads = existing?.summary.downloads ?? 0
    const summary = summaryFromManifest(input.manifest, input.packageUrl, "published", downloads)
    const record: SkillManifestRecord = {
      summary,
      manifest: input.manifest,
      signature: input.signature,
      published_at: Date.now(),
    }
    await Filesystem.mkdir(manifestsDir())
    await Filesystem.writeJson(manifestPath(summary.id, summary.version), record)
    return record
  }

  export async function install(input: { id: string; version?: string }) {
    const record = await get(input.id, input.version)
    if (!record) return null

    const next: SkillManifestRecord = {
      ...record,
      summary: {
        ...record.summary,
        downloads: record.summary.downloads + 1,
      },
    }
    await Filesystem.writeJson(manifestPath(next.summary.id, next.summary.version), next)

    const dir = path.join(Instance.directory, ".gizzi", "skills", next.summary.name)
    await Filesystem.mkdir(dir)
    await Filesystem.write(path.join(dir, "SKILL.md"), manifestToSkillMarkdown(next.summary, next.manifest))

    await Filesystem.mkdir(installsDir())
    await Filesystem.writeJson(
      installReceiptPath(next.summary.id, next.summary.version),
      {
        id: next.summary.id,
        version: next.summary.version,
        installed_at: Date.now(),
        workspace: Instance.directory,
      },
    )

    return next.summary
  }
}
