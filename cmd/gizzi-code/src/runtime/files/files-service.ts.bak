import { createHash } from "crypto"
import path from "path"
import { ulid } from "ulid"
import { Global } from "@/runtime/context/global/global"
import { Instance } from "@/runtime/context/project/instance"
import { Filesystem } from "@/runtime/util/filesystem"

export interface StoredFile {
  id: string
  filename: string
  created_at: number
  size: number
  media_type: string
  storage_uri: string
  content_hash: string
}

function projectKey(directory: string): string {
  return createHash("sha256").update(directory).digest("hex").slice(0, 16)
}

function rootDir() {
  return path.join(Global.Path.data, "files", projectKey(Instance.directory))
}

function metadataPath(id: string) {
  return path.join(rootDir(), `${id}.json`)
}

function contentPath(id: string, filename: string) {
  return path.join(rootDir(), `${id}${path.extname(filename)}`)
}

async function readMetadata(filePath: string): Promise<StoredFile | null> {
  return Filesystem.readJson<StoredFile>(filePath).catch(() => null)
}

export namespace FilesService {
  export async function list(): Promise<StoredFile[]> {
    if (!(await Filesystem.exists(rootDir()))) return []
    const entries = await Filesystem.list(rootDir())
    const files = await Promise.all(
      entries
        .filter((entry) => entry.isFile && entry.name.endsWith(".json"))
        .map((entry) => readMetadata(path.join(rootDir(), entry.name))),
    )
    return files
      .filter((entry): entry is StoredFile => !!entry)
      .sort((a, b) => b.created_at - a.created_at)
  }

  export async function get(id: string): Promise<StoredFile | null> {
    return readMetadata(metadataPath(id))
  }

  export async function save(input: {
    bytes: Uint8Array
    filename: string
    mediaType?: string
  }): Promise<StoredFile> {
    const id = `file_${ulid().toLowerCase()}`
    const filename = path.basename(input.filename || "upload.bin")
    const storagePath = contentPath(id, filename)
    const record: StoredFile = {
      id,
      filename,
      created_at: Date.now(),
      size: input.bytes.byteLength,
      media_type: input.mediaType || Filesystem.mimeType(filename),
      storage_uri: storagePath,
      content_hash: createHash("sha256").update(input.bytes).digest("hex"),
    }

    await Filesystem.mkdir(rootDir())
    await Filesystem.write(storagePath, input.bytes)
    await Filesystem.writeJson(metadataPath(id), record)
    return record
  }

  export async function remove(id: string): Promise<boolean> {
    const record = await get(id)
    if (!record) return false
    await Bun.file(record.storage_uri).delete().catch(() => {})
    await Bun.file(metadataPath(id)).delete().catch(() => {})
    return true
  }
}
