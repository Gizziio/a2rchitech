import z from "zod/v4"
import { Tool } from "@/runtime/tools/builtins/tool"
import { MemoryService, type MemoryEntry, type MemoryType } from "@/runtime/memory/memory-service"

function tierToType(tier?: "working" | "episodic" | "long_term"): MemoryType | undefined {
  if (tier === "episodic") return "project"
  if (tier === "long_term") return "reference"
  return undefined
}

function slugFromContent(content: string) {
  const slug = content
    .toLowerCase()
    .replace(/[^a-z0-9\s_-]/g, "")
    .trim()
    .split(/\s+/)
    .slice(0, 6)
    .join("_")
  return slug || `memory_${Date.now()}`
}

function summarize(entries: MemoryEntry[]) {
  return JSON.stringify(
    {
      content: entries.map((entry) => entry.body),
      entries: entries.map((entry) => ({
        name: entry.name,
        description: entry.description,
        type: entry.type,
        filename: entry.filename,
        filepath: entry.filepath,
      })),
    },
    null,
    2,
  )
}

export const MemoryReadTool = Tool.define("memory_read", {
  description: "Read memory entries relevant to a query from the in-process memory service.",
  parameters: z.object({
    query: z.string().describe("Keywords to search for in memory."),
    tier: z.enum(["working", "episodic", "long_term"]).optional(),
  }),
  async execute(params) {
    const type = tierToType(params.tier)
    const entries = await MemoryService.search(params.query)
    const filtered = type ? entries.filter((entry) => entry.type === type) : entries
    return {
      title: filtered.length ? `Memory read: ${filtered.length} match(es)` : "Memory read: no matches",
      output: summarize(filtered),
      metadata: { count: filtered.length, tier: params.tier },
    }
  },
})

export const MemoryWriteToolV2 = Tool.define("memory_write", {
  description: "Write a memory entry through the in-process memory service.",
  parameters: z.object({
    content: z.string().describe("Memory content to persist."),
    tier: z.enum(["episodic", "long_term"]).describe("Target memory tier."),
  }),
  async execute(params) {
    const type = tierToType(params.tier) ?? "project"
    const name = slugFromContent(params.content)
    const description = params.content.trim().slice(0, 120) || name
    const entry = await MemoryService.save(
      {
        name,
        description,
        type,
      },
      params.content,
    )
    return {
      title: `Memory stored: ${entry.filename}`,
      output: JSON.stringify({ stored: true, id: entry.filename, filepath: entry.filepath }, null, 2),
      metadata: { stored: true, filename: entry.filename, filepath: entry.filepath, type },
    }
  },
})
