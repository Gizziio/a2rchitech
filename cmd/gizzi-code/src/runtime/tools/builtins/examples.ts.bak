/**
 * Example Generation Tool
 * 
 * Detects when users request examples and automatically:
 * 1. Extracts code from agent responses
 * 2. Saves to files in .gizzi/examples/
 * 3. Opens files in default GUI application upon completion
 * 
 * Usage: User says things like:
 * - "show me examples of React hooks"
 * - "give me an example of a REST API"
 * - "create an example HTML page"
 * - "demonstrate how to use X"
 */

import path from "path"
import { unlink } from "fs/promises"
import { Filesystem } from "@/runtime/util/filesystem"
import { Instance } from "@/runtime/context/project/instance"
import { Global } from "@/runtime/context/global/global"
import { Log } from "@/runtime/util/log"
import { extractCodeBlocks } from "@/runtime/util/code-blocks"
import open from "open"

const log = Log.create({ service: "examples" })

// Intent patterns that suggest user wants examples
const EXAMPLE_INTENT_PATTERNS = [
  /show\s+me\s+(an?\s+)?example/i,
  /give\s+me\s+(an?\s+)?example/i,
  /create\s+(an?\s+)?example/i,
  /demonstrate\s+how\s+to/i,
  /show\s+me\s+how\s+to/i,
  /can\s+you\s+show/i,
  /i\s+want\s+to\s+see/i,
  /example\s+of/i,
  /examples\s+of/i,
  /sample\s+code/i,
  /code\s+sample/i,
  /template\s+for/i,
  /boilerplate/i,
]

export interface ExtractedExample {
  filename: string
  content: string
  language: string
  fullPath: string
}

/**
 * Check if user message indicates intent to see examples
 */
export function detectExampleIntent(message: string): boolean {
  return EXAMPLE_INTENT_PATTERNS.some((pattern) => pattern.test(message))
}

/**
 * Generate a filename based on content and language
 */
function generateFilename(content: string, language?: string): string {
  const timestamp = Date.now()
  
  // Try to extract a descriptive name from the content
  const classMatch = content.match(/class\s+(\w+)/)
  const functionMatch = content.match(/function\s+(\w+)/)
  const componentMatch = content.match(/(?:export\s+)?(?:default\s+)?(?:function|const)\s+(\w+)/)
  
  let name = "example"
  if (classMatch) name = classMatch[1]
  else if (functionMatch) name = functionMatch[1]
  else if (componentMatch) name = componentMatch[1]
  
  // Map language to extension
  const extMap: Record<string, string> = {
    typescript: "ts",
    javascript: "js",
    python: "py",
    rust: "rs",
    go: "go",
    java: "java",
    html: "html",
    css: "css",
    json: "json",
    yaml: "yml",
    markdown: "md",
    bash: "sh",
    sql: "sql",
  }
  
  const ext = language && extMap[language] ? extMap[language] : "txt"
  return `${name.toLowerCase()}-${timestamp}.${ext}`
}

/**
 * Get the examples directory for the current project
 */
async function getExamplesDirectory(): Promise<string> {
  try {
    const worktree = Instance.worktree
    const examplesDir = path.join(worktree, ".gizzi", "examples")
    await Filesystem.mkdir(examplesDir, { recursive: true })
    return examplesDir
  } catch {
    // Fallback to global data directory
    const examplesDir = path.join(Global.Path.data, "examples")
    await Filesystem.mkdir(examplesDir, { recursive: true })
    return examplesDir
  }
}

/**
 * Extract examples from agent response and save to files
 */
export async function extractAndSaveExamples(
  responseText: string,
  options?: {
    prefix?: string
    openFiles?: boolean
  }
): Promise<ExtractedExample[]> {
  const examplesDir = await getExamplesDirectory()
  const codeBlocks = extractCodeBlocks(responseText)
  const saved: ExtractedExample[] = []
  
  for (const block of codeBlocks) {
    const filename = generateFilename(block.code, block.language)
    const prefixedFilename = options?.prefix ? `${options.prefix}-${filename}` : filename
    const fullPath = path.join(examplesDir, prefixedFilename)
    
    await Filesystem.write(fullPath, block.code)
    
    saved.push({
      filename: prefixedFilename,
      content: block.code,
      language: block.language || "text",
      fullPath,
    })
    
    log.info("saved example", { filename: prefixedFilename, path: fullPath })
  }
  
  return saved
}

/**
 * Open files in default GUI applications
 */
export async function openExamples(examples: ExtractedExample[]): Promise<void> {
  for (const example of examples) {
    try {
      await open(example.fullPath)
      log.info("opened example", { filename: example.filename })
      
      // Small delay between opening files to avoid overwhelming the system
      await new Promise((resolve) => setTimeout(resolve, 500))
    } catch (err) {
      log.error("failed to open example", { filename: example.filename, error: err })
    }
  }
}

/**
 * Main function: process message and open examples when complete
 * Call this when an assistant message is completed
 */
export async function processExamples(
  userMessage: string,
  assistantResponse: string,
  options?: {
    openFiles?: boolean
    prefix?: string
  }
): Promise<ExtractedExample[]> {
  // Only process if user showed example intent
  if (!detectExampleIntent(userMessage)) {
    return []
  }
  
  const examples = await extractAndSaveExamples(assistantResponse, {
    prefix: options?.prefix,
    openFiles: false, // We'll open after saving
  })
  
  if (examples.length > 0 && options?.openFiles !== false) {
    await openExamples(examples)
  }
  
  return examples
}

/**
 * Get list of saved examples for the current project
 */
export async function listSavedExamples(): Promise<ExtractedExample[]> {
  const examplesDir = await getExamplesDirectory()
  
  try {
    const files = await Filesystem.list(examplesDir)
    const examples: ExtractedExample[] = []
    
    for (const file of files) {
      if (file.isFile) {
        const fullPath = path.join(examplesDir, file.name)
        const content = await Filesystem.readText(fullPath).catch(() => "")
        const ext = path.extname(file.name).slice(1)
        
        examples.push({
          filename: file.name,
          content,
          language: ext,
          fullPath,
        })
      }
    }
    
    // Sort by most recent
    return examples.sort((a, b) => {
      const aTime = a.filename.match(/-(\d+)\.\w+$/)?.[1] || "0"
      const bTime = b.filename.match(/-(\d+)\.\w+$/)?.[1] || "0"
      return parseInt(bTime) - parseInt(aTime)
    })
  } catch {
    return []
  }
}

/**
 * Clean up old examples (keep last 20)
 */
export async function cleanupOldExamples(keepCount: number = 20): Promise<void> {
  const examples = await listSavedExamples()
  
  if (examples.length > keepCount) {
    const toDelete = examples.slice(keepCount)
    
    for (const example of toDelete) {
      try {
        await unlink(example.fullPath)
        log.info("cleaned up old example", { filename: example.filename })
      } catch {
        // Ignore cleanup errors
      }
    }
  }
}
