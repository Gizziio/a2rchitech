import z from "zod/v4"
import { Tool } from "@/runtime/tools/builtins/tool"
import { BrowserTool } from "@/runtime/tools/builtins/browser"

const DESCRIPTION = `Run computer-use automation through the standard tool loop.`

export const ComputerUseTool = Tool.define("computer_use", async (initCtx) => {
  const browser = await BrowserTool.init(initCtx)

  return {
    description: DESCRIPTION,
    parameters: z.object({
      intent: z.string().describe("High-level description of what the computer-use run should accomplish."),
      mode: z.enum(["intent", "assist"]).default("intent").describe("Execution style for the run."),
    }),
    async execute(params: { intent: string; mode: "intent" | "assist" }, ctx) {
      return browser.execute(
        {
          action: "execute",
          goal: params.intent,
          parameters: { mode: params.mode },
          adapter_preference: params.mode === "assist" ? "desktop" : undefined,
        },
        ctx,
      )
    },
  }
})
