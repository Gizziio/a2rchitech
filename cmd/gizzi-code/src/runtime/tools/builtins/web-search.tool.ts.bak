import z from "zod/v4"
import { Tool } from "@/runtime/tools/builtins/tool"
import { WebSearchTool } from "@/runtime/tools/builtins/websearch"

const DESCRIPTION = `Search the web using a hosted search provider configured by SEARCH_PROVIDER_URL.`

const SearchResultSchema = z.object({
  title: z.string(),
  url: z.string(),
  snippet: z.string(),
  published_at: z.string().optional(),
})

function normalizeResults(payload: unknown) {
  if (!payload || typeof payload !== "object") return []
  const record = payload as Record<string, unknown>
  const raw = Array.isArray(record.results)
    ? record.results
    : Array.isArray(record.items)
      ? record.items
      : Array.isArray(record.organic)
        ? record.organic
        : []

  return raw
    .map((item) => {
      if (!item || typeof item !== "object") return undefined
      const value = item as Record<string, unknown>
      return {
        title: String(value.title ?? value.name ?? ""),
        url: String(value.url ?? value.link ?? ""),
        snippet: String(value.snippet ?? value.description ?? value.text ?? ""),
        published_at: value.published_at ? String(value.published_at) : undefined,
      }
    })
    .filter((item) => !!item && !!item.title && !!item.url)
}

export const HostedWebSearchTool = Tool.define("web_search", {
  description: DESCRIPTION,
  parameters: z.object({
    query: z.string(),
    max_results: z.number().default(5),
    allowed_domains: z.array(z.string()).optional(),
  }),
  async execute(params, ctx) {
    await ctx.ask({
      permission: "websearch",
      patterns: [params.query],
      always: ["*"],
      metadata: params,
    })

    const base = process.env.SEARCH_PROVIDER_URL
    if (base) {
      const url = new URL(base)
      url.searchParams.set("q", params.query)
      url.searchParams.set("limit", String(params.max_results))
      if (params.allowed_domains?.length) {
        url.searchParams.set("domains", params.allowed_domains.join(","))
      }

      const response = await fetch(url, {
        headers: { Accept: "application/json" },
        signal: ctx.abort,
      })
      if (!response.ok) {
        throw new Error(`Search provider request failed with status ${response.status}`)
      }

      const payload = await response.json().catch(() => ({}))
      const results = normalizeResults(payload).slice(0, params.max_results)
      return {
        title: `Web search: ${params.query}`,
        output: JSON.stringify({ results }, null, 2),
        metadata: { configured: true, count: results.length, provider: base },
      }
    }

    const fallback = await WebSearchTool.init()
    const result = await fallback.execute(
      {
        query: params.query,
        numResults: params.max_results,
        livecrawl: "fallback",
        type: "auto",
      },
      ctx,
    )
    return {
      title: `Web search: ${params.query}`,
      output: JSON.stringify(
        {
          results: [
            {
              title: params.query,
              url: "",
              snippet: result.output,
            },
          ],
          raw_output: result.output,
        },
        null,
        2,
      ),
      metadata: { configured: true, count: 1, provider: "exa-fallback" },
    }
  },
})
