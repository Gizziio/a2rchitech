import path from "path"
import { spawn } from "child_process"
import { existsSync } from "fs"
import z from "zod/v4"
import { Global } from "@/runtime/context/global/global"
import { Filesystem } from "@/runtime/util/filesystem"
import { Log } from "@/runtime/util/log"

const log = Log.create({ service: "computer-use-service" })

const ComputerUseArtifactSchema = z.object({
  type: z.enum(["screenshot", "download", "json", "text", "html"]),
  path: z.string().optional(),
  url: z.string().optional(),
  mime: z.string().optional(),
  content: z.string().optional(),
})

const ComputerUseReceiptSchema = z.object({
  action: z.string(),
  timestamp: z.string(),
  success: z.boolean(),
  details: z.record(z.string(), z.any()).optional(),
})

export const ComputerUseResponseSchema = z.object({
  run_id: z.string(),
  session_id: z.string(),
  adapter_id: z.string(),
  family: z.enum(["browser", "desktop", "retrieval", "hybrid"]),
  mode: z.enum(["assist", "execute", "inspect", "parallel", "desktop", "hybrid", "crawl"]),
  status: z.enum(["pending", "running", "needs_approval", "paused", "completed", "failed", "cancelled"]),
  summary: z.string().nullish(),
  extracted_content: z.any().nullish(),
  artifacts: z.array(ComputerUseArtifactSchema).default([]),
  receipts: z.array(ComputerUseReceiptSchema).default([]),
  error: z.object({
    code: z.string(),
    message: z.string(),
  }).nullish(),
  trace_id: z.string().nullish(),
})

const EngineEventRecordSchema = z.object({
  event_type: z.string(),
  timestamp: z.string(),
  data: z.record(z.string(), z.any()).optional(),
})

const EngineRunSchema = z.object({
  run_id: z.string(),
  session_id: z.string(),
  mode: z.string(),
  task: z.string(),
  target_scope: z.string().optional(),
  status: z.enum(["pending", "running", "needs_approval", "paused", "completed", "failed", "cancelled"]),
  created_at: z.string(),
  updated_at: z.string(),
  completed_at: z.string().optional(),
  summary: z.string().optional(),
  receipts: z.array(z.any()).default([]),
  artifacts: z.array(z.any()).default([]),
  result: z.any().optional(),
  error: z.record(z.string(), z.any()).optional(),
  events: z.array(EngineEventRecordSchema).default([]),
})

type EngineRun = z.infer<typeof EngineRunSchema>
type ComputerUseResponse = z.infer<typeof ComputerUseResponseSchema>

type LLMConfig =
  | { auth_type: "api_key"; base_url: string; api_key: string; model: string }
  | { auth_type: "none"; base_url: string; model: string }
  | { auth_type: "bearer"; base_url: string; token: string; model: string }
  | { auth_type: "subprocess"; subprocess_cmd: string; model: string }

type GatewayRequest = {
  action: string
  session_id: string
  run_id: string
  target?: string
  goal?: string
  parameters?: Record<string, any>
  adapter_preference?: string
  llm_config?: LLMConfig
}

function gatewayUrl() {
  return process.env.ALLTERNIT_COMPUTER_USE_URL || "http://localhost:3010"
}

function gatewayToken() {
  return process.env.ALLTERNIT_COMPUTER_USE_TOKEN || process.env.ALLTERNIT_OPERATOR_API_KEY
}

function runsRoot() {
  return path.join(Global.Path.data, "computer-use-runs")
}

function runPath(runID: string) {
  return path.join(runsRoot(), `${runID}.json`)
}

function nowISO() {
  return new Date().toISOString()
}

let operatorProc: ReturnType<typeof spawn> | null = null

function findOperatorDir(): string | null {
  if (process.env.ALLTERNIT_OPERATOR_PATH) return process.env.ALLTERNIT_OPERATOR_PATH
  const candidates = [
    path.join(process.cwd(), "domains/computer-use/service"),
    path.join(process.cwd(), "../domains/computer-use/service"),
    path.join(process.cwd(), "../../domains/computer-use/service"),
    path.join(process.cwd(), "../../../domains/computer-use/service"),
    path.join(process.cwd(), "services/operator/computer-use"),
    path.join(process.cwd(), "../services/operator/computer-use"),
    path.join(process.cwd(), "../../services/operator/computer-use"),
    path.join(process.cwd(), "../../../services/operator/computer-use"),
  ]
  return candidates.find(existsSync) ?? null
}

function findComputerUsePackageDir(operatorDir: string): string {
  const candidates = [
    path.join(operatorDir, "../../../packages/computer-use"),
    path.join(operatorDir, "../../../../packages/computer-use"),
    path.join(operatorDir, "../../packages/computer-use"),
    path.join(process.cwd(), "packages/computer-use"),
  ]
  return candidates.find(existsSync) ?? path.join(operatorDir, "../../../packages/computer-use")
}

async function waitForGateway(timeoutMs = 8000): Promise<boolean> {
  const deadline = Date.now() + timeoutMs
  while (Date.now() < deadline) {
    try {
      const response = await fetch(`${gatewayUrl()}/health`, {
        signal: AbortSignal.timeout(1000),
      })
      if (response.ok) return true
    } catch {}
    await new Promise((resolve) => setTimeout(resolve, 500))
  }
  return false
}

async function autoStartOperator(): Promise<boolean> {
  try {
    const response = await fetch(`${gatewayUrl()}/health`, {
      signal: AbortSignal.timeout(1500),
    })
    if (response.ok) return true
  } catch {}

  const operatorDir = findOperatorDir()
  if (!operatorDir) {
    log.warn("Cannot auto-start operator: service directory not found")
    return false
  }

  const computerUsePath =
    process.env.ALLTERNIT_COMPUTER_USE_PATH ??
    findComputerUsePackageDir(operatorDir)

  log.info("Auto-starting A2R Operator", { operatorDir })
  operatorProc = spawn(
    "python3",
    ["-m", "uvicorn", "src.main:app", "--host", "127.0.0.1", "--port", "3010", "--log-level", "warning"],
    {
      cwd: operatorDir,
      env: { ...process.env, ALLTERNIT_COMPUTER_USE_PATH: computerUsePath },
      stdio: "ignore",
      detached: true,
    },
  )
  operatorProc.unref()
  return waitForGateway(10000)
}

async function callGateway(request: GatewayRequest): Promise<ComputerUseResponse> {
  const url = `${gatewayUrl()}/v1/execute`
  const headers: Record<string, string> = {
    "Content-Type": "application/json",
    Accept: "application/json",
  }
  const token = gatewayToken()
  if (token) headers["Authorization"] = `Bearer ${token}`

  let response: Response
  try {
    response = await fetch(url, {
      method: "POST",
      headers,
      body: JSON.stringify(request),
    })
  } catch (error: any) {
    log.warn("Computer Use gateway unreachable, attempting auto-start", { error: error?.message, url })
    const started = await autoStartOperator()
    if (!started) {
      return ComputerUseResponseSchema.parse({
        run_id: request.run_id,
        session_id: request.session_id,
        adapter_id: "unavailable",
        family: "browser",
        mode: "execute",
        status: "failed",
        summary: "A2R Operator is not running and could not be auto-started",
        extracted_content: null,
        artifacts: [],
        receipts: [],
        error: {
          code: "GATEWAY_UNREACHABLE",
          message: `Cannot connect to A2R Operator at ${gatewayUrl()}`,
        },
        trace_id: crypto.randomUUID(),
      })
    }

    response = await fetch(url, {
      method: "POST",
      headers,
      body: JSON.stringify(request),
    })
  }

  if (!response.ok) {
    const errorText = await response.text()
    throw new Error(`Computer Use gateway error ${response.status}: ${errorText}`)
  }

  return ComputerUseResponseSchema.parse(await response.json())
}

async function fetchGatewayJson<T>(pathname: string, init?: RequestInit): Promise<T> {
  const token = gatewayToken()
  const headers = new Headers(init?.headers)
  if (token && !headers.has("Authorization")) headers.set("Authorization", `Bearer ${token}`)
  if (!headers.has("Accept")) headers.set("Accept", "application/json")
  const response = await fetch(`${gatewayUrl()}${pathname}`, {
    ...init,
    headers,
  })
  if (!response.ok) {
    const message = await response.text().catch(() => response.statusText)
    throw new Error(`Computer Use gateway error ${response.status}: ${message}`)
  }
  return response.json() as Promise<T>
}

async function readRun(runID: string): Promise<EngineRun | null> {
  const payload = await Filesystem.readJson(runPath(runID)).catch(() => null)
  return payload ? EngineRunSchema.parse(payload) : null
}

async function writeRun(run: EngineRun) {
  await Filesystem.writeJson(runPath(run.run_id), run)
}

async function mutateRun(runID: string, mutate: (current: EngineRun) => EngineRun | Promise<EngineRun>) {
  const current = await readRun(runID)
  if (!current) return null
  const next = await mutate(current)
  next.updated_at = nowISO()
  await writeRun(next)
  return next
}

function terminalStatus(status: EngineRun["status"]) {
  return status === "completed" || status === "failed" || status === "cancelled"
}

export namespace ComputerUseService {
  export const RunSchema = EngineRunSchema
  export const EventRecordSchema = EngineEventRecordSchema

  export async function executeManaged(input: {
    task: string
    mode: string
    target_scope?: string
    metadata?: Record<string, unknown>
  }) {
    try {
      return await fetchGatewayJson<{ run_id: string; status: string }>(`/v1/engine/execute`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(input),
      })
    } catch (error) {
      await autoStartOperator()
      return fetchGatewayJson<{ run_id: string; status: string }>(`/v1/engine/execute`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(input),
      })
    }
  }

  export async function execute(input: GatewayRequest) {
    return callGateway(input)
  }

  export async function createRun(input: {
    task: string
    mode: string
    target_scope?: string
    metadata?: Record<string, unknown>
  }) {
    await Filesystem.mkdir(runsRoot())
    const runID = `run_${crypto.randomUUID()}`
    const created: EngineRun = {
      run_id: runID,
      session_id: runID,
      mode: input.mode,
      task: input.task,
      target_scope: input.target_scope,
      status: "pending",
      created_at: nowISO(),
      updated_at: nowISO(),
      receipts: [],
      artifacts: [],
      events: [
        {
          event_type: "run.accepted",
          timestamp: nowISO(),
          data: {
            mode: input.mode,
            target_scope: input.target_scope,
            metadata: input.metadata ?? {},
          },
        },
      ],
    }
    await writeRun(created)
    return created
  }

  export async function startRun(input: {
    runID: string
    task: string
    mode: string
    target_scope?: string
    metadata?: Record<string, unknown>
    llm_config?: LLMConfig
  }) {
    await mutateRun(input.runID, (current) => ({
      ...current,
      status: "running",
      events: current.events.concat({
        event_type: "run.started",
        timestamp: nowISO(),
        data: {
          task: input.task,
          mode: input.mode,
          target_scope: input.target_scope,
        },
      }),
    }))

    try {
      const envelope = await callGateway({
        action: "execute",
        session_id: input.runID,
        run_id: input.runID,
        goal: input.task,
        adapter_preference: input.mode === "assist" || input.target_scope === "desktop" ? "desktop" : undefined,
        parameters: {
          mode: input.mode,
          target_scope: input.target_scope,
          ...(input.metadata ?? {}),
        },
        llm_config: input.llm_config,
      })

      await mutateRun(input.runID, (current) => {
        if (terminalStatus(current.status)) {
          return {
            ...current,
            receipts: envelope.receipts,
            artifacts: envelope.artifacts,
            result: envelope,
            summary: envelope.summary ?? current.summary,
            events: current.events.concat({
              event_type: "run.completed_after_terminal_status",
              timestamp: nowISO(),
              data: { ignored_status: current.status, operator_status: envelope.status },
            }),
          }
        }

        return {
          ...current,
          status: envelope.status === "failed" ? "failed" : envelope.status === "cancelled" ? "cancelled" : "completed",
          completed_at: nowISO(),
          summary: envelope.summary ?? undefined,
          receipts: envelope.receipts,
          artifacts: envelope.artifacts,
          result: envelope,
          error: envelope.error ?? undefined,
          events: current.events.concat({
            event_type: envelope.status === "failed" ? "run.failed" : "run.completed",
            timestamp: nowISO(),
            data: {
              adapter_id: envelope.adapter_id,
              family: envelope.family,
              mode: envelope.mode,
              status: envelope.status,
              summary: envelope.summary,
            },
          }),
        }
      })
    } catch (error) {
      const message = error instanceof Error ? error.message : String(error)
      await mutateRun(input.runID, (current) => {
        if (terminalStatus(current.status)) return current
        return {
          ...current,
          status: "failed",
          completed_at: nowISO(),
          error: { message },
          events: current.events.concat({
            event_type: "run.failed",
            timestamp: nowISO(),
            data: { message },
          }),
        }
      })
    }
  }

  export async function snapshot(runID: string) {
    try {
      return await fetchGatewayJson<any>(`/v1/engine/snapshot/${runID}`)
    } catch {
      return readRun(runID)
    }
  }

  export async function receipts(runID: string) {
    try {
      const result = await fetchGatewayJson<{ run_id: string; receipts: any[] }>(`/v1/engine/receipts/${runID}`)
      return result.receipts
    } catch {
      const run = await readRun(runID)
      return run ? run.receipts : null
    }
  }

  export async function events(runID: string, nextIndex = 0) {
    try {
      return await fetchGatewayJson<any>(`/v1/engine/runs/${runID}/events?next_index=${nextIndex}`)
    } catch {
      const run = await readRun(runID)
      if (!run) return null
      const events = run.events.slice(Math.max(0, nextIndex))
      return {
        run_id: runID,
        status: run.status,
        completed: terminalStatus(run.status),
        next_index: nextIndex + events.length,
        events,
      }
    }
  }

  export async function applyApproval(runID: string, input: { decision: string; approver_id?: string; comment?: string }) {
    try {
      return await fetchGatewayJson<any>(`/v1/engine/runs/${runID}/approval`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(input),
      })
    } catch {}
    return mutateRun(runID, (current) => {
      const nextStatus =
        current.status === "needs_approval"
          ? input.decision === "approve"
            ? "running"
            : "cancelled"
          : current.status
      return {
        ...current,
        status: nextStatus,
        completed_at: input.decision === "deny" ? nowISO() : current.completed_at,
        events: current.events.concat({
          event_type: input.decision === "approve" ? "run.approved" : "run.denied",
          timestamp: nowISO(),
          data: input,
        }),
      }
    })
  }

  export async function cancel(runID: string, input: { approver_id?: string; comment?: string }) {
    try {
      return await fetchGatewayJson<any>(`/v1/engine/runs/${runID}/cancel`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(input),
      })
    } catch {}
    return mutateRun(runID, (current) => {
      if (terminalStatus(current.status)) return current
      return {
        ...current,
        status: "cancelled",
        completed_at: nowISO(),
        events: current.events.concat({
          event_type: "run.cancelled",
          timestamp: nowISO(),
          data: input,
        }),
      }
    })
  }

  export async function pause(runID: string, input: { approver_id?: string; comment?: string }) {
    try {
      return await fetchGatewayJson<any>(`/v1/engine/runs/${runID}/pause`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(input),
      })
    } catch {}
    return mutateRun(runID, (current) => {
      if (terminalStatus(current.status) || current.status === "paused" || current.status === "needs_approval") return current
      return {
        ...current,
        status: "paused",
        events: current.events.concat({
          event_type: "run.paused",
          timestamp: nowISO(),
          data: input,
        }),
      }
    })
  }

  export async function resume(runID: string, input: { approver_id?: string; comment?: string }) {
    try {
      return await fetchGatewayJson<any>(`/v1/engine/runs/${runID}/resume`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(input),
      })
    } catch {}
    return mutateRun(runID, (current) => {
      if (current.status !== "paused") return current
      return {
        ...current,
        status: "pending",
        completed_at: undefined,
        events: current.events.concat({
          event_type: "run.resumed",
          timestamp: nowISO(),
          data: input,
        }),
      }
    })
  }

  export async function waitForEvents(runID: string, nextIndex: number, timeoutMs = 15000) {
    const deadline = Date.now() + timeoutMs
    while (Date.now() < deadline) {
      const batch = await events(runID, nextIndex)
      if (!batch) return null
      if (batch.events.length > 0 || batch.completed) return batch
      await new Promise((resolve) => setTimeout(resolve, 500))
    }
    return events(runID, nextIndex)
  }
}
