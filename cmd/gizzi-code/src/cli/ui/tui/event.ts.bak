/**
 * TUI Event Types
 */

export interface TuiEvent {
  type: string
  data?: unknown
  timestamp: number
}

export type TuiEventHandler = (event: TuiEvent) => void

export class TuiEventBus {
  private handlers: Map<string, TuiEventHandler[]> = new Map()

  on(event: string, handler: TuiEventHandler): () => void {
    if (!this.handlers.has(event)) {
      this.handlers.set(event, [])
    }
    this.handlers.get(event)!.push(handler)
    return () => {
      const handlers = this.handlers.get(event)
      if (handlers) {
        const index = handlers.indexOf(handler)
        if (index >= 0) handlers.splice(index, 1)
      }
    }
  }

  emit(event: string, data?: unknown): void {
    const handlers = this.handlers.get(event) || []
    const tuiEvent: TuiEvent = {
      type: event,
      data,
      timestamp: Date.now(),
    }
    for (const handler of handlers) {
      handler(tuiEvent)
    }
  }
}

export const tuiEventBus = new TuiEventBus()
