import { cmd } from "@/cli/commands/cmd"
import { UI } from "@/cli/ui/ui"

export const A2rCommand = cmd({
  command: "allternit",
  describe: "A2R architecture remote control",
  builder: (yargs) =>
    yargs
      .command("vms", "Manage A2R virtual machines", (yargs) =>
        yargs
          .positional("action", {
            type: "string",
            choices: ["list", "start", "stop", "restart", "logs", "connect"],
          })
          .positional("name", { type: "string" }),
      )
      .command("capsules", "Manage A2R capsules", (yargs) =>
        yargs
          .positional("action", {
            type: "string",
            choices: ["list", "start", "stop", "restart", "logs", "exec"],
          })
          .positional("name", { type: "string" }),
      )
      .command("plugins", "Manage A2R plugins", (yargs) =>
        yargs
          .positional("action", {
            type: "string",
            choices: ["list", "install", "uninstall", "enable", "disable", "update"],
          })
          .positional("name", { type: "string" }),
      )
      .command("sessions", "Manage A2R remote sessions", (yargs) =>
        yargs
          .positional("action", {
            type: "string",
            choices: ["list", "connect", "disconnect", "disconnect-all"],
          })
          .positional("id", { type: "string" }),
      )
      .demandCommand(1, "Please specify a subcommand"),
  handler: async (args) => {
    UI.empty()
    UI.println(UI.Style.TEXT_INFO_BOLD + "A2R Remote Control")
    UI.empty()
    UI.println("Usage: gizzi a2r <command> [options]")
    UI.empty()
    UI.println("Commands:")
    UI.println("  vms        Manage A2R virtual machines")
    UI.println("  capsules   Manage A2R capsules")
    UI.println("  plugins    Manage A2R plugins")
    UI.println("  sessions   Manage A2R remote sessions")
    UI.empty()
    UI.println(UI.Style.TEXT_DIM + "Run 'gizzi a2r <command> --help' for more information on a command.")
  },
})
