import { cmd } from "@/cli/commands/cmd"
import { UI } from "@/cli/ui/ui"
import { Instance } from "@/runtime/context/project/instance"
import { Filesystem } from "@/runtime/util/filesystem"
import path from "path"
import { EOL } from "os"

// ANSI color codes for terminal visualization
const COLORS = {
  // Context importance levels (like Gizzi)
  critical: "\x1b[48;2;217;119;87m\x1b[38;2;0;0;0m",  // Orange - Critical context
  high: "\x1b[48;2;91;142;222m\x1b[38;2;0;0;0m",      // Blue - High importance
  medium: "\x1b[48;2;212;176;140m\x1b[38;2;0;0;0m",   // Tan - Medium
  low: "\x1b[48;2;100;100;100m\x1b[38;2;255;255;255m", // Gray - Low
  none: "\x1b[48;2;40;40;40m\x1b[38;2;100;100;100m",   // Dark - None
  reset: "\x1b[0m",
}

type ContextItem = {
  path: string
  type: "file" | "directory" | "memory" | "tool" | "session"
  size: number
  tokens: number
  importance: "critical" | "high" | "medium" | "low" | "none"
  lastAccessed?: Date
}

function estimateTokens(content: string): number {
  // Rough estimation: ~4 chars per token on average
  return Math.ceil(content.length / 4)
}

function getColorForImportance(importance: ContextItem["importance"]): string {
  switch (importance) {
    case "critical": return COLORS.critical
    case "high": return COLORS.high
    case "medium": return COLORS.medium
    case "low": return COLORS.low
    default: return COLORS.none
  }
}

function getImportanceFromPath(filepath: string): ContextItem["importance"] {
  const lower = filepath.toLowerCase()
  if (lower.includes("memory") || lower.includes("gizzi.md")) return "critical"
  if (lower.includes("config") || lower.includes("package.json")) return "high"
  if (lower.includes("test") || lower.includes("spec")) return "medium"
  return "low"
}

async function scanDirectory(dir: string, maxDepth = 2, currentDepth = 0): Promise<ContextItem[]> {
  const items: ContextItem[] = []

  if (currentDepth > maxDepth) return items

  try {
    const entries = await Filesystem.list(dir)

    for (const entry of entries) {
      const fullPath = path.join(dir, entry.name)
      const relativePath = path.relative(Instance.directory, fullPath)

      if (entry.isDirectory) {
        // Skip node_modules, .git, etc.
        if (["node_modules", ".git", ".gizzi", "dist", "build", "target"].includes(entry.name)) {
          continue
        }

        items.push({
          path: relativePath,
          type: "directory",
          size: 0,
          tokens: 0,
          importance: getImportanceFromPath(relativePath),
        })

        // Recurse for depth 0 and 1
        if (currentDepth < maxDepth) {
          const children = await scanDirectory(fullPath, maxDepth, currentDepth + 1)
          items.push(...children)
        }
      } else {
        // It's a file
        try {
          const stats = await Filesystem.stat(fullPath)
          if (!stats) continue
          const content = await Filesystem.readText(fullPath).catch(() => "")
          const tokens = estimateTokens(content)
          const size = typeof stats.size === "bigint" ? Number(stats.size) : stats.size

          items.push({
            path: relativePath,
            type: "file",
            size,
            tokens,
            importance: getImportanceFromPath(relativePath),
            lastAccessed: stats.mtime ? new Date(stats.mtime) : undefined,
          })
        } catch {
          // Skip files we can't read
        }
      }
    }
  } catch {
    // Directory might not exist or be readable
  }

  return items
}

function formatBytes(bytes: number): string {
  if (bytes === 0) return "0 B"
  const k = 1024
  const sizes = ["B", "KB", "MB", "GB"]
  const i = Math.floor(Math.log(bytes) / Math.log(k))
  return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + " " + sizes[i]
}

function formatTokens(tokens: number): string {
  if (tokens < 1000) return `${tokens}`
  return `${(tokens / 1000).toFixed(1)}k`
}

function renderGrid(items: ContextItem[], width = 80): string {
  const lines: string[] = []
  const gridWidth = Math.min(width - 4, 60)
  const cellWidth = 2
  const cellsPerRow = Math.floor(gridWidth / cellWidth)

  // Header
  lines.push("")
  lines.push("Context Grid (importance visualization)")
  lines.push("")

  // Legend
  lines.push("Legend: " +
    COLORS.critical + "  " + COLORS.reset + " Critical " +
    COLORS.high + "  " + COLORS.reset + " High " +
    COLORS.medium + "  " + COLORS.reset + " Medium " +
    COLORS.low + "  " + COLORS.reset + " Low " +
    COLORS.none + "  " + COLORS.reset + " None"
  )
  lines.push("")

  // Sort by importance then by path
  const sorted = [...items].sort((a, b) => {
    const importanceOrder = { critical: 0, high: 1, medium: 2, low: 3, none: 4 }
    const diff = importanceOrder[a.importance] - importanceOrder[b.importance]
    if (diff !== 0) return diff
    return a.path.localeCompare(b.path)
  })

  // Grid
  let row = "  "
  let count = 0
  for (const item of sorted.slice(0, 200)) { // Limit to 200 items for display
    const color = getColorForImportance(item.importance)
    row += color + "  " + COLORS.reset
    count++

    if (count % cellsPerRow === 0) {
      lines.push(row)
      row = "  "
    }
  }
  if (count % cellsPerRow !== 0) {
    lines.push(row)
  }

  lines.push("")
  return lines.join("\n")
}

function renderStats(items: ContextItem[]): string {
  const files = items.filter((i) => i.type === "file")
  const dirs = items.filter((i) => i.type === "directory")
  const totalTokens = files.reduce((sum, f) => sum + f.tokens, 0)
  const totalSize = files.reduce((sum, f) => sum + f.size, 0)

  const byImportance = {
    critical: items.filter((i) => i.importance === "critical").length,
    high: items.filter((i) => i.importance === "high").length,
    medium: items.filter((i) => i.importance === "medium").length,
    low: items.filter((i) => i.importance === "low").length,
    none: items.filter((i) => i.importance === "none").length,
  }

  const lines: string[] = []
  lines.push("")
  lines.push(UI.Style.TEXT_INFO_BOLD + "Context Statistics" + UI.Style.TEXT_NORMAL)
  lines.push("")
  lines.push(`  Files scanned:     ${UI.Style.TEXT_BOLD}${files.length}${UI.Style.TEXT_NORMAL}`)
  lines.push(`  Directories:       ${UI.Style.TEXT_BOLD}${dirs.length}${UI.Style.TEXT_NORMAL}`)
  lines.push(`  Total size:        ${UI.Style.TEXT_BOLD}${formatBytes(totalSize)}${UI.Style.TEXT_NORMAL}`)
  lines.push(`  Estimated tokens:  ${UI.Style.TEXT_BOLD}${formatTokens(totalTokens)}${UI.Style.TEXT_NORMAL}`)
  lines.push("")
  lines.push("  By importance:")
  lines.push(`    ${COLORS.critical}  ${COLORS.reset} Critical: ${byImportance.critical}`)
  lines.push(`    ${COLORS.high}  ${COLORS.reset} High:     ${byImportance.high}`)
  lines.push(`    ${COLORS.medium}  ${COLORS.reset} Medium:   ${byImportance.medium}`)
  lines.push(`    ${COLORS.low}  ${COLORS.reset} Low:      ${byImportance.low}`)
  lines.push(`    ${COLORS.none}  ${COLORS.reset} None:     ${byImportance.none}`)
  lines.push("")

  return lines.join("\n")
}

function renderTopFiles(items: ContextItem[], limit = 10): string {
  const files = items
    .filter((i) => i.type === "file")
    .sort((a, b) => b.tokens - a.tokens)
    .slice(0, limit)

  const lines: string[] = []
  lines.push(UI.Style.TEXT_INFO_BOLD + "Top Files by Size" + UI.Style.TEXT_NORMAL)
  lines.push("")
  lines.push(`  ${"File".padEnd(40)} ${"Size".padStart(10)} ${"Tokens".padStart(10)}`)
  lines.push(`  ${"-".repeat(62)}`)

  for (const file of files) {
    const name = file.path.length > 38 ? "..." + file.path.slice(-35) : file.path
    const color = getColorForImportance(file.importance)
    lines.push(`  ${color} ${COLORS.reset}${name.padEnd(40)} ${formatBytes(file.size).padStart(10)} ${formatTokens(file.tokens).padStart(10)}`)
  }

  lines.push("")
  return lines.join("\n")
}

export const ContextCommand = cmd({
  command: "context",
  describe: "visualize current context usage as a colored grid",
  builder: (yargs) =>
    yargs
      .option("grid", {
        type: "boolean",
        default: true,
        describe: "show visual grid",
      })
      .option("stats", {
        type: "boolean",
        default: true,
        describe: "show statistics",
      })
      .option("files", {
        type: "boolean",
        default: true,
        describe: "show top files",
      })
      .option("limit", {
        type: "number",
        default: 10,
        describe: "limit for top files",
      })
      .option("depth", {
        type: "number",
        default: 2,
        describe: "directory scan depth",
      }),
  handler: async (args) => {
    UI.empty()
    UI.println(UI.Style.TEXT_INFO_BOLD + "Context Visualization" + UI.Style.TEXT_NORMAL)
    UI.println(UI.Style.TEXT_DIM + `  Directory: ${Instance.directory}${UI.Style.TEXT_NORMAL}`)

    // Scan for context items
    const items = await scanDirectory(Instance.directory, args.depth)

    if (args.grid) {
      UI.println(renderGrid(items))
    }

    if (args.stats) {
      UI.println(renderStats(items))
    }

    if (args.files) {
      UI.println(renderTopFiles(items, args.limit))
    }

    // Memory context (if exists)
    const memoryPath = path.join(Instance.directory, ".gizzi", "L1-COGNITIVE", "memory", "MEMORY.md")
    if (await Filesystem.exists(memoryPath)) {
      const content = await Filesystem.readText(memoryPath)
      const tokens = estimateTokens(content)
      UI.println(UI.Style.TEXT_INFO_BOLD + "Memory Context" + UI.Style.TEXT_NORMAL)
      UI.println(`  ${UI.Style.TEXT_SUCCESS}MEMORY.md${UI.Style.TEXT_NORMAL}: ${formatTokens(tokens)} tokens`)
      UI.println("")
    }

    // Tips
    UI.println(UI.Style.TEXT_DIM + "Tips:" + UI.Style.TEXT_NORMAL)
    UI.println("  • Use " + UI.Style.TEXT_INFO + "/memory" + UI.Style.TEXT_NORMAL + " to edit project memory")
    UI.println("  • Use " + UI.Style.TEXT_INFO + "/compact" + UI.Style.TEXT_NORMAL + " to reduce context size")
    UI.println("")
  },
})
