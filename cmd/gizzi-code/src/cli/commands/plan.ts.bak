import { cmd } from "@/cli/commands/cmd"
import { UI } from "@/cli/ui/ui"
import { Instance } from "@/runtime/context/project/instance"
import { Filesystem } from "@/runtime/util/filesystem"
import path from "path"

// Planning mode state file
const PLANNING_STATE_FILE = ".planning-mode"

type PlanningState = {
  enabled: boolean
  steps: PlanningStep[]
  currentStep: number
}

type PlanningStep = {
  id: string
  description: string
  status: "pending" | "in-progress" | "completed" | "blocked"
  dependencies?: string[]
}

async function readPlanningState(): Promise<PlanningState> {
  const statePath = path.join(Instance.directory, ".gizzi", PLANNING_STATE_FILE)
  try {
    const content = await Filesystem.readText(statePath)
    return JSON.parse(content)
  } catch {
    return { enabled: false, steps: [], currentStep: 0 }
  }
}

async function writePlanningState(state: PlanningState): Promise<void> {
  const statePath = path.join(Instance.directory, ".gizzi", PLANNING_STATE_FILE)
  await Filesystem.write(statePath, JSON.stringify(state, null, 2))
}

function renderPlanningMode(state: PlanningState): string {
  const lines: string[] = []

  lines.push("")
  lines.push(UI.Style.TEXT_INFO_BOLD + "Planning Mode" + UI.Style.TEXT_NORMAL)
  lines.push("")

  if (!state.enabled) {
    lines.push("Status: " + UI.Style.TEXT_DIM + "disabled" + UI.Style.TEXT_NORMAL)
    lines.push("")
    lines.push("When enabled, the agent will:")
    lines.push("  • Create a plan before executing")
    lines.push("  • Show thinking steps")
    lines.push("  • Ask for confirmation on complex changes")
    lines.push("  • Break down large tasks")
    lines.push("")
    return lines.join("\n")
  }

  lines.push("Status: " + UI.Style.TEXT_SUCCESS + "enabled" + UI.Style.TEXT_NORMAL)
  lines.push("")

  if (state.steps.length > 0) {
    lines.push(UI.Style.TEXT_INFO_BOLD + "Current Plan:" + UI.Style.TEXT_NORMAL)
    lines.push("")

    for (let i = 0; i < state.steps.length; i++) {
      const step = state.steps[i]
      const isCurrent = i === state.currentStep
      const icon = step.status === "completed" ? "✓" :
                   step.status === "in-progress" ? "▶" :
                   step.status === "blocked" ? "✗" : "○"
      const color = step.status === "completed" ? UI.Style.TEXT_SUCCESS :
                    step.status === "in-progress" ? UI.Style.TEXT_INFO :
                    step.status === "blocked" ? UI.Style.TEXT_ERROR :
                    UI.Style.TEXT_DIM

      const currentMarker = isCurrent ? UI.Style.TEXT_INFO_BOLD + " → " + UI.Style.TEXT_NORMAL : "   "
      lines.push(`${currentMarker}${color}${icon}${UI.Style.TEXT_NORMAL} ${step.description}`)
    }

    lines.push("")
  } else {
    lines.push(UI.Style.TEXT_DIM + "No active plan" + UI.Style.TEXT_NORMAL)
    lines.push("")
  }

  return lines.join("\n")
}

export const PlanCommand = cmd({
  command: "plan",
  describe: "toggle planning mode or manage plans",
  builder: (yargs) =>
    yargs
      .option("on", {
        type: "boolean",
        describe: "enable planning mode",
      })
      .option("off", {
        type: "boolean",
        describe: "disable planning mode",
      })
      .option("status", {
        type: "boolean",
        describe: "show current planning status",
      })
      .option("clear", {
        type: "boolean",
        describe: "clear current plan",
      })
      .option("add", {
        type: "string",
        describe: "add a step to the plan",
      })
      .option("complete", {
        type: "number",
        describe: "mark step as complete",
      }),
  handler: async (args) => {
    const state = await readPlanningState()

    // Toggle planning mode
    if (args.on) {
      state.enabled = true
      await writePlanningState(state)
      UI.println(UI.Style.TEXT_SUCCESS_BOLD + "Planning mode enabled" + UI.Style.TEXT_NORMAL)
      UI.println(renderPlanningMode(state))
      return
    }

    if (args.off) {
      state.enabled = false
      await writePlanningState(state)
      UI.println(UI.Style.TEXT_DIM + "Planning mode disabled" + UI.Style.TEXT_NORMAL)
      return
    }

    // Show status
    if (args.status || (!args.on && !args.off && !args.clear && !args.add && args.complete === undefined)) {
      UI.println(renderPlanningMode(state))
      return
    }

    // Clear plan
    if (args.clear) {
      state.steps = []
      state.currentStep = 0
      await writePlanningState(state)
      UI.println(UI.Style.TEXT_SUCCESS + "Plan cleared" + UI.Style.TEXT_NORMAL)
      return
    }

    // Add step
    if (args.add) {
      const newStep: PlanningStep = {
        id: `step-${Date.now()}`,
        description: args.add,
        status: "pending",
      }
      state.steps.push(newStep)
      await writePlanningState(state)
      UI.println(UI.Style.TEXT_SUCCESS + `Added step: ${args.add}` + UI.Style.TEXT_NORMAL)
      return
    }

    // Complete step
    if (args.complete !== undefined) {
      const index = args.complete
      if (index >= 0 && index < state.steps.length) {
        state.steps[index].status = "completed"
        // Move to next step
        if (state.currentStep === index) {
          state.currentStep = Math.min(index + 1, state.steps.length - 1)
          if (state.currentStep < state.steps.length) {
            state.steps[state.currentStep].status = "in-progress"
          }
        }
        await writePlanningState(state)
        UI.println(UI.Style.TEXT_SUCCESS + `Step ${index + 1} completed` + UI.Style.TEXT_NORMAL)
      } else {
        UI.println(UI.Style.TEXT_ERROR + `Invalid step index: ${index}` + UI.Style.TEXT_NORMAL)
      }
      return
    }
  },
})
