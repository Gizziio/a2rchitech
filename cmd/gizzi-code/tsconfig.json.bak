{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "exactOptionalPropertyTypes": false,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "types": ["bun-types", "node"],
    "baseUrl": ".",
    "rootDir": ".",
    "outDir": ".build",
    "paths": {
      "~/*": ["src/*"],
      "@/*": ["src/*"],
      "@shared/*": ["src/shared/*"],
      "@/shared/*": ["src/shared/*"],
      "@runtime/*": ["src/runtime/*"],
      "@/runtime/*": ["src/runtime/*"],
      "@cli/*": ["src/cli/*"],
      "@/cli/*": ["src/cli/*"]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", ".build", "dist", "**/*.test.ts", "**/*.spec.ts", "**/__tests__/**", "packages/**/*"]
}
