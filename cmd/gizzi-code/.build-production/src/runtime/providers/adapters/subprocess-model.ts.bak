/**
 * Subprocess Language Model Adapter
 *
 * Wraps a CLI tool (claude -p, kimi -p, llm prompt, …) as a LanguageModelV2.
 * The adapter converts the structured prompt to plain text and feeds it to the
 * subprocess via stdin, then streams stdout back as text-delta parts.
 *
 * Error handling:
 *   - Non-zero exit code: surface stderr as a typed error
 *   - Rate limit (429 / "rate limit" / "quota"): SubprocessRateLimitError
 *   - Auth failure (401/403 / "unauthorized"): SubprocessAuthError
 *   - Weekly/subscription quota: SubprocessQuotaError
 *   - Service unavailable (503): SubprocessServiceError
 *   - Generic failure: SubprocessError
 *
 * Usage: called from Provider.getLanguage() when provider.auth_type === "subprocess"
 */

import type {
  LanguageModelV2,
  LanguageModelV2CallOptions,
  LanguageModelV2StreamPart,
} from "@ai-sdk/provider"

// ─── Error types ─────────────────────────────────────────────────────────────

export class SubprocessError extends Error {
  constructor(
    public readonly providerID: string,
    public readonly modelId: string,
    message: string,
    public readonly exitCode: number | null,
    public readonly stderr: string,
  ) {
    super(message)
    this.name = "SubprocessError"
  }
}

export class SubprocessRateLimitError extends SubprocessError {
  constructor(providerID: string, modelId: string, stderr: string) {
    super(providerID, modelId, `Rate limit reached for ${providerID}/${modelId}. Wait and retry.`, null, stderr)
    this.name = "SubprocessRateLimitError"
  }
}

export class SubprocessAuthError extends SubprocessError {
  constructor(providerID: string, modelId: string, stderr: string) {
    super(providerID, modelId, `Authentication failed for ${providerID}. Run the CLI login command and try again.`, null, stderr)
    this.name = "SubprocessAuthError"
  }
}

export class SubprocessQuotaError extends SubprocessError {
  constructor(providerID: string, modelId: string, stderr: string) {
    super(providerID, modelId, `Usage quota or subscription limit reached for ${providerID}/${modelId}.`, null, stderr)
    this.name = "SubprocessQuotaError"
  }
}

export class SubprocessServiceError extends SubprocessError {
  constructor(providerID: string, modelId: string, stderr: string) {
    super(providerID, modelId, `${providerID} service is temporarily unavailable. Try again later.`, null, stderr)
    this.name = "SubprocessServiceError"
  }
}

// ─── Error classification ─────────────────────────────────────────────────────

function classifyError(
  providerID: string,
  modelId: string,
  exitCode: number | null,
  stderr: string,
  stdout: string,
): SubprocessError {
  const combined = (stderr + "\n" + stdout).toLowerCase()

  // Rate limit
  if (
    combined.includes("429") ||
    combined.includes("rate limit") ||
    combined.includes("too many requests") ||
    combined.includes("no capacity available") ||
    combined.includes("ratelimitexceeded")
  ) {
    return new SubprocessRateLimitError(providerID, modelId, stderr)
  }

  // Subscription / weekly quota
  if (
    combined.includes("weekly") ||
    combined.includes("subscription") ||
    combined.includes("quota exceeded") ||
    combined.includes("limit reached") ||
    combined.includes("usage limit") ||
    combined.includes("plan limit")
  ) {
    return new SubprocessQuotaError(providerID, modelId, stderr)
  }

  // Auth failures
  if (
    combined.includes("401") ||
    combined.includes("403") ||
    combined.includes("unauthorized") ||
    combined.includes("authentication") ||
    combined.includes("invalid api key") ||
    combined.includes("invalid key") ||
    combined.includes("api key") ||
    combined.includes("not authenticated") ||
    combined.includes("login") && combined.includes("required")
  ) {
    return new SubprocessAuthError(providerID, modelId, stderr)
  }

  // Service unavailable
  if (
    combined.includes("503") ||
    combined.includes("service unavailable") ||
    combined.includes("currently unavailable") ||
    combined.includes("backend error")
  ) {
    return new SubprocessServiceError(providerID, modelId, stderr)
  }

  const detail = stderr.trim() || stdout.trim() || `exit code ${exitCode}`
  return new SubprocessError(
    providerID,
    modelId,
    `${providerID}/${modelId} subprocess failed: ${detail}`,
    exitCode,
    stderr,
  )
}

// ─── Prompt serialization ─────────────────────────────────────────────────────

function promptToText(options: LanguageModelV2CallOptions): string {
  const lines: string[] = []

  for (const msg of options.prompt) {
    if (msg.role === "system") {
      if (msg.content) lines.push(`[System Instructions]\n${msg.content}`)
    } else if (msg.role === "user" || msg.role === "assistant") {
      const textParts = (msg.content as Array<{ type: string; text?: string }>)
        .filter((p) => p.type === "text" && p.text != null)
        .map((p) => p.text as string)
      const text = textParts.join("\n")
      if (text) lines.push(text)
    }
  }

  return lines.join("\n\n")
}

// ─── argv construction ────────────────────────────────────────────────────────

interface ArgvSpec {
  /** The command + flags to spawn (without the prompt text itself) */
  argv: string[]
  /**
   * How to deliver the prompt to the subprocess:
   *   "stdin"     — write prompt to proc.stdin (claude, ollama)
   *   "arg"       — append prompt as the last positional argument (kimi, gemini, qwen, codex)
   */
  promptMode: "stdin" | "arg"
}

function buildArgv(subprocessCmd: string, modelId: string, providerID: string): ArgvSpec {
  const parts = subprocessCmd.split(/\s+/).filter(Boolean)

  // claude CLI: claude -p --model <id>  — stdin delivery
  if (providerID === "claude-cli") {
    const argv = modelId && modelId !== "default"
      ? [...parts, "--model", modelId]
      : parts
    return { argv, promptMode: "stdin" }
  }

  // ollama CLI: ollama run <model> — stdin delivery, model id as positional
  if (providerID === "ollama-cli") {
    const argv = modelId && modelId !== "default" ? [...parts, modelId] : parts
    return { argv, promptMode: "stdin" }
  }

  // kimi CLI: kimi -p "<prompt>" — -p requires the prompt as its value (arg delivery)
  if (providerID === "kimi-cli") {
    return { argv: parts, promptMode: "arg" }
  }

  // gemini CLI: gemini -p "<prompt>" — same pattern as kimi
  if (providerID === "gemini-cli") {
    return { argv: parts, promptMode: "arg" }
  }

  // qwen CLI: qwen -m <model> "<prompt>" — positional prompt, model via -m
  if (providerID === "qwen-cli") {
    const argv = modelId && modelId !== "default"
      ? [...parts, "-m", modelId]
      : parts
    return { argv, promptMode: "arg" }
  }

  // codex CLI: codex "<prompt>" — positional prompt
  if (providerID === "codex-cli") {
    return { argv: parts, promptMode: "arg" }
  }

  // default: try stdin
  return { argv: parts, promptMode: "stdin" }
}

// ─── Main factory ─────────────────────────────────────────────────────────────

function spawnSubprocess(spec: ArgvSpec, promptText: string) {
  if (spec.promptMode === "arg") {
    // Prompt is the last positional argument — no stdin needed
    return Bun.spawn([...spec.argv, promptText], {
      stdin: "inherit",
      stdout: "pipe",
      stderr: "pipe",
    })
  }
  // stdin delivery
  const proc = Bun.spawn(spec.argv, {
    stdin: "pipe",
    stdout: "pipe",
    stderr: "pipe",
  })
  proc.stdin.write(promptText)
  proc.stdin.end()
  return proc
}

// ─── Ollama HTTP API ──────────────────────────────────────────────────────────

/**
 * `ollama run` doesn't output to stdout when stdin is piped (it writes to the
 * terminal directly). Use the Ollama REST API instead, which works with any
 * OLLAMA_HOST (local or remote).
 */
async function ollamaGenerate(modelId: string, promptText: string): Promise<string> {
  const base = (process.env.OLLAMA_HOST ?? "http://localhost:11434").replace(/\/$/, "")
  const res = await fetch(`${base}/api/generate`, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ model: modelId, prompt: promptText, stream: false }),
  })
  if (!res.ok) {
    const body = await res.text().catch(() => "")
    throw new SubprocessError("ollama-cli", modelId, `Ollama API error ${res.status}: ${body}`, res.status, body)
  }
  const data = await res.json() as { response?: string; error?: string }
  if (data.error) throw new SubprocessError("ollama-cli", modelId, `Ollama error: ${data.error}`, null, data.error)
  return (data.response ?? "").trim()
}

async function* ollamaStream(modelId: string, promptText: string): AsyncGenerator<string> {
  const base = (process.env.OLLAMA_HOST ?? "http://localhost:11434").replace(/\/$/, "")
  const res = await fetch(`${base}/api/generate`, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ model: modelId, prompt: promptText, stream: true }),
  })
  if (!res.ok) {
    const body = await res.text().catch(() => "")
    throw new SubprocessError("ollama-cli", modelId, `Ollama API error ${res.status}: ${body}`, res.status, body)
  }
  const reader = res.body!.getReader()
  const dec = new TextDecoder()
  let buf = ""
  while (true) {
    const { done, value } = await reader.read()
    if (done) break
    buf += dec.decode(value, { stream: true })
    const lines = buf.split("\n")
    buf = lines.pop() ?? ""
    for (const line of lines) {
      if (!line.trim()) continue
      try {
        const obj = JSON.parse(line) as { response?: string; done?: boolean; error?: string }
        if (obj.error) throw new SubprocessError("ollama-cli", modelId, `Ollama error: ${obj.error}`, null, obj.error)
        if (obj.response) yield obj.response
      } catch { /* skip malformed lines */ }
    }
  }
}

export function createSubprocessLanguageModel(
  providerID: string,
  modelId: string,
  subprocessCmd: string,
): LanguageModelV2 {
  const spec = buildArgv(subprocessCmd, modelId, providerID)

  return {
    specificationVersion: "v2",
    provider: providerID,
    modelId,
    supportedUrls: {},

    async doGenerate(options: LanguageModelV2CallOptions) {
      const promptText = promptToText(options)

      // ollama run doesn't output to stdout with piped stdin — use HTTP API
      if (providerID === "ollama-cli") {
        const text = await ollamaGenerate(modelId, promptText)
        return {
          content: [{ type: "text" as const, text }],
          finishReason: "stop" as const,
          usage: { inputTokens: undefined, outputTokens: undefined, totalTokens: undefined },
          warnings: [],
        }
      }

      const proc = spawnSubprocess(spec, promptText)

      const [stdout, stderr] = await Promise.all([
        new Response(proc.stdout).text(),
        new Response(proc.stderr).text(),
        proc.exited,
      ])

      if (proc.exitCode !== 0) {
        throw classifyError(providerID, modelId, proc.exitCode, stderr, stdout)
      }

      // Some CLIs (kimi) write reasoning steps to stdout — strip them
      const text = cleanOutput(stdout, providerID)

      return {
        content: [{ type: "text" as const, text }],
        finishReason: "stop" as const,
        usage: {
          inputTokens: undefined,
          outputTokens: undefined,
          totalTokens: undefined,
        },
        warnings: [],
      }
    },

    async doStream(options: LanguageModelV2CallOptions) {
      const promptText = promptToText(options)

      // ollama run doesn't output to stdout with piped stdin — use HTTP API
      if (providerID === "ollama-cli") {
        const stream = new ReadableStream<LanguageModelV2StreamPart>({
          async start(controller) {
            controller.enqueue({ type: "stream-start", warnings: [] })
            controller.enqueue({ type: "text-start", id: "0" })
            try {
              for await (const chunk of ollamaStream(modelId, promptText)) {
                controller.enqueue({ type: "text-delta", id: "0", delta: chunk })
              }
            } catch (err) {
              controller.enqueue({ type: "error", error: err })
              controller.close()
              return
            }
            controller.enqueue({ type: "text-end", id: "0" })
            controller.enqueue({
              type: "finish",
              finishReason: "stop" as const,
              usage: { inputTokens: undefined, outputTokens: undefined, totalTokens: undefined },
            })
            controller.close()
          },
        })
        return { stream }
      }

      const proc = spawnSubprocess(spec, promptText)

      // Collect stderr in parallel — needed for error classification
      const stderrPromise = new Response(proc.stderr).text().catch(() => "")

      const stream = new ReadableStream<LanguageModelV2StreamPart>({
        async start(controller) {
          controller.enqueue({ type: "stream-start", warnings: [] })
          controller.enqueue({ type: "text-start", id: "0" })

          const reader = proc.stdout.getReader()
          const decoder = new TextDecoder()
          let stdoutAccum = ""
          const buffered = isBufferedOutput(providerID)

          try {
            while (true) {
              const { done, value } = await reader.read()
              if (done) break
              const raw = decoder.decode(value, { stream: true })
              stdoutAccum += raw
              // Buffered providers (kimi): hold until process exits, then emit cleaned answer
              // Streaming providers: emit each delta immediately
              if (!buffered) {
                if (raw) controller.enqueue({ type: "text-delta", id: "0", delta: raw })
              }
            }
          } catch (err) {
            controller.enqueue({ type: "error", error: err })
            controller.close()
            return
          } finally {
            reader.releaseLock()
          }

          await proc.exited
          const stderr = await stderrPromise

          if (proc.exitCode !== 0) {
            const err = classifyError(providerID, modelId, proc.exitCode, stderr, stdoutAccum)
            controller.enqueue({ type: "error", error: err })
            controller.close()
            return
          }

          // For buffered providers: emit the cleaned final answer now
          if (buffered) {
            const answer = cleanOutput(stdoutAccum, providerID)
            if (answer) controller.enqueue({ type: "text-delta", id: "0", delta: answer })
          }

          controller.enqueue({ type: "text-end", id: "0" })
          controller.enqueue({
            type: "finish",
            finishReason: "stop" as const,
            usage: {
              inputTokens: undefined,
              outputTokens: undefined,
              totalTokens: undefined,
            },
          })
          controller.close()
        },
      })

      return { stream }
    },
  }
}

// ─── Output filtering ─────────────────────────────────────────────────────────

/**
 * Some CLIs output reasoning/thinking steps to stdout mixed with the final answer.
 *
 * Kimi format:
 *   • Reasoning thought, possibly spanning
 *     multiple lines with 2-space indent continuation.
 *   • Another thought.
 *   • Final answer text here.
 *
 * The final answer is the last "• " bullet and its continuation lines.
 * Strip the "• " prefix from it.
 */
function cleanOutput(raw: string, providerID: string): string {
  if (providerID === "kimi-cli") {
    const lines = raw.split("\n")
    // Find index of last line starting with "• "
    let lastBulletIdx = -1
    for (let i = 0; i < lines.length; i++) {
      if (lines[i].startsWith("• ")) lastBulletIdx = i
    }
    if (lastBulletIdx >= 0) {
      const answerLines = lines.slice(lastBulletIdx)
      // Strip leading "• " from the first line, trim indent from continuation lines
      answerLines[0] = answerLines[0].replace(/^• /, "")
      return answerLines
        .map((l) => l.replace(/^  /, "")) // strip 2-space continuation indent
        .join("\n")
        .trim()
    }
    return raw.trim()
  }
  return raw.trim()
}

/**
 * For streaming: kimi requires buffering the whole output before we know
 * which bullet is the final answer. Return empty string during streaming;
 * the doStream implementation emits the cleaned answer after process exits.
 */
function isBufferedOutput(providerID: string): boolean {
  return providerID === "kimi-cli"
}
