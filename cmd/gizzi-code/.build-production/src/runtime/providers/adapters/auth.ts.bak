import { Instance } from "@/runtime/context/project/instance"
import { Plugin } from "@/runtime/integrations/plugin"
import { map, filter, pipe, fromEntries, mapValues } from "remeda"
import z from "zod/v4"
import { fn } from "@/shared/util/fn"
import type { AuthOuathResult, Hooks, AuthCallbackResult, AuthCallbackResultSuccess, AuthAuthorizeResult } from "@allternit/plugin"

interface PendingAuth {
  token: string
  expiresAt?: number
  refreshToken?: string
  providerID?: string
  method?: string
  url: string
  instructions: string
  callback?: (code?: string) => Promise<AuthCallbackResult>
}
import { NamedError } from "@allternit/util/error"
import { Auth } from "@/runtime/integrations/auth"

export namespace ProviderAuth {
  const state = Instance.state(async () => {
    const methods = pipe(
      await Plugin.list(),
      filter((x) => x.auth?.provider !== undefined),
      map((x) => [x.auth!.provider, x.auth!] as const),
      fromEntries(),
    )
    return { methods, pending: {} as Record<string, PendingAuth> }
  })

  export const Method = z
    .object({
      type: z.union([z.literal("oauth"), z.literal("api"), z.literal("api_key")]),
      label: z.string(),
    })
    
  export type Method = z.infer<typeof Method>

  export async function methods() {
    const s = await state().then((x) => x.methods)
    return mapValues(s, (x) =>
      (x.methods ?? []).map(
        (y): Method => ({
          type: y.type === "api_key" ? "api" : y.type,
          label: y.label ?? y.name,
        }),
      ),
    )
  }

  export const Authorization = z
    .object({
      url: z.string(),
      method: z.union([z.literal("auto"), z.literal("code")]),
      instructions: z.string(),
    })
    
  export type Authorization = z.infer<typeof Authorization>

  export const authorize = fn(
    z.object({
      providerID: z.string(),
      method: z.number(),
    }),
    async (input): Promise<Authorization | undefined> => {
      const auth = await state().then((s) => s.methods[input.providerID])
      const method = auth?.methods?.[input.method]
      if (!method) return undefined
      if (method.type === "oauth" && method.authorize) {
        const result = await method.authorize()
        const oauthResult: PendingAuth = {
          token: "",
          url: result.url ?? "",
          method: result.method ?? "auto",
          instructions: result.instructions ?? "",
          callback: result.callback as ((code?: string) => Promise<AuthCallbackResult>) | undefined,
        }
        await state().then((s) => (s.pending[input.providerID] = oauthResult))
        return {
          url: oauthResult.url,
          method: oauthResult.method as "code" | "auto",
          instructions: oauthResult.instructions,
        }
      }
    },
  )

  export const callback = fn(
    z.object({
      providerID: z.string(),
      method: z.number(),
      code: z.string().optional(),
    }),
    async (input) => {
      const match = await state().then((s) => s.pending[input.providerID])
      if (!match) throw new OauthMissing({ providerID: input.providerID })
      let result

      let callbackResult: AuthCallbackResult | undefined
      
      if (match.method === "code") {
        if (!input.code) throw new OauthCodeMissing({ providerID: input.providerID })
        if (!match.callback) throw new OauthCallbackFailed({})
        callbackResult = await (match.callback(input.code) as unknown as Promise<AuthCallbackResult>)
      } else if (match.method === "auto") {
        if (!match.callback) throw new OauthCallbackFailed({})
        callbackResult = await (match.callback as unknown as () => Promise<AuthCallbackResult>)()
      }

      if (callbackResult?.type === "success") {
        const successResult = callbackResult as AuthCallbackResultSuccess
        if ("key" in successResult && successResult.key) {
          await Auth.set(input.providerID, {
            type: "api",
            key: successResult.key,
          })
        }
        if ("refresh" in successResult && successResult.refresh) {
          const info: Auth.Info = {
            type: "oauth",
            access: successResult.access ?? "",
            refresh: successResult.refresh,
            expires: successResult.expires ?? 0,
          }
          if (successResult.accountId) {
            info.accountId = successResult.accountId
          }
          await Auth.set(input.providerID, info)
        }
        return
      }

      throw new OauthCallbackFailed({})
    },
  )

  export const api = fn(
    z.object({
      providerID: z.string(),
      key: z.string(),
    }),
    async (input) => {
      await Auth.set(input.providerID, {
        type: "api",
        key: input.key,
      })
    },
  )

  export const OauthMissing = NamedError.create(
    "ProviderAuthOauthMissing",
    z.object({
      providerID: z.string(),
    }),
  )
  export const OauthCodeMissing = NamedError.create(
    "ProviderAuthOauthCodeMissing",
    z.object({
      providerID: z.string(),
    }),
  )

  export const OauthCallbackFailed = NamedError.create("ProviderAuthOauthCallbackFailed", z.object({}))
}
