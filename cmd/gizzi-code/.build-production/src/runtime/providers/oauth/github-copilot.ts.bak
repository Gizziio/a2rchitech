const GITHUB_CLIENT_ID = "Iv1.b507a08c87ecfe98"
const DEVICE_CODE_URL = "https://github.com/login/device/code"
const ACCESS_TOKEN_URL = "https://github.com/login/oauth/access_token"
const COPILOT_TOKEN_URL = "https://api.github.com/copilot_internal/v2/token"
const SCOPE = "read:user"

export const githubCopilotOAuth = {
  label: "Sign in with GitHub (Copilot subscription)",
  description: "Use your GitHub Copilot subscription",

  async authorize(_inputs: Record<string, string>) {
    // Request device code
    const deviceRes = await fetch(DEVICE_CODE_URL, {
      method: "POST",
      headers: { Accept: "application/json", "Content-Type": "application/x-www-form-urlencoded" },
      body: new URLSearchParams({ client_id: GITHUB_CLIENT_ID, scope: SCOPE }),
    })

    if (!deviceRes.ok) throw new Error(`GitHub device code failed: ${deviceRes.status}`)
    const device = (await deviceRes.json()) as {
      device_code: string
      user_code: string
      verification_uri: string
      expires_in: number
      interval: number
    }

    const expiresAt = Date.now() + device.expires_in * 1000
    const intervalMs = (device.interval ?? 5) * 1000

    return {
      url: device.verification_uri,
      method: "auto" as const,
      instructions: `Go to ${device.verification_uri} and enter code: ${device.user_code}`,
      async callback() {
        // Poll for token
        while (Date.now() < expiresAt) {
          await new Promise((r) => setTimeout(r, intervalMs))

          const tokenRes = await fetch(ACCESS_TOKEN_URL, {
            method: "POST",
            headers: { Accept: "application/json", "Content-Type": "application/x-www-form-urlencoded" },
            body: new URLSearchParams({
              client_id: GITHUB_CLIENT_ID,
              device_code: device.device_code,
              grant_type: "urn:ietf:params:oauth:grant-type:device_code",
            }),
          })

          if (!tokenRes.ok) continue
          const token = (await tokenRes.json()) as any

          if (token.error === "authorization_pending" || token.error === "slow_down") continue
          if (token.error === "access_denied") return { type: "failed" as const, error: "Access denied" }
          if (token.error === "expired_token") return { type: "failed" as const, error: "Code expired" }

          if (token.access_token) {
            // Exchange GitHub token for Copilot token to verify subscription
            const copilotRes = await fetch(COPILOT_TOKEN_URL, {
              headers: {
                Authorization: `token ${token.access_token}`,
                "User-Agent": "GizziCode/1.0",
              },
            })

            if (!copilotRes.ok) {
              return {
                type: "failed" as const,
                error: "No active Copilot subscription on this account",
              }
            }

            // Store GitHub access token (Copilot tokens are refreshed on demand)
            return {
              type: "success" as const,
              provider: "github-copilot",
              // Store as api key since GitHub tokens are long-lived
              key: token.access_token,
            }
          }
        }

        return { type: "failed" as const, error: "Device code expired" }
      },
    }
  },
}
