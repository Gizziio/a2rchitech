import { BusEvent } from "@/shared/bus/bus-event"
import { Bus } from "@/shared/bus"
import { spawn } from "bun"
import z from "zod/v4"
import { NamedError } from "@allternit/util/error"
import { Log } from "@/shared/util/log"

const SUPPORTED_IDES = [
  { name: "Windsurf" as const, cmd: "windsurf" },
  { name: "Visual Studio Code - Insiders" as const, cmd: "code-insiders" },
  { name: "Visual Studio Code" as const, cmd: "code" },
  { name: "Cursor" as const, cmd: "cursor" },
  { name: "VSCodium" as const, cmd: "codium" },
]

const EXTENSION_IDS = ["gizziio.vscode-gizzi", "gizzi-code.vscode-gizzi"] as const

export namespace Ide {
  const log = Log.create({ service: "ide" })

  export const Event = {
    Installed: BusEvent.define(
      "ide.installed",
      z.object({
        ide: z.string(),
      }),
    ),
  }

  export const AlreadyInstalledError = NamedError.create("AlreadyInstalledError", z.object({}))

  export const InstallFailedError = NamedError.create(
    "InstallFailedError",
    z.object({
      stderr: z.string(),
    }),
  )

  export function extensionIDs() {
    return [...EXTENSION_IDS]
  }

  export function ide() {
    if (process.env["TERM_PROGRAM"] === "vscode") {
      const v = process.env["GIT_ASKPASS"]
      for (const ide of SUPPORTED_IDES) {
        if (v?.includes(ide.name)) return ide.name
      }
    }
    return "unknown"
  }

  export function alreadyInstalled() {
    const caller = process.env["GIZZI_CALLER"]
    return caller === "vscode" || caller === "vscode-insiders"
  }

  export async function install(ide: (typeof SUPPORTED_IDES)[number]["name"]) {
    const cmd = SUPPORTED_IDES.find((i) => i.name === ide)?.cmd
    if (!cmd) throw new Error(`Unknown IDE: ${ide}`)

    let lastError = ""
    for (const extensionId of EXTENSION_IDS) {
      const p = spawn([cmd, "--install-extension", extensionId], {
        stdout: "pipe",
        stderr: "pipe",
      })
      await p.exited
      const stdout = await new Response(p.stdout).text()
      const stderr = await new Response(p.stderr).text()

      log.info("installed", {
        ide,
        extensionId,
        stdout,
        stderr,
      })

      if (stdout.includes("already installed")) {
        throw new AlreadyInstalledError({})
      }
      if (p.exitCode === 0) {
        return
      }
      lastError = stderr || stdout || `Failed to install ${extensionId}`
    }

    throw new InstallFailedError({ stderr: lastError })
  }
}
