/**
 * Plugin Registry
 *
 * Curated catalog of Gizzi plugins with categories, metadata, and
 * a remote refresh mechanism. The static list is always available offline;
 * remote fetches extend it with community / third-party listings.
 *
 * Entry types:
 *   plugin    — npm package with hooks (auth, workflow, theme, tools)
 *   skillpack — domain skill pack; contributes slash commands via SKILL.md files
 *   connector — OAuth integration that adds an MCP server + credential storage
 */

export type PluginCategory =
  | "auth"
  | "mcp"
  | "provider"
  | "tools"
  | "theme"
  | "search"
  | "workflow"
  | "skillpack"
  | "connector"
  | "community"

export type PluginType = "plugin" | "skillpack" | "connector"

export interface RegistryEntry {
  /** npm package name or connector ID */
  name: string
  /** Short human-readable label */
  label: string
  description: string
  category: PluginCategory
  /** Entry type — defaults to "plugin" */
  type?: PluginType
  author: string
  /** Latest known version */
  version?: string
  /** Homepage / docs URL */
  homepage?: string
  /** Star count / download rank proxy */
  downloads?: number
  /** Official / first-party entry */
  verified?: boolean
  /** Keywords for search matching */
  keywords?: string[]
  /**
   * For skillpack entries: the slash commands this pack provides.
   * Shown as /command pills in the marketplace listing.
   */
  skills?: string[]
  /**
   * For skillpack entries: always available without install.
   * Install/remove buttons are hidden for builtin entries.
   */
  builtin?: boolean
  /**
   * For connector entries: the OAuth provider slug.
   * Used to initiate the auth flow.
   */
  oauthProvider?: string
}

