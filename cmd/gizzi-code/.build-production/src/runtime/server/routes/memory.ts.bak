import { Hono } from "hono"
import { describeRoute, resolver, validator } from "hono-openapi"
import z from "zod/v4"
import { MemoryService } from "@/runtime/memory/memory-service"
import { errors } from "@/runtime/server/error"

const MemoryTypeSchema = z.enum(["user", "feedback", "project", "reference"])

const MemoryListItemSchema = z.object({
  filename: z.string(),
  name: z.string(),
  description: z.string(),
  type: MemoryTypeSchema,
  filepath: z.string(),
})

const MemoryEntrySchema = MemoryListItemSchema.extend({
  body: z.string().optional(),
})

const MemorySearchQuerySchema = z.object({
  q: z.string().optional(),
})

const MemoryWriteSchema = z.object({
  name: z.string(),
  description: z.string(),
  type: MemoryTypeSchema,
  body: z.string(),
})

const MemoryFilenameParamSchema = z.object({
  filename: z.string(),
})

export function MemoryRoutes() {
  return new Hono()
    // GET /memory — list all memory entries
    .get(
      "/",
      describeRoute({
        summary: "List memory entries",
        description: "List all stored memory entries available to the current Gizzi workspace.",
        operationId: "memory.list",
        responses: {
          200: {
            description: "Stored memory entries",
            content: { "application/json": { schema: resolver(z.array(MemoryListItemSchema)) } },
          },
        },
      }),
      async (c) => {
        const entries = await MemoryService.list()
        return c.json(
          entries.map((e) => ({
            filename: e.filename,
            name: e.name,
            description: e.description,
            type: e.type,
            filepath: e.filepath,
          })),
        )
      },
    )

    // GET /memory/search?q=<query> — search memories
    .get(
      "/search",
      describeRoute({
        summary: "Search memory entries",
        description: "Search stored memory entries by free-text query.",
        operationId: "memory.search",
        responses: {
          200: {
            description: "Matching memory entries",
            content: { "application/json": { schema: resolver(z.array(MemoryEntrySchema)) } },
          },
        },
      }),
      validator("query", MemorySearchQuerySchema),
      async (c) => {
        const { q } = c.req.valid("query")
        const entries = q ? await MemoryService.search(q) : await MemoryService.list()
        return c.json(entries)
      },
    )

    // GET /memory/:filename — read a specific memory
    .get(
      "/:filename",
      describeRoute({
        summary: "Get memory entry",
        description: "Read a specific stored memory entry by filename.",
        operationId: "memory.get",
        responses: {
          200: {
            description: "Stored memory entry",
            content: { "application/json": { schema: resolver(MemoryEntrySchema) } },
          },
          ...errors(404),
        },
      }),
      validator("param", MemoryFilenameParamSchema),
      async (c) => {
        const { filename } = c.req.valid("param")
        const entry = await MemoryService.get(filename.endsWith(".md") ? filename : filename + ".md")
        if (!entry) return c.json({ name: "NotFound", message: `Memory not found: ${filename}`, data: {} }, 404)
        return c.json(entry)
      },
    )

    // PUT /memory/:filename — save / update a memory
    .put(
      "/:filename",
      describeRoute({
        summary: "Save memory entry",
        description: "Create or update a stored memory entry.",
        operationId: "memory.put",
        responses: {
          200: {
            description: "Stored memory entry",
            content: { "application/json": { schema: resolver(MemoryEntrySchema) } },
          },
        },
      }),
      validator("param", MemoryFilenameParamSchema),
      validator("json", MemoryWriteSchema),
      async (c) => {
        const body = c.req.valid("json")
        const entry = await MemoryService.save(
          { name: body.name, description: body.description, type: body.type },
          body.body,
        )
        return c.json(entry)
      },
    )

    // DELETE /memory/:filename — delete a memory
    .delete(
      "/:filename",
      describeRoute({
        summary: "Delete memory entry",
        description: "Delete a stored memory entry by filename.",
        operationId: "memory.delete",
        responses: {
          200: {
            description: "Deletion result",
            content: { "application/json": { schema: resolver(z.boolean()) } },
          },
          ...errors(404),
        },
      }),
      validator("param", MemoryFilenameParamSchema),
      async (c) => {
        const { filename } = c.req.valid("param")
        const ok = await MemoryService.remove(filename.endsWith(".md") ? filename : filename + ".md")
        if (!ok) return c.json({ name: "NotFound", message: `Memory not found: ${filename}`, data: {} }, 404)
        return c.json(true)
      },
    )
}
