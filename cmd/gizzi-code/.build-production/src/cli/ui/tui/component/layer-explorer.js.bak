import { readdir } from "fs/promises";
async function scanLayerFiles(workspacePath, layerPath, depth = 0) {
  if (depth > 2) return []; // Limit recursion depth

  try {
    const entries = await readdir(layerPath, {
      withFileTypes: true
    });
    const files = [];
    for (const entry of entries) {
      const fullPath = path.join(layerPath, entry.name);
      const isDir = entry.isDirectory();
      const file = {
        name: entry.name,
        path: fullPath,
        type: isDir ? "directory" : "file"
      };
      if (isDir && depth < 2) {
        file.children = await scanLayerFiles(workspacePath, fullPath, depth + 1);
      }
      files.push(file);
    }

    // Sort: directories first, then files
    return files.sort((a, b) => {
      if (a.type === b.type) return a.name.localeCompare(b.name);
      return a.type === "directory" ? -1 : 1;
    });
  } catch {
    return [];
  }
}
