import { createComponent as _$createComponent } from "@opentui/solid";
/**
 * Agent Communication Dialog - TUI Component
 * 
 * Displays agent-to-agent communication in the terminal UI.
 * Shows messages, channels, and unread counts.
 */

import { createMemo, createSignal } from "solid-js";
import { useDialog } from "@/cli/ui/tui/ui/dialog";
import { DialogSelect } from "@/cli/ui/tui/ui/dialog-select";
import { useTheme } from "@/cli/ui/tui/context/theme";
import { useKeybind } from "@/cli/ui/tui/context/keybind";
import { useSync } from "@/cli/ui/tui/context/sync";

// Message type for agent communication

// Channel type for agent channels

export function DialogAgentCommunication(props) {
  const dialog = useDialog();
  const {
    theme
  } = useTheme();
  const keybind = useKeybind();
  const sync = useSync();
  const [selectedTab, setSelectedTab] = createSignal("messages");
  const [unreadCount, setUnreadCount] = createSignal(0);

  // Extract agent-to-agent messages from session parts
  const messages = createMemo(() => {
    const msgs = sync.data.message[props.sessionID];
    if (!msgs) return [];
    const result = [];
    for (const msg of msgs) {
      if (msg.role !== "assistant") continue;
      const parts = sync.data.part[msg.id] ?? [];
      const agentParts = parts.filter(p => p.type === "agent");
      if (agentParts.length === 0) continue;
      const textContent = parts.filter(p => p.type === "text").map(p => p.text ?? "").join("").slice(0, 100);
      for (const agentPart of agentParts) {
        result.push({
          id: `${msg.id}-${agentPart.name}`,
          from: {
            agentName: agentPart.name
          },
          to: {
            agentName: "coordinator"
          },
          content: agentPart.source?.value ?? textContent
        });
      }
    }
    return result;
  });

  // Derive channels from unique agent names seen in session parts
  const channels = createMemo(() => {
    const msgs = sync.data.message[props.sessionID];
    if (!msgs) return [];
    const agentNames = new Set();
    for (const msg of msgs) {
      const parts = sync.data.part[msg.id] ?? [];
      for (const part of parts) {
        if (part.type === "agent") agentNames.add(part.name);
      }
    }
    return [...agentNames].map(name => ({
      id: name,
      name,
      members: [name, "coordinator"]
    }));
  });

  // Format message content for display
  const formatMessage = msg => {
    const recipient = msg.to.channel ? `#${msg.to.channel}` : msg.to.agentName || "broadcast";
    const mentions = msg.mentions && msg.mentions.length > 0 ? ` ${msg.mentions.map(m => `@${m}`).join(" ")}` : "";
    return {
      title: `${msg.from.agentName} → ${recipient}: ${msg.content.slice(0, 60)}`,
      description: mentions,
      value: undefined
    };
  };

  // Format channel for display
  const formatChannel = channel => {
    return {
      title: `#${channel.name}`,
      description: `(${channel.members.length} members)`,
      value: undefined
    };
  };

  // Create options based on selected tab
  const options = createMemo(() => {
    const opts = selectedTab() === "messages" ? messages().slice(0, 10).map(formatMessage) : channels().map(formatChannel);

    // Add empty state option
    if (opts.length === 0) {
      return [{
        title: selectedTab() === "messages" ? "No agent messages yet" : "No channels yet",
        disabled: true,
        value: undefined
      }];
    }
    return opts;
  });
  const title = createMemo(() => {
    const unread = unreadCount();
    return `Agent Communication${unread > 0 ? ` (${unread} unread)` : ""}`;
  });
  return _$createComponent(DialogSelect, {
    get title() {
      return title();
    },
    get options() {
      return options();
    },
    onSelect: () => {
      dialog.clear();
    },
    skipFilter: true
  });
}
export default DialogAgentCommunication;