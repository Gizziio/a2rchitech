import { createComponent as _$createComponent } from "@opentui/solid";
import { memo as _$memo } from "@opentui/solid";
import { DialogSelect } from "@/cli/ui/tui/ui/dialog-select";
import { createResource, createMemo, Show } from "solid-js";
import { useDialog } from "@/cli/ui/tui/ui/dialog";
import { useSDK } from "@/cli/ui/tui/context/sdk";
import { GIZZICopy, sanitizeBrandSurface } from "@/shared/brand";
import { useTheme } from "@/cli/ui/tui/context/theme";

// Local type definition since SDK exports unknown

export function DialogSkill(props) {
  const dialog = useDialog();
  const sdk = useSDK();
  const {
    theme
  } = useTheme();
  dialog.setSize("large");
  const [skills] = createResource(async () => {
    const res = await sdk.client.app.skills();
    return sdk.dataOr(res, []);
  });
  const options = createMemo(() => {
    const list = skills() ?? [];
    const maxWidth = Math.max(0, ...list.map(s => s.name.length));
    return list.map(skill => ({
      title: skill.name.padEnd(maxWidth),
      description: skill.description ? sanitizeBrandSurface(skill.description.replace(/\s+/g, " ").trim()) : undefined,
      value: skill.name,
      category: GIZZICopy.dialogs.skillsCategory,
      onSelect: () => {
        props.onSelect(skill.name);
        dialog.clear();
      }
    }));
  });
  return _$createComponent(Show, {
    get when() {
      return !skills.error;
    },
    get fallback() {
      return _$createComponent(DialogSelect, {
        get title() {
          return GIZZICopy.dialogs.skillsTitle;
        },
        placeholder: "",
        get options() {
          return [{
            title: "Failed to load skills",
            description: String(skills.error?.message ?? "Unknown error"),
            value: "",
            onSelect: () => dialog.clear()
          }];
        }
      });
    },
    get children() {
      return _$createComponent(DialogSelect, {
        get title() {
          return GIZZICopy.dialogs.skillsTitle;
        },
        get placeholder() {
          return _$memo(() => !!skills.loading)() ? GIZZICopy.dialogs.loading : GIZZICopy.dialogs.skillsSearchPlaceholder;
        },
        get options() {
          return options();
        }
      });
    }
  });
}