import { createComponent as _$createComponent } from "@opentui/solid";
import { createMemo, createResource } from "solid-js";
import { DialogSelect } from "@/cli/ui/tui/ui/dialog-select";
import { useDialog } from "@/cli/ui/tui/ui/dialog";
import { useSDK } from "@/cli/ui/tui/context/sdk";
import { createStore } from "solid-js/store";
import { GIZZICopy } from "@/shared/brand";
export function DialogTag(props) {
  const sdk = useSDK();
  const dialog = useDialog();
  const [store] = createStore({
    filter: ""
  });
  const [files] = createResource(() => [store.filter], async () => {
    const result = await sdk.client.file.glob({
      query: {
        query: store.filter
      }
    });
    const sliced = sdk.dataOr(result, []).slice(0, 5);
    return sliced;
  });
  const options = createMemo(() => (files() ?? []).map(file => ({
    value: file,
    title: file
  })));
  return _$createComponent(DialogSelect, {
    get title() {
      return GIZZICopy.dialogs.autocompleteTitle;
    },
    get options() {
      return options();
    },
    onSelect: option => {
      props.onSelect?.(option.value);
      dialog.clear();
    }
  });
}