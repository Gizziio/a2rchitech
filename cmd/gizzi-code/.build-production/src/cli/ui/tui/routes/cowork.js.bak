        const text = msgPartsList.filter(p => p.type === "text").map(p => p.text).join("");
        blocks.push({
          type: "message",
          actor: "user",
          content: text || "...",
          timestamp: msg.time?.created
        });
      } else {
        for (const part of msgPartsList) {
          if (part.type === "tool") {
            blocks.push({
              type: "tool",
              tool: part.tool || "unknown",
              args: part.args || {},
              result: part.result,
              error: part.error,
