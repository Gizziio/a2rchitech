function truncateMiddle(value, max) {
  if (max <= 0) return "";
  if (value.length <= max) return value;
  if (max === 1) return "…";
  const left = Math.ceil((max - 1) / 2);
  const right = Math.floor((max - 1) / 2);
  return `${value.slice(0, left)}…${value.slice(-right)}`;
}