  }, {
    title: showGenericToolOutput() ? GIZZICopy.palette.hideGenericToolOutput : GIZZICopy.palette.showGenericToolOutput,
    value: "session.toggle.generic_tool_output",
    category: GIZZICopy.prompt.categorySession,
