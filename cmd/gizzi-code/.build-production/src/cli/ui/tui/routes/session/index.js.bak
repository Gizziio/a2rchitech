  let activeSyncRequest = 0;
  createEffect(on(() => route.sessionID, async sessionID => {
    const requestID = ++activeSyncRequest;
    const isStaleRequest = () => requestID !== activeSyncRequest || route.sessionID !== sessionID;
    const pause = ms => new Promise(resolve => setTimeout(resolve, ms));
    const readStatusCode = error => Number(error?.status ?? error?.statusCode ?? error?.response?.status ?? error?.cause?.status ?? NaN);
    const classifyMissingFromError = error => {
