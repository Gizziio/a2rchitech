      const lower = message.toLowerCase();
      const statusCode = readStatusCode(error);
      return statusCode === 404 || lower.includes("session not found") || lower.includes("not found") && lower.includes("session") || lower.includes("404") && lower.includes("session");
    };
    const checkSessionExistence = async () => {
      for (let attempt = 0; attempt < 4; attempt++) {
