import { useRenderer } from "@opentui/solid";
import { createSimpleContext } from "@/cli/ui/tui/context/helper";
import { FormatError, FormatUnknownError } from "@/shared/error/format";
import { win32FlushInputBuffer } from "@/cli/ui/tui/win32";
export const {
  use: useExit,
  provider: ExitProvider
} = createSimpleContext({
  name: "Exit",
  init: input => {
    const renderer = useRenderer();
    let message;
    const store = {
      set: value => {
        const prev = message;
        message = value;
        return () => {
          message = prev;
        };
      },
      clear: () => {
        message = undefined;
      },
      get: () => message
    };
    const exit = Object.assign(async reason => {
      // Reset window title before destroying renderer
      renderer.setTerminalTitle("");
      renderer.destroy();
      win32FlushInputBuffer();
      if (reason) {
        const formatted = FormatError(reason) ?? FormatUnknownError(reason);
        if (formatted) {
          process.stderr.write(formatted + "\n");
        }
      }
      const text = store.get();
      if (text) process.stdout.write(text + "\n");
      await input.onExit?.();
    }, {
      message: store
    });
    return exit;
  }
});