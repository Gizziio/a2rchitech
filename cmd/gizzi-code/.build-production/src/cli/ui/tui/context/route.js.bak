import { createStore } from "solid-js/store";
import { createSimpleContext } from "@/cli/ui/tui/context/helper";
export const {
  use: useRoute,
  provider: RouteProvider
} = createSimpleContext({
  name: "Route",
  init: () => {
    const [store, setStore] = createStore(process.env["GIZZI_ROUTE"] ? JSON.parse(process.env["GIZZI_ROUTE"]) : {
      type: "home"
    });
    return {
      get data() {
        return store;
      },
      navigate(route) {
        setStore(route);
      }
    };
  }
});
export function useRouteData(type) {
  const route = useRoute();
  return route.data;
}