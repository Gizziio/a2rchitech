import { cmd } from "@/cli/commands/cmd"
import { UI } from "@/cli/ui"
import { Instance } from "@/runtime/context/project/instance"
import { Filesystem } from "@/shared/util/filesystem"
import path from "path"

// Config file for effort settings
const CONFIG_FILE = ".gizzi/gizzi.json"

type EffortLevel = "low" | "medium" | "high" | "max"

interface EffortConfig {
  level: EffortLevel
  description: string
  maxTokens: number
  thinkingSteps: boolean
}

const EFFORT_LEVELS: Record<EffortLevel, EffortConfig> = {
  low: {
    level: "low",
    description: "Quick responses, minimal reasoning",
    maxTokens: 1024,
    thinkingSteps: false,
  },
  medium: {
    level: "medium",
    description: "Balanced reasoning (default)",
    maxTokens: 4096,
    thinkingSteps: true,
  },
  high: {
    level: "high",
    description: "Deep reasoning, thorough analysis",
    maxTokens: 8192,
    thinkingSteps: true,
  },
  max: {
    level: "max",
    description: "Maximum effort, comprehensive solutions",
    maxTokens: 8192,
    thinkingSteps: true,
  },
}

async function readCurrentEffort(): Promise<EffortLevel> {
  const configPath = path.join(Instance.directory, CONFIG_FILE)
  try {
    const content = await Filesystem.readText(configPath)
    const parsed = JSON.parse(content)
    return parsed.preferences?.effort || "medium"
  } catch {
    return "medium"
  }
}

async function writeEffort(level: EffortLevel): Promise<void> {
  const configPath = path.join(Instance.directory, CONFIG_FILE)
  let config: any = {}

  try {
    const content = await Filesystem.readText(configPath)
    config = JSON.parse(content)
  } catch {
    // Create new config
  }

  config.preferences ??= {}
  config.preferences.effort = level
  config.preferences.maxTokens = EFFORT_LEVELS[level].maxTokens

  await Filesystem.write(configPath, JSON.stringify(config, null, 2))
}

function renderEffortStatus(current: EffortLevel): string {
  const lines: string[] = []

  lines.push("")
  lines.push(UI.Style.TEXT_INFO_BOLD + "Effort Level" + UI.Style.TEXT_NORMAL)
  lines.push("")

  for (const [level, config] of Object.entries(EFFORT_LEVELS)) {
    const isCurrent = level === current
    const marker = isCurrent ? UI.Style.TEXT_SUCCESS_BOLD + "→ " + UI.Style.TEXT_NORMAL : "  "
    const name = isCurrent ? UI.Style.TEXT_BOLD + config.level + UI.Style.TEXT_NORMAL : config.level
    const desc = UI.Style.TEXT_DIM + config.description + UI.Style.TEXT_NORMAL

    lines.push(`${marker}${name.padEnd(8)} ${desc}`)

    if (isCurrent) {
      lines.push(`        Max tokens: ${UI.Style.TEXT_INFO}${config.maxTokens}${UI.Style.TEXT_NORMAL}`)
      lines.push(`        Thinking: ${config.thinkingSteps ? UI.Style.TEXT_SUCCESS + "enabled" : UI.Style.TEXT_DIM + "disabled"}${UI.Style.TEXT_NORMAL}`)
    }
  }

  lines.push("")
  lines.push(UI.Style.TEXT_DIM + "Usage: /effort <low|medium|high|max>" + UI.Style.TEXT_NORMAL)
  lines.push("")

  return lines.join("\n")
}

export const EffortCommand = cmd({
  command: "effort",
  describe: "set effort level for agent responses",
  aliases: ["think"], // Keep /think as alias for backward compatibility
  builder: (yargs) =>
    yargs
      .positional("level", {
        type: "string",
        choices: ["low", "medium", "high", "max"],
        describe: "effort level",
      })
      .option("low", {
        type: "boolean",
        describe: "quick responses",
      })
      .option("medium", {
        type: "boolean",
        describe: "balanced reasoning",
      })
      .option("high", {
        type: "boolean",
        describe: "deep reasoning",
      })
      .option("max", {
        type: "boolean",
        describe: "maximum effort",
      }),
  handler: async (args) => {
    const current = await readCurrentEffort()

    // Determine target level
    let target: EffortLevel | undefined

    if (args.level) {
      target = args.level as EffortLevel
    } else if (args.low) {
      target = "low"
    } else if (args.medium) {
      target = "medium"
    } else if (args.high) {
      target = "high"
    } else if (args.max) {
      target = "max"
    }

    // Show status if no level specified
    if (!target) {
      UI.println(renderEffortStatus(current))
      return
    }

    // Set effort level
    await writeEffort(target)

    const config = EFFORT_LEVELS[target]
    UI.println(UI.Style.TEXT_SUCCESS_BOLD + `Effort set to: ${target}` + UI.Style.TEXT_NORMAL)
    UI.println(`  ${UI.Style.TEXT_DIM}${config.description}${UI.Style.TEXT_NORMAL}`)
    UI.println(`  Max tokens: ${UI.Style.TEXT_INFO}${config.maxTokens}${UI.Style.TEXT_NORMAL}`)

    if (target === "max") {
      UI.println("")
      UI.println(UI.Style.TEXT_WARNING + "Max effort uses significantly more tokens" + UI.Style.TEXT_NORMAL)
    }
  },
})
