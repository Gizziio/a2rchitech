import type { Argv } from "yargs"
import path from "path"
import { cmd } from "@/cli/commands/cmd"
import { bootstrap } from "@/cli/bootstrap"
import { UI } from "@/cli/ui"
import { Workspace } from "@/runtime/workspace/workspace"
import { AgentWorkspace } from "@/runtime/memory/memory"
import * as Bridge from "@/runtime/kernel/bridge"
import { EOL } from "os"

// ── gizzi workspace ───────────────────────────────────────────────────────────

export const WorkspaceCommand = cmd({
  command: "workspace",
  describe: "manage agent workspace (.gizzi/)",
  builder: (yargs: Argv) =>
    yargs
      .command(WorkspaceInitCommand)
      .command(WorkspaceStatusCommand)
      .command(WorkspaceImportCommand)
      .demandCommand(),
  async handler() {},
})

// ── gizzi workspace init ──────────────────────────────────────────────────────

export const WorkspaceInitCommand = cmd({
  command: "init",
  describe: "create a .gizzi/ workspace in the current directory",
  builder: (yargs: Argv) =>
    yargs
      .option("format", {
        describe: "workspace format: flat (OpenClaw-compatible) or layered (A2R 5-layer)",
        type: "string",
        choices: ["flat", "layered"] as const,
        default: "flat",
      })
      .option("name", {
        describe: "agent name",
        type: "string",
      })
      .option("emoji", {
        describe: "agent emoji",
        type: "string",
      })
      .option("vibe", {
        describe: "agent vibe / personality",
        type: "string",
      })
      .option("global", {
        describe: "create in ~/.gizzi/ instead of the current directory",
        type: "boolean",
        default: false,
      }),
  handler: async (args) => {
    await bootstrap(process.cwd(), async () => {
      const cwd = process.cwd()
      const workspacePath = args.global
        ? Workspace.globalPath
        : path.join(cwd, ".gizzi")

      UI.empty()
      UI.println(UI.Style.TEXT_INFO_BOLD + `Initializing ${args.format} workspace...` + UI.Style.TEXT_NORMAL)
      UI.empty()

      if (args.format === "layered") {
        const parentDir = args.global ? path.dirname(Workspace.globalPath) : cwd
        await AgentWorkspace.initialize(parentDir, { runner: "gizzi" })
        UI.println(UI.Style.TEXT_SUCCESS_BOLD + "  +  " + UI.Style.TEXT_NORMAL + `Created 5-layer workspace at ${workspacePath}/`)
        UI.println(UI.Style.TEXT_DIM + "     L1-COGNITIVE/  L2-IDENTITY/  L3-GOVERNANCE/  L4-SKILLS/" + UI.Style.TEXT_NORMAL)
      } else {
        await Workspace.init(workspacePath, {
          name: args.name,
          emoji: args.emoji,
          vibe: args.vibe,
        })
        UI.println(UI.Style.TEXT_SUCCESS_BOLD + "  +  " + UI.Style.TEXT_NORMAL + `Created flat workspace at ${workspacePath}/`)
        UI.println(UI.Style.TEXT_DIM + "     IDENTITY.md  SOUL.md  USER.md  MEMORY.md  AGENTS.md" + UI.Style.TEXT_NORMAL)
      }

      UI.empty()
      UI.println(UI.Style.TEXT_SUCCESS_BOLD + "Done!" + UI.Style.TEXT_NORMAL + " Edit the files in .gizzi/ to configure your agent.")
      UI.empty()
    })
  },
})

// ── gizzi workspace status ────────────────────────────────────────────────────

export const WorkspaceStatusCommand = cmd({
  command: "status",
  describe: "show the active workspace",
  builder: (yargs: Argv) =>
    yargs.option("format", {
      describe: "output format",
      type: "string",
      choices: ["table", "json"] as const,
      default: "table",
    }),
  handler: async (args) => {
    await bootstrap(process.cwd(), async () => {
      const ws = await Bridge.detectWorkspace(process.cwd()).catch(() => null)

      if (!ws) {
        UI.empty()
        UI.println(UI.Style.TEXT_DIM + "No workspace found." + UI.Style.TEXT_NORMAL)
        UI.println(
          UI.Style.TEXT_DIM +
            "Run " +
            UI.Style.TEXT_NORMAL +
            UI.Style.TEXT_INFO_BOLD +
            "gizzi workspace init" +
            UI.Style.TEXT_NORMAL +
            UI.Style.TEXT_DIM +
            " to create one." +
            UI.Style.TEXT_NORMAL,
        )
        UI.empty()
        return
      }

      if (args.format === "json") {
        process.stdout.write(
          JSON.stringify(
            {
              type: ws.type,
              format: ws.format,
              path: ws.path,
              name: ws.identity?.name,
              emoji: ws.identity?.emoji,
              vibe: ws.identity?.vibe,
              layered: ws.identity?.layered ?? false,
              agentID: ws.agentID,
              files: {
                hasSoul: !!ws.identity?.soul,
                hasIdentity: !!ws.identity?.identity,
                hasUser: !!ws.identity?.user,
                hasMemory: !!ws.identity?.memory,
                hasAgents: !!ws.identity?.agents,
                hasBrain: !!ws.identity?.brain,
                hasVoice: !!ws.identity?.voice,
                hasPolicy: !!ws.identity?.policy,
              },
            },
            null,
            2,
          ) + EOL,
        )
        return
      }

      // Table output
      const id = ws.identity
      const emoji = id?.emoji ?? ""
      const name = id?.name ?? "Gizzi Agent"
      const vibe = id?.vibe ?? ""

      UI.empty()
      UI.println(UI.Style.TEXT_INFO_BOLD + `${emoji}  ${name}` + UI.Style.TEXT_NORMAL)
      if (vibe) UI.println(UI.Style.TEXT_DIM + `   ${vibe}` + UI.Style.TEXT_NORMAL)
      UI.empty()

      const row = (label: string, value: string) =>
        UI.println(`  ${(label + ":").padEnd(12)} ${value}`)

      row("Format", ws.format === "layered" ? "5-layer (A2R)" : "flat (OpenClaw-compatible)")
      row("Path", ws.path)
      if (ws.agentID) row("Agent ID", ws.agentID)

      UI.empty()

      if (ws.format === "layered") {
        UI.println(UI.Style.TEXT_DIM + "  Layers:" + UI.Style.TEXT_NORMAL)
        const check = (label: string, exists: boolean) =>
          UI.println(
            `    ${exists ? UI.Style.TEXT_SUCCESS_BOLD + "✓" : UI.Style.TEXT_DIM + "·"}  ${label}` + UI.Style.TEXT_NORMAL,
          )
        check("L1-COGNITIVE  (brain + memory)", !!id?.brain || !!id?.memory)
        check("L2-IDENTITY   (soul + identity + voice + policy)", !!id?.soul || !!id?.identity)
        check("L3-GOVERNANCE (playbook + agents)", !!id?.agents)
        check("L4-SKILLS     (skill files)", false) // can't check without fs scan here
      } else {
        UI.println(UI.Style.TEXT_DIM + "  Files:" + UI.Style.TEXT_NORMAL)
        const check = (label: string, exists: boolean) =>
          UI.println(
            `    ${exists ? UI.Style.TEXT_SUCCESS_BOLD + "✓" : UI.Style.TEXT_DIM + "·"}  ${label}` + UI.Style.TEXT_NORMAL,
          )
        check("IDENTITY.md", !!id?.identity)
        check("SOUL.md", !!id?.soul)
        check("USER.md", !!id?.user)
        check("MEMORY.md", !!id?.memory)
        check("AGENTS.md", !!id?.agents)
      }

      UI.empty()
    })
  },
})

// ── gizzi workspace import ────────────────────────────────────────────────────

export const WorkspaceImportCommand = cmd({
  command: "import",
  describe: "import workspace files from ~/.openclaw/workspace/",
  builder: (yargs: Argv) =>
    yargs.option("force", {
      describe: "overwrite existing files",
      type: "boolean",
      default: false,
    }),
  handler: async (args) => {
    await bootstrap(process.cwd(), async () => {
      UI.empty()
      UI.println(UI.Style.TEXT_INFO_BOLD + "Importing from ~/.openclaw/workspace/..." + UI.Style.TEXT_NORMAL)
      UI.empty()

      try {
        const result = await Workspace.importFromOpenClaw(undefined, { force: args.force })
        const { imported, skipped } = result

        if (imported.length === 0 && skipped.length === 0) {
          UI.println(UI.Style.TEXT_DIM + "  Nothing to import — no OpenClaw files found." + UI.Style.TEXT_NORMAL)
        } else {
          for (const f of imported) {
            UI.println(UI.Style.TEXT_SUCCESS_BOLD + "  +  " + UI.Style.TEXT_NORMAL + f)
          }
          for (const f of skipped) {
            UI.println(UI.Style.TEXT_DIM + "  ·  " + UI.Style.TEXT_NORMAL + `${f} (skipped — already exists)`)
          }
        }

        UI.empty()
        UI.println(UI.Style.TEXT_SUCCESS_BOLD + "Done!" + UI.Style.TEXT_NORMAL)
        UI.empty()
      } catch (e: any) {
        UI.error(e.message ?? "Import failed")
        process.exitCode = 1
      }
    })
  },
})
