import { cmd } from "@/cli/commands/cmd"
import { UI } from "@/cli/ui"
import { Instance } from "@/runtime/context/project/instance"
import { Filesystem } from "@/shared/util/filesystem"
import * as prompts from "@clack/prompts"
import path from "path"

// Additional directories file
const DIRS_FILE = ".gizzi/additional-dirs.json"

interface AdditionalDir {
  path: string
  addedAt: string
  name?: string
}

async function readDirs(): Promise<AdditionalDir[]> {
  const dirsPath = path.join(Instance.directory, DIRS_FILE)
  try {
    const content = await Filesystem.readText(dirsPath)
    return JSON.parse(content)
  } catch {
    return []
  }
}

async function writeDirs(dirs: AdditionalDir[]): Promise<void> {
  const dirsPath = path.join(Instance.directory, DIRS_FILE)
  await Filesystem.write(dirsPath, JSON.stringify(dirs, null, 2))
}

function renderDirs(dirs: AdditionalDir[]): string {
  const lines: string[] = []

  lines.push("")
  lines.push(UI.Style.TEXT_INFO_BOLD + "Additional Directories" + UI.Style.TEXT_NORMAL)
  lines.push("")

  if (dirs.length === 0) {
    lines.push("  " + UI.Style.TEXT_DIM + "No additional directories" + UI.Style.TEXT_NORMAL)
    lines.push("")
    lines.push("Use " + UI.Style.TEXT_INFO + "/add-dir <path>" + UI.Style.TEXT_NORMAL + " to add workspace folders")
    lines.push("")
    return lines.join("\n")
  }

  lines.push(`  ${"#".padEnd(4)} ${"Name".padEnd(20)} ${"Path"}`)
  lines.push(`  ${"-".repeat(60)}`)

  for (let i = 0; i < dirs.length; i++) {
    const dir = dirs[i]
    const name = (dir.name || path.basename(dir.path)).slice(0, 18)
    const displayPath = dir.path.length > 35 ? "..." + dir.path.slice(-32) : dir.path
    lines.push(`  ${String(i).padEnd(4)} ${name.padEnd(20)} ${UI.Style.TEXT_DIM}${displayPath}${UI.Style.TEXT_NORMAL}`)
  }

  lines.push("")
  return lines.join("\n")
}

export const AddDirCommand = cmd({
  command: "add-dir",
  describe: "add additional working directories (multi-root workspace)",
  builder: (yargs) =>
    yargs
      .positional("path", {
        type: "string",
        describe: "directory path to add",
      })
      .option("list", {
        type: "boolean",
        alias: "l",
        describe: "list added directories",
      })
      .option("remove", {
        type: "number",
        alias: "r",
        describe: "remove directory by index",
      })
      .option("name", {
        type: "string",
        alias: "n",
        describe: "custom name for the directory",
      })
      .option("clear", {
        type: "boolean",
        alias: "c",
        describe: "clear all additional directories",
      }),
  handler: async (args) => {
    let dirs = await readDirs()

    // List directories
    if (args.list) {
      UI.println(renderDirs(dirs))
      return
    }

    // Remove directory
    if (args.remove !== undefined) {
      if (args.remove < 0 || args.remove >= dirs.length) {
        UI.println(UI.Style.TEXT_ERROR + `Invalid index: ${args.remove}` + UI.Style.TEXT_NORMAL)
        return
      }
      const removed = dirs.splice(args.remove, 1)[0]
      await writeDirs(dirs)
      UI.println(UI.Style.TEXT_DIM + `Removed: ${removed.path}` + UI.Style.TEXT_NORMAL)
      return
    }

    // Clear all
    if (args.clear) {
      const count = dirs.length
      dirs = []
      await writeDirs(dirs)
      UI.println(UI.Style.TEXT_DIM + `Cleared ${count} directories` + UI.Style.TEXT_NORMAL)
      return
    }

    // Add directory
    const dirPath = args.path || process.cwd()
    const resolvedPath = path.resolve(dirPath)

    // Check if exists
    if (!(await Filesystem.exists(resolvedPath))) {
      UI.println(UI.Style.TEXT_ERROR + `Directory does not exist: ${resolvedPath}` + UI.Style.TEXT_NORMAL)
      return
    }

    // Check if already added
    if (dirs.some((d) => d.path === resolvedPath)) {
      UI.println(UI.Style.TEXT_WARNING + `Already added: ${resolvedPath}` + UI.Style.TEXT_NORMAL)
      return
    }

    // Check if it's the main directory
    if (resolvedPath === Instance.directory) {
      UI.println(UI.Style.TEXT_WARNING + "This is already the main workspace directory" + UI.Style.TEXT_NORMAL)
      return
    }

    // Add it
    dirs.push({
      path: resolvedPath,
      addedAt: new Date().toISOString(),
      name: args.name,
    })

    await writeDirs(dirs)
    UI.println(UI.Style.TEXT_SUCCESS_BOLD + "Added directory:" + UI.Style.TEXT_NORMAL)
    UI.println(`  ${UI.Style.TEXT_INFO}${resolvedPath}${UI.Style.TEXT_NORMAL}`)

    if (dirs.length === 1) {
      UI.println("")
      UI.println(UI.Style.TEXT_DIM + "This directory will now be included in:" + UI.Style.TEXT_NORMAL)
      UI.println("  • File searches")
      UI.println("  • Code context")
      UI.println("  • Glob patterns")
    }
  },
})
