import { cmd } from "@/cli/commands/cmd"
import { UI } from "@/cli/ui"
import { Instance } from "@/runtime/context/project/instance"
import { Filesystem } from "@/shared/util/filesystem"
import path from "path"

// Todo storage
const TODOS_FILE = "todos.json"

type TodoStatus = "pending" | "in-progress" | "completed" | "cancelled"

interface Todo {
  id: string
  description: string
  status: TodoStatus
  createdAt: string
  completedAt?: string
  priority?: "low" | "medium" | "high"
}

async function readTodos(): Promise<Todo[]> {
  const todosPath = path.join(Instance.directory, ".gizzi", TODOS_FILE)
  try {
    const content = await Filesystem.readText(todosPath)
    return JSON.parse(content)
  } catch {
    return []
  }
}

async function writeTodos(todos: Todo[]): Promise<void> {
  const todosPath = path.join(Instance.directory, ".gizzi", TODOS_FILE)
  await Filesystem.write(todosPath, JSON.stringify(todos, null, 2))
}

function generateId(): string {
  return `todo-${Date.now()}-${Math.random().toString(36).substr(2, 9)}`
}

function renderTodos(todos: Todo[], filter?: TodoStatus): string {
  const lines: string[] = []

  const filtered = filter ? todos.filter((t) => t.status === filter) : todos

  // Sort by priority and creation date
  const sorted = filtered.sort((a, b) => {
    const priorityOrder = { high: 0, medium: 1, low: 2, undefined: 3 }
    const pDiff = priorityOrder[a.priority || "undefined"] - priorityOrder[b.priority || "undefined"]
    if (pDiff !== 0) return pDiff
    return new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime()
  })

  // Group by status
  const grouped = {
    pending: sorted.filter((t) => t.status === "pending"),
    "in-progress": sorted.filter((t) => t.status === "in-progress"),
    completed: sorted.filter((t) => t.status === "completed"),
    cancelled: sorted.filter((t) => t.status === "cancelled"),
  }

  lines.push("")

  // Summary
  const total = todos.length
  const completed = todos.filter((t) => t.status === "completed").length
  const inProgress = todos.filter((t) => t.status === "in-progress").length
  const pending = todos.filter((t) => t.status === "pending").length

  lines.push(UI.Style.TEXT_INFO_BOLD + "Todo List" + UI.Style.TEXT_NORMAL)
  lines.push("")
  lines.push(`  Total: ${UI.Style.TEXT_BOLD}${total}${UI.Style.TEXT_NORMAL} | ` +
             `Pending: ${UI.Style.TEXT_WARNING}${pending}${UI.Style.TEXT_NORMAL} | ` +
             `In Progress: ${UI.Style.TEXT_INFO}${inProgress}${UI.Style.TEXT_NORMAL} | ` +
             `Completed: ${UI.Style.TEXT_SUCCESS}${completed}${UI.Style.TEXT_NORMAL}`)
  lines.push("")

  if (sorted.length === 0) {
    lines.push("  " + UI.Style.TEXT_DIM + "No todos found" + UI.Style.TEXT_NORMAL)
    lines.push("")
    return lines.join("\n")
  }

  // Render groups
  const renderGroup = (title: string, items: Todo[], icon: string, color: string) => {
    if (items.length === 0) return
    lines.push(`  ${color}${icon} ${title}${UI.Style.TEXT_NORMAL}`)
    for (const todo of items) {
      const priorityMarker = todo.priority === "high" ? "! " :
                            todo.priority === "medium" ? "* " : ""
      lines.push(`     ${priorityMarker}${todo.description}`)
    }
    lines.push("")
  }

  renderGroup("In Progress", grouped["in-progress"], "▶", UI.Style.TEXT_INFO)
  renderGroup("Pending", grouped.pending, "○", UI.Style.TEXT_NORMAL)
  renderGroup("Completed", grouped.completed, "✓", UI.Style.TEXT_SUCCESS)
  renderGroup("Cancelled", grouped.cancelled, "✗", UI.Style.TEXT_DIM)

  return lines.join("\n")
}

export const TodosCommand = cmd({
  command: "todos",
  describe: "list and manage todos",
  builder: (yargs) =>
    yargs
      .option("add", {
        type: "string",
        alias: "a",
        describe: "add a new todo",
      })
      .option("done", {
        type: "number",
        alias: "d",
        describe: "mark todo as complete (by index)",
      })
      .option("remove", {
        type: "number",
        alias: "r",
        describe: "remove a todo (by index)",
      })
      .option("clear", {
        type: "boolean",
        alias: "c",
        describe: "clear all completed todos",
      })
      .option("status", {
        type: "string",
        choices: ["pending", "in-progress", "completed", "cancelled"],
        describe: "filter by status",
      })
      .option("priority", {
        type: "string",
        choices: ["low", "medium", "high"],
        describe: "set priority for new todo",
      }),
  handler: async (args) => {
    let todos = await readTodos()

    // Add new todo
    if (args.add) {
      const newTodo: Todo = {
        id: generateId(),
        description: args.add,
        status: "pending",
        createdAt: new Date().toISOString(),
        priority: (args.priority as Todo["priority"]) || "medium",
      }
      todos.push(newTodo)
      await writeTodos(todos)
      UI.println(UI.Style.TEXT_SUCCESS + `Added: ${args.add}` + UI.Style.TEXT_NORMAL)
      return
    }

    // Mark as done
    if (args.done !== undefined) {
      const pending = todos.filter((t) => t.status !== "completed" && t.status !== "cancelled")
      if (args.done < 0 || args.done >= pending.length) {
        UI.println(UI.Style.TEXT_ERROR + `Invalid todo index: ${args.done}` + UI.Style.TEXT_NORMAL)
        return
      }

      const todo = pending[args.done]
      todo.status = "completed"
      todo.completedAt = new Date().toISOString()
      await writeTodos(todos)
      UI.println(UI.Style.TEXT_SUCCESS + `Completed: ${todo.description}` + UI.Style.TEXT_NORMAL)
      return
    }

    // Remove todo
    if (args.remove !== undefined) {
      if (args.remove < 0 || args.remove >= todos.length) {
        UI.println(UI.Style.TEXT_ERROR + `Invalid todo index: ${args.remove}` + UI.Style.TEXT_NORMAL)
        return
      }
      const removed = todos.splice(args.remove, 1)[0]
      await writeTodos(todos)
      UI.println(UI.Style.TEXT_DIM + `Removed: ${removed.description}` + UI.Style.TEXT_NORMAL)
      return
    }

    // Clear completed
    if (args.clear) {
      const before = todos.length
      todos = todos.filter((t) => t.status !== "completed")
      await writeTodos(todos)
      const removed = before - todos.length
      UI.println(UI.Style.TEXT_DIM + `Cleared ${removed} completed todos` + UI.Style.TEXT_NORMAL)
      return
    }

    // Show list (default)
    UI.println(renderTodos(todos, args.status as TodoStatus))
  },
})
