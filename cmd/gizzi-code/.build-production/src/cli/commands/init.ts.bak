import path from "path"
import { cmd } from "@/cli/commands/cmd"
import { UI } from "@/cli/ui"
import { Filesystem } from "@/shared/util/filesystem"
import * as prompts from "@clack/prompts"
import { EOL } from "os"

type ProjectType = {
  name: string
  language: string
  buildFile: string
}

const PROJECT_MARKERS: Record<string, ProjectType> = {
  "package.json": { name: "Node.js", language: "TypeScript/JavaScript", buildFile: "package.json" },
  "Cargo.toml": { name: "Rust", language: "Rust", buildFile: "Cargo.toml" },
  "go.mod": { name: "Go", language: "Go", buildFile: "go.mod" },
  "pyproject.toml": { name: "Python", language: "Python", buildFile: "pyproject.toml" },
  "requirements.txt": { name: "Python", language: "Python", buildFile: "requirements.txt" },
  "pom.xml": { name: "Java/Maven", language: "Java", buildFile: "pom.xml" },
  "build.gradle": { name: "Java/Gradle", language: "Java/Kotlin", buildFile: "build.gradle" },
  "Gemfile": { name: "Ruby", language: "Ruby", buildFile: "Gemfile" },
  "mix.exs": { name: "Elixir", language: "Elixir", buildFile: "mix.exs" },
  "Package.swift": { name: "Swift", language: "Swift", buildFile: "Package.swift" },
  "CMakeLists.txt": { name: "C/C++", language: "C/C++", buildFile: "CMakeLists.txt" },
  "Makefile": { name: "Make", language: "C/C++", buildFile: "Makefile" },
}

const TEMPLATES = {
  minimal: "Minimal setup (just MEMORY.md)",
  node: "Node.js/TypeScript project",
  python: "Python project",
  react: "React/Vite project",
  rust: "Rust project",
  go: "Go project",
}

async function detectProject(dir: string): Promise<ProjectType | undefined> {
  for (const [marker, info] of Object.entries(PROJECT_MARKERS)) {
    if (await Filesystem.exists(path.join(dir, marker))) {
      return info
    }
  }
  return undefined
}

function starterMemory(project?: ProjectType): string {
  const lines: string[] = []

  lines.push("# Project Memory")
  lines.push("")
  lines.push("This file contains persistent memory for Gizzi Code.")
  lines.push("Edit this file to help Gizzi understand your project better.")
  lines.push("")

  if (project) {
    lines.push(`## Project Type`)
    lines.push("")
    lines.push(`- **Type**: ${project.name}`)
    lines.push(`- **Language**: ${project.language}`)
    lines.push(`- **Build file**: ${project.buildFile}`)
    lines.push("")
  }

  lines.push("## Overview")
  lines.push("")
  lines.push("<!-- Describe what this project does, its purpose, and key features -->")
  lines.push("")

  lines.push("## Architecture")
  lines.push("")
  lines.push("<!-- Describe the project structure, key modules, and design patterns -->")
  lines.push("")

  lines.push("## Development")
  lines.push("")

  if (project?.name === "Node.js") {
    lines.push("```bash")
    lines.push("npm install    # Install dependencies")
    lines.push("npm run build  # Build the project")
    lines.push("npm test       # Run tests")
    lines.push("npm run dev    # Start development server")
    lines.push("```")
  } else if (project?.name === "Rust") {
    lines.push("```bash")
    lines.push("cargo build    # Build the project")
    lines.push("cargo test     # Run tests")
    lines.push("cargo clippy   # Lint")
    lines.push("cargo run      # Run the project")
    lines.push("```")
  } else if (project?.name === "Go") {
    lines.push("```bash")
    lines.push("go build ./... # Build the project")
    lines.push("go test ./...  # Run tests")
    lines.push("go vet ./...   # Lint")
    lines.push("go run .       # Run the project")
    lines.push("```")
  } else if (project?.language === "Python") {
    lines.push("```bash")
    lines.push("pip install -e .  # Install in development mode")
    lines.push("pytest            # Run tests")
    lines.push("python -m main    # Run the project")
    lines.push("```")
  } else {
    lines.push("<!-- Add build/test/lint/run commands here -->")
  }

  lines.push("")
  lines.push("## Conventions")
  lines.push("")
  lines.push("<!-- Add coding conventions, naming patterns, or style guidelines -->")
  lines.push("")

  lines.push("## Key Files")
  lines.push("")
  lines.push("<!-- List important files and their purposes -->")
  lines.push("")

  lines.push("## Dependencies")
  lines.push("")
  lines.push("<!-- Note any important external dependencies or services -->")
  lines.push("")

  return lines.join("\n")
}

function starterGizziJson(project?: ProjectType): string {
  const config = {
    version: "1.0.0",
    project: {
      type: project?.name || "unknown",
      language: project?.language || "unknown",
    },
    preferences: {
      model: "claude-sonnet-4-5",
      effort: "medium",
      maxTokens: 4096,
    },
    permissions: {
      allowedTools: ["Read", "Write", "Edit", "Bash", "Glob", "Grep", "List"],
      deniedTools: [],
    },
    hooks: {
      PostToolUse: [],
    },
    features: {
      sandbox: false,
      thinking: true,
      receipts: true,
    },
  }
  return JSON.stringify(config, null, 2)
}

function starterGitignore(): string {
  return [
    ".gizzi/",
    ".gizzi/L3-EPISODIC/",
    "*.log",
    "",
    "# Gizzi-specific ignores",
    ".gizzi/sessions/",
  ].join("\n")
}

async function ensureGitignore(dir: string): Promise<{ added: boolean; created: boolean }> {
  const gitignorePath = path.join(dir, ".gitignore")
  const entry = ".gizzi/"

  if (await Filesystem.exists(gitignorePath)) {
    const content = await Filesystem.readText(gitignorePath)
    const lines = content.split("\n")
    if (lines.some((line) => line.trim() === entry || line.trim() === ".gizzi")) {
      return { added: false, created: false }
    }
    const suffix = content.endsWith("\n") ? "" : "\n"
    await Filesystem.write(gitignorePath, content + suffix + entry + "\n")
    return { added: true, created: false }
  }

  await Filesystem.write(gitignorePath, starterGitignore())
  return { added: true, created: true }
}

export const InitCommand = cmd({
  command: "init",
  describe: "initialize gizzi in the current project",
  builder: (yargs) =>
    yargs
      .option("template", {
        type: "string",
        choices: Object.keys(TEMPLATES),
        describe: "project template to use",
      })
      .option("minimal", {
        type: "boolean",
        describe: "minimal setup (just MEMORY.md)",
      })
      .option("yes", {
        type: "boolean",
        alias: "y",
        describe: "skip prompts and use defaults",
      }),
  handler: async (args) => {
    const dir = process.cwd()
    const gizziDir = path.join(dir, ".gizzi")

    UI.empty()
    UI.println(UI.Style.TEXT_INFO_BOLD + "Initializing Gizzi..." + UI.Style.TEXT_NORMAL)
    UI.empty()

    // Detect project type
    const detectedProject = await detectProject(dir)
    if (detectedProject) {
      UI.println(UI.Style.TEXT_SUCCESS_BOLD + "  ✓  " + UI.Style.TEXT_NORMAL + `Detected ${detectedProject.name} project`)
    }

    // Determine template
    let template = args.template
    let minimal = args.minimal

    if (!args.yes && !template && !minimal) {
      const templateResult = await prompts.select({
        message: "Choose a setup template",
        options: [
          { value: "detected", label: detectedProject ? `Detected (${detectedProject.name})` : "Minimal", hint: "Recommended" },
          ...Object.entries(TEMPLATES).map(([key, label]) => ({ value: key, label })),
        ],
      })
      if (prompts.isCancel(templateResult)) {
        UI.println("Cancelled")
        return
      }
      if (templateResult === "detected") {
        if (detectedProject) {
          template = detectedProject.name.toLowerCase().includes("node") ? "node" :
                     detectedProject.name.toLowerCase().includes("python") ? "python" :
                     detectedProject.name.toLowerCase().includes("rust") ? "rust" :
                     detectedProject.name.toLowerCase().includes("go") ? "go" : undefined
        }
        minimal = !template
      } else {
        template = templateResult as string
        minimal = template === "minimal"
      }
    }

    // Create .gizzi/ directory structure
    const dirs = [
      gizziDir,
      path.join(gizziDir, "L1-COGNITIVE"),
      path.join(gizziDir, "L1-COGNITIVE", "memory"),
      path.join(gizziDir, "L2-PROCEDURAL"),
      path.join(gizziDir, "L2-PROCEDURAL", "skills"),
      path.join(gizziDir, "L3-EPISODIC"),
      path.join(gizziDir, "L3-EPISODIC", "sessions"),
    ]

    for (const d of dirs) {
      if (!(await Filesystem.exists(d))) {
        await Filesystem.mkdir(d)
      }
    }
    UI.println(UI.Style.TEXT_SUCCESS_BOLD + "  +  " + UI.Style.TEXT_NORMAL + "Created .gizzi/ directory structure")

    // Create MEMORY.md
    const memoryPath = path.join(gizziDir, "L1-COGNITIVE", "memory", "MEMORY.md")
    if (!(await Filesystem.exists(memoryPath))) {
      const content = starterMemory(detectedProject)
      await Filesystem.write(memoryPath, content)
      UI.println(UI.Style.TEXT_SUCCESS_BOLD + "  +  " + UI.Style.TEXT_NORMAL + "Created MEMORY.md")
    }

    // Create gizzi.json config
    const configPath = path.join(gizziDir, "gizzi.json")
    if (!(await Filesystem.exists(configPath))) {
      const content = starterGizziJson(detectedProject)
      await Filesystem.write(configPath, content)
      UI.println(UI.Style.TEXT_SUCCESS_BOLD + "  +  " + UI.Style.TEXT_NORMAL + "Created gizzi.json")
    }

    // Add to .gitignore
    const gitignoreResult = await ensureGitignore(dir)
    if (gitignoreResult.created) {
      UI.println(UI.Style.TEXT_SUCCESS_BOLD + "  +  " + UI.Style.TEXT_NORMAL + "Created .gitignore with .gizzi/")
    } else if (gitignoreResult.added) {
      UI.println(UI.Style.TEXT_SUCCESS_BOLD + "  +  " + UI.Style.TEXT_NORMAL + "Added .gizzi/ to .gitignore")
    }

    // Create legacy GIZZI.md for backward compatibility
    const legacyConfigPath = path.join(dir, "GIZZI.md")
    if (!(await Filesystem.exists(legacyConfigPath)) && !(await Filesystem.exists(configPath))) {
      const content = starterMemory(detectedProject)
      await Filesystem.write(legacyConfigPath, content)
    }

    UI.empty()
    UI.println(UI.Style.TEXT_SUCCESS_BOLD + "Done!" + UI.Style.TEXT_NORMAL)
    UI.println("")
    UI.println("Next steps:")
    UI.println("  1. Edit " + UI.Style.TEXT_INFO + ".gizzi/L1-COGNITIVE/memory/MEMORY.md" + UI.Style.TEXT_NORMAL + " to add project context")
    UI.println("  2. Run " + UI.Style.TEXT_INFO + "gizzi" + UI.Style.TEXT_NORMAL + " to start a session")
    UI.println("")
  },
})
