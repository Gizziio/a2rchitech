import { cmd } from "@/cli/commands/cmd"
import { UI } from "@/cli/ui"
import { Instance } from "@/runtime/context/project/instance"
import { Filesystem } from "@/shared/util/filesystem"
import path from "path"

// Sandbox config
const SANDBOX_FILE = ".gizzi/sandbox.json"

interface SandboxConfig {
  enabled: boolean
  filesystem: {
    readOnly: string[]
    allowWrite: string[]
    denyPaths: string[]
  }
  network: {
    allowedHosts: string[]
    blockedHosts: string[]
    allowAll: boolean
  }
  commands: {
    allowedCommands: string[]
    blockedCommands: string[]
    requireApproval: string[]
  }
}

const DEFAULT_CONFIG: SandboxConfig = {
  enabled: false,
  filesystem: {
    readOnly: [],
    allowWrite: [".gizzi/", "*.log"],
    denyPaths: [".env", "*.key", "*.pem", "secrets/"],
  },
  network: {
    allowedHosts: ["localhost", "127.0.0.1"],
    blockedHosts: [],
    allowAll: false,
  },
  commands: {
    allowedCommands: ["ls", "cat", "grep", "find", "git status", "git log"],
    blockedCommands: ["rm -rf /", "sudo", "curl | sh"],
    requireApproval: ["git push", "git reset", "npm publish", "docker"],
  },
}

async function readConfig(): Promise<SandboxConfig> {
  const configPath = path.join(Instance.directory, SANDBOX_FILE)
  try {
    const content = await Filesystem.readText(configPath)
    return { ...DEFAULT_CONFIG, ...JSON.parse(content) }
  } catch {
    return DEFAULT_CONFIG
  }
}

async function writeConfig(config: SandboxConfig): Promise<void> {
  const configPath = path.join(Instance.directory, SANDBOX_FILE)
  await Filesystem.write(configPath, JSON.stringify(config, null, 2))
}

function renderStatus(config: SandboxConfig): string {
  const lines: string[] = []

  lines.push("")
  lines.push(UI.Style.TEXT_INFO_BOLD + "Sandbox Mode" + UI.Style.TEXT_NORMAL)
  lines.push("")

  const status = config.enabled
    ? UI.Style.TEXT_SUCCESS + "ENABLED" + UI.Style.TEXT_NORMAL
    : UI.Style.TEXT_DIM + "DISABLED" + UI.Style.TEXT_NORMAL

  lines.push(`  Status: ${UI.Style.TEXT_BOLD}${status}${UI.Style.TEXT_NORMAL}`)
  lines.push("")

  if (config.enabled) {
    lines.push(UI.Style.TEXT_WARNING + "  Restrictions active:" + UI.Style.TEXT_NORMAL)
    lines.push(`    • Filesystem: ${config.filesystem.denyPaths.length} paths blocked`)
    lines.push(`    • Network: ${config.network.allowAll ? "All allowed" : "Restricted"}`)
    lines.push(`    • Commands: ${config.commands.requireApproval.length} require approval`)
  } else {
    lines.push("  When enabled, sandbox mode will:")
    lines.push("    • Block dangerous filesystem operations")
    lines.push("    • Restrict network access")
    lines.push("    • Require approval for destructive commands")
    lines.push("    • Prevent secret/credential access")
  }

  lines.push("")
  return lines.join("\n")
}

export const SandboxCommand = cmd({
  command: "sandbox",
  describe: "toggle sandbox mode for safer execution",
  builder: (yargs) =>
    yargs
      .option("on", {
        type: "boolean",
        describe: "enable sandbox mode",
      })
      .option("off", {
        type: "boolean",
        describe: "disable sandbox mode",
      })
      .option("status", {
        type: "boolean",
        alias: "s",
        describe: "show current sandbox status",
      })
      .option("config", {
        type: "boolean",
        alias: "c",
        describe: "show detailed configuration",
      })
      .option("add-deny", {
        type: "string",
        describe: "add path to deny list",
      })
      .option("add-allow", {
        type: "string",
        describe: "add command to allow list",
      }),
  handler: async (args) => {
    const config = await readConfig()

    // Toggle sandbox
    if (args.on) {
      config.enabled = true
      await writeConfig(config)
      UI.println(UI.Style.TEXT_SUCCESS_BOLD + "Sandbox mode ENABLED" + UI.Style.TEXT_NORMAL)
      UI.println(renderStatus(config))
      UI.println(UI.Style.TEXT_WARNING + "Restrictive mode active - some operations will be blocked" + UI.Style.TEXT_NORMAL)
      return
    }

    if (args.off) {
      config.enabled = false
      await writeConfig(config)
      UI.println(UI.Style.TEXT_DIM + "Sandbox mode disabled" + UI.Style.TEXT_NORMAL)
      return
    }

    // Add deny path
    if (args.addDeny) {
      config.filesystem.denyPaths.push(args.addDeny)
      await writeConfig(config)
      UI.println(UI.Style.TEXT_SUCCESS + `Added to deny list: ${args.addDeny}` + UI.Style.TEXT_NORMAL)
      return
    }

    // Add allow command
    if (args.addAllow) {
      config.commands.allowedCommands.push(args.addAllow)
      await writeConfig(config)
      UI.println(UI.Style.TEXT_SUCCESS + `Added to allow list: ${args.addAllow}` + UI.Style.TEXT_NORMAL)
      return
    }

    // Show config
    if (args.config) {
      UI.println(renderStatus(config))
      UI.println(UI.Style.TEXT_INFO_BOLD + "Configuration:" + UI.Style.TEXT_NORMAL)
      UI.println(JSON.stringify(config, null, 2))
      return
    }

    // Show status (default)
    UI.println(renderStatus(config))
  },
})
