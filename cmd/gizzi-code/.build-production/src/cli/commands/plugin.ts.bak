import { cmd } from "@/cli/commands/cmd"
import { UI } from "@/cli/ui"
import { Config } from "@/runtime/context/config/config"
import { Filesystem } from "@/shared/util/filesystem"
import { modify, applyEdits } from "jsonc-parser"
import fs from "fs/promises"
import path from "path"
import * as ClaudePluginLoader from "@/runtime/integrations/plugin/claude/loader"

async function getConfigPath(): Promise<string> {
  return Config.getGlobalConfigFile()
}

async function getPluginList(): Promise<string[]> {
  const config = await Config.global()
  return config.plugin ?? []
}

async function updatePluginList(plugins: string[]) {
  const configPath = await getConfigPath()
  let text = "{}"
  if (await Filesystem.exists(configPath)) {
    text = await Filesystem.readText(configPath)
  }
  const edits = modify(text, ["plugin"], plugins, {
    formattingOptions: { tabSize: 2, insertSpaces: true },
  })
  const result = applyEdits(text, edits)
  await Filesystem.write(configPath, result)
  return configPath
}

const PluginInstallCommand = cmd({
  command: "install <package>",
  describe: "install a plugin package",
  builder: (yargs) =>
    yargs.positional("package", {
      type: "string",
      describe: "npm package name (optionally with @version)",
      demandOption: true,
    }),
  handler: async (args) => {
    const pkg = args.package as string
    const plugins = await getPluginList()

    // Check for duplicates (ignore version)
    const baseName = pkg.includes("@") ? pkg.substring(0, pkg.lastIndexOf("@")) : pkg
    const existing = plugins.find((p) => {
      const pBase = p.includes("@") ? p.substring(0, p.lastIndexOf("@")) : p
      return pBase === baseName
    })

    if (existing) {
      // Update version
      const idx = plugins.indexOf(existing)
      plugins[idx] = pkg
      const configPath = await updatePluginList(plugins)
      UI.println(`Updated ${existing} -> ${pkg} in ${configPath}`)
    } else {
      plugins.push(pkg)
      const configPath = await updatePluginList(plugins)
      UI.println(`Installed ${pkg} in ${configPath}`)
    }
  },
})

const PluginRemoveCommand = cmd({
  command: "remove <package>",
  describe: "remove a plugin package",
  builder: (yargs) =>
    yargs.positional("package", {
      type: "string",
      describe: "npm package name to remove",
      demandOption: true,
    }),
  handler: async (args) => {
    const pkg = args.package as string
    const plugins = await getPluginList()
    const baseName = pkg.includes("@") ? pkg.substring(0, pkg.lastIndexOf("@")) : pkg

    const filtered = plugins.filter((p) => {
      const pBase = p.includes("@") ? p.substring(0, p.lastIndexOf("@")) : p
      return pBase !== baseName
    })

    if (filtered.length === plugins.length) {
      UI.println(`Plugin ${pkg} not found in config`)
      return
    }

    const configPath = await updatePluginList(filtered)
    UI.println(`Removed ${pkg} from ${configPath}`)
  },
})

const PluginListCommand = cmd({
  command: "list",
  describe: "list installed plugins",
  handler: async () => {
    const plugins = await getPluginList()
    if (plugins.length === 0) {
      UI.println("No plugins configured")
      return
    }
    UI.println("Configured plugins:")
    for (const plugin of plugins) {
      UI.println(`  - ${plugin}`)
    }
  },
})

const PluginSearchCommand = cmd({
  command: "search <query>",
  describe: "search for plugins on npm",
  builder: (yargs) =>
    yargs.positional("query", {
      type: "string",
      describe: "search query",
      demandOption: true,
    }),
  handler: async (args) => {
    const query = args.query as string
    UI.println(`Searching npm for "${query}"...`)
    try {
      const proc = Bun.spawn(
        ["npm", "search", "--json", query, "--searchlimit=10"],
        { stdout: "pipe", stderr: "pipe" },
      )
      const output = await new Response(proc.stdout).text()
      const results = JSON.parse(output.trim()) as Array<{
        name: string
        description?: string
        version?: string
        keywords?: string[]
      }>

      if (results.length === 0) {
        UI.println("No results found")
        return
      }

      UI.println(`\nFound ${results.length} result(s):\n`)
      for (const r of results) {
        UI.println(`  ${r.name}@${r.version || "latest"}`)
        if (r.description) UI.println(`    ${r.description}`)
        UI.println("")
      }
      UI.println("Install with: gizzi plugin install <package>")
    } catch (e) {
      UI.error(`Search failed: ${e instanceof Error ? e.message : String(e)}`)
    }
  },
})

const PluginEnableCommand = cmd({
  command: "enable <name>",
  describe: "re-enable a disabled plugin for the current session",
  builder: (yargs) =>
    yargs.positional("name", {
      type: "string",
      describe: "plugin name to enable",
      demandOption: true,
    }),
  handler: async (args) => {
    const { Plugin } = await import("@/runtime/integrations/plugin")
    Plugin.enable(args.name as string)
    UI.println(`Plugin "${args.name}" enabled`)
  },
})

const PluginDisableCommand = cmd({
  command: "disable <name>",
  describe: "disable a plugin for the current session",
  builder: (yargs) =>
    yargs.positional("name", {
      type: "string",
      describe: "plugin name to disable",
      demandOption: true,
    }),
  handler: async (args) => {
    const { Plugin } = await import("@/runtime/integrations/plugin")
    Plugin.disable(args.name as string)
    UI.println(`Plugin "${args.name}" disabled`)
  },
})

// ── gizzi plugin install-local <path> ─────────────────────────────────────────
// Installs a .claude-plugin/ format plugin from a local directory into
// ~/.gizzi/plugins/<name>/ so the native loader picks it up automatically.

const PluginInstallLocalCommand = cmd({
  command: "install-local <pluginPath>",
  describe: "install a .claude-plugin/ format plugin from a local directory",
  builder: (yargs) =>
    yargs
      .positional("pluginPath", {
        type: "string",
        describe: "path to the plugin directory (must contain .claude-plugin/plugin.json)",
        demandOption: true,
      })
      .option("name", {
        type: "string",
        describe: "override install name (defaults to manifest name)",
      }),
  handler: async (args) => {
    const src = path.resolve(args.pluginPath as string)
    const manifestPath = path.join(src, ".claude-plugin", "plugin.json")

    if (!(await Filesystem.exists(manifestPath))) {
      UI.error(`No .claude-plugin/plugin.json found at ${src}`)
      process.exitCode = 1
      return
    }

    let manifest: { name: string }
    try {
      manifest = JSON.parse(await fs.readFile(manifestPath, "utf8"))
    } catch (e: any) {
      UI.error(`Failed to read manifest: ${e.message}`)
      process.exitCode = 1
      return
    }

    const name = (args.name as string | undefined) ?? manifest.name
    const dest = path.join(ClaudePluginLoader.gizziPluginDir(), name)

    UI.empty()
    UI.println(UI.Style.TEXT_INFO_BOLD + `Installing ${name}...` + UI.Style.TEXT_NORMAL)

    await fs.mkdir(dest, { recursive: true })
    await fs.cp(src, dest, { recursive: true, force: true })
    ClaudePluginLoader.invalidate()

    UI.println(UI.Style.TEXT_SUCCESS_BOLD + "  ✓  " + UI.Style.TEXT_NORMAL + `${name} → ${dest}`)
    UI.empty()
    UI.println(UI.Style.TEXT_SUCCESS_BOLD + "Done!" + UI.Style.TEXT_NORMAL + " Restart gizzi to activate the plugin.")
    UI.empty()
  },
})

function printClaudePluginGroup(
  title: string,
  plugins: Awaited<ReturnType<typeof ClaudePluginLoader.all>>,
) {
  if (plugins.length === 0) return

  UI.println(UI.Style.TEXT_INFO_BOLD + `${title} (${plugins.length})` + UI.Style.TEXT_NORMAL)
  UI.empty()

  for (const plugin of plugins) {
    const { manifest, commands, skills, hooksConfig, mcpServers } = plugin
    const author = typeof manifest.author === "string" ? manifest.author : manifest.author?.name ?? ""
    UI.println(
      UI.Style.TEXT_SUCCESS_BOLD +
        `  ${manifest.name}` +
        (manifest.version ? `@${manifest.version}` : "") +
        UI.Style.TEXT_NORMAL +
        (author ? ` by ${author}` : ""),
    )
    if (manifest.description) UI.println(UI.Style.TEXT_DIM + `    ${manifest.description}` + UI.Style.TEXT_NORMAL)
    if (commands.length) UI.println(`    ${commands.length} command(s): /${commands.map((c) => c.name).join(", /")}`)
    if (skills.length) UI.println(`    ${skills.length} skill(s): ${skills.map((s) => s.name).join(", ")}`)
    if (hooksConfig) UI.println(`    hooks: ${Object.keys(hooksConfig.hooks).join(", ")}`)
    if (Object.keys(mcpServers).length) UI.println(`    MCP servers: ${Object.keys(mcpServers).join(", ")}`)
    UI.empty()
  }
}

// ── gizzi plugin list-claude ───────────────────────────────────────────────────
// Lists bundled built-ins plus discovered .claude-plugin/ format installs.

const PluginListClaudeCommand = cmd({
  command: "list-claude",
  describe: "list bundled and installed .claude-plugin/ format plugins",
  handler: async () => {
    const [builtinPlugins, installedPlugins] = await Promise.all([
      ClaudePluginLoader.allBuiltin(true),
      ClaudePluginLoader.all(true),
    ])
    const total = builtinPlugins.length + installedPlugins.length

    UI.empty()
    if (total === 0) {
      UI.println(UI.Style.TEXT_DIM + "No .claude-plugin/ format plugins found." + UI.Style.TEXT_NORMAL)
      UI.println(UI.Style.TEXT_DIM + "Install with: gizzi plugin install-local <path>" + UI.Style.TEXT_NORMAL)
      UI.empty()
      return
    }

    UI.println(UI.Style.TEXT_INFO_BOLD + `${total} plugin(s) available:` + UI.Style.TEXT_NORMAL)
    UI.empty()

    printClaudePluginGroup("Bundled Built-Ins", builtinPlugins)
    printClaudePluginGroup("Installed Plugins", installedPlugins)
  },
})

// ── gizzi plugin browse ───────────────────────────────────────────────────────
// Opens the plugin marketplace (consolidated from /marketplace command)

const PluginBrowseCommand = cmd({
  command: "browse",
  describe: "open plugin marketplace",
  aliases: ["marketplace"],
  handler: async () => {
    UI.empty()
    UI.println(UI.Style.TEXT_INFO_BOLD + "Plugin Marketplace" + UI.Style.TEXT_NORMAL)
    UI.empty()
    UI.println("Browse and install plugins from the community.")
    UI.println("")
    UI.println("Available sources:")
    UI.println("  • Built-in plugins (bundled with gizzi)")
    UI.println("  • npm registry (search with: gizzi plugin search <query>)")
    UI.println("  • Local installations (gizzi plugin install-local <path>)")
    UI.println("")
    UI.println("Quick commands:")
    UI.println("  gizzi plugin list          List installed plugins")
    UI.println("  gizzi plugin list-claude   List .claude-plugin format plugins")
    UI.println("  gizzi plugin search <q>    Search npm for plugins")
    UI.println("  gizzi plugin install <pkg> Install a plugin")
    UI.println("")
    
    // Show current plugins
    const [builtinPlugins, installedPlugins] = await Promise.all([
      ClaudePluginLoader.allBuiltin(true),
      ClaudePluginLoader.all(true),
    ])
    
    if (builtinPlugins.length > 0 || installedPlugins.length > 0) {
      UI.println(UI.Style.TEXT_DIM + "---" + UI.Style.TEXT_NORMAL)
      printClaudePluginGroup("Built-in", builtinPlugins)
      printClaudePluginGroup("Installed", installedPlugins)
    }
  },
})

// ── gizzi plugin reload ────────────────────────────────────────────────────────
// Hot reloads plugins without restart (consolidated from /reload command)

const PluginReloadCommand = cmd({
  command: "reload",
  describe: "hot reload plugins without restarting",
  aliases: ["refresh"],
  builder: (yargs) =>
    yargs.option("hard", {
      type: "boolean",
      describe: "hard reload (clear all caches)",
      default: false,
    }),
  handler: async (args) => {
    UI.empty()
    UI.println(UI.Style.TEXT_INFO_BOLD + "Reloading plugins..." + UI.Style.TEXT_NORMAL)
    UI.println("")
    
    if (args.hard) {
      UI.println("Clearing caches...")
      ClaudePluginLoader.invalidate()
    }
    
    try {
      // Reload all plugins
      const [builtinPlugins, installedPlugins] = await Promise.all([
        ClaudePluginLoader.allBuiltin(true),
        ClaudePluginLoader.all(true),
      ])
      
      const total = builtinPlugins.length + installedPlugins.length
      
      if (total === 0) {
        UI.println(UI.Style.TEXT_DIM + "No plugins to reload." + UI.Style.TEXT_NORMAL)
        return
      }
      
      // Re-enable all plugins to trigger reload
      const { Plugin } = await import("@/runtime/integrations/plugin")
      
      let successCount = 0
      for (const plugin of [...builtinPlugins, ...installedPlugins]) {
        try {
          Plugin.enable(plugin.manifest.name)
          UI.println(UI.Style.TEXT_SUCCESS + `  OK ${plugin.manifest.name}` + UI.Style.TEXT_NORMAL)
          successCount++
        } catch (e) {
          UI.println(UI.Style.TEXT_ERROR + `  X ${plugin.manifest.name}` + UI.Style.TEXT_NORMAL)
        }
      }
      
      UI.println("")
      UI.println(`${successCount}/${total} plugins reloaded successfully.`)
      
    } catch (e) {
      UI.error(`Reload failed: ${e instanceof Error ? e.message : String(e)}`)
    }
  },
})

export const PluginCommand = cmd({
  command: "plugin",
  describe: "manage plugins",
  builder: (yargs) =>
    yargs
      .command(PluginInstallCommand)
      .command(PluginInstallLocalCommand)
      .command(PluginRemoveCommand)
      .command(PluginListCommand)
      .command(PluginListClaudeCommand)
      .command(PluginSearchCommand)
      .command(PluginEnableCommand)
      .command(PluginDisableCommand)
      .command(PluginBrowseCommand)
      .command(PluginReloadCommand)
      .demandCommand(1, "specify a subcommand"),
  handler: () => {},
})
