{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://a2rchitech.local/schemas/computer-use/adapter.manifest.schema.json",
  "title": "A2R Computer Use Adapter Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "adapter_id",
    "family",
    "pattern",
    "modes_supported",
    "traits",
    "guarantees",
    "production_status",
    "policy_profile",
    "conformance_suite",
    "version"
  ],
  "properties": {
    "adapter_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(\\.[a-z0-9-]+)+$",
      "description": "Unique adapter identifier, e.g. browser.playwright"
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "family": {
      "type": "string",
      "enum": ["browser", "retrieval", "desktop", "hybrid"]
    },
    "pattern": {
      "type": "string",
      "enum": ["deterministic", "adaptive", "orchestrated-hybrid"]
    },
    "modes_supported": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["assist", "execute", "inspect", "parallel", "crawl", "desktop", "hybrid"]
      }
    },
    "capability_classes": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "deterministic-web",
          "adaptive-web",
          "embedded-surface",
          "fleet-session-infra",
          "visual-computer-use",
          "retrieval-crawl",
          "desktop-automation",
          "hybrid-orchestration"
        ]
      },
      "default": []
    },
    "traits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "headed",
        "headless",
        "parallel",
        "persistent_session",
        "visual_reasoning",
        "low_level_debug",
        "checkpointable"
      ],
      "properties": {
        "headed":              { "$ref": "#/$defs/triState" },
        "headless":            { "$ref": "#/$defs/triState" },
        "parallel":            { "$ref": "#/$defs/triState" },
        "persistent_session":  { "$ref": "#/$defs/triState" },
        "visual_reasoning":    { "$ref": "#/$defs/triState" },
        "low_level_debug":     { "$ref": "#/$defs/triState" },
        "checkpointable":      { "$ref": "#/$defs/triState" },
        "current_session_attach": { "$ref": "#/$defs/triState" },
        "artifact_handoff":    { "$ref": "#/$defs/triState" },
        "network_inspection":  { "$ref": "#/$defs/triState" },
        "multi_tab":           { "$ref": "#/$defs/triState" },
        "file_upload":         { "$ref": "#/$defs/triState" },
        "file_download":       { "$ref": "#/$defs/triState" }
      }
    },
    "guarantees": {
      "type": "object",
      "additionalProperties": false,
      "required": ["semantic", "policy", "receipt", "conformance", "routing_confidence"],
      "properties": {
        "semantic":           { "$ref": "#/$defs/grade" },
        "policy":             { "$ref": "#/$defs/grade" },
        "receipt":            { "$ref": "#/$defs/grade" },
        "conformance":        { "$ref": "#/$defs/grade" },
        "routing_confidence": { "$ref": "#/$defs/grade" }
      }
    },
    "production_status": {
      "type": "string",
      "enum": ["experimental", "beta", "production"]
    },
    "policy_profile": {
      "type": "string",
      "minLength": 1
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"],
      "default": "medium"
    },
    "conformance_suite": {
      "type": "string",
      "minLength": 1
    },
    "fallback_rank": {
      "type": "integer",
      "minimum": 0,
      "default": 100,
      "description": "Lower is preferred during ranking"
    },
    "default_for_modes": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["assist", "execute", "inspect", "parallel", "crawl", "desktop", "hybrid"]
      },
      "default": []
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "kind"],
        "properties": {
          "name":     { "type": "string", "minLength": 1 },
          "kind":     { "type": "string", "enum": ["python-package", "node-package", "binary", "service", "browser-runtime", "os-capability", "external-api"] },
          "required": { "type": "boolean", "default": true },
          "notes":    { "type": "string" }
        }
      },
      "default": []
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_parallel_sessions": { "type": ["integer", "null"], "minimum": 1 },
        "supports_remote":       { "$ref": "#/$defs/triState" },
        "supports_local":        { "$ref": "#/$defs/triState" },
        "supports_user_present": { "$ref": "#/$defs/triState" }
      }
    },
    "notes": { "type": "string" }
  },
  "$defs": {
    "grade":    { "type": "string", "enum": ["A", "B", "C", "X"] },
    "triState": { "type": "string", "enum": ["yes", "no", "partial", "unknown"] }
  }
}
