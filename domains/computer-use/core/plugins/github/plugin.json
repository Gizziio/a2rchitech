{
  "id": "github",
  "name": "GitHub Plugin",
  "version": "0.1.0",
  "description": "Automates GitHub workflows: pull request review, issue triage, label management, and comment posting via browser automation.",
  "families": ["browser"],
  "modes": ["execute", "inspect", "assist"],
  "permissions": [
    "browser.navigate",
    "browser.click",
    "browser.type",
    "browser.screenshot",
    "browser.extract",
    "auth.read_session"
  ],
  "golden_paths": ["GP-01", "GP-02", "GP-08", "GP-10"],
  "cookbooks": ["review-pr", "triage-issue"],
  "prompts": ["review-pr"],
  "conformance_suite": "plugin-github-v1",
  "production_status": "beta",
  "policy_profile": {
    "max_destructive_actions": 3,
    "requires_approval": true,
    "allowed_domains": ["github.com", "*.github.com", "api.github.com"],
    "blocked_actions": [
      "delete_repository",
      "force_push",
      "dismiss_review",
      "close_all_issues"
    ]
  },
  "author": "A2R Platform Team",
  "tags": ["git", "code-review", "developer-tools", "issue-tracking", "browser"],
  "homepage": "https://github.com/a2rchitech/computer-use"
}
