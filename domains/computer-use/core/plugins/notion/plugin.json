{
  "id": "notion",
  "name": "Notion Plugin",
  "version": "0.1.0",
  "description": "Automates Notion workflows: creating new pages with structured content, reading existing pages, and updating page properties via browser automation.",
  "families": ["browser"],
  "modes": ["execute", "inspect", "assist"],
  "permissions": [
    "browser.navigate",
    "browser.click",
    "browser.type",
    "browser.screenshot",
    "browser.extract",
    "auth.read_session"
  ],
  "golden_paths": ["GP-01", "GP-02", "GP-08", "GP-10"],
  "cookbooks": ["create-page"],
  "prompts": ["create-page"],
  "conformance_suite": "plugin-notion-v1",
  "production_status": "experimental",
  "policy_profile": {
    "max_destructive_actions": 2,
    "requires_approval": true,
    "allowed_domains": ["notion.so", "*.notion.so", "www.notion.com"],
    "blocked_actions": [
      "delete_workspace",
      "delete_database",
      "archive_all_pages",
      "remove_member"
    ]
  },
  "author": "Allternit Platform Team",
  "tags": ["notion", "notes", "wiki", "knowledge-base", "productivity", "browser"],
  "homepage": "https://github.com/allternit/computer-use"
}
