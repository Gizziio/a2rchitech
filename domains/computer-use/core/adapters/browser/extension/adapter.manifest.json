{
  "adapter_id": "browser.extension",
  "display_name": "Extension Adapter",
  "version": "0.2.0",
  "family": "browser",
  "pattern": "adaptive",
  "modes_supported": ["assist"],
  "capability_classes": ["embedded-surface"],
  "traits": {
    "headed": "yes",
    "headless": "no",
    "parallel": "no",
    "persistent_session": "yes",
    "visual_reasoning": "partial",
    "low_level_debug": "no",
    "checkpointable": "no",
    "current_session_attach": "yes",
    "artifact_handoff": "no",
    "network_inspection": "no",
    "multi_tab": "partial",
    "file_upload": "no",
    "file_download": "no"
  },
  "guarantees": {
    "semantic": "B",
    "policy": "B",
    "receipt": "B",
    "conformance": "C",
    "routing_confidence": "B"
  },
  "production_status": "experimental",
  "policy_profile": "standard-browser",
  "risk_level": "low",
  "conformance_suite": "browser-assist-v1",
  "fallback_rank": 50,
  "default_for_modes": ["assist"],
  "dependencies": [
    { "name": "aiohttp", "kind": "python-package", "required": true }
  ],
  "limits": {
    "max_parallel_sessions": 1,
    "supports_remote": "no",
    "supports_local": "yes",
    "supports_user_present": "yes"
  },
  "notes": "User-present assist adapter. Requires Allternit thin-client extension installed and running in browser."
}
