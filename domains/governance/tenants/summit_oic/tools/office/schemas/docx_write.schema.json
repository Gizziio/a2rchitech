{
  "type": "object",
  "required": ["path", "patches", "output_path"],
  "properties": {
    "path": {"type": "string"},
    "output_path": {"type": "string"},
    "patches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["op", "target", "value"],
        "properties": {
          "op": {"type": "string", "enum": ["replace", "append", "insert_after"]},
          "target": {"type": "string"},
          "value": {"type": "string"}
        }
      }
    },
    "track_changes": {"type": "boolean", "default": true}
  }
}
