# Summit OIC — Canvas API Configuration
# Copy this to .env and fill in your values

# Your Canvas LMS instance URL (no trailing slash)
CANVAS_BASE_URL=https://YOURDISTRICT.instructure.com

# Canvas API token (generate at: Canvas > Account > Settings > New Access Token)
CANVAS_API_TOKEN=your_token_here

# UI-TARS Desktop Agent (only needed for Step 5: Desktop MVP)
UI_TARS_URL=http://127.0.0.1:3008
