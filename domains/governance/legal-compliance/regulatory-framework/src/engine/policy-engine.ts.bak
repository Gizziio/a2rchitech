/**
 * Policy Engine
 * 
 * Core policy evaluation engine for the Law Layer.
 * Evaluates policies against tool/file contexts and returns decisions.
 */

import type {
  A2RKernel,
  WihItem,
  RoutingDecision,
  ToolContext,
  FileContext,
} from '@allternit/governor';
import {
  type Policy,
  type PolicyRule,
  type PolicyCondition,
  type PolicyAction,
  type PolicyDecision,
  type PolicyEvaluationRequest,
  type PolicyFilter,
  type LawLayerConfig,
  PolicyEvaluationError,
} from '../types.js';

/**
 * Default policy for deny-all fallback
 */
const DENY_ALL_POLICY: Policy = {
  id: 'default-deny',
  name: 'Default Deny',
  description: 'Deny all operations when no policy matches',
  version: '1.0.0',
  scope: 'global',
  rules: [
    {
      id: 'default-deny-rule',
      name: 'Deny All',
      condition: {
        type: 'custom',
        operator: 'equals',
        field: 'always',
        value: true,
      },
      action: {
        decision: 'deny',
        reason: 'No matching policy found',
      },
      priority: 0,
    },
  ],
  enabled: true,
  createdAt: new Date().toISOString(),
};

/**
 * Policy Engine Implementation
 */
export class LawPolicyEngine {
  private policies = new Map<string, Policy>();
  private config: LawLayerConfig;

  constructor(config: LawLayerConfig) {
    this.config = {
      auditLogging: true,
      requireExplicitMatch: false,
      ...config,
    };

    // Register default deny policy if not requiring explicit match
    if (!this.config.requireExplicitMatch) {
      this.registerPolicy(DENY_ALL_POLICY);
    }
  }

  /**
   * Register a policy
   */
  registerPolicy(policy: Policy): void {
    // Validate policy
    this.validatePolicy(policy);
    
    // Sort rules by priority (highest first)
    const sortedPolicy = {
      ...policy,
      rules: [...policy.rules].sort((a, b) => 
        (b.priority ?? 50) - (a.priority ?? 50)
      ),
    };
    
    this.policies.set(policy.id, sortedPolicy);
  }

  /**
   * Unregister a policy
   */
  unregisterPolicy(policyId: string): boolean {
    return this.policies.delete(policyId);
  }

  /**
   * Get a policy by ID
   */
  getPolicy(policyId: string): Policy | null {
    return this.policies.get(policyId) ?? null;
  }

  /**
   * List all policies
   */
  listPolicies(filter?: PolicyFilter): Policy[] {
    let policies = Array.from(this.policies.values());

    if (filter?.scope) {
      policies = policies.filter(p => p.scope === filter.scope);
    }

    if (filter?.enabled !== undefined) {
      policies = policies.filter(p => p.enabled === filter.enabled);
    }

    if (filter?.target) {
      policies = policies.filter(p => p.scopeTarget === filter.target);
    }

    return policies;
  }

  /**
   * Enable/disable a policy
   */
  setPolicyEnabled(policyId: string, enabled: boolean): boolean {
    const policy = this.policies.get(policyId);
    if (!policy) return false;

    policy.enabled = enabled;
    policy.updatedAt = new Date().toISOString();
    return true;
  }

  /**
   * Evaluate policies against a context
   */
  evaluate(request: PolicyEvaluationRequest): PolicyDecision {
    const { context, wihItem, overridePolicies } = request;
    const timestamp = new Date().toISOString();

    // Get applicable policies
    const policies = this.getApplicablePolicies(context, wihItem, overridePolicies);

    // Evaluate each policy in order
    for (const policy of policies) {
      if (!policy.enabled) continue;

      for (const rule of policy.rules) {
        if (rule.enabled === false) continue;

        try {
          if (this.evaluateCondition(rule.condition, context, wihItem)) {
            const decision: PolicyDecision = {
              policyId: policy.id,
              ruleId: rule.id,
              decision: rule.action.decision,
              reason: rule.action.reason ?? `Policy ${policy.id} rule ${rule.id}`,
              timestamp,
              context,
              metadata: rule.action.metadata,
            };

            // Log decision if audit logging is enabled
            if (this.config.auditLogging) {
              this.logDecision(decision);
            }

            // Call callback if provided
            this.config.onDecision?.(decision);

            return decision;
          }
        } catch (error) {
          // Log evaluation error but continue to next rule
          console.error(`Error evaluating rule ${rule.id}:`, error);
        }
      }
    }

    // No matching policy found
    if (this.config.requireExplicitMatch) {
      throw new PolicyEvaluationError(
        'No matching policy found and explicit match is required',
        { context }
      );
    }

    // Return deny by default
    return {
      policyId: 'default-deny',
      ruleId: 'default-deny-rule',
      decision: 'deny',
      reason: 'No matching policy found',
      timestamp,
      context,
    };
  }

  /**
   * Get policies applicable to the context
   */
  private getApplicablePolicies(
    context: ToolContext | FileContext,
    wihItem?: WihItem,
    overridePolicies?: string[]
  ): Policy[] {
    let policies = Array.from(this.policies.values());

    // If override policies specified, use only those
    if (overridePolicies && overridePolicies.length > 0) {
      policies = policies.filter(p => overridePolicies.includes(p.id));
    } else {
      // Filter by scope
      policies = policies.filter(p => {
        switch (p.scope) {
          case 'global':
            return true;
          case 'phase':
            return wihItem?.phase === p.scopeTarget;
          case 'wih':
            return context.wihId === p.scopeTarget;
          case 'agent':
            return context.agentId === p.scopeTarget;
          case 'session':
            return context.sessionId === p.scopeTarget;
          default:
            return false;
        }
      });
    }

    // Sort by priority (policies with higher priority rules first)
    return policies.sort((a, b) => {
      const aMaxPriority = Math.max(...a.rules.map(r => r.priority ?? 50));
      const bMaxPriority = Math.max(...b.rules.map(r => r.priority ?? 50));
      return bMaxPriority - aMaxPriority;
    });
  }

  /**
   * Evaluate a condition against context
   */
  private evaluateCondition(
    condition: PolicyCondition,
    context: ToolContext | FileContext,
    wihItem?: WihItem
  ): boolean {
    const value = this.extractValue(condition.field, context, wihItem);
    let matches = false;

    switch (condition.operator) {
      case 'equals':
        matches = value === condition.value;
        break;
      case 'contains':
        matches = String(value).includes(String(condition.value));
        break;
      case 'matches':
        matches = String(value).toLowerCase() === String(condition.value).toLowerCase();
        break;
      case 'startsWith':
        matches = String(value).startsWith(String(condition.value));
        break;
      case 'endsWith':
        matches = String(value).endsWith(String(condition.value));
        break;
      case 'in':
        matches = Array.isArray(condition.value) && 
                  condition.value.includes(value);
        break;
      case 'regex':
        matches = new RegExp(String(condition.value)).test(String(value));
        break;
      default:
        matches = false;
    }

    return condition.negate ? !matches : matches;
  }

  /**
   * Extract value from context by field path
   */
  private extractValue(
    field: string,
    context: ToolContext | FileContext,
    wihItem?: WihItem
  ): unknown {
    // Handle special fields
    if (field === 'always') return true;
    
    // Check context fields
    if (field in context) {
      return (context as Record<string, unknown>)[field];
    }

    // Check nested fields (e.g., 'toolParams.path')
    const parts = field.split('.');
    let value: unknown = context;
    
    for (const part of parts) {
      if (value && typeof value === 'object' && part in value) {
        value = (value as Record<string, unknown>)[part];
      } else {
        return undefined;
      }
    }

    return value;
  }

  /**
   * Validate policy structure
   */
  private validatePolicy(policy: Policy): void {
    if (!policy.id) {
      throw new PolicyEvaluationError('Policy must have an ID');
    }

    if (!policy.name) {
      throw new PolicyEvaluationError('Policy must have a name');
    }

    if (!Array.isArray(policy.rules) || policy.rules.length === 0) {
      throw new PolicyEvaluationError('Policy must have at least one rule');
    }

    for (const rule of policy.rules) {
      if (!rule.id) {
        throw new PolicyEvaluationError('Rule must have an ID');
      }

      if (!rule.condition) {
        throw new PolicyEvaluationError(`Rule ${rule.id} must have a condition`);
      }

      if (!rule.action) {
        throw new PolicyEvaluationError(`Rule ${rule.id} must have an action`);
      }
    }
  }

  /**
   * Log decision to audit log
   */
  private logDecision(decision: PolicyDecision): void {
    const logEntry = {
      timestamp: decision.timestamp,
      policyId: decision.policyId,
      ruleId: decision.ruleId,
      decision: decision.decision,
      reason: decision.reason,
      context: {
        sessionId: decision.context.sessionId,
        agentId: decision.context.agentId,
        wihId: decision.context.wihId,
      },
    };

    console.log('[Law Layer Audit]', JSON.stringify(logEntry));
  }

  /**
   * Create a policy from a simple rule
   */
  static createSimplePolicy(
    id: string,
    name: string,
    rule: Omit<PolicyRule, 'id'>
  ): Policy {
    return {
      id,
      name,
      version: '1.0.0',
      scope: 'global',
      rules: [
        {
          ...rule,
          id: `${id}-rule-1`,
        },
      ],
      enabled: true,
      createdAt: new Date().toISOString(),
    };
  }
}

/**
 * Predefined policy templates
 */
export const PolicyTemplates = {
  /**
   * Allow specific tools only
   */
  allowTools: (tools: string[]): Policy =>
    LawPolicyEngine.createSimplePolicy(
      `allow-tools-${Date.now()}`,
      `Allow tools: ${tools.join(', ')}`,
      {
        name: 'Allow Specific Tools',
        condition: {
          type: 'tool',
          operator: 'in',
          field: 'toolName',
          value: tools,
        },
        action: {
          decision: 'allow',
          reason: `Tool is in allowlist: ${tools.join(', ')}`,
        },
        priority: 100,
      }
    ),

  /**
   * Deny specific tools
   */
  denyTools: (tools: string[]): Policy =>
    LawPolicyEngine.createSimplePolicy(
      `deny-tools-${Date.now()}`,
      `Deny tools: ${tools.join(', ')}`,
      {
        name: 'Deny Specific Tools',
        condition: {
          type: 'tool',
          operator: 'in',
          field: 'toolName',
          value: tools,
        },
        action: {
          decision: 'deny',
          reason: `Tool is in denylist: ${tools.join(', ')}`,
        },
        priority: 200, // Higher priority than allow
      }
    ),

  /**
   * Require WIH for all operations
   */
  requireWih: (): Policy =>
    LawPolicyEngine.createSimplePolicy(
      'require-wih',
      'Require WIH for all operations',
      {
        name: 'Check WIH Present',
        condition: {
          type: 'custom',
          operator: 'equals',
          field: 'wihId',
          value: undefined,
        },
        action: {
          decision: 'deny',
          reason: 'No active WIH item. All work must be ticketed.',
        },
        priority: 999,
      }
    ),

  /**
   * Read-only file access
   */
  readOnlyFiles: (): Policy =>
    LawPolicyEngine.createSimplePolicy(
      'read-only-files',
      'Read-only file access',
      {
        name: 'Deny Write Operations',
        condition: {
          type: 'file',
          operator: 'equals',
          field: 'operation',
          value: 'write',
        },
        action: {
          decision: 'deny',
          reason: 'File system is in read-only mode',
        },
        priority: 100,
      }
    ),

  /**
   * Protect specific paths
   */
  protectPaths: (patterns: string[]): Policy =>
    LawPolicyEngine.createSimplePolicy(
      `protect-paths-${Date.now()}`,
      `Protect paths matching: ${patterns.join(', ')}`,
      {
        name: 'Protect Sensitive Paths',
        condition: {
          type: 'path',
          operator: 'regex',
          field: 'path',
          value: patterns.join('|'),
        },
        action: {
          decision: 'delegate',
          reason: 'Path matches protected pattern',
          delegateTo: 'human-review',
        },
        priority: 150,
      }
    ),
};
