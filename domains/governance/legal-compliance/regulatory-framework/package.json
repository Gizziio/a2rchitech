{
  "name": "@allternit/lawlayer",
  "version": "1.0.0",
  "description": "Allternit Law Layer - Governance and policy engine for allternit",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./policies": {
      "import": "./dist/policies/index.js",
      "types": "./dist/policies/index.d.ts"
    },
    "./engine": {
      "import": "./dist/engine/index.js",
      "types": "./dist/engine/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "allternit",
    "law",
    "policy",
    "governance",
    "beads"
  ],
  "author": "allternit Team",
  "license": "MIT",
  "dependencies": {
    "@allternit/governor": "workspace:*",
    "@allternit/runtime": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}