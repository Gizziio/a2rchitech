/**
 * Ant Farm Webhook Normalizer
 * 
 * Transforms raw Ant Farm webhook payloads into normalized events.
 */

import type {
  AntFarmWebhookPayload,
  NormalizedWebhookEvent,
  WebhookSource,
} from '../types/webhook.types.js';
import { v4 as uuidv4 } from 'uuid';
import { createHash } from 'crypto';

/**
 * Normalize Ant Farm webhook payload
 */
export function normalizeAntFarmWebhook(
  rawPayload: AntFarmWebhookPayload
): NormalizedWebhookEvent {
  const { eventType, timestamp, rawPayload: originalRaw } = rawPayload;
  
  // Extract base components
  const [category, action] = eventType.split('.');
  
  // Build actor
  const actor = buildActor(rawPayload);
  
  // Build target
  const target = buildTarget(rawPayload);
  
  // Build action description
  const actionDesc = buildActionDescription(rawPayload, actor);
  
  // Build content
  const content = buildContent(rawPayload);
  
  // Build context
  const context: Record<string, string> = {
    eventType: eventType,
  };
  
  if (rawPayload.room) {
    context.room = rawPayload.room.name;
    context.roomId = rawPayload.room.id;
    context.roomType = rawPayload.room.type;
  }
  
  if (rawPayload.task) {
    context.taskId = rawPayload.task.id;
    context.taskStatus = rawPayload.task.status;
    context.taskPriority = rawPayload.task.priority;
  }
  
  // Generate idempotency key
  const idempotencyKey = generateIdempotencyKey(rawPayload);
  
  // Generate deterministic event ID
  const eventId = generateEventId(rawPayload);
  
  return {
    eventId,
    source: 'antfarm' as WebhookSource,
    type: `antfarm.${category}.${action}`,
    timestamp: timestamp,
    actor,
    target,
    action: {
      type: mapActionType(action),
      description: actionDesc,
    },
    content,
    context,
    idempotencyKey,
    rawPayload: originalRaw as Record<string, unknown>,
    metadata: {
      receivedAt: new Date().toISOString(),
      normalizerVersion: '1.0.0',
    },
  };
}

/**
 * Build actor from Ant Farm payload
 */
function buildActor(payload: AntFarmWebhookPayload): NormalizedWebhookEvent['actor'] {
  if (payload.message?.author) {
    return {
      id: payload.message.author.id,
      name: payload.message.author.name,
      type: payload.message.author.type === 'agent' ? 'bot' : 'human',
    };
  }
  
  if (payload.task?.requestedBy) {
    return {
      id: payload.task.requestedBy,
      name: payload.task.requestedBy,
      type: 'human',
    };
  }
  
  if (payload.member) {
    return {
      id: payload.member.id,
      name: payload.member.name,
      type: 'human',
    };
  }
  
  return undefined;
}

/**
 * Build target from Ant Farm payload
 */
function buildTarget(payload: AntFarmWebhookPayload): NormalizedWebhookEvent['target'] {
  // Task events
  if (payload.task) {
    return {
      type: 'message',
      id: payload.task.id,
      name: payload.task.description.slice(0, 50) + (payload.task.description.length > 50 ? '...' : ''),
    };
  }
  
  // Message events
  if (payload.message) {
    return {
      type: 'message',
      id: payload.message.id,
      name: payload.message.content.slice(0, 50) + (payload.message.content.length > 50 ? '...' : ''),
    };
  }
  
  // Room events
  if (payload.room) {
    return {
      type: 'room',
      id: payload.room.id,
      name: payload.room.name,
    };
  }
  
  return undefined;
}

/**
 * Build action description
 */
function buildActionDescription(
  payload: AntFarmWebhookPayload,
  actor?: NormalizedWebhookEvent['actor']
): string {
  const actorName = actor?.name || 'Unknown';
  const eventType = payload.eventType;
  const taskStatus = payload.task?.status;
  
  const descriptions: Record<string, string> = {
    'room.message.created': `${actorName} sent a message in ${payload.room?.name || 'room'}`,
    'room.task.requested': `${actorName} requested a task: ${payload.task?.description || 'unknown'}`,
    'room.member.joined': `${actorName} joined ${payload.room?.name || 'room'}`,
    'room.member.left': `${actorName} left ${payload.room?.name || 'room'}`,
    'task.acknowledged': `Task ${payload.task?.id} acknowledged by ${payload.task?.assignedTo || 'agent'}`,
    'task.completed': `Task ${payload.task?.id} completed with status: ${taskStatus || 'unknown'}`,
  };
  
  return descriptions[eventType] || `${actorName} triggered ${eventType}`;
}

/**
 * Build content from Ant Farm payload
 */
function buildContent(payload: AntFarmWebhookPayload): NormalizedWebhookEvent['content'] {
  const content: NormalizedWebhookEvent['content'] = {};
  
  // Message content
  if (payload.message?.content) {
    content.text = payload.message.content;
  }
  
  // Task description
  if (payload.task?.description) {
    content.text = payload.task.description;
  }
  
  return Object.keys(content).length > 0 ? content : undefined;
}

/**
 * Map Ant Farm action to normalized action type
 */
function mapActionType(action: string): NonNullable<NormalizedWebhookEvent['action']>['type'] {
  const typeMap: Record<string, NonNullable<NormalizedWebhookEvent['action']>['type']> = {
    created: 'created',
    requested: 'created',
    joined: 'created',
    left: 'deleted',
    acknowledged: 'updated',
    completed: 'updated',
  };
  
  return typeMap[action] || 'updated';
}

/**
 * Generate idempotency key for deduplication
 */
function generateIdempotencyKey(payload: AntFarmWebhookPayload): string {
  const components: string[] = [
    payload.source,
    payload.eventType,
  ];
  
  // Add message ID if present
  if (payload.message?.id) {
    components.push(`msg:${payload.message.id}`);
  }
  
  // Add task ID if present
  if (payload.task?.id) {
    components.push(`task:${payload.task.id}`);
  }
  
  // Add room ID if present
  if (payload.room?.id) {
    components.push(`room:${payload.room.id}`);
  }
  
  // Add timestamp rounded to minute
  const minuteTimestamp = Math.floor(new Date(payload.timestamp).getTime() / 60000);
  components.push(`min:${minuteTimestamp}`);
  
  const keyString = components.join('|');
  return `af_${createHash('sha256').update(keyString).digest('hex').slice(0, 16)}`;
}

/**
 * Generate deterministic event ID
 */
function generateEventId(_payload: AntFarmWebhookPayload): string {
  return `evt_af_${uuidv4()}`;
}

/**
 * Check if Ant Farm webhook requires agent action
 */
export function requiresAgentAction(payload: AntFarmWebhookPayload): boolean {
  const actionEvents: Set<string> = new Set([
    'room.task.requested',
    'room.message.created',
  ]);
  
  // Task requests always require action
  if (payload.eventType === 'room.task.requested') {
    return true;
  }
  
  // Messages with @mentions require action
  if (payload.message?.mentions && payload.message.mentions.length > 0) {
    return true;
  }
  
  return actionEvents.has(payload.eventType);
}

/**
 * Infer agent role from Ant Farm webhook
 */
export function inferAgentRole(payload: AntFarmWebhookPayload): 'builder' | 'validator' | 'reviewer' | 'security' {
  const content = (payload.message?.content || payload.task?.description || '').toLowerCase();
  
  if (content.includes('review') || content.includes('audit') || content.includes('check')) {
    return 'reviewer';
  }
  
  if (content.includes('test') || content.includes('validate') || content.includes('verify')) {
    return 'validator';
  }
  
  if (content.includes('security') || content.includes('vulnerability')) {
    return 'security';
  }
  
  return 'builder';
}

/**
 * Extract @mentions from Ant Farm message
 */
export function extractMentions(payload: AntFarmWebhookPayload): string[] {
  return payload.message?.mentions || [];
}

/**
 * Check if message is a task request
 */
export function isTaskRequest(payload: AntFarmWebhookPayload): boolean {
  return payload.eventType === 'room.task.requested';
}

/**
 * Get task priority score
 */
export function getTaskPriorityScore(priority: string): number {
  const scores: Record<string, number> = {
    low: 1,
    medium: 5,
    high: 10,
    critical: 100,
  };
  
  return scores[priority] || 1;
}
