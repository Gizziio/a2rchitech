/**
 * Moltbook Webhook Normalizer
 * 
 * Transforms raw Moltbook webhook payloads into normalized events.
 */

import type {
  MoltbookWebhookPayload,
  NormalizedWebhookEvent,
  WebhookSource,
} from '../types/webhook.types.js';
import { v4 as uuidv4 } from 'uuid';
import { createHash } from 'crypto';

/**
 * Normalize Moltbook webhook payload
 */
export function normalizeMoltbookWebhook(
  rawPayload: MoltbookWebhookPayload
): NormalizedWebhookEvent {
  const { eventType, timestamp, rawPayload: originalRaw } = rawPayload;
  
  // Extract base components
  const [category, action] = eventType.split('.');
  
  // Build actor
  const actor = buildActor(rawPayload);
  
  // Build target
  const target = buildTarget(rawPayload);
  
  // Build action description
  const actionDesc = buildActionDescription(rawPayload, actor);
  
  // Build content
  const content = buildContent(rawPayload);
  
  // Build context
  const context: Record<string, string> = {
    eventType: eventType,
  };
  
  if (rawPayload.post?.realm) {
    context.realm = rawPayload.post.realm.name;
    context.realmSlug = rawPayload.post.realm.slug;
    context.realmId = rawPayload.post.realm.id;
  }
  
  if (rawPayload.post) {
    context.postId = rawPayload.post.id;
    context.postSubject = rawPayload.post.subject;
  }
  
  if (rawPayload.comment) {
    context.commentId = rawPayload.comment.id;
    context.postId = rawPayload.comment.postId;
  }
  
  if (rawPayload.mention) {
    context.mentionId = rawPayload.mention.id;
    context.mentionedBy = rawPayload.mention.mentionedBy.name;
  }
  
  // Generate idempotency key
  const idempotencyKey = generateIdempotencyKey(rawPayload);
  
  // Generate deterministic event ID
  const eventId = generateEventId(rawPayload);
  
  return {
    eventId,
    source: 'moltbook' as WebhookSource,
    type: `moltbook.${category}.${action}`,
    timestamp: timestamp,
    actor,
    target,
    action: {
      type: mapActionType(action),
      description: actionDesc,
    },
    content,
    context,
    idempotencyKey,
    rawPayload: originalRaw as Record<string, unknown>,
    metadata: {
      receivedAt: new Date().toISOString(),
      normalizerVersion: '1.0.0',
    },
  };
}

/**
 * Build actor from Moltbook payload
 */
function buildActor(payload: MoltbookWebhookPayload): NormalizedWebhookEvent['actor'] {
  if (payload.post?.author) {
    return {
      id: payload.post.author.id,
      name: payload.post.author.name,
      type: 'human',
    };
  }
  
  if (payload.comment?.author) {
    return {
      id: payload.comment.author.id,
      name: payload.comment.author.name,
      type: 'human',
    };
  }
  
  if (payload.mention?.mentionedBy) {
    return {
      id: payload.mention.mentionedBy.id,
      name: payload.mention.mentionedBy.name,
      type: 'human',
    };
  }
  
  if (payload.challenge?.requestedBy) {
    return {
      id: payload.challenge.requestedBy,
      name: payload.challenge.requestedBy,
      type: 'human',
    };
  }
  
  return undefined;
}

/**
 * Build target from Moltbook payload
 */
function buildTarget(payload: MoltbookWebhookPayload): NormalizedWebhookEvent['target'] {
  // Post events
  if (payload.post) {
    return {
      type: 'post',
      id: payload.post.id,
      name: payload.post.subject,
    };
  }
  
  // Comment events
  if (payload.comment) {
    return {
      type: 'post',
      id: payload.comment.postId,
      name: `Comment on post ${payload.comment.postId}`,
    };
  }
  
  // Mention events
  if (payload.mention) {
    return {
      type: 'message',
      id: payload.mention.id,
      name: `Mention in ${payload.mention.context.slice(0, 30)}...`,
    };
  }
  
  return undefined;
}

/**
 * Build action description
 */
function buildActionDescription(
  payload: MoltbookWebhookPayload,
  actor?: NormalizedWebhookEvent['actor']
): string {
  const actorName = actor?.name || 'Unknown';
  const eventType = payload.eventType;
  
  const descriptions: Record<string, string> = {
    'post.created': `${actorName} created a post: ${payload.post?.subject || 'unknown'}`,
    'comment.created': `${actorName} commented on a post`,
    'mention.received': `${actorName} was mentioned`,
    'challenge.created': `${actorName} issued a challenge`,
    'challenge.verified': `${actorName} verified a challenge`,
  };
  
  return descriptions[eventType] || `${actorName} triggered ${eventType}`;
}

/**
 * Build content from Moltbook payload
 */
function buildContent(payload: MoltbookWebhookPayload): NormalizedWebhookEvent['content'] {
  const content: NormalizedWebhookEvent['content'] = {};
  
  // Post content
  if (payload.post?.content) {
    content.text = payload.post.content;
  }
  
  // Comment content
  if (payload.comment?.content) {
    content.text = payload.comment.content;
  }
  
  // Mention context
  if (payload.mention?.context) {
    content.text = payload.mention.context;
  }
  
  // Attachments
  const attachments: Array<{ type: 'image' | 'file' | 'link'; url: string; filename?: string }> = [];
  
  if (payload.post?.attachments) {
    for (const attachment of payload.post.attachments) {
      const isImage = attachment.filename?.match(/\.(png|jpg|jpeg|gif|webp)$/i);
      attachments.push({
        type: isImage ? 'image' : 'file',
        url: attachment.url,
        filename: attachment.filename,
      });
    }
  }
  
  if (attachments.length > 0) {
    content.attachments = attachments;
  }
  
  return Object.keys(content).length > 0 ? content : undefined;
}

/**
 * Map Moltbook action to normalized action type
 */
function mapActionType(action: string): NonNullable<NormalizedWebhookEvent['action']>['type'] {
  const typeMap: Record<string, NonNullable<NormalizedWebhookEvent['action']>['type']> = {
    created: 'created',
    received: 'created',
    verified: 'updated',
  };
  
  return typeMap[action] || 'updated';
}

/**
 * Generate idempotency key for deduplication
 */
function generateIdempotencyKey(payload: MoltbookWebhookPayload): string {
  const components: string[] = [
    payload.source,
    payload.eventType,
  ];
  
  // Add post ID if present
  if (payload.post?.id) {
    components.push(`post:${payload.post.id}`);
  }
  
  // Add comment ID if present
  if (payload.comment?.id) {
    components.push(`comment:${payload.comment.id}`);
  }
  
  // Add mention ID if present
  if (payload.mention?.id) {
    components.push(`mention:${payload.mention.id}`);
  }
  
  // Add challenge ID if present
  if (payload.challenge?.id) {
    components.push(`challenge:${payload.challenge.id}`);
  }
  
  // Add timestamp rounded to minute
  const minuteTimestamp = Math.floor(new Date(payload.timestamp).getTime() / 60000);
  components.push(`min:${minuteTimestamp}`);
  
  const keyString = components.join('|');
  return `mb_${createHash('sha256').update(keyString).digest('hex').slice(0, 16)}`;
}

/**
 * Generate deterministic event ID
 */
function generateEventId(_payload: MoltbookWebhookPayload): string {
  return `evt_mb_${uuidv4()}`;
}

/**
 * Check if Moltbook webhook requires agent action
 */
export function requiresAgentAction(payload: MoltbookWebhookPayload): boolean {
  const actionEvents: Set<string> = new Set([
    'post.created',
    'comment.created',
    'mention.received',
    'challenge.created',
  ]);
  
  return actionEvents.has(payload.eventType);
}

/**
 * Infer agent role from Moltbook webhook
 */
export function inferAgentRole(payload: MoltbookWebhookPayload): 'builder' | 'validator' | 'reviewer' | 'security' {
  const content = ((payload.post?.content || '') + ' ' + (payload.comment?.content || '')).toLowerCase();
  
  if (content.includes('review') || content.includes('feedback') || content.includes('critique')) {
    return 'reviewer';
  }
  
  if (content.includes('test') || content.includes('validate') || content.includes('verify')) {
    return 'validator';
  }
  
  if (content.includes('security') || content.includes('vulnerability') || content.includes('exploit')) {
    return 'security';
  }
  
  if (payload.challenge) {
    return 'validator';
  }
  
  return 'builder';
}

/**
 * Check if webhook is a mention
 */
export function isMention(payload: MoltbookWebhookPayload): boolean {
  return payload.eventType === 'mention.received' || !!payload.mention;
}

/**
 * Check if webhook is a challenge
 */
export function isChallenge(payload: MoltbookWebhookPayload): boolean {
  return payload.eventType === 'challenge.created' || !!payload.challenge;
}

/**
 * Get challenge verification data
 */
export function getChallengeData(payload: MoltbookWebhookPayload): { type: string; data: string } | null {
  if (payload.challenge) {
    return {
      type: payload.challenge.type,
      data: payload.challenge.data,
    };
  }
  return null;
}
