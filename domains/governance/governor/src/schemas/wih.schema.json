{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://allternit.dev/schemas/wih.json",
  "title": "Work-In-Hand (WIH) Schema",
  "description": "Schema for Allternit Kernel work items governing task execution and dependency tracking",
  "type": "object",
  "required": ["id", "title", "status", "createdAt", "version"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Z0-9]+-[A-Z0-9]+$",
      "description": "Unique work item identifier (e.g., 'P2-T0200', 'Allternit-001')"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Human-readable task title"
    },
    "description": {
      "type": "string",
      "description": "Detailed task description"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "ready", "in_progress", "blocked", "review", "complete", "cancelled"],
      "description": "Current lifecycle state"
    },
    "priority": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "default": 50,
      "description": "Priority score (0-100, higher = more important)"
    },
    "blockedBy": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9]+-[A-Z0-9]+$"
      },
      "description": "List of WIH IDs that must complete before this item"
    },
    "blocks": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9]+-[A-Z0-9]+$"
      },
      "description": "List of WIH IDs waiting on this item"
    },
    "assignee": {
      "type": "string",
      "description": "Agent or person assigned (e.g., 'BuildOps', 'Lead-Orchestrator')"
    },
    "phase": {
      "type": "string",
      "description": "Development phase this item belongs to"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      },
      "description": "Categorical tags for filtering"
    },
    "estimatedEffort": {
      "type": "object",
      "properties": {
        "value": { "type": "number", "minimum": 0 },
        "unit": { "type": "string", "enum": ["minutes", "hours", "days", "story-points"] }
      }
    },
    "actualEffort": {
      "type": "object",
      "properties": {
        "value": { "type": "number", "minimum": 0 },
        "unit": { "type": "string", "enum": ["minutes", "hours", "days", "story-points"] }
      }
    },
    "receiptRefs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "References to completion receipts"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "type"],
        "properties": {
          "path": { "type": "string" },
          "type": { "type": "string", "enum": ["code", "doc", "config", "test", "schema"] },
          "description": { "type": "string" }
        }
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "completedAt": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "default": "1.0.0",
      "description": "Schema version for migration tracking"
    },
    "routing": {
      "type": "object",
      "description": "Allternit Kernel routing configuration",
      "properties": {
        "preToolUse": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Functions to call before tool execution"
        },
        "postToolUse": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Functions to call after tool execution"
        },
        "fileAccessCheck": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Functions to validate file operations"
        }
      }
    }
  },
  "additionalProperties": false
}
