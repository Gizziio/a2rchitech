{
  "name": "@a2r/thin-client-extension",
  "version": "0.1.0",
  "description": "A2R Thin Client - Desktop companion extension for web integration",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build --mode production",
    "build:prod": "npm run build && npm run package",
    "package": "npm run package:chrome && npm run package:firefox",
    "package:chrome": "cd dist && zip -r ../a2r-thin-client-v$npm_package_version.zip .",
    "install:native-host": "bash scripts/install-native-host.sh",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.246",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.45.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-web-extension": "^4.0.0"
  },
  "dependencies": {
    "zod": "^3.22.4"
  }
}
