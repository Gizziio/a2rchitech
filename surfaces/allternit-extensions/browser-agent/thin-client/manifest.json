{
  "manifest_version": 3,
  "name": "A2R Thin Client - Desktop Companion",
  "version": "0.1.0",
  "description": "Connects A2R Desktop to web applications. Enables agent automation on GitHub, Figma, and more.",
  "permissions": [
    "nativeMessaging",
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://github.com/*",
    "https://*.github.com/*",
    "https://figma.com/*",
    "https://*.figma.com/*",
    "https://docs.google.com/*",
    "https://notion.so/*",
    "https://*.notion.so/*",
    "https://linear.app/*",
    "https://*.atlassian.net/*",
    "https://app.slack.com/*",
    "https://discord.com/*",
    "https://*.discord.com/*",
    "http://localhost:*/",
    "https://localhost:*/"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*",
        "https://*.github.com/*"
      ],
      "js": ["content-github.js"],
      "run_at": "document_idle",
      "world": "ISOLATED"
    },
    {
      "matches": [
        "https://figma.com/*",
        "https://*.figma.com/*"
      ],
      "js": ["content-figma.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["content-generic.js"],
      "run_at": "document_idle",
      "world": "ISOLATED"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected-bridge.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "externally_connectable": {
    "matches": ["http://localhost:*/*", "https://*.a2r.io/*"]
  },
  "key": "MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA2YOUR_EXTENSION_KEY_HERE"
}
