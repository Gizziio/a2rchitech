{
  "name": "@allternit/office",
  "private": true,
  "version": "1.0.0",
  "description": "Allternit Office Add-ins — Excel, PowerPoint, Word task pane",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000",
    "dev:excel": "concurrently \"npm run dev\" \"office-addin-debugging start manifest.xml --app excel --dev-server-port 3000\"",
    "dev:powerpoint": "concurrently \"npm run dev\" \"office-addin-debugging start manifest.xml --app powerpoint --dev-server-port 3000\"",
    "dev:word": "concurrently \"npm run dev\" \"office-addin-debugging start manifest.xml --app word --dev-server-port 3000\"",
    "stop": "office-addin-debugging stop manifest.xml",
    "certs": "office-addin-dev-certs install",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 3000",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/office-js": "^1.0.508",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.0.0",
    "lucide-react": "^0.577.0",
    "office-addin-debugging": "^6.0.0",
    "office-addin-dev-certs": "^1.10.0",
    "tailwind-merge": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.7",
    "zod": "^3.25.0"
  }
}
