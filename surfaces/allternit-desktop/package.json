{
  "name": "@allternit/desktop",
  "version": "1.0.0",
  "description": "Allternit Desktop — Electron shell loading the Allternit platform with local VM management via Apple Virtualization.framework.",
  "main": "dist/main/unified-main.js",
  "type": "module",
  "keywords": [
    "allternit",
    "desktop",
    "electron"
  ],
  "scripts": {
    "dev": "NODE_ENV=development electron .",
    "prepare:platform-server": "node scripts/prepare-platform-server.cjs",
    "prepare:gateway-runtime": "node scripts/prepare-gateway-runtime.cjs",
    "build": "npm run build:main && npm run build:preload",
    "build:main": "tsc -p src/main/tsconfig.json",
    "build:preload": "tsc -p src/preload/tsconfig.json",
    "download:lima": "node scripts/download-lima.cjs",
    "build:electron": "npm run prepare:platform-server && npm run prepare:gateway-runtime && npm run download:lima && npm run build && electron-builder --mac",
    "build:electron:dmg": "npm run prepare:platform-server && npm run prepare:gateway-runtime && npm run download:lima && npm run build && electron-builder --mac dmg",
    "start": "electron .",
    "typecheck": "tsc --noEmit -p src/main/tsconfig.json && tsc --noEmit -p src/preload/tsconfig.json",
    "pack": "npm run prepare:platform-server && npm run prepare:gateway-runtime && electron-builder --dir",
    "dist": "npm run prepare:platform-server && npm run prepare:gateway-runtime && npm run build && electron-builder"
  },
  "dependencies": {
    "electron-log": "^5.2.0",
    "electron-store": "^8.2.0",
    "fix-path": "^4.0.0",
    "update-electron-app": "^3.0.0"
  },
  "devDependencies": {
    "@electron/notarize": "^2.3.2",
    "@types/electron-store": "^1.3.1",
    "concurrently": "^8.2.2",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.4.0",
    "wait-on": "^8.0.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "Allternit",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/allternit/desktop"
  },
    "build": {
      "appId": "com.allternit.desktop",
      "productName": "Allternit Desktop",
      "protocols": [
        {
          "name": "Allternit Protocol",
          "schemes": ["allternit"]
        }
      ],
      "npmRebuild": false,
    "nodeGypRebuild": false,
    "copyright": "Copyright © 2026 Allternit",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "build/**/*",
      "!build/entitlements*",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "resources/bin/",
        "to": "bin/",
        "filter": ["**/*"]
      },
      {
        "from": "resources/platform-server/",
        "to": "platform-server/",
        "filter": ["**/*"]
      },
      {
        "from": "resources/gateway-runtime/",
        "to": "gateway-runtime/",
        "filter": ["**/*"]
      },
      {
        "from": "resources/lima/",
        "to": "lima/",
        "filter": ["**/*"]
      },
      {
        "from": "cmd/gizzi-code/src/runtime/vm/allternit.yaml",
        "to": "allternit.yaml"
      }
    ],
    "asarUnpack": [
      "resources/bin/**",
      "resources/lima/**"
    ],
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "darkModeSupport": true
    },
    "dmg": {
      "title": "Allternit ${version}",
      "icon": "build/icon.icns",
      "background": "build/dmg-background.png",
      "window": { "width": 540, "height": 380 },
      "contents": [
        { "x": 130, "y": 200, "name": "Allternit" },
        { "x": 410, "y": 200, "type": "link", "path": "/Applications" }
      ],
      "internetEnabled": false
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "build/icon.png",
      "category": "Development",
      "synopsis": "Your AI Platform",
      "description": "Allternit Desktop — fully offline AI platform with local VM execution."
    },
    "appImage": {
      "artifactName": "Allternit-${version}.AppImage"
    },
    "deb": {
      "packageCategory": "utils",
      "priority": "optional",
      "compression": "xz"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "build/icon.ico",
      "signingHashAlgorithms": ["sha256"],
      "publisherName": "Allternit"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeader": "build/installer-header.bmp",
      "installerSidebar": "build/installer-sidebar.bmp",
      "uninstallerSidebar": "build/installer-sidebar.bmp",
      "include": "build/installer.nsh",
      "shortcutName": "Allternit",
      "menuCategory": "Allternit",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "differentialPackage": true,
      "artifactName": "Allternit-Setup-${version}.exe",
      "license": "build/LICENSE.txt"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "allternit",
        "repo": "desktop",
        "releaseType": "release"
      }
    ],
    "afterSign": "scripts/notarize.cjs"
  }
}
