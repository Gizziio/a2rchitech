{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://allternit.local/spec/contracts/ReplayManifest.schema.json",
  "title": "Replay Manifest",
  "description": "Schema for run replay manifests in the Allternit system",
  "type": "object",
  "properties": {
    "manifest_version": {
      "type": "string",
      "description": "Version of the manifest schema"
    },
    "replay_id": {
      "type": "string",
      "description": "Unique identifier for the replay"
    },
    "original_run_id": {
      "type": "string",
      "description": "ID of the original run being replayed"
    },
    "replay_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp of the replay"
    },
    "replayer_id": {
      "type": "string",
      "description": "ID of the entity performing the replay"
    },
    "graph_id": {
      "type": "string",
      "description": "ID of the graph used for replay"
    },
    "replay_mode": {
      "type": "string",
      "enum": ["FULL", "FROM_NODE", "SELECTIVE_NODES"],
      "description": "Mode of the replay"
    },
    "starting_node": {
      "type": "string",
      "description": "Starting node for partial replays (optional)"
    },
    "selected_nodes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Selected nodes for selective replay (optional)"
    },
    "replay_config": {
      "type": "object",
      "properties": {
        "preserve_original_timestamps": {
          "type": "boolean",
          "description": "Whether to preserve original timestamps"
        },
        "simulate_delays": {
          "type": "boolean",
          "description": "Whether to simulate original delays"
        },
        "dry_run": {
          "type": "boolean",
          "description": "Whether to perform a dry run"
        },
        "parallel_execution": {
          "type": "boolean",
          "description": "Whether to allow parallel execution"
        }
      },
      "required": ["preserve_original_timestamps", "simulate_delays", "dry_run"]
    },
    "node_execution_order": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "task_id": {
            "type": "string"
          },
          "expected_dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "execution_sequence_number": {
            "type": "integer"
          }
        },
        "required": ["task_id", "expected_dependencies", "execution_sequence_number"]
      }
    },
    "memory_state_snapshot": {
      "type": "object",
      "properties": {
        "promoted_candidates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "active_layers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "expected_receipts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Paths to expected receipts for verification"
    },
    "verification_strategy": {
      "type": "object",
      "properties": {
        "hash_comparison": {
          "type": "boolean"
        },
        "signature_verification": {
          "type": "boolean"
        },
        "semantic_equivalence": {
          "type": "boolean"
        }
      },
      "required": ["hash_comparison", "signature_verification"]
    }
  },
  "required": [
    "manifest_version",
    "replay_id",
    "original_run_id",
    "replay_timestamp",
    "replayer_id",
    "graph_id",
    "replay_mode",
    "replay_config",
    "node_execution_order",
    "memory_state_snapshot",
    "expected_receipts",
    "verification_strategy"
  ]
}