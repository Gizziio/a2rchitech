{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://allternit.local/spec/contracts/PromotionRules.schema.json",
  "title": "Deterministic Promotion Rules",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "rules"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+$"
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "applies_to",
          "risk",
          "requires_checks",
          "auto_approve"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Z0-9_-]{4,64}$"
          },
          "applies_to": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "prompt",
                "policy",
                "spec_delta",
                "tool",
                "index",
                "memory_pack",
                "routing_rule",
                "ui_config"
              ]
            },
            "minItems": 1
          },
          "risk": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "requires_checks": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "auto_approve": {
            "type": "boolean"
          },
          "deny_if": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}