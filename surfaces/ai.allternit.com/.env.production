# Production build env — baked into the static JS bundle at build time.
# Vite exposes VITE_* prefixed vars to the browser bundle.
# NEVER put secret keys here.

# Clerk — enabled for production
VITE_ALLTERNIT_PLATFORM_DISABLE_CLERK=0
VITE_CLERK_PUBLISHABLE_KEY=pk_live_Y2xlcmsucGxhdGZvcm0uYWxsdGVybml0LmNvbSQ
