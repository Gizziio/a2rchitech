VITE_CLERK_SIGN_UP_URL=https://platform.allternit.com/sign-up
VITE_CLERK_AFTER_SIGN_IN_URL=https://ai.allternit.com
VITE_CLERK_AFTER_SIGN_UP_URL=https://ai.allternit.com

# Legacy fallbacks (migration period)
