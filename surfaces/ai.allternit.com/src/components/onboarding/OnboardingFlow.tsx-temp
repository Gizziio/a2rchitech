function ModesStep({ data, onUpdate }: { data: WizardData; onUpdate: (d: Partial<WizardData>) => void }) {
  // Discovery state
  const [discovery, setDiscovery] = useState<DiscoveryResult | null>(null);
  const [scanning, setScanning] = useState(true);

  // Cloud key state
  const [expandedProvider, setExpandedProvider] = useState<CloudProviderId | null>(null);
  const [keyDraft, setKeyDraft] = useState<Partial<Record<CloudProviderId, string>>>({});
  const [keyStatus, setKeyStatus] = useState<Partial<Record<CloudProviderId, KeyStatus>>>({});
  const [keyModels, setKeyModels] = useState<Partial<Record<CloudProviderId, Array<{ id: string; name: string }>>>>({});
  const [keyError, setKeyError] = useState<Partial<Record<CloudProviderId, string>>>({});
  const [showKey, setShowKey] = useState<Partial<Record<CloudProviderId, boolean>>>({});

  const selected = data.defaultProvider;

  // Local Brain download state
  const [lbPullState, setLbPullState] = useState<'idle' | 'pulling' | 'done' | 'error'>('idle');
  const [lbPullProgress, setLbPullProgress] = useState<{ status: string; total?: number; completed?: number } | null>(null);

  const localBrainAlreadyPulled = discovery?.ollama.models.some(
    (m) => m.modelId === 'llama3.2:3b' || m.modelId.startsWith('llama3.2:3b') || m.modelId === 'llama3.2:3b:latest'
  ) ?? false;

  const lbPullPct =
    lbPullProgress?.total && lbPullProgress.completed
      ? Math.round((lbPullProgress.completed / lbPullProgress.total) * 100)
      : null;

  async function startLocalBrainDownload() {
    setLbPullState('pulling');
    setLbPullProgress(null);
    try {
      const res = await fetch('/api/local-brain', { method: 'POST' });
      if (!res.ok) { setLbPullState('error'); return; }
      const reader = res.body!.getReader();
      const dec = new TextDecoder();
      let buf = '';
      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        buf += dec.decode(value, { stream: true });
        const lines = buf.split('\n');
        buf = lines.pop() ?? '';
        for (const line of lines) {
          if (!line.startsWith('data: ')) continue;
          try {
            const ev = JSON.parse(line.slice(6)) as { status: string; total?: number; completed?: number };
            setLbPullProgress(ev);
            if (ev.status === 'success' || ev.status === 'done') {
              setLbPullState('done');
              onUpdate({ defaultProvider: 'ollama', defaultModelId: 'llama3.2:3b' });
            } else if (ev.status === 'error') {
              setLbPullState('error');
            }
          } catch {}
        }
      }
    } catch {
      setLbPullState('error');
    }
  }

  // Run discovery on mount
  useEffect(() => {
    setScanning(true);
    fetch('/api/onboarding/discover')
      .then((r) => r.json())
      .then((d) => setDiscovery(d as DiscoveryResult))
      .catch(() => setDiscovery({ ollama: { running: false, models: [] }, lmstudio: { running: false, models: [] }, cli: [] }))
      .finally(() => setScanning(false));
  }, []);

  // Validate an API key against the backend
  async function validateKey(provider: CloudProviderId) {
    const key = (keyDraft[provider] ?? '').trim();
    if (key.length < 10) return;

    setKeyStatus((s) => ({ ...s, [provider]: 'checking' }));
    setKeyError((s) => ({ ...s, [provider]: undefined }));

    try {
      const res = await fetch('/api/onboarding/validate-key', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ provider, key }),
      });
      const json = await res.json() as { valid: boolean; models?: Array<{ id: string; name: string }>; error?: string };

      if (json.valid) {
        setKeyStatus((s) => ({ ...s, [provider]: 'valid' }));
        setKeyModels((s) => ({ ...s, [provider]: json.models ?? [] }));
        // Store the key + mark provider active
        const keys = { ...(data.configuredKeys ?? {}), [provider]: key };
        onUpdate({ configuredKeys: keys, apiKeysConfigured: true, defaultProvider: provider });
      } else {
        setKeyStatus((s) => ({ ...s, [provider]: 'invalid' }));
        setKeyError((s) => ({ ...s, [provider]: json.error ?? 'Key rejected' }));
      }
    } catch {
      setKeyStatus((s) => ({ ...s, [provider]: 'invalid' }));
      setKeyError((s) => ({ ...s, [provider]: 'Could not reach validation server' }));
    }
  }

  // Select a discovered local/CLI model
  function selectDiscovered(m: DiscoveredModel) {
    onUpdate({ defaultProvider: m.source, defaultModelId: m.modelId });
  }

  const allLocalModels: DiscoveredModel[] = [
    ...(discovery?.ollama.models ?? []),
    ...(discovery?.lmstudio.models ?? []),
    ...(discovery?.cli ?? []),
  ];

  const hasLocalModels = allLocalModels.length > 0;

  return (
    <div className="flex flex-col gap-3">
      <HintBox>
        Connect the AI "brain" you want to use. If you have Ollama or other tools installed, we found them automatically. Or paste an API key from a cloud provider.
      </HintBox>

      {/* ── Local / CLI section ── */}
      <div>
        <div className="text-xs font-bold tracking-widest uppercase text-[var(--ui-text-muted)] mb-[7px] flex items-center gap-[7px]">
          Found on this machine
          {scanning && (
            <motion.div
              animate={{ rotate: 360 }}
              transition={{ repeat: Infinity, duration: 1, ease: 'linear' }}
              className="flex"
            >
              <ArrowClockwise size={12} className="text-[var(--accent-primary)]" />
            </motion.div>
          )}
        </div>

        {scanning && (
          <div className="p-3 px-3.5 rounded-xl text-xs text-[var(--ui-text-muted)] bg-[var(--surface-panel)] border border-[var(--ui-border-subtle)]">
            Scanning for Ollama, LM Studio and AI CLI tools…
          </div>
        )}

        {!scanning && !hasLocalModels && (
          <div className="p-3 px-3.5 rounded-xl text-xs text-[var(--ui-text-muted)] bg-[var(--surface-panel)] border border-[var(--ui-border-subtle)]">
            Nothing found — no Ollama, LM Studio or CLI agents detected. Use a cloud key below.
          </div>
        )}

        {!scanning && allLocalModels.map((m) => {
          const sel = selected === m.source && data.defaultModelId === m.modelId;
          return (
            <motion.button
              key={m.id}
              onClick={() => selectDiscovered(m)}
              whileHover={{ scale: 1.01 }}
              whileTap={{ scale: 0.99 }}
              aria-label={`Select ${m.name} (${m.modelId})`}
              className={`flex items-center gap-3 w-full mb-1.5 p-[11px] px-3.5 rounded-xl border-none cursor-pointer text-left transition-[outline-color,background] duration-150 ${
                sel
                  ? 'bg-[color-mix(in_srgb,var(--accent-primary)_8%,var(--surface-panel))] outline-2 outline-[var(--accent-primary)] outline-offset-0'
                  : 'bg-[var(--surface-panel)] outline-2 outline-[var(--ui-border-subtle)] outline-offset-0'
              }`}
            >
              <div className={`w-[34px] h-[34px] rounded-[9px] flex-shrink-0 flex items-center justify-center text-xs font-bold tracking-tight font-mono ${
                sel ? 'bg-[color-mix(in_srgb,var(--accent-primary)_18%,var(--surface-panel))] text-[var(--accent-primary)]' : 'bg-[var(--surface-panel-muted)] text-[var(--ui-text-muted)]'
              }`}>
                {m.source === 'ollama' ? 'OL' : m.source === 'lmstudio' ? 'LM' : 'AI'}
              </div>

              <div className="flex-1 min-w-0">
                <div className="flex items-center gap-1.5 flex-wrap">
                  <span className="text-[13px] font-semibold text-[var(--ui-text-primary)]">
                    {m.name}
                  </span>
                  {m.size && (
                    <span className="text-xs font-bold px-1.5 py-0.5 rounded bg-[color-mix(in_srgb,var(--ui-text-muted)_12%,transparent)] text-[var(--ui-text-muted)]">
                      {m.size}
                    </span>
                  )}
                  {m.badge && (
                    <span className="text-xs font-bold px-1.5 py-0.5 rounded bg-[color-mix(in_srgb,#10b981_15%,transparent)] text-[var(--status-success)] tracking-wider">
                      {m.badge}
                    </span>
                  )}
                </div>
                <div className="text-xs text-[var(--ui-text-muted)] mt-px">
                  {m.modelId}
                </div>
              </div>

              <motion.div
                animate={{
                  backgroundColor: sel ? 'var(--accent-primary)' : 'transparent',
                  borderColor: sel ? 'var(--accent-primary)' : 'var(--ui-border-default)',
                }}
                className="w-[17px] h-[17px] rounded-full border-2 flex items-center justify-center flex-shrink-0"
              >
                {sel && <Check weight="bold" size={9} className="text-[var(--text-inverse)]" />}
              </motion.div>
            </motion.button>
          );
        })}
      </div>

      {/* ── Local Brain section ── */}
      {!scanning && !localBrainAlreadyPulled && (
        <div>
          <div className="text-xs font-bold tracking-widest uppercase text-[var(--ui-text-muted)] mb-[7px]">
            Local Brain
          </div>

          {!discovery?.ollama.running ? (
            <div className="p-3 px-3.5 rounded-xl text-xs text-[var(--ui-text-muted)] bg-[var(--surface-panel)] border border-[var(--ui-border-subtle)] flex items-center gap-2.5">
              <HardDrive size={16} className="flex-shrink-0" />
              <span>
                Install{' '}
                <strong className="text-[var(--ui-text-primary)]">Ollama</strong>
                {' '}to run AI offline — no API key needed.{' '}
                <a
                  href="https://ollama.com/download"
                  target="_blank"
                  rel="noreferrer"
                  className="text-[var(--accent-primary)] underline"
                >
                  Get Ollama →
                </a>
              </span>
            </div>
          ) : lbPullState === 'pulling' ? (
            <div className="p-3 px-3.5 rounded-xl bg-[color-mix(in_srgb,var(--accent-primary)_5%,var(--surface-panel))] border-2 border-[var(--accent-primary)]">
              <div className="flex items-center gap-2 mb-2">
                <motion.div
                  animate={{ rotate: 360 }}
                  transition={{ repeat: Infinity, duration: 1, ease: 'linear' }}
                  className="flex text-[var(--accent-primary)]"
                >
                  <ArrowClockwise size={13} />
                </motion.div>
                <span className="text-[13px] font-semibold text-[var(--ui-text-primary)]">
                  Downloading Local Brain
                </span>
                {lbPullPct !== null && (
                  <span className="text-xs text-[var(--accent-primary)] ml-auto">
                    {lbPullPct}%
                  </span>
                )}
              </div>
              <div className="h-1 rounded-sm bg-[var(--ui-border-subtle)] overflow-hidden">
                <div 
                  className="h-full rounded-sm bg-[var(--accent-primary)] transition-[width] duration-300 ease-out"
                  style={{ width: lbPullPct !== null ? `${lbPullPct}%` : '5%' }}
                />
              </div>
              <div className="text-xs text-[var(--ui-text-muted)] mt-1.5">
                {lbPullProgress?.status ?? 'Preparing…'} · llama3.2:3b (~2 GB)
              </div>
            </div>
          ) : lbPullState === 'done' ? (
            <motion.div
              initial={{ scale: 0.97, opacity: 0 }}
              animate={{ scale: 1, opacity: 1 }}
              className="p-[11px] px-3.5 rounded-xl bg-[color-mix(in_srgb,#10b981_8%,var(--surface-panel))] border-2 border-[#10b981] flex items-center gap-2.5"
            >
              <CheckCircle size={20} weight="fill" className="text-[var(--status-success)] flex-shrink-0" />
              <div>
                <div className="text-[13px] font-semibold text-[var(--ui-text-primary)]">
                  Local Brain ready
                </div>
                <div className="text-xs text-[var(--ui-text-muted)]">
                  llama3.2:3b · offline · selected as your brain
                </div>
              </div>
            </motion.div>
          ) : lbPullState === 'error' ? (
            <div className="p-[11px] px-3.5 rounded-xl text-xs bg-[var(--surface-panel)] border border-[var(--ui-border-subtle)] flex items-center gap-2.5">
              <Warning size={15} className="text-[var(--status-error)] flex-shrink-0" />
              <span className="text-[var(--ui-text-muted)]">Download failed — </span>
              <button
                onClick={startLocalBrainDownload}
                className="bg-transparent border-none cursor-pointer text-[var(--accent-primary)] text-xs font-semibold p-0"
              >
                try again
              </button>
            </div>
          ) : (
            <motion.button
              onClick={startLocalBrainDownload}
              whileHover={{ scale: 1.01 }}
              whileTap={{ scale: 0.99 }}
              aria-label="Download Local Brain"
              className="flex items-center gap-3 w-full p-[11px] px-3.5 rounded-xl border-none cursor-pointer text-left bg-[var(--surface-panel)] outline-2 outline-[var(--ui-border-subtle)] outline-offset-0 transition-[outline-color] duration-150"
            >
              <div className="w-[34px] h-[34px] rounded-[9px] flex-shrink-0 flex items-center justify-center bg-[color-mix(in_srgb,var(--accent-primary)_12%,transparent)] text-[var(--accent-primary)]">
                <CloudArrowDown size={18} />
              </div>
              <div className="flex-1 min-w-0">
                <div className="flex items-center gap-1.5">
                  <span className="text-[13px] font-semibold text-[var(--ui-text-primary)]">
                    Local Brain
                  </span>
                  <span className="text-xs font-bold px-1.5 py-0.5 rounded bg-[color-mix(in_srgb,var(--accent-primary)_12%,transparent)] text-[var(--accent-primary)]">
                    ~2 GB
                  </span>
                  <span className="text-xs font-bold px-1.5 py-0.5 rounded bg-[color-mix(in_srgb,#10b981_15%,transparent)] text-[var(--status-success)] tracking-wider">
                    Offline · private
                  </span>
                </div>
                <div className="text-xs text-[var(--ui-text-muted)] mt-px">
                  llama3.2:3b — works on any machine, no API key needed
                </div>
              </div>
              <div className="text-xs font-bold px-2.5 py-[5px] rounded-[7px] bg-[var(--accent-primary)] text-[var(--text-inverse)] flex-shrink-0">
                Download
              </div>
            </motion.button>
          )}
        </div>
      )}

      {/* ── Cloud providers section ── */}
      <div>
        <div className="text-xs font-bold tracking-widest uppercase text-[var(--ui-text-muted)] mb-[7px]">
          Cloud AI (paste your API key)
        </div>

        {CLOUD_PROVIDERS.map((p) => {
          const isExpanded = expandedProvider === p.id;
          const status = keyStatus[p.id] ?? 'idle';
          const isValid = status === 'valid';
          const isChecking = status === 'checking';
          const models = keyModels[p.id] ?? [];
          const selectedModel = data.defaultModelId && data.defaultProvider === p.id
            ? data.defaultModelId : null;
          const sel = data.defaultProvider === p.id && isValid;

          return (
            <div key={p.id} className="mb-1.5">
              {/* Provider row */}
              <motion.button
                onClick={() => setExpandedProvider(isExpanded ? null : p.id)}
                whileHover={{ scale: 1.005 }}
                aria-expanded={isExpanded}
                aria-label={`Configure ${p.name}`}
                className={`flex items-center gap-3 w-full p-[11px] px-3.5 border-none cursor-pointer text-left transition-[outline-color,background,border-radius] duration-150 ${
                  isExpanded ? 'rounded-t-xl rounded-b-none' : 'rounded-xl'
                } ${
                  sel
                    ? 'bg-[color-mix(in_srgb,var(--accent-primary)_8%,var(--surface-panel))] outline-2 outline-[var(--accent-primary)] outline-offset-0'
                    : isExpanded ? 'bg-[var(--surface-panel)] outline-2 outline-[var(--ui-border-default)] outline-offset-0' : 'bg-[var(--surface-panel)] outline-2 outline-[var(--ui-border-subtle)] outline-offset-0'
                }`}
              >
                <div 
                  className="w-[34px] h-[34px] rounded-[9px] flex-shrink-0 flex items-center justify-center text-[var(--ui-text-primary)]"
                  style={{ background: p.logoBg }}
                >
                  <p.Logo size={18} />
                </div>

                <div className="flex-1 min-w-0">
                  <div className="flex items-center gap-[7px]">
                    <span className="text-[13px] font-semibold text-[var(--ui-text-primary)]">
                      {p.name}
                    </span>
                    {p.badge && !isValid && (
                      <span 
                        className="text-xs font-bold px-1.5 py-0.5 rounded tracking-wider"
                        style={{ background: `color-mix(in srgb, ${p.badgeColor} 15%, transparent)`, color: p.badgeColor }}
                      >
                        {p.badge}
                      </span>
                    )}
                    {isValid && (
                      <span className="text-xs font-bold px-1.5 py-0.5 rounded bg-[color-mix(in_srgb,#10b981_15%,transparent)] text-[var(--status-success)] tracking-wider">
                        <Check weight="bold" size={9} className="mr-0.5 inline-block" /> Connected
                      </span>
                    )}
                  </div>
                  <div className="text-xs text-[var(--ui-text-muted)] mt-px">
                    {p.tagline}
                  </div>
                </div>

                <CaretRight
                  size={13}
                  className={`text-[var(--ui-text-muted)] flex-shrink-0 transition-transform duration-200 ${isExpanded ? 'rotate-90' : ''}`}
                />
              </motion.button>

              {/* Expandable key entry */}
              <AnimatePresence initial={false}>
                {isExpanded && (
                  <motion.div
                    initial={{ height: 0, opacity: 0 }}
                    animate={{ height: 'auto', opacity: 1 }}
                    exit={{ height: 0, opacity: 0 }}
                    transition={{ duration: 0.22, ease: [0.25, 0.1, 0.25, 1] }}
                    className="overflow-hidden bg-[var(--surface-panel)] border-2 border-t-0 border-[var(--ui-border-default)] rounded-b-xl"
                  >
                    <div className="p-3 px-3.5 flex flex-col gap-2">
                      {/* Key input */}
                      <div className="relative">
                        <input
                          type={showKey[p.id] ? 'text' : 'password'}
                          value={keyDraft[p.id] ?? ''}
                          onChange={(e) => {
                            setKeyDraft((d) => ({ ...d, [p.id]: e.target.value }));
                            if (keyStatus[p.id] !== 'idle') setKeyStatus((s) => ({ ...s, [p.id]: 'idle' }));
                          }}
                          onKeyDown={(e) => { if (e.key === 'Enter') validateKey(p.id); }}
                          placeholder={p.keyPlaceholder}
                          className="flex-1 w-full px-3 py-[9px] pr-20 rounded-[10px] text-[13px] bg-[var(--surface-canvas)] border border-[var(--ui-border-default)] text-[var(--ui-text-primary)] outline-none font-mono placeholder:text-[var(--ui-text-muted)]"
                          autoFocus
                        />
                        <button
                          onClick={() => setShowKey((s) => ({ ...s, [p.id]: !s[p.id] }))}
                          aria-label={showKey[p.id] ? "Hide API Key" : "Show API Key"}
                          className="absolute right-10 top-1/2 -translate-y-1/2 bg-transparent border-none cursor-pointer text-[var(--ui-text-muted)] flex p-1"
                        >
                          {showKey[p.id] ? <EyeSlash size={13} /> : <Eye size={13} />}
                        </button>
                        <button
                          onClick={() => validateKey(p.id)}
                          disabled={isChecking || (keyDraft[p.id] ?? '').trim().length < 10}
                          className={`absolute right-1.5 top-1/2 -translate-y-1/2 px-2 py-1 rounded-[7px] text-xs font-bold border-none cursor-pointer flex items-center gap-[3px] transition-[opacity,background] duration-150 ${
                            isChecking ? 'bg-[var(--surface-panel-muted)] text-[var(--ui-text-muted)]' : 'bg-[var(--accent-primary)] text-[var(--text-inverse)]'
                          } ${ (keyDraft[p.id] ?? '').trim().length < 10 ? 'opacity-40' : 'opacity-100' }`}
                        >
                          {isChecking ? (
                            <motion.div
                              animate={{ rotate: 360 }}
                              transition={{ repeat: Infinity, duration: 0.8, ease: 'linear' }}
                              className="flex"
                            >
                              <ArrowClockwise size={11} />
                            </motion.div>
                          ) : 'Test'}
                        </button>
                      </div>

                      {/* Error / hint */}
                      {keyError[p.id] && status === 'invalid' && (
                        <div className="text-xs p-1.5 px-2.5 rounded-lg bg-[var(--status-error-bg)] text-[var(--status-error)]">
                          {keyError[p.id]}
                        </div>
                      )}

                      {!keyError[p.id] && (
                        <div className="text-xs text-[var(--ui-text-muted)]">
                          {p.keyHint}
                        </div>
                      )}

                      {/* Model picker once key is valid */}
                      {isValid && models.length > 0 && (
                        <div className="flex flex-col gap-1.5 pt-1">
                          <div className="text-[12px] font-bold tracking-wider uppercase text-[var(--ui-text-muted)]">
                            Choose default model
                          </div>
                          <div className="flex flex-col gap-1">
                            {models.map((m) => {
                              const mSel = selectedModel === m.id;
                              return (
                                <button
                                  key={m.id}
                                  onClick={() => onUpdate({ defaultModelId: m.id, defaultProvider: p.id })}
                                  className={`flex items-center gap-[9px] p-2 px-2.5 rounded-[9px] border cursor-pointer text-left transition-[border-color,background] duration-150 ${
                                    mSel
                                      ? 'border-[var(--accent-primary)] bg-[color-mix(in_srgb,var(--accent-primary)_8%,var(--surface-panel))]'
                                      : 'border-[var(--ui-border-subtle)] bg-[var(--surface-panel-muted)]'
                                  }`}
                                >
                                  {mSel && <Check weight="bold" size={10} className="text-[var(--accent-primary)] flex-shrink-0" />}
                                  <span className={`text-xs text-[var(--ui-text-primary)] ${mSel ? 'font-semibold' : 'font-normal'}`}>
                                    {m.name}
                                  </span>
                                  <span className="text-[12px] text-[var(--ui-text-muted)] ml-auto font-mono">
                                    {m.id}
                                  </span>
                                </button>
                              );
                            })}
                          </div>
                        </div>
                      )}
                    </div>
                  </motion.div>
                )}
              </AnimatePresence>
            </div>
          );
        })}
      </div>

      {!selected && !scanning && (
        <div className="text-xs text-[var(--ui-text-muted)] text-center mt-0.5">
          Select a brain above to continue — you can add more in Settings anytime.
        </div>
      )}
    </div>
  );
}

// ─── Done screen — mode showcase ─────────────────────────────────────────────

type ModeKey = 'chat' | 'code' | 'browser' | 'agents' | 'private';

const MODE_TABS: Array<{
  key: ModeKey;
  label: string;
  Icon: UIIcon;
  color: string;
  bg: string;
}> = [
  { key: 'chat',    label: 'A:// Chat',    Icon: ChatCircle,  color: '#6366f1', bg: 'rgba(99,102,241,0.1)'  },
  { key: 'code',    label: 'A:// Code',    Icon: Code,        color: 'var(--status-success)', bg: 'rgba(16,185,129,0.1)'  },
  { key: 'browser', label: 'A:// Browser', Icon: Globe,       color: '#ec4899', bg: 'rgba(236,72,153,0.1)'  },
  { key: 'agents',  label: 'A:// Agents',  Icon: Robot,       color: 'var(--status-warning)', bg: 'var(--status-warning-bg)'  },
  { key: 'private', label: 'Private',      Icon: ShieldCheck, color: 'var(--status-info)', bg: 'rgba(6,182,212,0.1)'   },
];

function ModePreviewChat() {
  return (
    <div className="flex flex-col gap-2.5">
      <div className="flex justify-end">
        <div className="max-w-[72%] p-2 px-3 rounded-[14px_14px_4px_14px] bg-[rgba(99,102,241,0.15)] border border-[rgba(99,102,241,0.2)] text-xs text-[var(--ui-text-primary)] leading-relaxed">
          Explain quantum computing simply
        </div>
      </div>
      <div className="flex gap-2 items-start">
        <div className="w-[22px] h-[22px] rounded-full flex-shrink-0 mt-0.5 bg-[rgba(99,102,241,0.15)] border border-[rgba(99,102,241,0.2)] flex items-center justify-center">
          <MatrixLogo state="idle" size={13} />
        </div>
        <div className="flex-1 p-2 px-3 rounded-[4px_14px_14px_14px] bg-[var(--surface-panel)] border border-[var(--ui-border-subtle)] text-xs text-[var(--ui-text-secondary)] leading-relaxed">
          Quantum computers use qubits that can exist as both 0 and 1 simultaneously — unlike classical bits. This lets them solve certain problems exponentially faster.
        </div>
      </div>
      <div className="flex gap-1 pl-[30px] items-center">
        {[0, 1, 2].map(i => (
          <motion.div
            key={i}
            className="w-1.25 h-1.25 rounded-full bg-[rgba(99,102,241,0.5)]"
            animate={{ opacity: [0.3, 1, 0.3], scale: [0.7, 1, 0.7] }}
            transition={{ duration: 1.2, repeat: Infinity, delay: i * 0.22, ease: 'easeInOut' }}
          />
        ))}
      </div>
    </div>
  );
}

function ModePreviewCode() {
  const lines = [
    { text: '$ allternit code --fix auth.ts', color: 'rgba(255,255,255,0.55)' },
    { text: '',                                color: '' },
    { text: '✓ Scanning workspace…',           color: 'var(--status-success)' },
    { text: '✓ Found issue in auth.ts:42',     color: 'var(--status-success)' },
    { text: '~ Applying null-check fix…',      color: 'var(--status-warning)' },
    { text: '',                                color: '' },
    { text: '1 file patched — 0 errors remain', color: 'rgba(255,255,255,0.4)' },
  ];
  return (
    <div className="bg-[rgba(0,0,0,0.35)] rounded-[10px] p-3 px-3.5 font-mono text-xs border border-[var(--ui-border-muted)]">
      {lines.map((l, i) => (
        <motion.div
          key={i}
          initial={{ opacity: 0, x: -6 }}
          animate={{ opacity: 1, x: 0 }}
          transition={{ delay: 0.08 + i * 0.07, duration: 0.22 }}
          className="leading-relaxed"
          style={{ height: l.text ? 'auto' : 6, color: l.color || 'transparent' }}
        >
          {l.text}
        </motion.div>
      ))}
    </div>
  );
}

