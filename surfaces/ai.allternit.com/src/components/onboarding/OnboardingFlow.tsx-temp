      <div className="flex items-center gap-1.5 p-1.5 px-2.5 bg-[rgba(0,0,0,0.25)] rounded-lg border border-[var(--ui-border-muted)]">
        <div className="flex gap-1">
          {['#ff5f57','#febc2e','#28c840'].map(c => (
            <div key={c} className="w-2 h-2 rounded-full opacity-70" style={{ background: c }} />
          ))}
        </div>
        <div className="flex-1 p-[3px] px-2 rounded-md bg-[var(--surface-hover)] border border-[var(--ui-border-muted)] text-[12px] text-[rgba(255,255,255,0.35)] font-mono">
          competitor.com/pricing
        </div>
      </div>
      {/* Steps */}
      <div className="flex flex-col gap-1.25 pl-1">
        {steps.map((s, i) => (
          <motion.div
            key={i}
            initial={{ opacity: 0, x: -8 }}
