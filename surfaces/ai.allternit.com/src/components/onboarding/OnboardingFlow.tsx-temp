      <div className="flex items-center gap-2 p-2 px-3 rounded-[9px] bg-[rgba(6,182,212,0.08)] border border-[rgba(6,182,212,0.18)]">
        <motion.div
          className="w-1.75 h-1.75 rounded-full bg-[var(--status-info)] flex-shrink-0"
          animate={{ opacity: [1, 0.4, 1] }}
          transition={{ duration: 1.8, repeat: Infinity }}
        />
        <span className="text-xs font-semibold text-[rgba(6,182,212,0.9)]">
          Running entirely on your machine
        </span>
      </div>
      {[
        { label: 'Model',   value: 'llama3.2 · Ollama' },
        { label: 'Device',  value: 'Your computer' },
        { label: 'Network', value: 'None — fully offline' },
      ].map(({ label, value }) => (
        <div key={label} className="flex justify-between items-center text-xs">
          <span className="text-[var(--ui-text-muted)]">{label}</span>
          <span className="text-[var(--ui-text-primary)] font-medium">{value}</span>
        </div>
      ))}
      <div className="pt-1">
        <div className="flex justify-between text-xs text-[var(--ui-text-muted)] mb-1.25">
