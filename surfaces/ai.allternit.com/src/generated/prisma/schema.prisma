// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// User Model (assuming Clerk integration)
// ============================================================================

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sshKeys              SshKey[]
  sshConnections       SshConnection[]
  remoteBackendTargets RemoteBackendTarget[]
  backendPreference    UserBackendPreference?

  @@map("users")
}

// ============================================================================
// SSH Connection Model
// ============================================================================

model SshConnection {
  id                  String    @id @default(cuid())
  userId              String
  name                String
  host                String
  port                Int       @default(22)
  username            String
  authType            String    @map("auth_type") // 'key' or 'password'
  encryptedPrivateKey String?   @map("encrypted_private_key")
  encryptedPassword   String?   @map("encrypted_password")
  status              String    @default("disconnected") // 'connected', 'disconnected', 'connecting', 'error'
  os                  String?
  architecture        String?
  dockerInstalled     Boolean?  @map("docker_installed")
  allternitInstalled  Boolean?  @map("a2r_installed")
  allternitVersion    String?   @map("a2r_version")
  lastConnectedAt     DateTime? @map("last_connected_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  // Relations
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  backendTarget RemoteBackendTarget?

  @@index([userId])
  @@index([status])
  @@map("ssh_connections")
}

model RemoteBackendTarget {
  id                    String    @id @default(cuid())
  userId                String
  sshConnectionId       String    @unique @map("ssh_connection_id")
  name                  String
  status                String    @default("disconnected")
  installState          String    @default("unknown") @map("install_state")
  backendUrl            String?   @map("backend_url")
  gatewayUrl            String?   @map("gateway_url")
  gatewayWsUrl          String?   @map("gateway_ws_url")
  encryptedGatewayToken String?   @map("encrypted_gateway_token")
  installedVersion      String?   @map("installed_version")
  supportedClientRange  String?   @map("supported_client_range")
  lastVerifiedAt        DateTime? @map("last_verified_at")
  lastHeartbeatAt       DateTime? @map("last_heartbeat_at")
  lastError             String?   @map("last_error")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  sshConnection  SshConnection           @relation(fields: [sshConnectionId], references: [id], onDelete: Cascade)
  activeForUsers UserBackendPreference[] @relation("ActiveRemoteBackendTarget")

  @@index([userId])
  @@index([status])
  @@map("remote_backend_targets")
}

model UserBackendPreference {
  id                          String   @id @default(cuid())
  userId                      String   @unique
  orgId                       String?  @map("org_id")
  mode                        String   @default("local")
  fallbackMode                String   @default("local") @map("fallback_mode")
  executionMode               String   @default("auto") @map("execution_mode")
  executionModeUpdatedAt      DateTime @default(now()) @map("execution_mode_updated_at")
  activeRemoteBackendTargetId String?  @map("active_remote_backend_target_id")
  createdAt                   DateTime @default(now()) @map("created_at")
  updatedAt                   DateTime @updatedAt @map("updated_at")

  user                      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeRemoteBackendTarget RemoteBackendTarget? @relation("ActiveRemoteBackendTarget", fields: [activeRemoteBackendTargetId], references: [id], onDelete: SetNull)

  @@index([activeRemoteBackendTargetId])
  @@map("user_backend_preferences")
}

model SshKey {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  name        String
  publicKey   String    @map("public_key")
  privateKey  String?   @map("private_key")
  passphrase  String?
  fingerprint String
  keyType     String    @default("ed25519") @map("key_type")
  bits        Int       @default(256)
  lastUsedAt  DateTime? @map("last_used_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([fingerprint])
  @@map("ssh_keys")
}

model Artifact {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  workspaceId String   @map("workspace_id")
  title       String
  type        String
  status      String
  summary     String?
  tags        String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sections  ArtifactSection[]
  revisions ArtifactRevision[]

  @@index([userId])
  @@index([workspaceId])
  @@index([status])
  @@index([type])
  @@map("artifacts")
}

model ArtifactSection {
  id         String   @id @default(cuid())
  artifactId String   @map("artifact_id")
  heading    String
  kind       String
  body       String
  position   Int
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  artifact Artifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  @@index([artifactId])
  @@index([artifactId, position])
  @@map("artifact_sections")
}

model ArtifactRevision {
  id         String   @id @default(cuid())
  artifactId String   @map("artifact_id")
  reason     String
  snapshot   String
  createdAt  DateTime @default(now()) @map("created_at")

  artifact Artifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  @@index([artifactId])
  @@index([artifactId, createdAt])
  @@map("artifact_revisions")
}

// ============================================================================
// Workflow Models
// ============================================================================

model Workflow {
  id          String              @id @default(cuid())
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  title       String
  description String?
  userId      String?
  nodes       String // JSON: WorkflowNode[]
  edges       String // JSON: WorkflowEdge[]
  executions  WorkflowExecution[]

  @@map("workflows")
}

model WorkflowExecution {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workflowId  String
  workflow    Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  status      String // "pending" | "running" | "completed" | "failed" | "cancelled"
  startedAt   DateTime?
  completedAt DateTime?
  result      String? // JSON
  error       String?

  @@index([workflowId])
  @@map("workflow_executions")
}

// ============================================================================
// Agent Session Storage (migrated from Gizzi runtime)
// ============================================================================

model AgentSession {
  id            String   @id
  name          String?
  agentId       String
  agentName     String
  runtimeModel  String
  originSurface String   @default("remote-agents-api")
  sessionMode   String   @default("chat")
  metadata      String // JSON: Record<string, unknown>
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([agentId])
  @@map("agent_sessions")
}

// ============================================================================
// Reply Persistence
// ============================================================================

model Reply {
  id             String   @id
  conversationId String
  status         String // "streaming" | "completed" | "error"
  content        String // JSON: ReplyItem[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([conversationId])
  @@map("replies")
}

// ============================================================================
// Conversation Branching Models
// ============================================================================

model Conversation {
  id                   String                @id @default(cuid())
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  title                String?
  userId               String?
  parentConversationId String?
  gizziSessionId       String?               @map("gizzi_session_id")
  parentConversation   Conversation?         @relation("ConversationBranches", fields: [parentConversationId], references: [id])
  branches             Conversation[]        @relation("ConversationBranches")
  messages             ConversationMessage[]

  @@index([userId])
  @@index([parentConversationId])
  @@index([gizziSessionId])
  @@map("conversations")
}

model ConversationMessage {
  id              String       @id @default(cuid())
  createdAt       DateTime     @default(now())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role            String // "user" | "assistant" | "system"
  content         String
  parentMessageId String?
  metadata        String? // JSON

  @@index([conversationId])
  @@index([parentMessageId])
  @@map("conversation_messages")
}

// ============================================================================
// Workspace Models (Team isolation — from Multica)
// ============================================================================

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  ownerId     String   @map("owner_id")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members     WorkspaceMember[]
  invitations WorkspaceInvitation[]
  boardItems  BoardItem[]
  skills      TeamSkill[]
  runtimes    AgentRuntime[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  userId      String?  @map("user_id")
  agentId     String?  @map("agent_id")
  role        String // 'owner' | 'admin' | 'member' | 'agent'
  joinedAt    DateTime @default(now()) @map("joined_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@unique([workspaceId, agentId])
  @@map("workspace_members")
}

model WorkspaceInvitation {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  email       String
  role        String // 'admin' | 'member' | 'agent'
  token       String   @unique
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_invitations")
}

// ============================================================================
// Board Models (Kanban — from Multica)
// ============================================================================

model BoardItem {
  id               String    @id @default(cuid())
  workspaceId      String    @map("workspace_id")
  title            String
  description      String?
  status           String // 'backlog' | 'todo' | 'in_progress' | 'in_review' | 'done' | 'blocked'
  assigneeType     String?   @map("assignee_type") // 'human' | 'agent'
  assigneeId       String?   @map("assignee_id")
  reporterId       String    @map("reporter_id")
  priority         Int       @default(0)
  labels           String? // JSON string[]
  estimatedMinutes Int?      @map("estimated_minutes")
  deadline         DateTime?
  dependencies     String? // JSON string[]
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  comments  BoardComment[]

  @@index([workspaceId])
  @@index([status])
  @@map("board_items")
}

model BoardComment {
  id         String   @id @default(cuid())
  itemId     String   @map("item_id")
  authorType String   @map("author_type") // 'human' | 'agent'
  authorId   String   @map("author_id")
  body       String
  createdAt  DateTime @default(now()) @map("created_at")

  item BoardItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@map("board_comments")
}

// ============================================================================
// Team Skill Model (Skills Marketplace — from Multica)
// ============================================================================

model TeamSkill {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  name        String
  description String?
  manifest    String? // JSON: Plugin SDK manifest
  sourceRepo  String?  @map("source_repo")
  version     String
  installedBy String   @map("installed_by")
  installedAt DateTime @default(now()) @map("installed_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("team_skills")
}

// ============================================================================
// Task Audit Log Model (from Taskdog)
// ============================================================================

model TaskAuditLog {
  id        String   @id @default(cuid())
  taskId    String   @map("task_id")
  action    String // 'created' | 'updated' | 'deleted' | 'status_changed' | 'assigned' | 'commented' | 'time_tracked'
  actorType String   @map("actor_type") // 'human' | 'agent' | 'system'
  actorId   String   @map("actor_id")
  payload   String? // JSON: before/after diff
  createdAt DateTime @default(now()) @map("created_at")

  @@index([taskId])
  @@index([createdAt])
  @@map("task_audit_logs")
}

// ============================================================================
// Agent Runtime Model (Runtime Discovery — from Multica)
// ============================================================================

model AgentRuntime {
  id            String    @id @default(cuid())
  name          String
  host          String
  agentClis     String?   @map("agent_clis") // JSON string[]
  status        String // 'online' | 'offline' | 'busy'
  lastHeartbeat DateTime? @map("last_heartbeat")
  workspaceId   String?   @map("workspace_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([status])
  @@map("agent_runtimes")
}

// ============================================================================
// Agent Platform Models (Memory, Testing, Metrics, Identity)
// ============================================================================

model Agent {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  name          String
  description   String?
  type          String    @default("worker") // orchestrator | sub-agent | worker | specialist | reviewer
  parentAgentId String?   @map("parent_agent_id")
  model         String
  provider      String // openai | anthropic | local | custom
  capabilities  String? // JSON string[]
  systemPrompt  String?   @map("system_prompt")
  tools         String? // JSON string[]
  maxIterations Int       @default(10) @map("max_iterations")
  temperature   Float     @default(0.7)
  config        String? // JSON Record<string, unknown>
  status        String    @default("idle") // idle | running | paused | error
  workspaceId   String?   @map("workspace_id")
  avatar        String? // JSON AvatarConfig
  identityKey   String?   @map("identity_key") // Ed25519 public key for agent signing
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  lastRunAt     DateTime? @map("last_run_at")

  // Relations
  memoryEvents   MemoryEvent[]
  memoryEntities MemoryEntity[]
  testSuites     TestSuite[]
  metrics        AgentMetric[]

  @@index([userId])
  @@index([status])
  @@map("agents")
}

model MemoryEvent {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  agentId   String?  @map("agent_id")
  type      String // message_sent | tool_called | file_read | session_start | knowledge_added
  payload   String // JSON or text payload
  source    String   @default("user") // user | agent | system
  timestamp DateTime @default(now())

  agent Agent? @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([agentId])
  @@index([type])
  @@index([timestamp])
  @@map("memory_events")
}

model MemoryEntity {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  agentId       String?  @map("agent_id")
  entityId      String   @map("entity_id") // Stable external ID
  name          String
  type          String   @default("General") // Person | Company | Project | File | Session | Tool | Concept
  content       String? // Full content or summary
  properties    String? // JSON Record<string, unknown>
  propertyCount Int      @default(0) @map("property_count")
  vectorId      String?  @map("vector_id") // External vector DB reference
  lastUpdated   DateTime @updatedAt @map("last_updated")
  createdAt     DateTime @default(now()) @map("created_at")

  agent Agent? @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([agentId])
  @@index([entityId])
  @@index([type])
  @@map("memory_entities")
}

model MemoryEdge {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  source       String
  relationship String
  target       String
  confidence   Float    @default(1.0)
  metadata     String? // JSON
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([source])
  @@index([target])
  @@map("memory_edges")
}

model MemoryDocument {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  agentId    String?  @map("agent_id")
  title      String
  content    String
  sourceType String   @map("source_type") // upload | url | paste | generated
  sourceUrl  String?  @map("source_url")
  chunkCount Int      @default(0) @map("chunk_count")
  vectorIds  String?  @map("vector_ids") // JSON string[] of vector DB IDs
  isIndexed  Boolean  @default(false) @map("is_indexed")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([agentId])
  @@index([isIndexed])
  @@map("memory_documents")
}

model TestSuite {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  agentId     String   @map("agent_id")
  name        String
  description String?
  cases       String // JSON TestCase[]
  runs        String? // JSON TestRun[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([agentId])
  @@map("test_suites")
}

model AgentMetric {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  agentId    String   @map("agent_id")
  runId      String?  @map("run_id")
  metricType String   @map("metric_type") // latency | tokens | cost | success | tool_calls
  value      Float
  unit       String // ms | tokens | usd | percent | count
  metadata   String? // JSON
  timestamp  DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([agentId])
  @@index([metricType])
  @@index([timestamp])
  @@map("agent_metrics")
}

model InboxItem {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  agentId   String?  @map("agent_id")
  type      String // mail | gate_review | run_complete | system_alert | ban_triggered
  title     String
  body      String
  severity  String   @default("info") // info | warning | critical
  status    String   @default("unread") // unread | read | acknowledged | dismissed
  actionUrl String?  @map("action_url")
  metadata  String? // JSON
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([agentId])
  @@index([status])
  @@index([createdAt])
  @@map("inbox_items")
}

// ============================================================================
// Cowork Engine Models
// ============================================================================

model CoworkProject {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  title        String
  description  String?
  instructions String?
  metadata     String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sessions       CoworkSession[]
  scheduledTasks CoworkScheduledTask[]
  memoryEntries  CoworkMemoryEntry[]

  @@index([userId])
  @@map("cowork_projects")
}

model CoworkSession {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  projectId   String?   @map("project_id")
  title       String?
  status      String    @default("idle")
  mode        String    @default("agent")
  checkpoint  String?
  metadata    String?
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  project CoworkProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([projectId])
  @@map("cowork_sessions")
}

model CoworkScheduledTask {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  projectId        String?  @map("project_id")
  title            String
  prompt           String
  runAt            BigInt   @map("run_at")
  nextRunAt        BigInt?  @map("next_run_at")
  scheduleConfig   String?  @map("schedule_config")
  repeatEvery      Int?     @map("repeat_every")
  repeatUnit       String?  @map("repeat_unit")
  enabled          Boolean  @default(true)
  lastRunAt        BigInt?  @map("last_run_at")
  lastRunSessionId String?  @map("last_run_session_id")
  lastError        String?  @map("last_error")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  project CoworkProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([enabled, nextRunAt])
  @@index([projectId])
  @@map("cowork_scheduled_tasks")
}

model CoworkMemoryEntry {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  projectId String?  @map("project_id")
  sessionId String?  @map("session_id")
  content   String
  type      String   @default("fact")
  tags      String?
  source    String?
  createdAt DateTime @default(now()) @map("created_at")

  project CoworkProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
  @@index([type])
  @@map("cowork_memory_entries")
}

model CoworkPersona {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  name         String
  description  String?
  systemPrompt String   @map("system_prompt")
  tools        String?
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("cowork_personas")
}

model CoworkConnector {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  name      String
  enabled   Boolean   @default(true)
  config    String?
  lastUsed  DateTime? @map("last_used")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@unique([userId, name])
  @@index([userId])
  @@map("cowork_connectors")
}

model CoworkSuggestion {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  content   String
  source    String   @default("system")
  dismissed Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([dismissed])
  @@map("cowork_suggestions")
}
