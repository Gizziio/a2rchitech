{
  "name": "@a2rchitech/shell-electron",
  "version": "0.1.0",
  "description": "A2rchitect Shell - Desktop Application (Electron wrapper). Bundles the web/ app and adds native features: shortcuts, tray, system menus, Rust sidecar.",
  "main": "main/index.cjs",
  "type": "commonjs",
  "keywords": [
    "a2rchitect",
    "shell",
    "electron",
    "desktop",
    "wrapper"
  ],
  "scripts": {
    "dev": "concurrently \"npm run wait:ui && npm run dev:electron\" \"npm run dev:ui\"",
    "wait:ui": "wait-on http://127.0.0.1:5177 --timeout 60000 --interval 1000",
    "dev:electron": "electron . --remote-debugging-port=9222",
    "dev:ui": "cd ../web && pnpm dev",
    "build": "npm run build:ui && npm run build:electron",
    "build:ui": "cd ../web && pnpm build",
    "build:electron": "tsc -p tsconfig.json",
    "start": "electron .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "electron": "^28.0.0",
    "electron-store": "^11.0.2",
    "nanoid": "^5.1.6",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/electron-store": "^1.3.1",
    "@types/ws": "^8.18.1",
    "concurrently": "^8.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "wait-on": "^8.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "A2rchitect",
  "license": "MIT"
}
