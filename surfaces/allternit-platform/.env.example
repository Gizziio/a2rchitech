# Allternit Platform - Environment Variables
# Copy this file to .env.local and fill in the values

# =============================================================================
# REQUIRED: Database (SQLite for desktop app)
# =============================================================================
DATABASE_URL="file:./app.db"

# =============================================================================
# REQUIRED: Clerk Authentication (Production)
# Get from: https://dashboard.clerk.com
# =============================================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_YOUR_KEY_HERE
CLERK_SECRET_KEY=sk_live_YOUR_KEY_HERE

# =============================================================================
# REQUIRED: Encryption Key for Production
# Generate with: openssl rand -hex 32
# =============================================================================
ENCRYPTION_KEY=YOUR_ENCRYPTION_KEY_HERE

# =============================================================================
# OPTIONAL: Backend Gateway (for local development)
# =============================================================================
NEXT_PUBLIC_ALLTERNIT_GATEWAY_URL=http://localhost:4096/api/v1
