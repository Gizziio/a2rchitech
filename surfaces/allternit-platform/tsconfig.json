{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": [
      "ES2021",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@allternit/visual-state": [
        "../../3-adapters/ts/allternit-visual-state/src/index.ts"
      ],
      "@allternit/visual-state/*": [
        "../../3-adapters/ts/allternit-visual-state/src/*"
      ],
      "@allternit/avatar-adapters": [
        "../../3-adapters/ts/allternit-avatar-adapters/src/index.ts"
      ],
      "@allternit/avatar-adapters/*": [
        "../../3-adapters/ts/allternit-avatar-adapters/src/*"
      ],
      "@allternit/governor": [
        "../../2-governance/governor/src/index.ts"
      ],
      "@allternit/governor/*": [
        "../../2-governance/governor/src/*"
      ]
    },
    "allowJs": true,
    "incremental": true,
    "tsBuildInfoFile": ".tsbuildinfo",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "src/**/*",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "src/dev-portal/**/*",
    "src/allternit-usage-example/**/*",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ]
}
