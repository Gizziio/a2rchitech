{
  "name": "allternit-platform",
  "version": "1.0.0",
  "description": "A2rchitect Platform Kit - Shell UI Kernel (pure library)",
  "type": "module",
  "main": "electron/main.cjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "next dev -p 3013",
    "build": "next build",
    "start": "next start -p 3013",
    "typecheck": "tsc --noEmit",
    "audit:theme:shell": "node scripts/audit-shell-theme.mjs",
    "typecheck:refactor-slice": "tsc --project tsconfig.refactor-slice.json --noEmit",
    "typecheck:v2": "tsc --project tsconfig.v2.json --noEmit",
    "db:generate": "drizzle-kit generate --config drizzle.config.sqlite.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.sqlite.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.sqlite.ts",
    "db:push": "drizzle-kit push --config drizzle.config.sqlite.ts",
    "db:setup": "mkdir -p data && touch data/.gitkeep",
    "guard:ai-elements": "bash scripts/no-legacy-ai-elements.sh",
    "guard:no-drift": "bash scripts/guard:no-drift.sh",
    "coverage:ai-elements": "bash scripts/coverage-ai-elements.sh",
    "record:sse": "bash scripts/record-chat-sse.sh",
    "test": "vitest run",
    "test:replay": "vitest run src/lib/ai/rust-stream-adapter.replay.test.ts",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "test:storybook": "test-storybook",
    "test:a11y": "test-storybook --a11y",
    "chromatic": "chromatic --project-token=$CHROMATIC_PROJECT_TOKEN",
    "evidence:ui": "bash ../../scripts/ui-evidence-lane.sh",
    "build:electron": "npm run build && node electron/prepare-next-standalone.cjs && electron-builder --mac",
    "electron:dev": "electron electron/main.cjs"
  },
  "build": {
    "appId": "com.a2r.platform",
    "productName": "A2R Platform",
    "copyright": "Copyright © 2024 A2R Technologies",
    "npmRebuild": false,
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "electron/**/*",
      "node_modules/**/*",
      "package.json",
      "!a2r-platform"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone",
        "filter": [
          "**/*",
          "!**/node_modules/.bun/**"
        ]
      },
      {
        "from": ".next/static",
        "to": "standalone/surfaces/platform/.next/static"
      },
      {
        "from": "public",
        "to": "standalone/surfaces/platform/public"
      },
      {
        "from": ".next/standalone/server",
        "to": "server"
      },
      {
        "from": "../../services/gateway/http/dist-bundle",
        "to": "standalone/services/gateway/dist"
      },
      {
        "from": "../../cmd/gizzi-code/dist/gizzi-code-darwin-arm64",
        "to": "standalone/bin/gizzi-code"
      },
      {
        "from": "../../cmd/a2r-api/target/debug/a2r-api",
        "to": "standalone/bin/a2r-api"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "electron/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    }
  },
