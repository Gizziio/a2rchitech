      "@/drawers/*": ["../../../6-ui/a2r-platform/src/drawers/*"],
      "@/dock/*": ["../../../6-ui/a2r-platform/src/dock/*"],
      "@/runner/*": ["../../../6-ui/a2r-platform/src/runner/*"],
      "@/design/*": ["../../../6-ui/a2r-platform/src/design/*"],
