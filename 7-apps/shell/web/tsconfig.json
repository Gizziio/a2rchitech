      "@/types/*": ["../../../6-ui/a2r-platform/src/types/*"],
      "@/app/*": ["../../../6-ui/a2r-platform/src/app/*"],
      "@/hooks/*": ["../../../6-ui/a2r-platform/src/hooks/*"],
