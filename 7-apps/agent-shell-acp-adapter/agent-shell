#!/bin/bash
#
# agent-shell - Single-command launcher for A2rchitect Agent Shell
#

A2R_DIR="/Users/macbook/Desktop/a2rchitech-workspace/a2rchitech"
A2R_ACP="${A2R_DIR}/target/release/a2r-acp"

echo "🚀 A2rchitect Agent Shell"
echo ""

# Check for Emacs
if ! command -v emacs &> /dev/null; then
    echo "❌ Emacs not found."
    if [[ "$OSTYPE" == "darwin"* ]] && command -v brew &> /dev/null; then
        echo "📦 Installing Emacs via Homebrew..."
        brew install emacs
    else
        echo "Please install Emacs 29.1+"
        exit 1
    fi
fi

# Build a2r-acp if needed
if [ ! -f "$A2R_ACP" ]; then
    echo "📦 Building ACP adapter..."
    cd "$A2R_DIR"
    cargo build --release -p agent-shell-acp-adapter 2>&1 | tail -3
fi

# Ensure a2r-acp is in PATH
if ! command -v a2r-acp &> /dev/null; then
    export PATH="${A2R_DIR}/target/release:$PATH"
fi

echo "✓ Emacs ready"
echo "✓ a2r-acp ready"
echo ""

# For macOS, just run directly in current terminal with proper TTY
if [[ "$OSTYPE" == "darwin"* ]]; then
    echo "🎯 Starting agent-shell (press any key to continue)..."
    echo ""
    
    # Create temp elisp file
    cat > /tmp/agent-shell-start.el << 'ELISP'
(add-to-list 'load-path "/Users/macbook/Desktop/a2rchitech-workspace/a2rchitech/7-apps/agent-shell-acp-adapter")
(require 'package)
(add-to-list 'package-archives '("melpa" . "https://melpa.org/packages/") t)
(package-initialize)

(unless (package-installed-p 'agent-shell)
  (package-refresh-contents)
  (package-install 'agent-shell))

(unless (package-installed-p 'acp)
  (package-refresh-contents)
  (package-install 'acp))

(unless (package-installed-p 'shell-maker)
  (package-refresh-contents)
  (package-install 'shell-maker))

(require 'agent-shell-a2r)
(agent-shell-a2r-start)
ELISP

    # Run emacs in terminal mode
    export PATH="${A2R_DIR}/target/release:$PATH"
    exec emacs -nw -l /tmp/agent-shell-start.el
else
    # Linux
    echo "🎯 Starting agent-shell..."
    export PATH="${A2R_DIR}/target/release:$PATH"
    
    cat > /tmp/agent-shell-start.el << 'ELISP'
(add-to-list 'load-path "/Users/macbook/Desktop/a2rchitech-workspace/a2rchitech/7-apps/agent-shell-acp-adapter")
(require 'package)
(add-to-list 'package-archives '("melpa" . "https://melpa.org/packages/") t)
(package-initialize)
(require 'agent-shell-a2r)
(agent-shell-a2r-start)
ELISP

    exec emacs -nw -l /tmp/agent-shell-start.el
fi
