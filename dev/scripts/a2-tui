#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

DEBUG_BIN="$PROJECT_ROOT/target/debug/a2rchitech"
RELEASE_BIN="$PROJECT_ROOT/target/release/a2rchitech"

if [[ -x "$DEBUG_BIN" ]]; then
  exec "$DEBUG_BIN" tui "$@"
fi

if [[ -x "$RELEASE_BIN" ]]; then
  exec "$RELEASE_BIN" tui "$@"
fi

cd "$PROJECT_ROOT"
cargo build -p a2rchitech-cli
exec "$DEBUG_BIN" tui "$@"
