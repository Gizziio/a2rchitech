        },
        "data_access": {
          "read": ["notes"],
          "write": ["notes"],
          "delete": []
        },
        "system_capabilities": ["alarms"]
      },
      "confirmation_rules": [
        {
          "id": "rule-high-risk",
          "name": "Require confirmation for high+ risk",
