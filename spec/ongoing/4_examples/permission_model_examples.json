{
  "examples": [
    {
      "id": "perm-set-user123-agent456",
      "user_id": "user123",
      "agent_id": "agent456",
      "permissions": {
        "functions": {
          "allowed": [
            "com.a2rchitech.os.create_note",
            "com.a2rchitech.os.schedule_event",
            "com.a2rchitech.web.search"
          ],
          "denied": [
            "com.a2rchitech.finance.transfer_money"
          ],
          "scoped": [
            {
              "function_id": "com.a2rchitech.os.send_message",
              "constraints": {
                "parameter_restrictions": {
                  "recipient": {
                    "allowed_values": ["+1234567890", "+0987654321"]
                  }
                },
                "frequency_limits": {
                  "max_calls": 10,
                  "time_window_ms": 3600000
                }
              }
            }
          ]
        },
        "data_access": {
          "read": ["calendar", "notes"],
          "write": ["notes"],
          "delete": []
        },
        "system_capabilities": ["alarms", "location"]
      },
      "confirmation_rules": [
        {
          "id": "rule-medium-risk",
          "name": "Require confirmation for medium+ risk",
          "description": "Require user confirmation for functions with medium risk level or higher",
          "condition": {
            "type": "risk_level",
            "operator": "greater_than",
            "value": "low"
          },
          "action": "require_confirmation",
          "priority": 10
        },
        {
          "id": "rule-finance",
          "name": "Always confirm finance functions",
          "description": "Always require confirmation for finance-related functions",
          "condition": {
            "type": "function_id",
            "operator": "contains",
            "value": "finance"
          },
          "action": "require_confirmation",
          "priority": 20
        }
      ],
      "default_confirmation_threshold": "medium",
      "audit_requirements": {
        "log_all_executions": true,
        "log_parameters": true,
        "log_results": true,
        "retention_days": 180
      },
      "created_at": 1697088000,
      "updated_at": 1697088000,
      "status": "active"
    },
    {
      "id": "perm-set-user456-assistant789",
