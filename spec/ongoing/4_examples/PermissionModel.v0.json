{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Permission Model v0",
  "description": "Schema for managing permissions and confirmation rules in the A2rchitech system",
  "required": ["user_id", "agent_id", "permissions", "confirmation_rules", "created_at"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for this permission set"
    },
    "user_id": {
      "type": "string",
      "description": "ID of the user this permission set belongs to"
    },
    "agent_id": {
      "type": "string",
      "description": "ID of the agent this permission set applies to"
    },
    "permissions": {
      "type": "object",
      "description": "Permissions granted to the agent",
      "properties": {
        "functions": {
          "type": "object",
          "description": "Function-specific permissions",
          "properties": {
            "allowed": {
              "type": "array",
              "items": {
                "type": "string",
                "description": "Function ID that is allowed"
              }
            },
            "denied": {
              "type": "array",
              "items": {
                "type": "string",
                "description": "Function ID that is denied (overrides allowed)"
              }
            },
            "scoped": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "function_id": {
                    "type": "string",
                    "description": "Function ID"
                  },
                  "constraints": {
                    "type": "object",
                    "description": "Constraints for this function",
                    "properties": {
                      "parameter_restrictions": {
                        "type": "object",
                        "description": "Restrictions on parameter values",
                        "additionalProperties": {
                          "type": "object",
                          "properties": {
                            "allowed_values": {
                              "type": "array",
                              "items": {}
                            },
                            "min_value": {
                              "type": "number"
                            },
                            "max_value": {
                              "type": "number"
                            },
                            "pattern": {
                              "type": "string"
                            }
                          }
                        }
                      },
                      "frequency_limits": {
                        "type": "object",
                        "properties": {
                          "max_calls": {
                            "type": "integer",
                            "description": "Maximum number of calls allowed"
                          },
                          "time_window_ms": {
                            "type": "integer",
                            "description": "Time window in milliseconds"
                          }
                        }
                      },
                      "context_restrictions": {
                        "type": "object",
                        "description": "Context-based restrictions",
                        "properties": {
                          "allowed_times": {
                            "type": "array",
                            "items": {
                              "type": "string",
                              "description": "Allowed time ranges (HH:MM-HH:MM)"
                            }
                          },
                          "allowed_locations": {
                            "type": "array",
                            "items": {
                              "type": "string",
                              "description": "Allowed location identifiers"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "data_access": {
          "type": "object",
          "description": "Data access permissions",
          "properties": {
            "read": {
              "type": "array",
              "items": {
                "type": "string",
                "description": "Data types that can be read"
              }
            },
            "write": {
              "type": "array",
              "items": {
                "type": "string",
                "description": "Data types that can be written"
              }
            },
            "delete": {
              "type": "array",
              "items": {
                "type": "string",
                "description": "Data types that can be deleted"
              }
            }
          }
        },
        "system_capabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "description": "System capabilities granted to the agent"
          }
        }
      }
    },
    "confirmation_rules": {
      "type": "array",
      "description": "Rules that determine when user confirmation is required",
      "items": {
        "type": "object",
        "required": ["id", "condition", "action"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for this rule"
          },
          "name": {
            "type": "string",
            "description": "Human-readable name for this rule"
          },
          "description": {
            "type": "string",
            "description": "Description of what this rule does"
          },
          "condition": {
            "type": "object",
            "description": "Condition that triggers this rule",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["risk_level", "function_id", "parameter_value", "frequency", "context"],
                "description": "Type of condition"
              },
              "operator": {
                "type": "string",
                "enum": ["equals", "greater_than", "less_than", "contains", "matches", "in_list"],
                "description": "Operator to use for comparison"
              },
              "value": {},
              "field": {
                "type": "string",
                "description": "Field to apply the condition to (for parameter_value conditions)"
              }
            }
          },
          "action": {
            "type": "string",
            "enum": ["require_confirmation", "block", "log", "notify"],
            "description": "Action to take when condition is met"
          },
          "priority": {
            "type": "integer",
            "description": "Priority of this rule (higher numbers execute first)",
            "default": 0
          }
        }
      }
    },
    "default_confirmation_threshold": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"],
      "description": "Minimum risk level that requires confirmation by default",
      "default": "medium"
    },
    "audit_requirements": {
      "type": "object",
      "description": "Requirements for audit logging",
      "properties": {
        "log_all_executions": {
          "type": "boolean",
          "description": "Whether all executions should be logged",
          "default": true
        },
        "log_parameters": {
          "type": "boolean",
          "description": "Whether function parameters should be logged",
          "default": true
        },
        "log_results": {
          "type": "boolean",
          "description": "Whether function results should be logged",
          "default": true
        },
        "retention_days": {
          "type": "integer",
          "description": "Number of days to retain audit logs",
          "default": 90
        }
      }
    },
    "created_at": {
      "type": "integer",
      "description": "Unix timestamp when this permission set was created"
    },
    "updated_at": {
      "type": "integer",
      "description": "Unix timestamp when this permission set was last updated"
    },
    "expires_at": {
      "type": "integer",
      "description": "Unix timestamp when this permission set expires (optional)"
    },
    "status": {
      "type": "string",
      "enum": ["active", "inactive", "revoked", "expired"],
      "description": "Status of this permission set",
      "default": "active"
    }
  }
}