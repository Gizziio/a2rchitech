[
  {
    "id": "com.a2rchitech.os.set_alarm",
    "name": "Set Alarm",
    "description": "Sets an alarm on the device for a specified time",
    "version": "1.0.0",
    "platform_support": {
      "ios": true,
      "android": true,
      "web": false,
      "desktop": false,
      "backend": false
    },
    "risk_level": "low",
    "requires_confirmation": true,
    "parameters": {
      "type": "object",
      "properties": {
        "time": {
          "type": "string",
          "description": "Time for the alarm in HH:MM format",
          "pattern": "^([01]?[0-9]|2[0-3]):[0-5][0-9]$"
        },
        "label": {
          "type": "string",
          "description": "Optional label for the alarm"
        }
      },
      "required": ["time"]
    },
    "examples": [
      {
        "description": "Set an alarm for 7:30 AM",
        "input": {
          "time": "07:30",
          "label": "Wake up"
        }
      }
    ],
    "execution_context": "local",
    "capabilities_required": ["alarms"],
    "timeout_ms": 5000,
    "category": "system"
  },
  {
    "id": "com.a2rchitech.os.send_message",
    "name": "Send Message",
    "description": "Sends a text message to a contact",
    "version": "1.0.0",
    "platform_support": {
      "ios": true,
      "android": true,
      "web": false,
      "desktop": false,
      "backend": false
    },
    "risk_level": "medium",
    "requires_confirmation": true,
    "parameters": {
      "type": "object",
      "properties": {
        "recipient": {
          "type": "string",
          "description": "Phone number or contact name"
        },
        "message": {
          "type": "string",
          "description": "Message content to send"
        }
      },
      "required": ["recipient", "message"]
    },
    "examples": [
      {
        "description": "Send a message to a contact",
        "input": {
          "recipient": "+1234567890",
          "message": "Hello, how are you?"
        }
      }
    ],
    "execution_context": "local",
    "capabilities_required": ["messages"],
    "timeout_ms": 10000,
    "category": "communication"
  },
  {
    "id": "com.a2rchitech.os.create_note",
    "name": "Create Note",
    "description": "Creates a new note in the device's notes app",
    "version": "1.0.0",
    "platform_support": {
      "ios": true,
      "android": true,
      "web": true,
      "desktop": true,
      "backend": false
    },
    "risk_level": "low",
    "requires_confirmation": false,
    "parameters": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Title of the note"
        },
        "content": {
          "type": "string",
          "description": "Content of the note"
        },
        "folder": {
          "type": "string",
          "description": "Optional folder to place the note in"
        }
      },
      "required": ["content"]
    },
    "examples": [
      {
        "description": "Create a note with title and content",
        "input": {
          "title": "Shopping List",
          "content": "Milk, Eggs, Bread"
        }
      }
    ],
    "execution_context": "local",
    "capabilities_required": ["notes"],
    "timeout_ms": 5000,
    "category": "productivity"
  },
  {
    "id": "com.a2rchitech.os.schedule_event",
    "name": "Schedule Event",
    "description": "Creates a calendar event",
    "version": "1.0.0",
    "platform_support": {
      "ios": true,
      "android": true,
      "web": true,
      "desktop": true,
      "backend": false
    },
    "risk_level": "low",
    "requires_confirmation": true,
    "parameters": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Title of the event"
        },
        "start_time": {
          "type": "string",
          "description": "Start time in ISO 8601 format"
        },
        "end_time": {
          "type": "string",
          "description": "End time in ISO 8601 format"
        },
        "location": {
          "type": "string",
          "description": "Optional location for the event"
        },
        "attendees": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional list of attendees"
        }
      },
      "required": ["title", "start_time", "end_time"]
    },
    "examples": [
      {
        "description": "Schedule a meeting",
        "input": {
          "title": "Team Meeting",
          "start_time": "2023-10-15T10:00:00Z",
          "end_time": "2023-10-15T11:00:00Z",
          "location": "Conference Room A"
        }
      }
    ],
    "execution_context": "local",
    "capabilities_required": ["calendar"],
    "timeout_ms": 10000,
    "category": "productivity"
  },
  {
    "id": "com.a2rchitech.web.search",
    "name": "Web Search",
    "description": "Performs a web search using the default search engine",
    "version": "1.0.0",
    "platform_support": {
      "ios": true,
      "android": true,
      "web": true,
      "desktop": true,
      "backend": true
    },
    "risk_level": "low",
    "requires_confirmation": false,
    "parameters": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Search query"
        },
        "max_results": {
          "type": "integer",
          "description": "Maximum number of results to return",
          "default": 5
        }
      },
      "required": ["query"]
    },
    "examples": [
      {
        "description": "Search for information",
        "input": {
          "query": "best pizza in New York",
          "max_results": 3
        }
      }
    ],
    "execution_context": "remote",
    "capabilities_required": ["internet"],
    "timeout_ms": 15000,
    "category": "custom"
  },
  {
    "id": "com.a2rchitech.finance.transfer_money",
    "name": "Transfer Money",
    "description": "Transfers money to another account",
    "version": "1.0.0",
    "platform_support": {
      "ios": true,
      "android": true,
      "web": true,
      "desktop": true,
      "backend": false
    },
    "risk_level": "critical",
    "requires_confirmation": true,
    "parameters": {
      "type": "object",
      "properties": {
        "recipient": {
          "type": "string",
          "description": "Recipient account identifier"
        },
        "amount": {
          "type": "number",
          "description": "Amount to transfer"
        },
        "currency": {
          "type": "string",
          "description": "Currency code (e.g., USD, EUR)",
          "default": "USD"
        },
        "note": {
          "type": "string",
          "description": "Optional note for the transfer"
        }
      },
      "required": ["recipient", "amount"]
    },
    "examples": [
      {
        "description": "Transfer money to a friend",
        "input": {
          "recipient": "jane.doe@example.com",
          "amount": 50.00,
          "currency": "USD",
          "note": "For dinner"
        }
      }
    ],
    "execution_context": "remote",
    "capabilities_required": ["finance"],
    "timeout_ms": 30000,
    "category": "finance"
  }
]