{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://a2rchitech/spec/contracts/agent-manifest.schema.json",
  "title": "AgentCapabilityManifest",
  "type": "object",
  "required": [
    "manifest_version",
    "provider",
    "capabilities"
  ],
  "properties": {
    "manifest_version": {
      "type": "string"
    },
    "provider": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "did": {
          "type": "string"
        },
        "contact": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "auth": {
      "type": "object",
      "properties": {
        "methods": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "scopes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "rate_limits": {
      "type": "object",
      "properties": {
        "requests_per_minute": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "inputs_schema",
          "outputs_schema",
          "risk"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "inputs_schema": {
            "type": "object"
          },
          "outputs_schema": {
            "type": "object"
          },
          "risk": {
            "type": "object",
            "required": [
              "max_scope"
            ],
            "properties": {
              "max_scope": {
                "type": "string",
                "enum": [
                  "read",
                  "write",
                  "exec"
                ]
              },
              "requires_consent": {
                "type": "boolean",
                "default": true
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}