{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://a2rchitech/spec/contracts/CardRender.schema.json",
  "title": "CardRender",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "subtitle", "bullets", "preview_bubbles", "cta_label", "theme"],
  "properties": {
    "title": { "type": "string", "minLength": 1, "maxLength": 80 },
    "subtitle": { "type": "string", "minLength": 0, "maxLength": 120 },
    "bullets": {
      "type": "array",
      "minItems": 0,
      "maxItems": 6,
      "items": { "type": "string", "minLength": 1, "maxLength": 120 }
    },
    "preview_bubbles": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "text"],
        "properties": {
          "from": { "type": "string", "enum": ["user", "agent"] },
          "text": { "type": "string", "minLength": 1, "maxLength": 200 }
        }
      }
    },
    "cta_label": { "type": "string", "minLength": 1, "maxLength": 40 },
    "theme": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "background"],
      "properties": {
        "primary": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6})$" },
        "background": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6})$" }
      }
    }
  }
}
