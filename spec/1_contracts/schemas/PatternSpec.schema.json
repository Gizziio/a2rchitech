{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://a2rchitech/spec/skills/patternspec.schema.json",
  "title": "PatternSpec",
  "type": "object",
  "required": [
    "pattern_id",
    "version",
    "status",
    "intent_signature",
    "plan_template",
    "tool_requirements",
    "risk_profile",
    "eval_suite"
  ],
  "properties": {
    "pattern_id": {
      "type": "string",
      "pattern": "^pat_[a-z0-9_\\-]+$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "candidate",
        "active",
        "deprecated"
      ]
    },
    "intent_signature": {
      "type": "object",
      "required": [
        "verbs",
        "entities"
      ],
      "properties": {
        "verbs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "entities": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "preconditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "plan_template": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "step_id",
          "action",
          "outputs"
        ],
        "properties": {
          "step_id": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "inputs": {
            "type": "object"
          },
          "outputs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "tool_hint": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "tool_requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "tool_id",
          "scope"
        ],
        "properties": {
          "tool_id": {
            "type": "string"
          },
          "scope": {
            "type": "string",
            "enum": [
              "read",
              "write",
              "exec"
            ]
          },
          "requires_confirmation": {
            "type": "boolean",
            "default": false
          }
        },
        "additionalProperties": false
      }
    },
    "risk_profile": {
      "type": "object",
      "required": [
        "max_scope",
        "requires_human_approval_for_exec"
      ],
      "properties": {
        "max_scope": {
          "type": "string",
          "enum": [
            "read",
            "write",
            "exec"
          ]
        },
        "requires_human_approval_for_exec": {
          "type": "boolean"
        },
        "privacy": {
          "type": "string",
          "enum": [
            "local_only",
            "allow_remote_providers"
          ],
          "default": "local_only"
        }
      },
      "additionalProperties": false
    },
    "evidence_requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "eval_suite": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "failure_modes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "fallback": {
      "type": "string"
    },
    "explainability_template": {
      "type": "string"
    },
    "stats": {
      "type": "object",
      "properties": {
        "invocations": {
          "type": "integer",
          "minimum": 0
        },
        "success_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}