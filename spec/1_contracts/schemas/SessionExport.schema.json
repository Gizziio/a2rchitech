{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://a2rchitech/spec/contracts/SessionExport.schema.json",
  "title": "SessionExport",
  "type": "object",
  "additionalProperties": false,
  "required": ["session_id", "created_at", "model_ref", "messages", "handoff_reason"],
  "properties": {
    "session_id": { "type": "string", "minLength": 8 },
    "created_at": { "type": "integer", "minimum": 0 },
    "model_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine", "model_id", "filename"],
      "properties": {
        "engine": { "type": "string", "enum": ["webllm", "wllama"] },
        "model_id": { "type": "string", "minLength": 1 },
        "filename": { "type": "string", "minLength": 1 }
      }
    },
    "messages": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "content", "ts"],
        "properties": {
          "role": { "type": "string", "enum": ["user", "assistant"] },
          "content": { "type": "string" },
          "ts": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "handoff_reason": {
      "type": "string",
      "enum": ["long_session", "save", "tools", "auth", "offline_fail"]
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    }
  }
}
