{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "A2rchitech Roles Schema",
  "description": "Schema for defining agent roles with capabilities and responsibility boundaries",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "description": "Version of the roles specification",
      "default": "1.0"
    },
    "roles": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/role"
      }
    }
  },
  "required": ["version", "roles"],
  "definitions": {
    "role": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the role"
        },
        "name": {
          "type": "string",
          "description": "Human-readable name for the role"
        },
        "description": {
          "type": "string",
          "description": "Description of the role's purpose and responsibilities"
        },
        "responsibilities": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of responsibilities for this role"
        },
        "capabilities": {
          "type": "object",
          "properties": {
            "allowed_skill_tiers": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["T0", "T1", "T2", "T3", "T4"]
              },
              "description": "Skill tiers this role is allowed to execute",
              "default": ["T0"]
            },
            "allowed_tools": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "List of allowed tools for this role"
            },
            "allowed_phases": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["Observe", "Think", "Plan", "Build", "Execute", "Verify", "Learn"]
              },
              "description": "Workflow phases this role can participate in",
              "default": ["Observe", "Think", "Plan"]
            },
            "resource_limits": {
              "type": "object",
              "properties": {
                "max_cpu_millicores": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Maximum CPU allowed in millicores"
                },
                "max_memory_mb": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Maximum memory allowed in MB"
                },
                "max_execution_time_seconds": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Maximum execution time in seconds"
                }
              }
            }
          }
        },
        "permissions": {
          "type": "object",
          "properties": {
            "required_permissions": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Required permissions for this role"
            },
            "forbidden_actions": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Actions that are forbidden for this role"
            }
          }
        },
        "verification_requirements": {
          "type": "object",
          "properties": {
            "required_verify_artifacts": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Required verification artifacts for this role's outputs"
            },
            "confidence_threshold": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0,
              "description": "Minimum confidence required for verification",
              "default": 0.8
            }
          }
        },
        "memory_policy": {
          "type": "object",
          "properties": {
            "allowed_memory_tiers": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["Working", "Episodic", "Semantic", "Procedural", "Declarative", "Meta"]
              },
              "description": "Memory tiers this role can access",
              "default": ["Working", "Episodic"]
            },
            "retention_policy": {
              "type": "object",
              "properties": {
                "max_retention_days": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Maximum retention period in days"
                },
                "automatic_consolidation": {
                  "type": "boolean",
                  "description": "Whether automatic consolidation is enabled",
                  "default": false
                }
              }
            }
          }
        }
      },
      "required": ["id", "name", "description", "capabilities"]
    }
  }
}