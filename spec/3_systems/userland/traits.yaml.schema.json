{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "A2rchitech Traits Schema",
  "description": "Schema for defining reusable personality traits that can be composed into agent templates",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "description": "Version of the traits specification",
      "default": "1.0"
    },
    "traits": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/trait"
      }
    }
  },
  "required": ["version", "traits"],
  "definitions": {
    "trait": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the trait"
        },
        "name": {
          "type": "string",
          "description": "Human-readable name for the trait"
        },
        "category": {
          "type": "string",
          "enum": ["tone", "risk_appetite", "verbosity", "skepticism", "compliance", "attention", "creativity", "analytical"],
          "description": "Category of the trait"
        },
        "description": {
          "type": "string",
          "description": "Description of what the trait affects"
        },
        "persona_overlay": {
          "type": "object",
          "description": "Overlay to apply to persona when this trait is used",
          "properties": {
            "context_overlay": {
              "type": "object",
              "description": "Context overlay for the persona",
              "properties": {
                "expertise": {
                  "type": "string",
                  "description": "Areas of expertise"
                },
                "methodology": {
                  "type": "string",
                  "description": "Methodology and approach"
                },
                "limitations": {
                  "type": "string",
                  "description": "Known limitations"
                },
                "tone_guidelines": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Guidelines for communication tone"
                }
              }
            },
            "behavior_modifiers": {
              "type": "object",
              "properties": {
                "risk_tolerance": {
                  "type": "number",
                  "minimum": 0.0,
                  "maximum": 1.0,
                  "description": "Risk tolerance level (0.0 = conservative, 1.0 = aggressive)"
                },
                "verbosity_level": {
                  "type": "number",
                  "minimum": 0.0,
                  "maximum": 1.0,
                  "description": "Verbosity level (0.0 = concise, 1.0 = verbose)"
                },
                "skepticism_level": {
                  "type": "number",
                  "minimum": 0.0,
                  "maximum": 1.0,
                  "description": "Skepticism level (0.0 = trusting, 1.0 = skeptical)"
                },
                "compliance_strictness": {
                  "type": "number",
                  "minimum": 0.0,
                  "maximum": 1.0,
                  "description": "Compliance strictness (0.0 = flexible, 1.0 = strict)"
                }
              }
            }
          }
        },
        "tool_constraints": {
          "type": "object",
          "properties": {
            "preferred_tools": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Preferred tools when this trait is active"
            },
            "avoided_tools": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Tools to avoid when this trait is active"
            }
          }
        },
        "workflow_preferences": {
          "type": "object",
          "properties": {
            "preferred_phases": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["Observe", "Think", "Plan", "Build", "Execute", "Verify", "Learn"]
              },
              "description": "Phases this trait prefers to operate in"
            },
            "time_allocation_bias": {
              "type": "object",
              "description": "How this trait allocates time across phases",
              "additionalProperties": {
                "type": "number",
                "minimum": 0.0,
                "maximum": 1.0
              }
            }
          }
        }
      },
      "required": ["id", "name", "category", "description", "persona_overlay"]
    }
  }
}