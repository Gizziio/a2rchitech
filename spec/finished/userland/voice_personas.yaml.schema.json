{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "A2rchitech Voice Persona Schema",
  "description": "Schema for defining voice presentation settings for personas (presentation-only, no kernel execution impact)",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "description": "Version of the voice persona specification",
      "default": "1.0"
    },
    "voice_personas": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/voice_persona"
      }
    }
  },
  "required": ["version", "voice_personas"],
  "definitions": {
    "voice_persona": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the voice persona"
        },
        "persona_ref": {
          "type": "string",
          "description": "Reference to the base persona this voice persona applies to"
        },
        "voice_profile": {
          "type": "object",
          "properties": {
            "voice_id": {
              "type": "string",
              "description": "Provider-specific voice identifier"
            },
            "style_labels": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Style and tone labels for the voice"
            },
            "speaking_rate": {
              "type": "number",
              "minimum": 0.5,
              "maximum": 2.0,
              "description": "Speaking rate multiplier (0.5 to 2.0)"
            },
            "pitch": {
              "type": "number",
              "minimum": -1.0,
              "maximum": 1.0,
              "description": "Pitch adjustment (-1.0 to 1.0)"
            },
            "temperature_voice": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0,
              "description": "Voice temperature/randomness (0.0 to 1.0)"
            },
            "barge_in_enabled": {
              "type": "boolean",
              "description": "Whether barge-in is enabled for this voice"
            },
            "turn_detection": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "description": "Whether turn detection is enabled"
                },
                "timeout_ms": {
                  "type": "integer",
                  "minimum": 100,
                  "description": "Turn timeout in milliseconds"
                }
              }
            }
          }
        },
        "metadata": {
          "type": "object",
          "description": "Additional metadata for the voice persona"
        }
      },
      "required": ["id", "persona_ref"]
    }
  }
}