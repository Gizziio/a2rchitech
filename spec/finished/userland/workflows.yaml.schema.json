{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "A2rchitech Workflow Definition Schema",
  "description": "Schema for defining A2rchitech workflows that compile to frozen kernel contracts",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "description": "Version of the workflow definition schema",
      "default": "1.0"
    },
    "workflow": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the workflow, maps to RunModel.run_id"
        },
        "name": {
          "type": "string",
          "description": "Human-readable name for the workflow"
        },
        "description": {
          "type": "string",
          "description": "Description of the workflow purpose and function"
        },
        "version": {
          "type": "string",
          "description": "Version of the workflow",
          "default": "1.0.0"
        },
        "tenant_id": {
          "type": "string",
          "description": "Tenant identifier for multi-tenant isolation"
        },
        "required_tiers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["T0", "T1", "T2", "T3", "T4"]
          },
          "description": "Maps to RunModel.allowed_skill_tiers",
          "default": ["T0"]
        },
        "success_criteria": {
          "type": "string",
          "description": "Maps to RunModel.success_criteria"
        },
        "failure_modes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Maps to RunModel.failure_modes"
        },
        "phases_used": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["Observe", "Think", "Plan", "Build", "Execute", "Verify", "Learn"]
          },
          "description": "Maps to RunModel.phases_used"
        },
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/workflow_node"
          },
          "description": "Maps to WorkflowDefinition.nodes"
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/workflow_edge"
          },
          "description": "Maps to WorkflowDefinition.edges"
        }
      },
      "required": ["id", "name", "description", "tenant_id", "phases_used", "nodes"]
    }
  },
  "required": ["version", "workflow"],
  "definitions": {
    "workflow_node": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the workflow node"
        },
        "name": {
          "type": "string",
          "description": "Human-readable name for the node"
        },
        "phase": {
          "type": "string",
          "enum": ["Observe", "Think", "Plan", "Build", "Execute", "Verify", "Learn"],
          "description": "Scientific loop phase for the node, maps to WorkflowNode.phase"
        },
        "skill_id": {
          "type": "string",
          "description": "Reference to skill, maps to WorkflowNode.skill_id"
        },
        "description": {
          "type": "string",
          "description": "Description of the node purpose"
        },
        "instructions": {
          "type": "string",
          "description": "Instructions for the node execution"
        },
        "inputs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "References to input artifacts or previous node outputs"
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Names of outputs this node produces"
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Tool references for the node execution"
        },
        "constraints": {
          "$ref": "#/definitions/node_constraints"
        },
        "expected_output_schema": {
          "type": "object",
          "description": "Schema that output must match, becomes VerifyArtifact requirement"
        }
      },
      "required": ["id", "name", "phase", "skill_id", "description", "inputs", "outputs"]
    },
    "workflow_edge": {
      "type": "object",
      "properties": {
        "from": {
          "type": "string",
          "description": "Source node ID"
        },
        "to": {
          "type": "string",
          "description": "Destination node ID"
        },
        "condition": {
          "type": "string",
          "description": "Optional condition expression for the dependency"
        }
      },
      "required": ["from", "to"]
    },
    "node_constraints": {
      "type": "object",
      "properties": {
        "time_budget": {
          "type": "integer",
          "minimum": 1,
          "description": "Time budget in seconds, maps to NodeConstraints.time_budget"
        },
        "resource_limits": {
          "type": "object",
          "properties": {
            "cpu": {
              "type": "string",
              "description": "CPU resource limit (e.g., \"200m\")"
            },
            "memory": {
              "type": "string",
              "description": "Memory resource limit (e.g., \"256Mi\")"
            }
          }
        },
        "allowed_tools": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of allowed tools, maps to NodeConstraints.allowed_tools"
        },
        "required_permissions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Required permissions for execution, maps to NodeConstraints.required_permissions"
        }
      }
    }
  }
}