{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "A2rchitech Persona Definition Schema",
  "description": "Schema for defining A2rchitech personas that compile to frozen kernel contracts",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "description": "Version of the persona definition schema",
      "default": "1.0"
    },
    "personas": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/persona"
      }
    }
  },
  "required": ["version", "personas"],
  "definitions": {
    "persona": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the persona, maps to PersonaManifest.id"
        },
        "name": {
          "type": "string",
          "description": "Human-readable name for the persona"
        },
        "description": {
          "type": "string",
          "description": "Description of the persona purpose and function"
        },
        "tenant_id": {
          "type": "string",
          "description": "Tenant identifier for multi-tenant isolation"
        },
        "context_overlay": {
          "type": "object",
          "description": "Context overlay for the persona, maps to PersonaManifest.context_overlay",
          "properties": {
            "expertise": {
              "type": "string",
              "description": "Areas of expertise for the persona"
            },
            "methodology": {
              "type": "string",
              "description": "Methodology and approach of the persona"
            },
            "limitations": {
              "type": "string",
              "description": "Known limitations of the persona"
            },
            "tone_guidelines": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Guidelines for communication tone"
            }
          }
        },
        "goals": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Goals for the persona, maps to PersonaManifest.goals"
        },
        "constraints": {
          "type": "object",
          "properties": {
            "safety_tier": {
              "type": "string",
              "enum": ["T0", "T1", "T2", "T3", "T4"],
              "description": "Safety tier for the persona, maps to SkillManifest.risk_tier"
            },
            "required_permissions": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Required permissions for the persona, maps to SkillManifest.required_permissions"
            },
            "resource_limits": {
              "type": "object",
              "properties": {
                "cpu": {
                  "type": "string",
                  "description": "CPU resource limit (e.g., \"200m\")"
                },
                "memory": {
                  "type": "string",
                  "description": "Memory resource limit (e.g., \"256Mi\")"
                },
                "time_limit": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Time limit in seconds"
                }
              }
            }
          }
        },
        "provider_preferences": {
          "type": "object",
          "properties": {
            "priority_order": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Priority order for provider selection"
            },
            "fallback_timeout": {
              "type": "integer",
              "minimum": 1,
              "description": "Fallback timeout in seconds"
            }
          }
        },
        "signature": {
          "type": "object",
          "properties": {
            "manifest_sig": {
              "type": "string",
              "description": "Manifest signature, maps to SignatureInfo.manifest_sig"
            },
            "bundle_hash": {
              "type": "string",
              "description": "Bundle hash, maps to SignatureInfo.bundle_hash"
            }
          },
          "required": ["manifest_sig", "bundle_hash"]
        }
      },
      "required": ["id", "name", "description", "tenant_id", "context_overlay", "goals"]
    }
  }
}