{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "A2rchitech Agent Template Schema",
  "description": "Schema for defining reusable agent templates with persona overlays, constraints, and capabilities",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "description": "Version of the agent template specification",
      "default": "1.0"
    },
    "agent_templates": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/agent_template"
      }
    }
  },
  "required": ["version", "agent_templates"],
  "definitions": {
    "agent_template": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the agent template"
        },
        "name": {
          "type": "string",
          "description": "Human-readable name for the agent template"
        },
        "description": {
          "type": "string",
          "description": "Description of the agent template purpose and function"
        },
        "version": {
          "type": "string",
          "description": "Version of the agent template",
          "default": "1.0.0"
        },
        "tenant_id": {
          "type": "string",
          "description": "Tenant identifier for multi-tenant isolation"
        },
        "persona_ref": {
          "type": "string",
          "description": "Reference to an existing persona definition"
        },
        "persona_overlay": {
          "type": "object",
          "description": "Inline persona definition that overrides persona_ref",
          "properties": {
            "role": {
              "type": "string",
              "description": "Role of the agent (e.g., researcher, executor, auditor)"
            },
            "goal": {
              "type": "string",
              "description": "Primary goal of the agent"
            },
            "backstory": {
              "type": "string",
              "description": "Background context for the agent"
            },
            "constraints": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Constraints on agent behavior"
            },
            "provider_preferences": {
              "type": "object",
              "properties": {
                "priority_order": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Priority order for provider selection"
                },
                "fallback_timeout": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Fallback timeout in seconds"
                }
              }
            },
            "signature": {
              "type": "object",
              "properties": {
                "manifest_sig": {
                  "type": "string",
                  "description": "Manifest signature"
                },
                "bundle_hash": {
                  "type": "string",
                  "description": "Bundle hash"
                }
              }
            }
          }
        },
        "traits": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Arbitrary labels for agent characteristics (metadata only)"
        },
        "roles": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "One or more role tags for the agent"
        },
        "default_workflow_refs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of default workflow IDs for this agent type"
        },
        "default_task_template_refs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of default task template IDs for this agent type"
        },
        "skill_policy": {
          "type": "object",
          "properties": {
            "allowed_skill_tiers": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["T0", "T1", "T2", "T3", "T4"]
              },
              "description": "Allowed skill tiers for this agent",
              "default": ["T0"]
            },
            "allowed_tools": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Allowlist of tool IDs this agent can use"
            },
            "denied_tools": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Denylist of tool IDs this agent cannot use"
            }
          }
        },
        "provider_preferences": {
          "type": "object",
          "properties": {
            "priority_order": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Priority order for provider selection"
            },
            "fallback_timeout": {
              "type": "integer",
              "minimum": 1,
              "description": "Fallback timeout in seconds"
            }
          }
        },
        "signing_metadata": {
          "type": "object",
          "properties": {
            "manifest_sig": {
              "type": "string",
              "description": "Manifest signature"
            },
            "bundle_hash": {
              "type": "string",
              "description": "Bundle hash"
            }
          }
        }
      },
      "required": ["id", "name", "description", "tenant_id"]
    }
  }
}