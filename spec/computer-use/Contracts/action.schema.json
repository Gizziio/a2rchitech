{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://a2rchitech.dev/schemas/computer-use/action.schema.json",
  "title": "A2R Computer Use Action",
  "description": "Canonical action contract for all adapters",
  "type": "object",
  "required": ["action_id", "action_type", "target"],
  "properties": {
    "action_id": { "type": "string" },
    "action_type": {
      "type": "string",
      "enum": ["goto", "observe", "act", "extract", "screenshot", "download", "upload", "eval", "inspect", "handoff"]
    },
    "target": { "type": "string", "description": "URL, selector, app name, file path, or element reference" },
    "parameters": {
      "type": "object",
      "description": "Action-specific parameters",
      "properties": {
        "url": { "type": "string" },
        "selector": { "type": "string" },
        "text": { "type": "string" },
        "coordinates": {
          "type": "object",
          "properties": { "x": { "type": "integer" }, "y": { "type": "integer" } }
        },
        "file_path": { "type": "string" },
        "script": { "type": "string" },
        "handoff_target": { "type": "string", "enum": ["browser", "desktop", "human"] },
        "wait_ms": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "timeout_ms": { "type": "integer", "default": 30000, "minimum": 0 },
    "retry_count": { "type": "integer", "default": 0, "minimum": 0, "maximum": 3 }
  },
  "additionalProperties": false
}
