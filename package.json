{
  "name": "a2rchitect",
  "version": "1.0.0",
  "description": "A2rchitect - AI Governance and Workflow System",
  "type": "module",
  "private": true,
  "pnpm": {
    "overrides": {
      "@types/react": "^18.3.28",
      "@types/react-dom": "^18.3.1",
      "@reduxjs/toolkit": "^2.2.7",
      "react-redux": "^9.1.2",
      "redux": "^5.0.1"
    }
  },
  "workspaces": [
    "extension/*",
    "extensions/*",
    "7-apps/*",
    "6-ui/a2r-platform"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "dev": "concurrently \"cd 7-apps/api && cargo run\" \"pnpm --filter @a2r/runtime serve\" \"pnpm --filter @a2rchitech/shell-electron dev\"",
    "dev:api": "cd 7-apps/api && cargo run",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config tests/vitest.config.ts",
    "test:unit": "vitest run",
    "test:e2e": "pnpm --filter @a2rchitech/shell-ui test:e2e",
    "test:e2e:headed": "pnpm --filter @a2rchitech/shell test:e2e:headed",
    "test:e2e:debug": "pnpm --filter @a2rchitech/shell test:e2e:debug",
    "test:e2e:ci": "pnpm --filter @a2rchitech/shell test:e2e:ci",
    "test:benchmark": "vitest run tests/benchmarks",
    "test:coverage": "vitest run --coverage",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean && rm -rf dist",
    "shell": "pnpm --filter @a2rchitech/shell-electron dev",
    "shell:web": "pnpm --filter @a2rchitech/shell-ui dev",
    "shell:desktop": "pnpm --filter @a2rchitech/shell-electron dev",
    "tui": "bun run --cwd 7-apps/shell/terminal dev",
    "tui:build": "bun run --cwd 7-apps/shell/terminal build",
    "tui:test": "bun run --cwd 7-apps/shell/terminal test",
    "start:all": "concurrently \"pnpm --filter @a2r/runtime serve\" \"pnpm --filter @a2rchitech/shell-electron dev"
  },
  "keywords": [
    "a2r",
    "ai",
    "governance",
    "workflow"
  ],
  "author": "A2rchitect Team",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "concurrently": "^8.2.2",
    "framer-motion": "^12.29.2",
    "playwright": "^1.58.2",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
