#!/bin/bash
# Stop all allternit launchd services

LAUNCH_AGENTS_DIR="$HOME/Library/LaunchAgents"

unload_service() {
    local label="$1"
    local plist="$LAUNCH_AGENTS_DIR/$label.plist"
    if [ -f "$plist" ]; then
        echo "Unloading $label..."
        launchctl unload "$plist" 2>/dev/null || true
    fi
}

unload_service "com.allternitchitech.intent-graph-kernel"
unload_service "com.allternitchitech.capsule-runtime"
unload_service "com.allternitchitech.presentation-kernel"
unload_service "com.allternitchitech.kernel"
unload_service "com.allternitchitech.shell"
unload_service "com.allternitchitech.ui-tars-operator"
unload_service "com.allternitchitech.agui-gateway"

echo "All allternit development services stopped."
