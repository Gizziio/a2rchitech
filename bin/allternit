#!/bin/bash
#
# Allternit - allternit Platform Command
#
# Unified entry point for the Allternit platform.
# Delegates to the TypeScript CLI in 7-apps/shell/terminal
#

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

TUI_DIR="$PROJECT_ROOT/7-apps/shell/terminal"
Allternit_TS="$TUI_DIR/src/cli/allternit.ts"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'
BOLD='\033[1m'

print_error() {
    echo -e "${RED}[✗]${NC} $1"
}

print_info() {
    echo -e "${CYAN}[ℹ]${NC} $1"
}

# Check if bun is available
if ! command -v bun &> /dev/null; then
    print_error "Bun is required but not installed."
    echo "Install from: https://bun.sh"
    exit 1
fi

# Check if TUI directory exists
if [ ! -d "$TUI_DIR" ]; then
    print_error "TUI not found at $TUI_DIR"
    exit 1
fi

# Run the TypeScript CLI
exec bun run "$Allternit_TS" "$@"
