#!/usr/bin/env python3
import json
import sys
import subprocess
import os

def run_graph(graph_path):
    repo_root = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    runner_script = os.path.join(repo_root, 'bin', 'graph-runner.py')
    
    # Get topological order
    result = subprocess.run(['python3', runner_script, graph_path], capture_output=True, text=True)
    if result.returncode != 0:
        print(f"Error: {result.stderr}")
        return

    task_order = result.stdout.strip().split(' ')
    print(f"[GraphExecutor] Analyzing graph dependencies...")
    print(f"[GraphExecutor] Execution Sequence: {' -> '.join(task_order)}")

    with open(graph_path) as f:
        graph = json.load(f)
    
    nodes = {node['task_id']: node for node in graph['nodes']}

    for task_id in task_order:
        node = nodes.get(task_id)
        if node:
            print(f"[GraphExecutor] Running Task {task_id}: {node.get('description', 'No description')}")

    print("[GraphExecutor] Graph execution complete.")

if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("Usage: bin/run-graph <graph.json>")
        sys.exit(1)
    run_graph(sys.argv[1])
