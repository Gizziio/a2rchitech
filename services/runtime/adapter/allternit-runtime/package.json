{
  "name": "@allternit/runtime",
  "version": "1.0.0",
  "description": "A2R Runtime Bridge for AI Agent Integration",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./adapters": {
      "import": "./dist/adapters/index.js",
      "types": "./dist/adapters/index.d.ts"
    },
    "./hooks": {
      "import": "./dist/hooks/index.js",
      "types": "./dist/hooks/index.d.ts"
    },
    "./wrappers": {
      "import": "./dist/wrappers/index.js",
      "types": "./dist/wrappers/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "serve": "node dist/server.js"
  },
  "keywords": [
    "a2r",
    "runtime",
    "bridge",
    "adapter"
  ],
  "author": "A2rchitect Team",
  "license": "MIT",
  "dependencies": {
    "@allternit/governor": "workspace:*",
    "@allternit/engine": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}