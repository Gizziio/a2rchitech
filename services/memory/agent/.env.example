# A2rchitech Memory Agent - Environment Configuration
# Copy this file to .env and update with your VPS details

# ==================== Ollama Configuration ====================

# VPS IP Address (replace with your actual VPS IP)
OLLAMA_HOST=<VPS_IP>

# Ollama port (default: 11434)
OLLAMA_PORT=11434

# ==================== Model Selection ====================

# Models available on your VPS (Qwen 3.5):
# - qwen3.5:0.8b (1.0 GB) - Fastest, lightweight
# - qwen3.5:2b  (2.7 GB) - Best balance
# - qwen3.5:4b  (3.4 GB) - Most capable

# Model for ingestion (summarization, entity extraction)
OLLAMA_INGEST_MODEL=qwen3.5:2b

# Model for consolidation (pattern finding, insights)
OLLAMA_CONSOLIDATE_MODEL=qwen3.5:4b

# Model for query synthesis
OLLAMA_QUERY_MODEL=qwen3.5:2b

# ==================== Paths ====================

# Directory to watch for new files (auto-ingest)
MEMORY_WATCH_DIRECTORY=./inbox

# SQLite database file location
MEMORY_DATABASE_PATH=./memory.db

# ==================== Optional: HTTP API ====================

# Enable HTTP API server (for external access)
MEMORY_ENABLE_HTTP_API=true

# HTTP API port (if enabled)
MEMORY_HTTP_PORT=3201

# ==================== Consolidation Settings ====================

# How often to run consolidation (in minutes)
MEMORY_CONSOLIDATION_INTERVAL_MINUTES=30
