{
  "name": "@a2rchitech/memory",
  "version": "1.0.0",
  "description": "Always-on AI memory agent with local LLM (Ollama)",
  "type": "module",
  "main": "dist/orchestrator.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/orchestrator.ts",
    "start": "node dist/orchestrator.js",
    "start:http": "tsx src/http-server.ts",
    "start:watcher": "tsx src/watcher.ts",
    "daemon": "tsx daemon/memory-daemon.ts",
    "daemon:start": "tsx daemon/memory-daemon.ts start",
    "daemon:stop": "tsx daemon/memory-daemon.ts stop",
    "daemon:status": "tsx daemon/memory-daemon.ts status",
    "ingest:receipts": "tsx src/pipelines/receipt-ingester.ts",
    "ingest:wih": "tsx src/pipelines/wih-indexer.ts",
    "ingest:sessions": "tsx src/pipelines/session-tracker.ts",
    "ingest:all": "pnpm run ingest:receipts && pnpm run ingest:wih && pnpm run ingest:sessions",
    "consolidate:daily": "./scripts/daily-consolidate.sh",
    "setup:cron": "./scripts/setup-cron.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "memory",
    "agent",
    "ollama",
    "local-llm",
    "a2rchitech"
  ],
  "author": "A2rchitect Team",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.6.0",
    "chokidar": "^3.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "glob": "^10.4.5",
    "ollama": "^0.5.11",
    "uuid": "^10.0.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
