{
  "name": "@allternit/capsule-sdk",
  "version": "0.1.0",
  "description": "Headless Capsule SDK - lifecycle, contracts, and guardrails for Allternit capsules",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./controllers": {
      "types": "./dist/controllers/index.d.ts",
      "import": "./dist/controllers/index.js"
    },
    "./guards": {
      "types": "./dist/guards/index.d.ts",
      "import": "./dist/guards/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "check": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "allternit",
    "capsule",
    "lifecycle",
    "contracts",
    "sdk"
  ],
  "author": "Allternit",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
