{
  "name": "x-bookmark-cache",
  "version": "1.0.0",
  "description": "Hybrid Twitter/X bookmark archiver — intercepts GraphQL, syncs locally, exports to pipeline",
  "type": "module",
  "scripts": {
    "start": "node src/server/server.js",
    "dev": "node --watch src/server/server.js",
    "sync": "node src/server/sync.js",
    "export:json": "node src/server/export.js json",
    "export:md": "node src/server/export.js markdown",
    "export:pipeline": "node src/server/export.js pipeline",
    "media:download": "node src/server/media.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.0.0",
    "express": "^4.21.0",
    "cors": "^2.8.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
