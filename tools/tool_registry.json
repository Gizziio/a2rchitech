    {
      "id": "agent-browser.automation",
      "title": "Agent Browser Automation",
      "kind": "write",
      "safety_level": "caution",
      "entrypoint": "tools/agent-browser/mod.ts",
      "version": "1.0.0",
      "tags": ["browser", "automation", "playwright", "web", "screenshot"],
      "inputs_schema": {
        "type": "object",
        "required": ["action"],
        "properties": {
          "action": {
            "type": "string",
            "enum": ["open", "snapshot", "click", "fill", "type", "screenshot", "get_text", "get_html", "get_value", "wait", "find", "close"],
            "description": "Browser action to perform"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL to navigate to (for 'open' action)"
          },
          "selector": {
            "type": "string",
            "description": "Element selector (e.g., '@e2', 'button.submit', '#login', 'role=button')"
          },
          "value": {
            "type": "string",
            "description": "Value to fill/type into input field"
          },
          "path": {
            "type": "string",
            "description": "File path for screenshot (e.g., '/tmp/screenshot.png')"
          },
          "timeout": {
            "type": "number",
            "minimum": 0,
            "maximum": 60000,
            "description": "Timeout in milliseconds (default: 30000)"
          },
          "session_id": {
            "type": "string",
            "description": "Session ID for persistent browser session"
          },
          "profile": {
            "type": "string",
            "description": "Profile path for persistent cookies/login (e.g., '~/.myapp-profile')"
          },
          "json": {
            "type": "boolean",
            "default": true,
            "description": "Return JSON output (default: true)"
          }
        }
      },
      "outputs_schema": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Whether the action succeeded"
          },
          "data": {
            "type": "object",
            "description": "Action-specific data (text, HTML, values)"
          },
          "error": {
            "type": "string",
            "description": "Error message if action failed"
          },
          "screenshot": {
            "type": "string",
            "description": "Base64-encoded screenshot (if applicable)"
          },
          "snapshot": {
            "type": "object",
            "description": "Accessibility tree snapshot with element refs",
            "properties": {
              "elements": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "ref": { "type": "string" },
                    "role": { "type": "string" },
                    "text": { "type": "string" },
                    "label": { "type": "string" }
                  }
                }
              }
            }
          },
          "execution_time_ms": {
            "type": "number",
            "description": "Execution time in milliseconds"
          }
        }
      },
      "preconditions": ["WIH_VALID", "TASK_RUNNING"],
      "postconditions": ["BROWSER_STATE_UPDATED"],
      "side_effects": ["browser_navigation", "dom_modification", "screenshot_capture"],
      "policy": {
        "domain_allowlist": [],
        "require_approval_for": ["fill", "click", "type"],
        "output_limit_bytes": 10485760,
        "session_isolation_recommended": true
      }
    }
  ]
