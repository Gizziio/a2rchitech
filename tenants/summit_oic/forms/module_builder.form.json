{
  "type": "object",
  "required": ["course_id", "module_name", "objective", "lesson_count"],
  "properties": {
    "course_id": {"type": "integer"},
    "module_name": {"type": "string"},
    "objective": {"type": "string"},
    "lesson_count": {"type": "integer", "minimum": 1, "maximum": 20},
    "include_assignment": {"type": "boolean", "default": true},
    "publish": {"type": "boolean", "default": false},
    "reading_level": {"type": "string", "enum": ["elementary", "middle", "high"], "default": "middle"}
  }
}
