# Summit OIC Tenant - Sample Environment
# Copy this file to tenants/summit_oic/secrets/summit_oic.env
# Then fill in your actual credentials

# Canvas LMS Configuration
CANVAS_BASE_URL=https://example.com
CANVAS_API_TOKEN=test_token_12345

# Canvas API Token Requirements:
# - Courses: Read
# - Modules: Read/Write
# - Pages: Read/Write
# - Assignments: Read/Write
# - Files: Read/Write

# Optional: Remotion Demo Configuration
REMOTION_RENDER_API_KEY=YOUR_REMOTION_KEY_HERE

# Kernel Configuration
KERNEL_HOST=127.0.0.1
KERNEL_PORT=3004

# Demo Configuration
DEMO_COURSE_ID=12345
DEMO_TEACHER_EMAIL=teacher@summitacademy.org
