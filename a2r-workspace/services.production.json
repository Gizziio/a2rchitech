{
  "version": "2026-02-06-enterprise-production",
  "description": "Production service configuration using pre-built binaries",
  "hosts": {
    "internal": "127.0.0.1",
    "public": "0.0.0.0"
  },
  "ports": {
    "gateway": 8013,
    "api": 3000,
    "registry": 8080,
    "kernel": 3004,
    "memory": 3200,
    "policy": 3003
  },
  "services": [
    {
      "id": "policy",
      "label": "Policy Service",
      "description": "Authorization and policy enforcement",
      "order": 10,
      "command": "./dist/policy",
      "env": { 
        "HOST": "${hosts.internal}",
        "PORT": "${ports.policy}",
        "RUST_LOG": "info"
      },
      "log": "policy.log",
      "health_check": "http://${hosts.internal}:${ports.policy}/health"
    },
    {
      "id": "memory",
      "label": "Memory Service",
      "description": "State and context management",
      "order": 20,
      "command": "./dist/memory",
      "env": { 
        "HOST": "${hosts.internal}",
        "PORT": "${ports.memory}",
        "RUST_LOG": "info"
      },
      "log": "memory.log",
      "health_check": "http://${hosts.internal}:${ports.memory}/health"
    },
    {
      "id": "registry",
      "label": "Registry Service",
      "description": "Agent, skill, and tool definitions",
      "order": 30,
      "command": "./dist/registry-server",
      "env": { 
        "HOST": "${hosts.internal}",
        "PORT": "${ports.registry}",
        "RUST_LOG": "info"
      },
      "log": "registry.log",
      "health_check": "http://${hosts.internal}:${ports.registry}/health"
    },
    {
      "id": "kernel",
      "label": "Kernel (Internal)",
      "description": "Tool execution and brain session management",
      "order": 40,
      "command": "./dist/kernel",
      "env": { 
        "HOST": "127.0.0.1",
        "PORT": "${ports.kernel}",
        "RUST_LOG": "info",
        "A2R_BIND_LOCAL_ONLY": "true"
      },
      "log": "kernel.log",
      "health_check": "http://127.0.0.1:${ports.kernel}/health"
    },
    {
      "id": "api",
      "label": "Public API",
      "description": "Business logic and orchestration",
      "order": 50,
      "command": "./dist/api",
      "env": { 
        "HOST": "${hosts.internal}",
        "PORT": "${ports.api}",
        "RUST_LOG": "info",
        "A2R_KERNEL_URL": "http://127.0.0.1:${ports.kernel}",
        "A2R_REGISTRY_URL": "http://${hosts.internal}:${ports.registry}",
        "A2R_MEMORY_URL": "http://${hosts.internal}:${ports.memory}",
        "A2R_POLICY_URL": "http://${hosts.internal}:${ports.policy}"
      },
      "log": "api.log",
      "health_check": "http://${hosts.internal}:${ports.api}/health",
      "depends_on": ["kernel", "registry", "memory", "policy"]
    },
    {
      "id": "gateway",
      "label": "API Gateway",
      "description": "Public entry point",
      "order": 60,
      "command": "python3",
      "args": ["4-services/gateway/src/main.py"],
      "env": { 
        "HOST": "${hosts.public}",
        "PORT": "${ports.gateway}",
        "API_URL": "http://${hosts.internal}:${ports.api}",
        "CORS_ORIGINS": "http://localhost:5177,http://127.0.0.1:5177",
        "LOG_LEVEL": "info"
      },
      "log": "gateway.log",
      "health_check": "http://${hosts.public}:${ports.gateway}/health",
      "depends_on": ["api"]
    },
    {
      "id": "shell-electron",
      "label": "Shell Electron",
      "description": "Desktop Electron application",
      "order": 70,
      "command": "npm",
      "args": ["run", "dev:electron"],
      "cwd": "6-apps/shell-electron",
      "log": "electron.log",
      "depends_on": ["gateway"]
    }
  ],
  "notes": [
    "PRODUCTION configuration - expects pre-built binaries in ./dist/",
    "Build with: ./scripts/build-services.sh",
    "Start with: cargo run -p a2rchitech-platform",
    "All services start instantly (no compilation on startup)"
  ]
}
