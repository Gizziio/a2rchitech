+) -> Result<serde_json::Value, (StatusCode, String)> {
+    let response = request
+        .send()
+        .await
+        .map_err(|e| (StatusCode::BAD_GATEWAY, e.to_string()))?;
+    let status = response.status();
+    let body = response
