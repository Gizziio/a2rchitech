+import React, { useEffect, useRef } from 'react';
+import cytoscape from 'cytoscape';
+import { Graph, Node } from '../types/ui';
+
+interface DAGCanvasProps {
+  graph: Graph;
+  onNodeSelect: (node: Node) => void;
+  selectedNodeId?: string;
+}
+
+const DAGCanvas: React.FC<DAGCanvasProps> = ({ graph, onNodeSelect, selectedNodeId }) => {
+  const containerRef = useRef<HTMLDivElement>(null);
+  const cyRef = useRef<cytoscape.Core | null>(null);
+
+  useEffect(() => {
+    if (!containerRef.current || !graph) return;
+
+    // Destroy previous instance if exists
+    if (cyRef.current) {
+      cyRef.current.destroy();
+    }
+
+    // Prepare elements for cytoscape
+    const elements: cytoscape.ElementDefinition[] = [];
+
+    // Add nodes
+    graph.nodes.forEach(node => {
+      elements.push({
+        data: {
+          id: node.node_id,
+          label: node.title,
+          status: node.status,
+          blocked_by: node.blocked_by
+        }
+      });
+    });
+
+    // Add edges
+    graph.edges.forEach(edge => {
+      elements.push({
+        data: {
+          id: `${edge.from}-${edge.to}`,
+          source: edge.from,
+          target: edge.to
+        }
+      });
+    });
+
+    // Initialize cytoscape
+    cyRef.current = cytoscape({
+      container: containerRef.current,
+      elements: elements,
+      style: [
+        {
+          selector: 'node',
+          style: {
+            'label': 'data(label)',
+            'width': 80,
+            'height': 80,
+            'background-color': (ele) => {
+              const status = ele.data('status');
+              switch(status) {
+                case 'COMPLETE': return '#4ade80';
+                case 'RUNNING': return '#60a5fa';
+                case 'FAILED': return '#f87171';
+                case 'PENDING': return '#fbbf24';
+                case 'BLOCKED': return '#94a3b8';
+                default: return '#cbd5e1';
+              }
+            },
+            'color': '#1e293b',
+            'font-size': '12px',
+            'text-valign': 'center',
+            'text-halign': 'center',
+            'border-width': 2,
+            'border-color': '#94a3b8'
+          }
+        },
+        {
+          selector: 'edge',
+          style: {
+            'width': 2,
+            'line-color': '#94a3b8',
+            'target-arrow-color': '#94a3b8',
+            'target-arrow-shape': 'triangle',
+            'curve-style': 'bezier'
+          }
+        },
+        {
+          selector: 'node:selected',
+          style: {
+            'border-width': 3,
+            'border-color': '#3b82f6'
+          }
+        },
+        {
+          selector: 'node[status = "FAILED"]',
+          style: {
+            'border-width': 3,
+            'border-color': '#ef4444',
+            'background-color': '#fecaca'
+          }
+        }
+      ],
+      layout: {
+        name: 'breadthfirst',
+        directed: true,
+        circle: false,
+        spacingFactor: 1.2,
+        nodeDimensionsIncludeLabels: true
+      }
+    });
+
+    // Add event listener for node selection
+    cyRef.current.on('tap', 'node', (event) => {
+      const nodeId = event.target.id();
+      const node = graph.nodes.find(n => n.node_id === nodeId);
+      if (node) {
+        onNodeSelect(node);
+      }
+    });
+
+    // Clean up
+    return () => {
+      if (cyRef.current) {
+        cyRef.current.destroy();
+      }
+    };
+  }, [graph, onNodeSelect]);
+
+  // Update selected node style when selectedNodeId changes
+  useEffect(() => {
+    if (cyRef.current && selectedNodeId) {
+      cyRef.current.elements().unselect();
+      const node = cyRef.current.getElementById(selectedNodeId);
+      if (node) {
+        node.select();
+      }
+    }
  }, [selectedNodeId]);

  return <div ref={containerRef} className="h-full w-full rounded border border-gray-300" />;
};

export default DAGCanvas;

