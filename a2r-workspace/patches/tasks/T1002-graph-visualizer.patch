+import React, { useState, useEffect } from 'react';
+import { useGraph } from '../hooks/useGraph';
+import DAGCanvas from '../components/DAGCanvas';
+import { Graph, Node } from '../types/ui';
+
+const GraphVisualizer: React.FC = () => {
+  const { graphs, loading, error, fetchGraphs } = useGraph();
+  const [selectedGraphId, setSelectedGraphId] = useState<string | null>(null);
+  const [selectedNode, setSelectedNode] = useState<Node | null>(null);
+  
+  useEffect(() => {
+    fetchGraphs();
+  }, [fetchGraphs]);
+
+  const handleNodeSelect = (node: Node) => {
+    setSelectedNode(node);
+  };
+
+  const handleGraphSelect = (graphId: string) => {
+    setSelectedGraphId(graphId);
+  };
+
+  const selectedGraph = graphs.find(g => g.graph_id === selectedGraphId);
+
+  if (loading) {
+    return (
+      <div className="p-6">
+        <h2 className="text-2xl font-bold text-gray-900 mb-6">Graph Visualizer</h2>
+        <div className="text-center py-10">
+          <div className="inline-block animate-spin rounded-full h-8 w-8 border-t-2 border-b-2 border-blue-500"></div>
+          <p className="mt-2 text-gray-600">Loading graphs...</p>
+        </div>
+      </div>
+    );
+  }
+
+  if (error) {
+    return (
+      <div className="p-6">
+        <h2 className="text-2xl font-bold text-gray-900 mb-6">Graph Visualizer</h2>
+        <div className="bg-red-50 border border-red-200 rounded-md p-4">
+          <p className="text-red-700">Error: {error}</p>
+          <button
+            onClick={fetchGraphs}
+            className="mt-2 px-4 py-2 bg-red-600 text-white rounded-md hover:bg-red-700"
+          >
+            Retry
+          </button>
+        </div>
+      </div>
+    );
+  }
+
+  return (
+    <div className="p-6">
+      <div className="flex justify-between items-center mb-6">
+        <h2 className="text-2xl font-bold text-gray-900">Graph Visualizer</h2>
+        <button
+          onClick={fetchGraphs}
+          className="px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700"
+        >
+          Refresh
+        </button>
+      </div>
+
+      <div className="grid grid-cols-1 lg:grid-cols-4 gap-6">
+        {/* Graph List Panel */}
+        <div className="lg:col-span-1 bg-white shadow rounded-lg p-4">
+          <h3 className="text-lg font-medium text-gray-900 mb-4">Available Graphs</h3>
+          <div className="space-y-2 max-h-96 overflow-y-auto">
+            {graphs.map((graph) => (
+              <div
+                key={graph.graph_id}
+                className={`p-3 rounded border cursor-pointer ${
+                  selectedGraphId === graph.graph_id
+                    ? 'border-blue-500 bg-blue-50'
+                    : 'border-gray-200 hover:bg-gray-50'
+                }`}
+                onClick={() => handleGraphSelect(graph.graph_id)}
+              >
+                <div className="font-medium text-gray-900 truncate">{graph.title}</div>
+                <div className="text-sm text-gray-500">
+                  {graph.nodes.length} nodes, {graph.edges.length} edges
+                </div>
+              </div>
+            ))}
+          </div>
+
+          {graphs.length === 0 && (
+            <div className="text-center py-4 text-gray-500">
+              No graphs available
+            </div>
+          )}
+        </div>
+
+        {/* Graph Canvas and Inspector Panel */}
+        <div className="lg:col-span-3 flex flex-col">
+          {selectedGraph ? (
+            <>
+              <div className="bg-white shadow rounded-lg p-4 mb-6">
+                <div className="flex justify-between items-center mb-4">
+                  <h3 className="text-lg font-medium text-gray-900">{selectedGraph.title}</h3>
+                  <span className="px-2 py-1 text-xs font-medium rounded-full bg-gray-100 text-gray-800">
+                    {selectedGraph.nodes.length} nodes
+                  </span>
+                </div>
+                
+                <div className="h-[500px] border border-gray-200 rounded">
+                  <DAGCanvas
+                    graph={selectedGraph}
+                    onNodeSelect={handleNodeSelect}
+                    selectedNodeId={selectedNode?.node_id}
+                  />
+                </div>
+              </div>
+
+              {/* Node Inspector Panel */}
+              {selectedNode && (
+                <div className="bg-white shadow rounded-lg p-4">
+                  <h3 className="text-lg font-medium text-gray-900 mb-4">Node Details</h3>
+                  <div className="grid grid-cols-2 gap-4">
+                    <div>
+                      <label className="block text-sm font-medium text-gray-700">Node ID</label>
+                      <div className="mt-1 text-sm text-gray-900">{selectedNode.node_id}</div>
+                    </div>
+                    <div>
+                      <label className="block text-sm font-medium text-gray-700">Status</label>
+                      <div className={`mt-1 text-sm px-2 py-1 rounded inline-block ${
+                        selectedNode.status === 'COMPLETE' ? 'bg-green-100 text-green-800' :
+                        selectedNode.status === 'RUNNING' ? 'bg-blue-100 text-blue-800' :
+                        selectedNode.status === 'FAILED' ? 'bg-red-100 text-red-800' :
+                        selectedNode.status === 'BLOCKED' ? 'bg-yellow-100 text-yellow-800' :
+                        selectedNode.status === 'PENDING' ? 'bg-gray-100 text-gray-800' :
+                        'bg-gray-100 text-gray-800'
+                      }`}>
+                        {selectedNode.status}
+                      </div>
+                    </div>
+                    <div className="col-span-2">
+                      <label className="block text-sm font-medium text-gray-700">Title</label>
+                      <div className="mt-1 text-sm text-gray-900">{selectedNode.title}</div>
+                    </div>
+                    <div className="col-span-2">
+                      <label className="block text-sm font-medium text-gray-700">Blocked By</label>
+                      <div className="mt-1 text-sm text-gray-900">
+                        {selectedNode.blocked_by && selectedNode.blocked_by.length > 0
+                          ? selectedNode.blocked_by.join(', ')
+                          : 'None'}
+                      </div>
+                    </div>
+                    <div className="col-span-2">
+                      <label className="block text-sm font-medium text-gray-700">WIH Path</label>
+                      <div className="mt-1 text-sm text-gray-900">{selectedNode.wih_path}</div>
+                    </div>
+                  </div>
+
+                  <div className="mt-6">
+                    <button
+                      onClick={() => {
+                        // Navigate to receipts view filtered by this node/run
+                        window.location.href = `/receipts?node_id=${selectedNode.node_id}&run_id=${selectedGraph.graph_id}`;
+                      }}
+                      className="px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700"
+                    >
+                      View Receipts for Node
+                    </button>
+                  </div>
+                </div>
+              )}
+            </>
+          ) : (
+            <div className="bg-white shadow rounded-lg p-8 flex items-center justify-center">
+              <div className="text-center">
+                <h3 className="text-lg font-medium text-gray-900">No Graph Selected</h3>
+                <p className="mt-1 text-sm text-gray-500">
+                  Select a graph from the list to visualize it
+                </p>
+              </div>
+            </div>
+          )}
+        </div>
+      </div>
+    </div>
+  );
+};
+
+export default GraphVisualizer;

