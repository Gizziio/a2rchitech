{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CapsuleSpec",
  "version": "0.1",
  "type": "object",
  "required": ["id", "goal", "evidence", "ui", "provenance"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "capsule_type": { "type": "string" },
    "goal": {
      "type": "object",
      "required": ["text"],
      "properties": {
        "text": { "type": "string" },
        "tokens": { "type": "array", "items": { "type": "object" } }
      }
    },
    "evidence": {
      "type": "array",
      "items": { "type": "object" }
    },
    "ui": {
      "type": "object",
      "required": ["a2ui_payload"],
      "properties": {
        "a2ui_payload": { "type": "object" },
        "surface_policy": { "type": "object" }
      }
    },
    "actions": {
      "type": "array",
      "items": { "type": "object" }
    },
    "update_rules": {
      "type": "array",
      "items": { "type": "object" }
    },
    "provenance": {
      "type": "object",
      "required": ["run_id", "created_at_ms"]
    }
  }
}
