+++ b/tests/acceptance/test_boot_manifest_validation.sh
@@ -0,0 +1,21 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+boot_dir=".a2r/boot"
+manifest_path="$boot_dir/receipt.json"
+
+mkdir -p "$boot_dir"
+
+cat > "$manifest_path" <<'JSON'
+{
+  "b0_version": "v0.1",
+  "timestamp": "2026-01-01T00:00:00Z",
+  "loaded_files": ["/SOT.md"],
+  "hashes": {"/SOT.md": "deadbeef"},
+  "env": {"profile": "test"}
+}
+JSON
+
+python3 scripts/validate_law.py --validate-boot-manifest
+
+rm -f "$manifest_path"
