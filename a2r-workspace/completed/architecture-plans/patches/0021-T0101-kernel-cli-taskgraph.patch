+use clap::{Args, Subcommand};
+use serde_json::json;
+
+use crate::client::KernelClient;
+
+#[derive(Args)]
+pub struct TaskGraphArgs {
+    #[command(subcommand)]
+    pub command: TaskGraphCommand,
+}
+
+#[derive(Subcommand)]
+pub enum TaskGraphCommand {
+    /// Initialize a run_state for a graph
+    Install { graph_id: String },
+    /// Resume a run from run_state + receipts
+    Resume { run_id: String },
+}
+
+pub async fn handle_taskgraph(cmd: TaskGraphCommand, client: &KernelClient) -> anyhow::Result<()> {
+    match cmd {
+        TaskGraphCommand::Install { graph_id } => {
+            let payload = json!({ "graph_id": graph_id });
+            let resp: serde_json::Value = client.post("/v1/taskgraph/install", &payload).await?;
+            println!("{}", serde_json::to_string_pretty(&resp)?);
+        }
+        TaskGraphCommand::Resume { run_id } => {
+            let payload = json!({ "run_id": run_id });
+            let resp: serde_json::Value = client.post("/v1/taskgraph/resume", &payload).await?;
+            println!("{}", serde_json::to_string_pretty(&resp)?);
+        }
+    }
+    Ok(())
+}
