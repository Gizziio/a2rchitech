+#!/usr/bin/env bash
+set -euo pipefail
+
+wih_file=".a2r/wih/T0000.wih.json"
+backup="${wih_file}.bak"
+
+cp "$wih_file" "$backup"
+
+python3 - <<'PY'
+import json
+from pathlib import Path
+path = Path('.a2r/wih/T0000.wih.json')
+obj = json.loads(path.read_text())
+obj.setdefault('tools', {}).setdefault('allowlist', []).append('tool.invalid')
+path.write_text(json.dumps(obj, indent=2))
+PY
+
+set +e
+python3 scripts/validate_law.py
+status=$?
+set -e
+
+mv "$backup" "$wih_file"
+
+if [ "$status" -eq 0 ]; then
+  echo "Expected validator failure for invalid tool id"
+  exit 1
+fi
