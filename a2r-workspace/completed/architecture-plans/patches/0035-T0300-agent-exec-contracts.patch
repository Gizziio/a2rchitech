diff --git a/spec/Contracts/AgentExecutionRequest.schema.json b/spec/Contracts/AgentExecutionRequest.schema.json
new file mode 100644
index 0000000..6374e82
--- /dev/null
+++ b/spec/Contracts/AgentExecutionRequest.schema.json
@@ -0,0 +1,46 @@
+{
+  "$schema": "https://json-schema.org/draft/2020-12/schema",
+  "$id": "https://a2rchitech.local/spec/contracts/AgentExecutionRequest.schema.json",
+  "title": "Agent Execution Request",
+  "type": "object",
+  "additionalProperties": false,
+  "required": [
+    "request_id",
+    "created_at",
+    "run_id",
+    "graph_id",
+    "node_id",
+    "wih_id",
+    "agent_profile_id",
+    "write_scope"
+  ],
+  "properties": {
+    "request_id": { "type": "string" },
+    "created_at": { "type": "string" },
+    "run_id": { "type": "string" },
+    "graph_id": { "type": "string" },
+    "node_id": { "type": "string" },
+    "wih_id": { "type": "string" },
+    "agent_profile_id": { "type": "string" },
+    "write_scope": {
+      "type": "object",
+      "additionalProperties": false,
+      "required": ["root", "allowed_globs"],
+      "properties": {
+        "root": { "type": "string", "const": "/.a2r/" },
+        "allowed_globs": {
+          "type": "array",
+          "items": { "type": "string" },
+          "minItems": 1
+        }
+      }
+    },
+    "input": {},
+    "trace_id": { "type": "string" },
+    "idempotency_key": { "type": "string" },
+    "mode": {
+      "type": "string",
+      "enum": ["install", "resume", "execute"]
+    }
+  }
+}

diff --git a/spec/Contracts/AgentExecutionReceipt.schema.json b/spec/Contracts/AgentExecutionReceipt.schema.json
new file mode 100644
index 0000000..be43555
--- /dev/null
+++ b/spec/Contracts/AgentExecutionReceipt.schema.json
@@ -0,0 +1,48 @@
+{
+  "$schema": "https://json-schema.org/draft/2020-12/schema",
+  "$id": "https://a2rchitech.local/spec/contracts/AgentExecutionReceipt.schema.json",
+  "title": "Agent Execution Receipt",
+  "type": "object",
+  "additionalProperties": false,
+  "required": [
+    "receipt_id",
+    "created_at",
+    "run_id",
+    "graph_id",
+    "agent_profile_id",
+    "status",
+    "run_state_path",
+    "receipts_dir",
+    "artifacts_dir"
+  ],
+  "properties": {
+    "receipt_id": { "type": "string" },
+    "created_at": { "type": "string" },
+    "run_id": { "type": "string" },
+    "graph_id": { "type": "string" },
+    "agent_profile_id": { "type": "string" },
+    "status": {
+      "type": "string",
+      "enum": ["INSTALLED", "RESUMED", "RUNNING", "COMPLETE", "FAILED"]
+    },
+    "run_state_path": { "type": "string" },
+    "receipts_dir": { "type": "string" },
+    "artifacts_dir": { "type": "string" },
+    "node_receipts": {
+      "type": "array",
+      "items": { "type": "string" },
+      "default": []
+    },
+    "tool_receipts": {
+      "type": "array",
+      "items": { "type": "string" },
+      "default": []
+    },
+    "subprocess_receipts": {
+      "type": "array",
+      "items": { "type": "string" },
+      "default": []
+    },
+    "execution_hash": { "type": "string" }
+  }
+}

diff --git a/spec/Contracts/AgentProfile.schema.json b/spec/Contracts/AgentProfile.schema.json
new file mode 100644
index 0000000..90a4687
--- /dev/null
+++ b/spec/Contracts/AgentProfile.schema.json
@@ -0,0 +1,63 @@
+{
+  "$schema": "https://json-schema.org/draft/2020-12/schema",
+  "$id": "https://a2rchitech.local/spec/contracts/AgentProfile.schema.json",
+  "title": "Agent Profile Registry",
+  "type": "object",
+  "additionalProperties": false,
+  "required": ["version", "profiles"],
+  "properties": {
+    "version": { "type": "string" },
+    "profiles": {
+      "type": "array",
+      "minItems": 1,
+      "items": { "$ref": "#/$defs/AgentProfile" }
+    }
+  },
+  "$defs": {
+    "AgentProfile": {
+      "type": "object",
+      "additionalProperties": false,
+      "required": [
+        "id",
+        "description",
+        "worker_allowlist",
+        "tool_allowlist",
+        "write_scope_policy",
+        "network_policy",
+        "receipts_required"
+      ],
+      "properties": {
+        "id": { "type": "string" },
+        "description": { "type": "string" },
+        "worker_allowlist": {
+          "type": "array",
+          "items": { "type": "string" },
+          "default": []
+        },
+        "tool_allowlist": {
+          "type": "array",
+          "items": { "type": "string" },
+          "default": []
+        },
+        "write_scope_policy": {
+          "type": "object",
+          "additionalProperties": false,
+          "required": ["mode", "allowed_globs"],
+          "properties": {
+            "mode": { "type": "string", "enum": ["run_scoped"] },
+            "allowed_globs": {
+              "type": "array",
+              "items": { "type": "string" },
+              "minItems": 1
+            }
+          }
+        },
+        "network_policy": {
+          "type": "string",
+          "enum": ["none", "allowlist", "unrestricted"]
+        },
+        "receipts_required": { "type": "boolean" }
+      }
+    }
+  }
+}

diff --git a/spec/Contracts/ExecutionPlan.schema.json b/spec/Contracts/ExecutionPlan.schema.json
new file mode 100644
index 0000000..ad94dc9
--- /dev/null
+++ b/spec/Contracts/ExecutionPlan.schema.json
@@ -0,0 +1,30 @@
+{
+  "$schema": "https://json-schema.org/draft/2020-12/schema",
+  "$id": "https://a2rchitech.local/spec/contracts/ExecutionPlan.schema.json",
+  "title": "Execution Plan",
+  "type": "object",
+  "additionalProperties": false,
+  "required": ["plan_id", "graph_id", "nodes"],
+  "properties": {
+    "plan_id": { "type": "string" },
+    "graph_id": { "type": "string" },
+    "created_at": { "type": "string" },
+    "nodes": {
+      "type": "array",
+      "minItems": 1,
+      "items": {
+        "type": "object",
+        "additionalProperties": false,
+        "required": ["task_id", "blocked_by"],
+        "properties": {
+          "task_id": { "type": "string" },
+          "blocked_by": {
+            "type": "array",
+            "items": { "type": "string" },
+            "default": []
+          }
+        }
+      }
+    }
+  }
+}

