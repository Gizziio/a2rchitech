diff --git a/tests/acceptance/test_task_beads_mismatch.sh b/tests/acceptance/test_task_beads_mismatch.sh
index 6b51203..4a33ccb 100755
--- a/tests/acceptance/test_task_beads_mismatch.sh
+++ b/tests/acceptance/test_task_beads_mismatch.sh
@@ -9,6 +9,19 @@ fi
 wih_file=".a2r/wih/T0004.wih.json"
 backup="${wih_file}.bak"
 
+if [ ! -f "$wih_file" ]; then
+  echo "Expected WIH file to exist at $wih_file" >&2
+  exit 1
+fi
+
+restore_wih() {
+  if [ -f "$backup" ]; then
+    mv "$backup" "$wih_file"
+  fi
+}
+
+trap restore_wih EXIT
+
 cp "$wih_file" "$backup"
 
 $PYTHON_BIN - <<'PY'
@@ -23,7 +36,7 @@ path.write_text(json.dumps(obj, indent=2))
 PY
 
 set +e
-$PYTHON_BIN scripts/taskgraph.py install graph-0001
+out=$($PYTHON_BIN scripts/taskgraph.py install graph-0001 2>&1)
 status=$?
 set -e
 
@@ -33,3 +46,19 @@ if [ "$status" -eq 0 ]; then
   echo "Expected install to fail on beads mismatch" >&2
   exit 1
 fi
+
+if ! echo "$out" | grep -q "Beads.blocked_by mismatch"; then
+  echo "Expected Beads.blocked_by mismatch error, got:" >&2
+  echo "$out" >&2
+  exit 1
+fi
+
+restore_wih
+trap - EXIT
+
+if [ ! -f "$wih_file" ]; then
+  echo "Expected WIH file to be restored at $wih_file" >&2
+  exit 1
+fi
+
+echo "$out"
