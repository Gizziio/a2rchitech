diff --git a/spec/Contracts/WorkerDefinition.schema.json b/spec/Contracts/WorkerDefinition.schema.json
new file mode 100644
index 0000000..81a8540
--- /dev/null
+++ b/spec/Contracts/WorkerDefinition.schema.json
@@ -0,0 +1,70 @@
+{
+  "$schema": "https://json-schema.org/draft/2020-12/schema",
+  "$id": "https://a2rchitech.local/spec/contracts/WorkerDefinition.schema.json",
+  "title": "A2rchitech Worker Definition",
+  "type": "object",
+  "additionalProperties": false,
+  "required": [
+    "worker_id",
+    "description",
+    "command",
+    "args_template",
+    "cwd_policy",
+    "env_allowlist",
+    "fs_policy",
+    "timeouts",
+    "output_limits"
+  ],
+  "properties": {
+    "worker_id": {
+      "type": "string",
+      "pattern": "^[a-z0-9][a-z0-9-.]{2,64}$"
+    },
+    "description": { "type": "string" },
+    "command": { "type": "string" },
+    "args_template": {
+      "type": "array",
+      "items": { "type": "string" }
+    },
+    "cwd_policy": {
+      "type": "string",
+      "description": "repo_root | run_artifacts_dir | path:<relative>",
+      "pattern": "^(repo_root|run_artifacts_dir|path:[A-Za-z0-9_./-]+)$"
+    },
+    "env_allowlist": {
+      "type": "array",
+      "items": { "type": "string" },
+      "default": []
+    },
+    "fs_policy": {
+      "type": "object",
+      "additionalProperties": false,
+      "required": ["must_be_run_scoped", "allowed_output_roots"],
+      "properties": {
+        "must_be_run_scoped": { "type": "boolean", "const": true },
+        "allowed_output_roots": {
+          "type": "array",
+          "items": { "type": "string" }
+        }
+      }
+    },
+    "timeouts": {
+      "type": "object",
+      "additionalProperties": false,
+      "required": ["wall_ms"],
+      "properties": {
+        "wall_ms": { "type": "integer", "minimum": 1 },
+        "cpu_ms": { "type": "integer", "minimum": 1 }
+      }
+    },
+    "output_limits": {
+      "type": "object",
+      "additionalProperties": false,
+      "required": ["max_stdout_bytes", "max_stderr_bytes"],
+      "properties": {
+        "max_stdout_bytes": { "type": "integer", "minimum": 0 },
+        "max_stderr_bytes": { "type": "integer", "minimum": 0 }
+      }
+    }
+  }
+}
