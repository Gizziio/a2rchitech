diff --git a/tests/acceptance/test_boot_manifest_path_consistency.sh b/tests/acceptance/test_boot_manifest_path_consistency.sh
new file mode 100755
index 0000000..4c398aa
--- /dev/null
+++ b/tests/acceptance/test_boot_manifest_path_consistency.sh
@@ -0,0 +1,10 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+kernel_file="services/kernel/src/main.rs"
+validator_file="scripts/validate_law.py"
+
+rg -n "boot_dir = StdPath::new\(\"\.a2r/boot\"\)" "$kernel_file" > /dev/null
+rg -n "receipt_path = boot_dir.join\(\"receipt.json\"\)" "$kernel_file" > /dev/null
+
+rg -n "DEFAULT_BOOT_MANIFEST_PATH = ROOT / \"\.a2r\" / \"boot\" / \"receipt.json\"" "$validator_file" > /dev/null
