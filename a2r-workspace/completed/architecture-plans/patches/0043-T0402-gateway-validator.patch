+def validate_gateway_registry(registry, path: Path):
+    external = registry.get("external_ingress")
+    if not isinstance(external, dict):
+        fail(f"Gateway registry missing external_ingress in {path}")
+
+    services = registry.get("services", [])
+    ensure_nonempty_list(services, f"{path} services")
+    service_names = set()
+    for service in services:
+        name = service.get("name")
+        if not name:
+            fail(f"Gateway service missing name in {path}")
+        if name in service_names:
+            fail(f"Duplicate service name '{name}' in {path}")
+        service_names.add(name)
+        if service.get("exposed") is True:
+            fail(f"Gateway service '{name}' must not be externally exposed")
+
+    routes = external.get("routes", [])
+    ensure_nonempty_list(routes, f"{path} external_ingress.routes")
+    for route in routes:
+        service = route.get("service")
+        if service not in service_names:
+            fail(f"Gateway route references unknown service '{service}' in {path}")
+
 
