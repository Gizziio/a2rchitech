+#!/usr/bin/env bash
+set -euo pipefail
+
+PYTHON_BIN="${PYTHON_BIN:-python3}"
+if [ -x ".venv-law/bin/python" ]; then
+  PYTHON_BIN=".venv-law/bin/python"
+fi
+
+registry="infra/gateway/gateway_registry.json"
+backup="${registry}.bak"
+
+mv "$registry" "$backup"
