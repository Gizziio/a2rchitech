+reg["external_ingress"]["routes"][0]["service"] = "missing-service"
+path.write_text(json.dumps(reg, indent=2))
+PY
+
+set +e
+"$PYTHON_BIN" scripts/validate_law.py
+status=$?
+set -e
+
+mv "$backup" "$registry"
+
+if [ "$status" -eq 0 ]; then
+  echo "Expected validator failure for unknown route service" >&2
+  exit 1
+fi

