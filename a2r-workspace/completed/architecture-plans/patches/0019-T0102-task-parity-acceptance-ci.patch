+#!/usr/bin/env bash
+set -euo pipefail
+
+PYTHON_BIN="${PYTHON_BIN:-python3}"
+if [ -x ".venv-law/bin/python" ]; then
+  PYTHON_BIN=".venv-law/bin/python"
+fi
+
+wih_file=".a2r/wih/T0004.wih.json"
+backup="${wih_file}.bak"
+
+cp "$wih_file" "$backup"
+
+$PYTHON_BIN - <<'PY'
+import json
+from pathlib import Path
+path = Path('.a2r/wih/T0004.wih.json')
+obj = json.loads(path.read_text())
+beads = obj.get('beads', {})
+beads['blocked_by'] = ['T0009']
+obj['beads'] = beads
+path.write_text(json.dumps(obj, indent=2))
+PY
+
+set +e
+$PYTHON_BIN scripts/taskgraph.py install graph-0001
+status=$?
+set -e
+
+mv "$backup" "$wih_file"
+
+if [ "$status" -eq 0 ]; then
+  echo "Expected install to fail on beads mismatch" >&2
+  exit 1
+fi
