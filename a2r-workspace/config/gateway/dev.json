{
  "environment": "dev",
  "routes": [
    {
      "path_prefix": "/api/kernel",
      "service": "kernel",
      "methods": [
        "GET",
        "POST",
        "PUT",
        "DELETE",
        "OPTIONS"
      ],
      "operations": [
        "POST:/api/kernel/dispatch",
        "GET:/api/kernel/journal",
        "POST:/api/kernel/capsules/spawn"
      ]
    },
    {
      "path_prefix": "/api/router",
      "service": "router",
      "methods": [
        "GET",
        "POST",
        "PUT",
        "DELETE",
        "OPTIONS"
      ],
      "operations": [
        "POST:/api/router/route",
        "GET:/api/router/policies"
      ]
    },
    {
      "path_prefix": "/api/memory",
      "service": "memory",
      "methods": [
        "GET",
        "POST",
        "PUT",
        "DELETE",
        "OPTIONS"
      ],
      "operations": [
        "POST:/api/memory/ingest",
        "GET:/api/memory/search",
        "POST:/api/memory/promote"
      ]
    }
  ],
  "ports": {
    "kernel": 8001,
    "router": 8002,
    "memory": 8003,
    "gateway": 8000,
    "ui-platform": 5177,
    "ui-tars": 3008,
    "brain-kernel": 3004
  }
}