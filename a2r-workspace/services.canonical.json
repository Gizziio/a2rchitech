{
  "version": "2026-02-06-enterprise",
  "description": "Canonical enterprise service configuration for A2rchitect",
  "hosts": {
    "internal": "127.0.0.1",
    "public": "0.0.0.0"
  },
  "ports": {
    "gateway": 8013,
    "api": 3000,
    "registry": 8080,
    "kernel": 3004,
    "memory": 3200,
    "policy": 3003,
    "shell_ui": 5177
  },
  "services": [
    {
      "id": "policy",
      "label": "Policy Service",
      "description": "Authorization and policy enforcement",
      "order": 10,
      "command": "cargo",
      "args": ["run", "--manifest-path", "2-governance/rust/a2r-governor/Cargo.toml"],
      "env": { 
        "HOST": "${hosts.internal}",
        "PORT": "${ports.policy}",
        "RUST_LOG": "info"
      },
      "log": "policy.log",
      "health_check": "http://${hosts.internal}:${ports.policy}/health"
    },
    {
      "id": "memory",
      "label": "Memory Service",
      "description": "State and context management",
      "order": 20,
      "command": "cargo",
      "args": ["run", "--manifest-path", "4-services/memory/Cargo.toml"],
      "env": { 
        "HOST": "${hosts.internal}",
        "PORT": "${ports.memory}",
        "RUST_LOG": "info"
      },
      "log": "memory.log",
      "health_check": "http://${hosts.internal}:${ports.memory}/health"
    },
    {
      "id": "registry",
      "label": "Registry Service",
      "description": "Agent, skill, and tool definitions",
      "order": 30,
      "command": "cargo",
      "args": ["run", "--manifest-path", "4-services/registry/registry-server/Cargo.toml"],
      "env": { 
        "HOST": "${hosts.internal}",
        "PORT": "${ports.registry}",
        "RUST_LOG": "info"
      },
      "log": "registry.log",
      "health_check": "http://${hosts.internal}:${ports.registry}/health"
    },
    {
      "id": "kernel",
      "label": "Kernel (Internal)",
      "description": "Tool execution and brain session management (INTERNAL ONLY)",
      "order": 40,
      "command": "cargo",
      "args": ["run", "--manifest-path", "4-services/orchestration/kernel-service/Cargo.toml"],
      "env": { 
        "HOST": "127.0.0.1",
        "PORT": "${ports.kernel}",
        "RUST_LOG": "info",
        "A2R_BIND_LOCAL_ONLY": "true",
        "A2R_INTERNAL_MODE": "true"
      },
      "log": "kernel.log",
      "health_check": "http://127.0.0.1:${ports.kernel}/health",
      "notes": "Kernel binds to localhost only - external access through API"
    },
    {
      "id": "api",
      "label": "Public API",
      "description": "Business logic and orchestration layer",
      "order": 50,
      "command": "cargo",
      "args": ["run", "--manifest-path", "6-apps/api/Cargo.toml"],
      "env": { 
        "HOST": "${hosts.internal}",
        "PORT": "${ports.api}",
        "RUST_LOG": "info",
        "A2R_KERNEL_URL": "http://127.0.0.1:${ports.kernel}",
        "A2R_REGISTRY_URL": "http://${hosts.internal}:${ports.registry}",
        "A2R_MEMORY_URL": "http://${hosts.internal}:${ports.memory}",
        "A2R_POLICY_URL": "http://${hosts.internal}:${ports.policy}"
      },
      "log": "api.log",
      "health_check": "http://${hosts.internal}:${ports.api}/health",
      "depends_on": ["kernel", "registry", "memory", "policy"]
    },
    {
      "id": "gateway",
      "label": "API Gateway",
      "description": "Public entry point - auth, routing, rate limiting",
      "order": 60,
      "command": "python3",
      "args": ["4-services/gateway/src/main.py"],
      "env": { 
        "HOST": "${hosts.public}",
        "PORT": "${ports.gateway}",
        "API_URL": "http://${hosts.internal}:${ports.api}",
        "CORS_ORIGINS": "http://localhost:5177,http://127.0.0.1:5177",
        "LOG_LEVEL": "info"
      },
      "log": "gateway.log",
      "health_check": "http://${hosts.public}:${ports.gateway}/health",
      "depends_on": ["api"]
    },
    {
      "id": "shell-ui",
      "label": "Shell UI",
      "description": "Web user interface",
      "order": 70,
      "command": "pnpm",
      "args": ["-C", "6-apps/shell-ui", "dev", "--", "--port", "${ports.shell_ui}", "--host", "${hosts.internal}"],
      "env": { 
        "VITE_A2R_GATEWAY_URL": "http://${hosts.internal}:${ports.gateway}",
        "VITE_A2R_API_VERSION": "v1"
      },
      "log": "shell-ui.log",
      "depends_on": ["gateway"]
    }
  ],
  "notes": [
    "This is the canonical enterprise service configuration.",
    "All UI traffic MUST go through the Gateway (port 8013).",
    "Kernel (port 3004) is internal-only and not accessible externally.",
    "Deprecated services removed: multiple gateways, multiple registries, router-service.",
    "To start: cargo run -p a2rchitech-platform"
  ]
}
