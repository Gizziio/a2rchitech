{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://a2rchitech/spec/presentation/viewspec.schema.json",
  "title": "ViewSpec",
  "type": "object",
  "required": [
    "view_id",
    "type",
    "bindings"
  ],
  "properties": {
    "view_id": {
      "type": "string",
      "pattern": "^view_[a-z0-9_\\-]+$"
    },
    "type": {
      "type": "string",
      "enum": [
        "object_view",
        "artifact_view",
        "config_view",
        "snapshot_view",
        "diff_view",
        "patch_view",
        "comparison_view",
        "regression_view",
        "timeline_view",
        "run_view",
        "log_stream",
        "playback_view",
        "table_view",
        "list_view",
        "gallery_view",
        "capsule_gallery",
        "registry_view",
        "graph_view",
        "tree_view",
        "dependency_view",
        "context_map",
        "decision_log",
        "proposal_view",
        "policy_view",
        "risk_view",
        "form_view",
        "command_palette",
        "workflow_view",
        "approval_queue",
        "search_lens",
        "filter_lens",
        "summary_lens",
        "explanation_view",
        "recommendation_view",
        "memory_trace",
        "provenance_view",
        "audit_view",
        "workspace_view",
        "zone_view",
        "avatar_presence",
        "attention_field"
      ]
    },
    "title": {
      "type": "string"
    },
    "bindings": {
      "type": "object",
      "required": [
        "journal_refs"
      ],
      "properties": {
        "journal_refs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "artifact_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "query": {
          "type": "object"
        },
        "filters": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "interaction_spec": {
      "type": "object",
      "properties": {
        "allowed_intents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "controls": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "motion_semantics": {
          "type": "boolean",
          "default": true
        }
      },
      "additionalProperties": false
    },
    "renderer_hints": {
      "type": "object"
    },
    "layout": {
      "type": "object"
    }
  },
  "additionalProperties": false
}