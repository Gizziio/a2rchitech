{
  "spec_name": "A2R Crypto Layer Spec",
  "version": "v0.1.0",
  "boundaries": {
    "kms": "Key Management Service (Vault/Hardware)",
    "signing_authority": "Internal service for agent/manifest signatures",
    "auth_provider": "JWT/OAuth2 provider for workspace tokens"
  },
  "contracts": {
    "publisher_key": {
      "fields": [
        "publisher_id",
        "public_key",
        "signature",
        "revocation_status"
      ]
    },
    "agent_signature": {
      "fields": [
        "agent_id",
        "manifest_hash",
        "signature_payload",
        "timestamp"
      ]
    }
  },
  "security_policies": [
    "Strict UDS-only access for KMS admin ops",
    "Short-lived session tokens (max 1hr)",
    "Mandatory audit logging for all key access"
  ]
}