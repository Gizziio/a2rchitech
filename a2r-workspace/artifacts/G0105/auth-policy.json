{
  "policy_name": "A2R Gateway AuthZ",
  "token_types": {
    "workspace": {
      "scope": "workspace",
      "ttl": "30d",
      "requirements": ["X-A2R-Workspace-ID"]
    },
    "session": {
      "scope": "session",
      "ttl": "24h",
      "requirements": ["X-A2R-Session-ID"]
    }
  },
  "service_scopes": {
    "kernel": ["kernel.exec", "kernel.read"],
    "router": ["router.manage"],
    "memory": ["memory.rw"]
  }
}
