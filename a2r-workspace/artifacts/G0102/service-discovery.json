{
  "spec_name": "A2R Service Discovery",
  "version": "v0.1.0",
  "name_patterns": {
    "kernel": "kernel.a2r.internal",
    "router": "router.a2r.internal",
    "memory": "memory.a2r.internal"
  },
  "resolver_strategies": [
    {
      "env": "dev",
      "strategy": "localhost",
      "mappings": {
        "kernel.a2r.internal": "http://127.0.0.1:8001",
        "router.a2r.internal": "http://127.0.0.1:8002",
        "memory.a2r.internal": "http://127.0.0.1:8003"
      }
    },
    {
      "env": "prod-k8s",
      "strategy": "kube-dns",
      "suffix": "svc.cluster.local"
    },
    {
      "env": "prod-docker",
      "strategy": "docker-link"
    }
  ]
}
