{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://allternit.local/spec/contracts/CapsuleManifest.schema.json",
  "title": "Capsule Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capsule_id",
    "name",
    "version",
    "entry",
    "sandbox",
    "permissions",
    "provenance"
  ],
  "properties": {
    "capsule_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "ref"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "mcp_app",
            "local_bundle",
            "remote_url"
          ]
        },
        "ref": {
          "type": "string"
        }
      }
    },
    "sandbox": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "isolation",
        "allow_popups",
        "allow_downloads"
      ],
      "properties": {
        "isolation": {
          "type": "string",
          "enum": [
            "iframe_sandbox",
            "webview_sandbox",
            "process_isolation"
          ]
        },
        "allow_popups": {
          "type": "boolean",
          "default": false
        },
        "allow_downloads": {
          "type": "boolean",
          "default": false
        },
        "csp": {
          "type": "string"
        }
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tools",
        "network",
        "filesystem",
        "clipboard"
      ],
      "properties": {
        "tools": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "network": {
          "type": "string",
          "enum": [
            "none",
            "gateway_only",
            "full"
          ],
          "default": "gateway_only"
        },
        "filesystem": {
          "type": "string",
          "enum": [
            "none",
            "allternit_scoped"
          ],
          "default": "allternit_scoped"
        },
        "clipboard": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "publisher",
        "signature",
        "hash"
      ],
      "properties": {
        "publisher": {
          "type": "string"
        },
        "signature": {
          "type": "string"
        },
        "hash": {
          "type": "string"
        }
      }
    },
    "ui": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        },
        "default_size": {
          "type": "object",
          "properties": {
            "w": {
              "type": "integer"
            },
            "h": {
              "type": "integer"
            }
          }
        }
      }
    }
  }
}