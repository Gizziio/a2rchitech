{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://a2rchitech.local/spec/contracts/ToolDefinition.schema.json",
  "title": "A2rchitech Tool Definition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "kind",
    "safety_level",
    "entrypoint",
    "inputs_schema",
    "outputs_schema"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-.]{2,64}$"
    },
    "title": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "read",
        "write",
        "destructive",
        "network",
        "exec"
      ]
    },
    "safety_level": {
      "type": "string",
      "enum": [
        "safe",
        "caution",
        "danger"
      ]
    },
    "entrypoint": {
      "type": "string"
    },
    "inputs_schema": {
      "type": "object"
    },
    "outputs_schema": {
      "type": "object"
    },
    "preconditions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "rate_limits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "per_minute": {
          "type": "integer",
          "minimum": 1
        },
        "burst": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
