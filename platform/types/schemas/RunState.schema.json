{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://a2rchitech.local/spec/contracts/RunState.schema.json",
  "title": "A2rchitech Run State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "graph_id",
    "status"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "graph_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "RUNNING",
        "PAUSED",
        "FAILED",
        "COMPLETE"
      ]
    },
    "started_at": {
      "type": "string"
    },
    "completed_at": {
      "type": "string"
    },
    "node_states": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "task_id",
          "status"
        ],
        "properties": {
          "task_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "PENDING",
              "RUNNING",
              "BLOCKED",
              "SUCCEEDED",
              "FAILED",
              "SKIPPED"
            ]
          },
          "last_receipt_id": {
            "type": "string"
          }
        }
      },
      "default": []
    },
    "resume_cursor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "last_node": {
          "type": "string"
        },
        "next_nodes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "receipts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  }
}
