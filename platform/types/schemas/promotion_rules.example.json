{
  "version": "v0.1",
  "rules": [
    {
      "id": "AUTO_LOW_RISK_DOCS",
      "applies_to": [
        "prompt",
        "ui_config",
        "index"
      ],
      "risk": "low",
      "requires_checks": [
        "AT-BOOT-0004",
        "AT-IO-0001"
      ],
      "auto_approve": true,
      "deny_if": [
        "touches:/spec/Contracts/",
        "touches:/agent/",
        "touches:/SOT.md"
      ],
      "notes": "Auto-approve low risk artifacts that do not touch law-layer files."
    },
    {
      "id": "AUTO_LOW_RISK_TOOL_META",
      "applies_to": [
        "tool",
        "routing_rule"
      ],
      "risk": "medium",
      "requires_checks": [
        "AT-TOOLS-0001",
        "AT-TOOLS-0002",
        "AT-TOOLS-0003"
      ],
      "auto_approve": true,
      "deny_if": [
        "kind:destructive",
        "requires:danger"
      ],
      "notes": "Auto-approve if tool is safe/caution and passes tool gating tests."
    },
    {
      "id": "MANUAL_LAW_LAYER",
      "applies_to": [
        "policy",
        "spec_delta",
        "memory_pack"
      ],
      "risk": "high",
      "requires_checks": [
        "AT-BOOT-0001",
        "AT-BOOT-0002",
        "AT-BOOT-0003"
      ],
      "auto_approve": false,
      "deny_if": [],
      "notes": "Law-layer changes require explicit approval and full checks."
    }
  ]
}