{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://allternit.local/spec/contracts/MCPAppDescriptor.schema.json",
  "title": "MCP App Descriptor",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "app_id",
    "ui_resource",
    "bridge",
    "state"
  ],
  "properties": {
    "app_id": {
      "type": "string"
    },
    "ui_resource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri",
        "content_type"
      ],
      "properties": {
        "uri": {
          "type": "string"
        },
        "content_type": {
          "type": "string",
          "enum": [
            "text/html",
            "application/vnd.allternit.mcpapp+json"
          ]
        }
      }
    },
    "bridge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol",
        "channel"
      ],
      "properties": {
        "protocol": {
          "type": "string",
          "enum": [
            "postMessage",
            "rpc"
          ]
        },
        "channel": {
          "type": "string",
          "enum": [
            "host_mediated"
          ]
        }
      }
    },
    "state": {
      "type": "object",
      "additionalProperties": true
    }
  }
}