{
  "claude-code": {
    "id": "claude-code",
    "name": "Claude Code",
    "vendor": "Anthropic",
    "type": "cli",
    "logo_asset": "claude-logo.svg",
    "description": "Advanced AI coding assistant with Claude 3.5 Sonnet",
    "install": {
      "darwin": "brew install claude-code",
      "linux": "curl -fsSL https://claude.ai/install.sh | sh",
      "windows": "winget install Anthropic.ClaudeCode"
    },
    "verify": {
      "command": "claude-code",
      "args": ["--version"],
      "expected_output": "claude-code version"
    },
    "auth": {
      "required": true,
      "instructions": "First run will prompt for API key. Enter your Anthropic API key when prompted.",
      "detection_regex": "Successfully authenticated|API key set"
    },
    "launch": {
      "command": "claude-code",
      "args": []
    },
    "event_mode": "acp",
    "capabilities": ["code", "terminal", "files", "chat"]
  },
