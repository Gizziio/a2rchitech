version: "v1"
description: "Prime an agent session with deterministic context injection"
argument_hint: "context_prime --wih={{wih_id}} --dag={{dag_id}}"
model: "any"
anchors: "input | workflow | output"
allowed_tools: ["fs.read", "fs.glob"]
