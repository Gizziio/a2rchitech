[tool.poetry]
name = "{{PROJECT_NAME}}"
version = "1.0.0"
description = "Python ML & Data Science Project"
authors = ["Your Name <your.email@example.com>"]
readme = "README.md"
license = "MIT"
packages = [{include = "src"}]

[tool.poetry.dependencies]
python = "^3.12"

# Core Scientific Computing
numpy = "^1.26.0"
scipy = "^1.12.0"
pandas = "^2.2.0"

# PyTorch Ecosystem
torch = "^2.2.0"
torchvision = "^0.17.0"
torchaudio = "^2.2.0"
pytorch-lightning = "^2.2.0"
torchmetrics = "^1.3.0"

# Machine Learning
scikit-learn = "^1.4.0"
xgboost = "^2.0.0"
lightgbm = "^4.3.0"
catboost = "^1.2.0"
imbalanced-learn = "^0.12.0"

# Deep Learning & Transformers
transformers = "^4.37.0"
datasets = "^2.16.0"
accelerate = "^0.27.0"
peft = "^0.8.0"
bitsandbytes = "^0.42.0"
einops = "^0.7.0"
timm = "^0.9.0"

# LLM Frameworks
langchain = "^0.1.0"
langchain-community = "^0.0.20"
langchain-openai = "^0.0.6"
langchain-huggingface = "^0.0.1"
openai = "^1.12.0"

# Computer Vision
opencv-python = "^4.9.0"
pillow = "^10.2.0"
albumentations = "^1.4.0"
imgaug = "^0.4.0"

# NLP
spacy = "^3.7.0"
nltk = "^3.8.0"
gensim = "^4.3.0"
textblob = "^0.17.0"

# Data Visualization
matplotlib = "^3.8.0"
seaborn = "^0.13.0"
plotly = "^5.19.0"
bokeh = "^3.3.0"
altair = "^5.2.0"

# Experiment Tracking
mlflow = "^2.10.0"
wandb = "^0.16.0"
tensorboard = "^2.15.0"
sacred = "^0.8.0"

# Jupyter & Interactive Computing
jupyterlab = "^4.1.0"
notebook = "^7.1.0"
ipywidgets = "^8.0.0"
ipython = "^8.21.0"

# Data Processing
pyarrow = "^15.0.0"
polars = "^0.20.0"
dask = "^2024.2.0"
modin = "^0.28.0"

# Databases & Storage
sqlalchemy = "^2.0.0"
psycopg2-binary = "^2.9.0"
pymongo = "^4.6.0"
redis = "^5.0.0"

# Web Frameworks (for serving models)
fastapi = "^0.109.0"
uvicorn = "^0.27.0"
streamlit = "^1.31.0"
gradio = "^4.19.0"
dash = "^2.15.0"

# Utilities
pydantic = "^2.6.0"
python-dotenv = "^1.0.0"
pyyaml = "^6.0.0"
rich = "^13.7.0"
tqdm = "^4.66.0"
joblib = "^1.3.0"
click = "^8.1.0"
typer = "^0.9.0"
omegaconf = "^2.3.0"
hydra-core = "^1.3.0"
python-json-logger = "^2.0.0"

[tool.poetry.group.dev.dependencies]
# Testing
pytest = "^8.0.0"
pytest-cov = "^4.1.0"
pytest-xdist = "^3.5.0"
pytest-asyncio = "^0.23.0"
hypothesis = "^6.98.0"

# Code Quality
black = "^24.0.0"
isort = "^5.13.0"
flake8 = "^7.0.0"
mypy = "^1.8.0"
pylint = "^3.0.0"
bandit = "^1.7.0"
safety = "^3.0.0"

# Documentation
sphinx = "^7.2.0"
sphinx-rtd-theme = "^2.0.0"
mkdocs = "^1.5.0"
mkdocs-material = "^9.5.0"

# Jupyter Extensions
jupyterlab-code-formatter = "^2.2.0"
jupyterlab-git = "^0.50.0"
nbstripout = "^0.7.0"
nbval = "^0.10.0"

[tool.poetry.group.optional.dependencies]
# Optional: TensorFlow (large download)
tensorflow = {version = "^2.15.0", optional = true}
tensorflow-gpu = {version = "^2.12.0", optional = true}
keras = {version = "^2.15.0", optional = true}

# Optional: JAX
jax = {version = "^0.4.0", extras = ["cuda12_pip"], optional = true}
flax = {version = "^0.8.0", optional = true}
optax = {version = "^0.1.0", optional = true}

[tool.poetry.extras]
tensorflow = ["tensorflow", "tensorflow-gpu", "keras"]
jax = ["jax", "flax", "optax"]
all = ["tensorflow", "tensorflow-gpu", "keras", "jax", "flax", "optax"]

[build-system]
requires = ["poetry-core"]
build-backend = "poetry.core.masonry.api"

[tool.black]
line-length = 100
target-version = ['py312']
include = '\.pyi?$'
extend-exclude = '''
/(
  # directories
  \.eggs
  | \.git
  | \.hg
  | \.mypy_cache
  | \.tox
  | \.venv
  | build
  | dist
)/
'''

[tool.isort]
profile = "black"
line_length = 100
multi_line_output = 3
include_trailing_comma = true
force_grid_wrap = 0
use_parentheses = true
ensure_newline_before_comments = true
skip_glob = ["**/.venv/**", "**/build/**", "**/dist/**"]

[tool.mypy]
python_version = "3.12"
warn_return_any = true
warn_unused_configs = true
disallow_untyped_defs = true
disallow_incomplete_defs = true
check_untyped_defs = true
disallow_untyped_decorators = false
no_implicit_optional = true
warn_redundant_casts = true
warn_unused_ignores = true
warn_no_return = true
warn_unreachable = true
strict_equality = true
show_error_codes = true
show_column_numbers = true
show_error_context = true
ignore_missing_imports = true
exclude = [
    "\.venv",
    "build",
    "dist",
    ".tox",
]

[tool.pytest.ini_options]
minversion = "8.0"
addopts = "-ra -q --strict-markers --strict-config"
testpaths = [
    "tests",
]
python_files = ["test_*.py", "*_test.py"]
python_classes = ["Test*"]
python_functions = ["test_*"]
markers = [
    "slow: marks tests as slow (deselect with '-m \"not slow\"')",
    "gpu: marks tests that require GPU",
    "integration: marks tests as integration tests",
    "unit: marks tests as unit tests",
]
filterwarnings = [
    "ignore::DeprecationWarning",
    "ignore::PendingDeprecationWarning",
]

[tool.coverage.run]
source = ["src"]
branch = true
omit = [
    "*/tests/*",
    "*/test_*",
    "*/__pycache__/*",
    "*/.venv/*",
]

[tool.coverage.report]
exclude_lines = [
    "pragma: no cover",
    "def __repr__",
    "if self.debug:",
    "if settings.DEBUG",
    "raise AssertionError",
    "raise NotImplementedError",
    "if 0:",
    "if __name__ == .__main__.:",
    "class .*\\bProtocol\\):",
    "@(abc\\.)?abstractmethod",
]
show_missing = true
skip_covered = false

[tool.pylint.messages_control]
disable = [
    "C0103",  # invalid-name
    "C0114",  # missing-module-docstring
    "C0115",  # missing-class-docstring
    "C0116",  # missing-function-docstring
    "R0903",  # too-few-public-methods
    "R0913",  # too-many-arguments
    "W1203",  # logging-fstring-interpolation
]
max-line-length = 100

[tool.bandit]
exclude_dirs = ["tests", ".venv", "build", "dist"]
skips = ["B101", "B601"]
